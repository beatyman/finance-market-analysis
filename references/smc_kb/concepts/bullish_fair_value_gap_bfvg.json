{
  "card_id": "bullish_fair_value_gap_bfvg",
  "type": "merged_concept",
  "canonical_term": "Bullish Fair Value Gap (BFVG)",
  "aliases": [
    "BISI",
    "bullish fair value gap",
    "buy side imbalance sell side inefficiency",
    "Buy Side Imbalance Sell Side Inefficiency"
  ],
  "school": "ICT",
  "definition": "A bullish fair value gap (BFVG) is a three-candlestick pattern where the first candle's low does not overlap the third candle's high, indicating buy side was offered but sell side was inefficient. Price often returns to this zone as support before continuing higher.",
  "identification_rules": [
    "Locate three consecutive candlesticks.",
    "The low of the first candle is higher than the high of the third candle, with no overlapping wicks.",
    "The gap between the third candle's high and the first candle's low represents the BFVG zone.",
    "The pattern appears after an aggressive bullish move displacing higher.",
    "Mark the gap's start, midpoint (Consequent Encroachment/50% level), and full fill point."
  ],
  "trading_implication": "BFVG acts as a support zone in an uptrend. Traders anticipate price retracing into the gap to find support, ideally respecting the consequent encroachment (50% level) or the full gap before continuing upward. Entries are taken on signs of rejection; a close through the BFVG invalidates it and may flip it to resistance (inversion).",
  "common_mistakes": [
    "Misidentifying a volume imbalance or a gap as a BFVG.",
    "Entering before price shows respect or a reaction at the BFVG level.",
    "Invalidating the BFVG too early—only a close through the zone or its consequent encroachment confirms invalidation.",
    "Expecting BFVG to be retested immediately, ignoring that the gap may be revisited after a consolidation period."
  ],
  "related_concepts": [],
  "merge_strategy": "llm_synthesis",
  "merge_model": "deepseek/deepseek-chat",
  "merge_notes": "Both cards are from ICT school; no conflict. The first card provided additional detail on marking the gap and inversion, which was merged into identification_rules and trading_implication.",
