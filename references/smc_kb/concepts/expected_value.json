{
  "card_id": "expected_value",
  "type": "merged_concept",
  "canonical_term": "Expected Value",
  "aliases": [],
  "school": "Risk Management",
  "definition": "The average profit or loss per trade over many trades. Calculated as (win rate × average win) − (loss rate × average loss). A positive expected value indicates that the strategy is profitable in the long run.",
  "identification_rules": [
    "Calculate win rate by dividing the number of winning trades by total trades over a representative sample.",
    "Determine average win and average loss in currency or percentage terms from historical trades.",
    "Compute expected value using the formula: (win rate × average win) − (loss rate × average loss).",
    "Interpret the result: a positive value means the strategy is expected to be profitable; a negative value means it is unprofitable."
  ],
  "trading_implication": "Expected value is the foundation for evaluating strategy profitability. Traders should only take trades when the strategy's expected value is positive, indicating a statistical edge. Even with a positive EV, short-term losses are possible, so consistency and a large sample of trades are required to realize the expected gains. It integrates win rate and risk/reward into a single decision metric.",
  "common_mistakes": [
    "Expecting positive expected value to guarantee profits over a small number of trades.",
    "Focusing solely on win rate without considering average win/loss sizes.",
    "Failing to collect enough trade samples to verify that the expected value is reliable."
  ],
