{
  "card_id": "aggressive_pullback_model",
  "type": "merged_concept",
  "canonical_term": "Aggressive Pullback Model",
  "aliases": [],
  "school": "Smart Money Concepts (SMC)",
  "definition": "A pullback model where price quickly reverses after a sharp move, offering an entry into the trend with a tight stop loss as it resumes.",
  "identification_rules": [
    "Price makes a sharp impulsive move in the direction of the dominant trend.",
    "A steep pullback occurs against the trend with little to no consolidation.",
    "Entry is taken near the extreme of the pullback, often using an order block or inducement zone as a reference, with a tight stop beyond the pullback's swing point."
  ],
  "trading_implication": "This model allows traders to join a trending market after a shallow, aggressive retracement, aiming to capture the next leg of the trend. The tight stop loss placement offers a favorable risk-to-reward ratio, assuming the trend continues.",
  "common_mistakes": [
    "Entering on a pullback that turns into a full reversal (a trap)."
  ],
