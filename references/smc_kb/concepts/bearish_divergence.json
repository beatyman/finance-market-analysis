{
  "card_id": "bearish_divergence",
  "type": "merged_concept",
  "canonical_term": "Bearish Divergence",
  "aliases": [
    "bearish div",
    "Bearish MACD Divergence",
    "bearish RSI divergence",
    "bearish rsi divergence",
    "normal bearish divergence",
    "regular bearish divergence"
  ],
  "school": "Indicator Based",
  "definition": "A bearish divergence occurs when price forms a higher high while an oscillator (e.g., RSI, Stochastic RSI %D, or MACD) forms a lower high, signaling weakening upward momentum and a potential downside reversal.",
  "identification_rules": [
    "Compare the highs on both price and the oscillator, focusing only on swing highs, not lows.",
    "Identify two consecutive swing highs on price: the second high must be higher than the first.",
    "On the oscillator, the corresponding highs must show the second high lower than the first.",
    "For oscillators with multiple lines (e.g., Stochastic RSI), use the smoother line (e.g., %D) for divergence signals to avoid false signals.",
    "The price higher high and oscillator lower high should occur at approximately the same time to confirm the divergence.",
    "On the MACD histogram or line, observe the peaks corresponding to those price highs; the second peak must be lower than the first.",
    "Ensure the swing highs are clearly separated by a distinct trough for more reliable signals."
  ],
  "trading_implication": "Bearish divergence warns of potential upside momentum exhaustion and a possible reversal from an uptrend to a downtrend. It serves as a sell signal, prompting traders to exit long positions or enter short positions. To improve accuracy, confirm with price action signals such as bearish candlestick patterns, break of structure, or support/resistance breaks.",
  "common_mistakes": [
    "Confusing regular bearish divergence (reversal) with hidden bearish divergence (continuation).",
    "Checking price and oscillator lows instead of highs for bearish divergence.",
    "Using the %K line instead of the %D line when using Stochastic RSI, leading to unreliable signals.",
    "Relying solely on divergence without additional confirmation, increasing the risk of false signals.",
    "Misinterpreting convergence (price and MACD moving in the same direction) as divergence.",
    "Treating overlapping or indistinct peaks as valid divergence, leading to false signals."
  ],
