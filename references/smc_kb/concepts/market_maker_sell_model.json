{
  "card_id": "market_maker_sell_model",
  "type": "merged_concept",
  "canonical_term": "Market Maker Sell Model",
  "aliases": [
    "mmsm",
    "MMSM",
    "sell model",
    "Sell Model"
  ],
  "school": "ICT",
  "definition": "A bearish price delivery sequence where price moves from external range liquidity (an old high) into internal range liquidity (a fair value gap), then displaces lower toward new external range liquidity (old lows). The inverse of the market maker buy model.",
  "identification_rules": [
    "Identify an external range high that has been swept or is the prior swing high on the working time frame.",
    "Locate internal range liquidity (a fair value gap) below that external high which price can reach into.",
    "Confirm price reacts to / respects the fair value gap and displaces lower toward old lows (new external range liquidity).",
    "On lower time frames, look for a high to form inside the higher-time-frame fair value gap, followed by displacement down and a change in state of delivery.",
    "Model is invalidated/transitions to a buy model when price changes state of delivery by closing above the most recent opposing swing high."
  ],
  "trading_implication": "Use the sell model to frame bearish bias by mapping external-to-internal-to-external range liquidity flow. Higher time frame fair value gap acts as the point of interest; drop to lower time frames (e.g., 5m, 1m) for confirmation entries — a high forming in the HTF FVG with displacement lower and an order block entry. Stop above the swept high, target the old lows representing external range liquidity. Watch for state-of-delivery shifts that flip the model into a buy model.",
  "common_mistakes": [
    "Expecting a clean retracement before continuation when price may simply continue in the bias direction without retracing.",
    "Failing to recognize when price changes state of delivery and transitions from a sell model to a buy model, continuing to look for shorts."
  ],
