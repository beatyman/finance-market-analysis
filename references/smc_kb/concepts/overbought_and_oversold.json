  "card_id": "overbought_and_oversold",
  "type": "merged_concept",
  "canonical_term": "Overbought and Oversold",
  "aliases": [],
  "school": "Indicator Based",
  "definition": "Overbought occurs when RSI exceeds 70, indicating strong bullish momentum; oversold occurs when RSI falls below 30, indicating strong bearish momentum. These conditions reflect extreme momentum but do not guarantee imminent reversal.",
  "identification_rules": [
    "RSI value above 70 indicates an overbought condition.",
    "RSI value below 30 indicates an oversold condition."
  ],
  "trading_implication": "Overbought/oversold conditions signal extreme momentum and should not be used as standalone buy/sell signals. Strong trends can persist, and entering counter-trend trades solely based on these levels may lead to losses. Use in conjunction with other tools to confirm potential reversals.",
  "common_mistakes": [
    "Treating overbought as an automatic sell signal.",
    "Treating oversold as an automatic buy signal."
  ],
