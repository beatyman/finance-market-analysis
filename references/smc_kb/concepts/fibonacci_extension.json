{
  "card_id": "fibonacci_extension",
  "type": "merged_concept",
  "canonical_term": "Fibonacci Extension",
  "aliases": [],
  "school": "Indicator Based",
  "definition": "A trend-based Fibonacci tool that projects price targets beyond a swing by extending a measured move. It uses three anchor points: a swing low, a swing high, and a pullback low. Key levels include 1.0 (100% measured move) and 1.618, acting as profit-taking zones; 2.618 can be used for all-time high breakouts.",
  "identification_rules": [
    "Select the Trend-Based Fib Extension tool (not the Fibonacci Retracement tool).",
    "Identify an impulsive move: a clear swing low and swing high.",
    "Click on the swing low, then the swing high, then the low of the subsequent pullback (the next swing low) to anchor the tool.",
    "Configure the tool to show key extension levels (typically 0, 1.0, and 1.618; optionally 0.786 and 2.618) and remove unnecessary levels to avoid clutter.",
    "Drag the extension lines to the right to project the levels into future price action.",
    "The 1.0 level acts as an initial profit target equal to the prior swing; the 1.618 level is a primary reversal/resistance zone."
  ],
  "trading_implication": "Fibonacci Extensions provide objective profit targets based on historical price swings. Traders use the 1.0 (100%) level as an initial target for partial profit-taking and the 1.618 level as a primary target, anticipating reversals or resistance. They are useful for setting risk-to-reward ratios and managing exits, with price reactions at these levels informing exit decisions.",
  "common_mistakes": [
    "Using the Fibonacci Retracement tool instead of the Trend-Based Fib Extension tool.",
    "Placing anchor points incorrectly (e.g., not at clear swing lows/highs), leading to inaccurate projections.",
    "Cluttering the chart with too many extension levels, making it hard to identify key targets."
  ],
