{
  "card_id": "external_change_of_character",
  "type": "merged_concept",
  "canonical_term": "External Change of Character",
  "aliases": [
    "eCHoCH",
    "echoch",
    "external choch",
    "External CHoCH"
  ],
  "school": "ICT / Smart Money Concepts (SMC)",
  "definition": "A change of character occurring on the higher time frame, where price fails to maintain a key swing low in an uptrend or a key swing high in a downtrend, signaling a major trend reversal. It is more significant than internal changes and indicates a potential shift in market structure on the higher time frame.",
  "identification_rules": [
    "On the higher time frame, define the trend: an uptrend has higher highs and higher lows; a downtrend has lower highs and lower lows.",
    "A bearish external change of character occurs when price breaks below the most recent significant higher low in the uptrend.",
    "A bullish external change of character occurs when price breaks above the most recent significant lower high in the downtrend.",
    "The break must be decisive, with price clearly moving beyond the key level."
  ],
  "trading_implication": "It signals a major trend reversal on the higher time frame, prompting traders to shift their directional bias (e.g., from bullish to bearish) and prepare for larger moves. It is more reliable than internal changes, which may only represent pullbacks. Traders often wait for this signal to confirm a trend change before entering positions.",
  "common_mistakes": [
    "Mistaking an internal change of character on a lower time frame for an external one, leading to premature reversal bias when it is merely a pullback.",
    "Trading the reversal without waiting for the external change of character to fully form on the higher time frame."
  ],
