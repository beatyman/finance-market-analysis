{
  "card_id": "order_block_and_change_of_character_entry",
  "type": "merged_concept",
  "canonical_term": "Order Block and Change of Character Entry",
  "aliases": [
    "ob + choch entry",
    "OB + CHoCH Entry",
    "Two-Timeframe Order Block Strategy",
    "two-timeframe order block strategy"
  ],
  "school": "Smart Money Concepts (SMC)",
  "definition": "A two-timeframe entry strategy combining a higher timeframe (HTF) order block with a lower timeframe (LTF) change of character (CHoCH). Price retraces to the HTF OB, then a CHoCH on the LTF confirms a reversal. Entry is either above a new OB formed with a fair value gap, or via Fibonacci retracement levels if no OB forms.",
  "identification_rules": [
    "Identify the HTF trend and mark a valid order block (last opposing candle before a strong move).",
    "Wait for price to retrace into the HTF order block zone.",
    "Switch to a LTF (at least 2x lower) and look for a change of character (CHoCH) where price reverses after breaking a key structure.",
    "If the CHoCH creates a fair value gap (inefficiency) and a new order block, place a buy limit order a spread size above that order block.",
    "If the CHoCH creates no inefficiency or order block, apply a Fibonacci retracement from the start to the end of the CHoCH move and enter between the 61.8% and 78.6% retracement levels.",
    "Set a stop-loss below the swing low formed during the CHoCH or below the order block low."
  ],
  "trading_implication": "This strategy provides a structured, multi-timeframe confirmation for entering trades at discount zones within a trend. By requiring a CHoCH on the LTF, it filters out false reversals and offers precise entry points. It aims to trade in the direction of the HTF trend with a well-defined risk profile, targeting subsequent liquidity levels.",
  "common_mistakes": [
    "Entering before a clear CHoCH forms on the LTF, leading to premature or false entries.",
    "Using an HTF order block that is not in the direction of the dominant trend.",
    "Misidentifying the order block zone, such as choosing a candle that does not represent the last opposing pressure.",
    "Using Fibonacci retracement levels outside 61.8-78.6% when no inefficiency appears, reducing entry precision.",
    "Placing stop-losses incorrectly, such as too tight or not below the relevant swing low, leading to early stop-outs."
  ],
