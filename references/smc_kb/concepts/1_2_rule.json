{
  "card_id": "1_2_rule",
  "type": "merged_concept",
  "canonical_term": "1-2% Rule",
  "aliases": [],
  "school": "Risk Management",
  "definition": "A risk management rule stating that a trader should never risk more than 1-2% of their total trading account on a single trade, in order to preserve capital and avoid account blowouts.",
  "identification_rules": [
    "Calculate the maximum dollar risk per trade as 1-2% of the account balance.",
    "Determine the stop-loss distance in price or pips.",
    "Compute position size such that the total loss if stopped out does not exceed the maximum dollar risk.",
    "Consistently apply the rule to every trade regardless of confidence level."
  ],
  "trading_implication": "The rule limits losses to small, manageable amounts during losing streaks, allowing traders to survive and remain profitable over many trades. It enforces discipline in position sizing and is fundamental to long-term consistency, as it prevents a single bad trade from devastating the account.",
  "common_mistakes": [
    "Risking more than 2% in pursuit of quick profits.",
    "Ignoring the rule during high-conviction trades and overexposing the account.",
    "Failing to adjust position size after account balance changes."
  ],
