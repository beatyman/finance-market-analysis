{
  "card_id": "order_flow_analysis",
  "type": "merged_concept",
  "canonical_term": "Order Flow Analysis",
  "aliases": [],
  "school": "Volume Analysis",
  "definition": "A method of analyzing individual buy and sell orders to assess market sentiment and order imbalance, typically used on short timeframes to identify precise entry and exit points.",
  "identification_rules": [
    "Observe the balance of buy orders versus sell orders; a dominance of buy orders suggests upward pressure, while sell order dominance suggests downward pressure.",
    "Apply on short timeframes (e.g., 1-minute to 1-hour) where order flow changes can signal immediate entry opportunities."
  ],
  "trading_implication": "Enables more accurate timing of entries and exits by revealing real-time buying/selling pressure; often used alongside volume profile and higher timeframe analysis for confirmation.",
  "common_mistakes": [
    "None explicitly mentioned in the material."
  ],
