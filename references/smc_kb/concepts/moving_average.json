{
  "card_id": "moving_average",
  "type": "merged_concept",
  "canonical_term": "Moving Average",
  "aliases": [
    "MA",
    "ma"
  ],
  "school": "Indicator-Based",
  "definition": "A statistical calculation that smooths price data by averaging closing prices over a designated number of periods, reducing noise and revealing underlying trends.",
  "identification_rules": [
    "The line is smoother than raw price, filtering erratic movements.",
    "Its length is the number of periods (e.g., candles) used in the average.",
    "Common types include Simple Moving Average (SMA) and Exponential Moving Average (EMA)."
  ],
  "trading_implication": "Moving averages identify trend direction and can generate buy/sell signals. They serve as versatile tools for filtering noise and confirming momentum across timeframes.",
  "common_mistakes": [
    "Ignoring that SMA and EMA differ in calculation and responsiveness, leading to misinterpretation.",
    "Failing to account for the impact of period length and chart timeframe on the average's sensitivity."
  ],
  "related_concepts": [],
