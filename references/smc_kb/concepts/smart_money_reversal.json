{
  "card_id": "smart_money_reversal",
  "type": "merged_concept",
  "canonical_term": "Smart Money Reversal",
  "aliases": [
    "Order Block at Smart Money Reversal",
    "order block at smart money reversal",
    "智能货币反转"
  ],
  "school": "ICT",
  "definition": "A reversal pattern where price reaches an important higher-time-frame level, sweeps buy-side or sell-side liquidity, then displaces and closes below the opening price of up-close candles (bearish) or above the opening price of down-close candles (bullish), validating a delivery direction flip.",
  "identification_rules": [
    "Price must reach an important higher-time-frame level (HTF PD array, order block, fair value gap, or significant swing high/low).",
    "Price sweeps buy-side liquidity (above swing high) for bearish reversal, or sell-side liquidity (below swing low) for bullish reversal.",
    "After the sweep, a displacement candle must close below the opening price of the single or series of up-close candles (bearish) or above the opening price of the down-close candle series (bullish).",
    "The up-close or down-close candle series that gets closed through becomes the order block used as resistance or support on retrace.",
    "A short-term low (for bullish) or high (for bearish) must form after the reversal to confirm validity.",
    "Without a sweep, the pattern can still qualify if a high-low-higher-high-lower-low sequence forms, but a preceding sweep is preferred."
  ],
  "trading_implication": "Used as primary signal for delivery shift. After validation, trade retest of the order block opening price with stop beyond swept high/low, targeting 2R minimum or opposing liquidity. For larger order blocks, enter at 50% body for better R:R. The reversal order block seeds subsequent continuation entries.",
  "common_mistakes": [
    "Identifying reversal at random chart spots without higher-time-frame important level, producing invalid order block.",
    "Confusing up-close candles that formed equal highs in a retracement with a true reversal order block.",
    "Skipping the requirement that displacement candle closes below/above the opening price of the candle series before entering.",
    "Placing stops on opposite end of order block for better R:R while accepting price may wick the stop even when trade is still valid.",
    "Entering at the reversal point itself instead of waiting for retest of the order block."
  ],
