{
  "card_id": "multiple_timeframe_analysis",
  "type": "merged_concept",
  "canonical_term": "Multiple Timeframe Analysis",
  "aliases": [
    "HTF/LTF Analysis",
    "htf/ltf analysis",
    "mtf analysis",
    "MTF analysis",
    "multi-timeframe analysis",
    "Timeframe Alignment",
    "Top-Down Analysis",
    "多时间框架分析",
    "时间框架递推",
    "跨时间框架分析"
  ],
  "school": "ICT",
  "definition": "A method of analyzing price action across multiple timeframes: higher timeframe (e.g., daily) determines directional bias via swing points and market structure shifts; intermediate timeframe identifies supporting structures (order blocks, fair value gaps); lower timeframe (e.g., 1-min) provides precise entry. Each timeframe may project standard deviations of manipulation legs to find confluent target zones.",
  "identification_rules": [
    "On the higher timeframe (e.g., daily), identify directional bias via market structure shift or swing highs/lows, and mark key structures (e.g., daily FVG, swing points).",
    "On the higher timeframe, identify a manipulation leg (a complete move in one direction) and project its standard deviations (±2, ±2.5, ±4) to obtain primary target zones.",
    "On the intermediate timeframe (e.g., 4H or 1H), find structures supporting the higher timeframe bias, including change in state of delivery, order blocks, or fair value gaps; also identify manipulation legs and project standard deviations on this timeframe.",
    "Continue drilling down to lower timeframes (e.g., 15-min, 5-min, 1-min), repeating identification of manipulation legs and standard deviation projections on each.",
    "Check if standard deviation projections from multiple timeframes align with PD arrays (FVG, OB, equal highs/lows) to find cross-timeframe confluences as high-probability entry or target zones.",
    "On the lowest timeframe, wait for a change in state of delivery or a counter-candle (e.g., retest of order block) as a specific entry signal.",
    "Verify that signals from three timeframes are aligned: higher timeframe bias, intermediate timeframe structure, and lower timeframe entry signal all point in the same direction.",
    "Determine market structure bias on a higher timeframe (e.g., 15-min) by identifying swing highs and lows.",
    "Identify a discount or premium zone on the higher timeframe using a Fibonacci retracement from the recent swing low to high.",
    "Find a point of interest (order block or fair value gap) within that discount/premium zone on the higher timeframe.",
    "Zoom to a lower timeframe (e.g., 1-min) and wait for a structural shift (break of structure or change of character) that confirms the higher timeframe bias.",
    "Enter the trade on the lower timeframe's order block or fair value gap, placing the stop loss at the extreme of that confluence."
  ],
  "trading_implication": "Higher timeframe prevents counter-trend trading and provides overall targets; intermediate timeframe validates trend continuation and offers structured risk management points; lower timeframe refines entry. When standard deviation projections from multiple timeframes coincide with PD arrays (e.g., one projection's -4 aligns with another's -2.5), a high-confluence zone forms, representing optimal trade setups. Alignment across three timeframes typically produces strong price expansions, used for setting stops, targets, and risk-reward ratios.",
  "common_mistakes": [
    "Trading solely on one timeframe, missing early confirmation signals and entering with poorer risk-reward.",
    "Taking a trade at the first confluence seen on the higher timeframe without waiting for a lower timeframe structural shift.",
    "Guessing between multiple confluences on the same timeframe without using the lower timeframe to confirm which will hold.",
    "Buying the breakout of structure without a lower timeframe retest and confirmation, leading to being trapped after the real move.",
    "Only trading on lower timeframe while ignoring higher timeframe bias, resulting in counter-trend trades stopped out.",
    "Entering when higher timeframe bias and lower timeframe signal are inconsistent, reducing success rate.",
    "Not waiting for intermediate timeframe structure confirmation (e.g., change in state of delivery) before entering on lower timeframe, increasing false signal risk.",
    "Confusing the roles of timeframes, e.g., using lower timeframe for bias or higher timeframe for precise entry.",
    "Projecting standard deviations on only one timeframe, neglecting cross-timeframe confluence verification, leading to less precise target zones.",
    "Ignoring higher timeframe overall targets when entering on lower timeframe, potentially closing too early or too late.",
    "Failing to correctly identify manipulation legs on each timeframe, causing wrong projection direction or magnitude.",
    "Improperly overlapping or mixing projections from multiple timeframes, failing to form clear confluence points."
  ],
