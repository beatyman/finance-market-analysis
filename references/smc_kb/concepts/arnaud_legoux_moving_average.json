{
  "card_id": "arnaud_legoux_moving_average",
  "type": "merged_concept",
  "canonical_term": "Arnaud Legoux Moving Average",
  "aliases": [
    "ALMA"
  ],
  "school": "Indicator Based",
  "definition": "ALMA (Arnaud Legoux Moving Average) is a moving average calculated using a Gaussian distribution, offering a balance between smoothness and responsiveness. It uses three parameters: Window Size (period), Offset, and Sigma, to reduce lag and false signals compared to traditional moving averages.",
  "identification_rules": [
    "Apply the ALMA indicator to a chart and set Window Size to the desired period (e.g., 50), Offset to 0.85, and Sigma to 6.",
    "Observe the smooth line that acts as dynamic support/resistance; in an uptrend, price tends to stay above the ALMA line.",
    "Compare ALMA to faster moving averages; it will show fewer price-line crossovers during trends."
  ],
  "trading_implication": "ALMA helps traders identify trend direction and market structure with reduced noise, making it suitable for trend-following and breakout strategies where false signals are costly. It can be used as a trailing support/resistance level, but its lower responsiveness may delay entries/exits compared to faster moving averages like HMA.",
  "common_mistakes": [
    "Using the default low period (9) without adjusting, causing the line to hug price too closely and produce noise.",
    "Expecting ALMA to react as quickly as HMA, leading to disappointment in fast-moving markets.",
    "Not considering the asset's volatility and trading style when choosing between ALMA and more responsive moving averages."
  ],
