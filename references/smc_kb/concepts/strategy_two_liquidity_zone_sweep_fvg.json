{
  "card_id": "strategy_two_liquidity_zone_sweep_fvg",
  "type": "merged_concept",
  "canonical_term": "Strategy Two (Liquidity Zone Sweep + FVG)",
  "aliases": [],
  "school": "ICT",
  "definition": "A multi-timeframe ICT strategy: identify key liquidity zones on a higher timeframe, wait for a sweep (false breakout) with price closing back inside, then enter on a lower timeframe at a fair value gap formed after the sweep, targeting opposite liquidity.",
  "identification_rules": [
    "Mark major buy-side and sell-side liquidity zones on a higher timeframe chart (e.g., major swing highs/lows, equal highs/lows).",
    "Wait for price to break beyond a liquidity zone and then close back inside the zone's range, confirming a liquidity sweep.",
    "Switch to a lower timeframe and locate a fair value gap (FVG) that formed immediately after the sweep.",
    "Enter in the direction opposite to the sweep: short after a buy-side liquidity sweep, long after a sell-side liquidity sweep.",
    "Place stop loss beyond the sweep extreme: above the high for shorts, below the low for longs.",
    "Take profit at the next opposing liquidity zone (sell-side for shorts, buy-side for longs)."
  ],
  "trading_implication": "This strategy aligns trades with institutional order flow by entering after smart money has collected liquidity and reversed price. The use of FVG on a lower timeframe provides a high-probability entry point with a defined stop and target, often yielding a favorable risk-to-reward ratio.",
  "common_mistakes": [
    "Entering before price closes back inside the liquidity zone, failing to confirm the sweep.",
    "Trading without a clear FVG on the lower timeframe, leading to premature entries.",
    "Misidentifying liquidity zones by using minor or insignificant levels instead of major, high-conviction zones.",
    "Placing stop losses too tight, getting stopped out by minor wicks before the reversal."
  ],
