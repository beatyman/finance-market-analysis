{
  "card_id": "premium_and_discount",
  "type": "merged_concept",
  "canonical_term": "Premium and Discount",
  "aliases": [
    "0.5 Fib Range Division",
    "0.5 fib range division",
    "Discount Zone",
    "p/d array",
    "P/D Array",
    "pd区域",
    "PD区域",
    "Premium Zone",
    "Premium/Discount",
    "premium/discount range",
    "Premium/Discount Range",
    "溢价区/折价区"
  ],
  "school": "ICT",
  "definition": "A framework dividing any defined price range (e.g., daily range, impulse leg) at its 50% Fibonacci midpoint (equilibrium) into two halves: the upper half (premium) where price is considered overvalued and selling is preferred, and the lower half (discount) where price is considered undervalued and buying is preferred.",
  "identification_rules": [
    "Identify a clearly defined price range by marking its swing high and swing low (e.g., daily range, impulse/displacement leg).",
    "Calculate the 50% Fibonacci level (midpoint/equilibrium) of that range; everything above this midpoint is premium, everything below is discount.",
    "When price is in the upper half (premium) of the range, label it as premium and bias toward sell/short entries.",
    "When price is in the lower half (discount) of the range, label it as discount and bias toward buy/long entries.",
    "The range can be extended or adjusted if price expands beyond the original boundaries, recalculating the midpoint accordingly.",
    "In the discount zone, look for long entries using PD array structures (e.g., Fair Value Gap, Order Block); in the premium zone, look for short entries using PD array structures."
  ],
  "trading_implication": "Premium/Discount framework refines entry decisions by waiting for price to retrace into the discount zone (for longs) or premium zone (for shorts) after a manipulation sweep, improving risk-to-reward. It serves as a confluence filter: entries are taken only when a PD array (e.g., FVG, OB) aligns with the premium/discount zone. Stop placement is beyond the range extreme; targets are at the opposite side or external liquidity.",
  "common_mistakes": [
    "Entering at the opening price or current price after a manipulation sweep instead of waiting for price to retrace into the discount (for longs) or premium (for shorts) within the range.",
    "Failing to adjust (extend) the premium/discount range when price expands beyond the original range boundaries, which can misclassify the current price location.",
    "Confusing the directional meaning of premium and discount zones (premium should be short, discount should be long).",
    "Using premium/discount as a standalone entry signal without additional confirmation from PD array structures (e.g., FVG, Order Block)."
  ],
