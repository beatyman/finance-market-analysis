{
  "card_id": "higher_high",
  "type": "merged_concept",
  "canonical_term": "Higher High",
  "aliases": [],
  "school": "Price Action",
  "definition": "A swing high that surpasses the previous swing high, confirming an uptrend. It forms when an impulsive move breaks above the prior peak, signaling continued bullish momentum and trend strength.",
  "identification_rules": [
    "Locate the most recent swing high, a peak with lower highs on both sides.",
    "Wait for price to break above that swing high with an impulsive move, characterized by a large candle and strong momentum.",
    "Confirm the higher high remains valid only if the subsequent pullback does not breach the nearest higher low."
  ],
  "trading_implication": "Higher highs confirm an uptrend and provide a bias for long trades. As long as price continues making higher highs and higher lows, the trend is intact, and traders can look for buying opportunities on pullbacks.",
  "common_mistakes": [
    "Assuming any peak above price is a higher high without verifying it against a prior swing high.",
    "Misidentifying minor oscillations as swing highs, leading to false higher high signals in complex price action.",
    "Ignoring the requirement of an impulsive move, causing premature entries when the break lacks momentum."
  ],
  "related_concepts": [],
