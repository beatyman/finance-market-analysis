{
  "card_id": "pip",
  "type": "merged_concept",
  "canonical_term": "Pip",
  "aliases": [],
  "school": "General",
  "definition": "The smallest standard price movement in a forex currency pair, typically equal to 0.0001 for most pairs, but 0.01 for pairs involving the Japanese Yen. It measures price change and profit/loss.",
  "identification_rules": [
    "For non-JPY currency pairs, observe the fourth decimal place: one pip is a change of 0.0001.",
    "For JPY currency pairs, observe the second decimal place: one pip is a change of 0.01."
  ],
  "trading_implication": "Pips quantify price changes, enabling traders to measure profit, loss, and movement. They are used to set stop-loss and take-profit distances, calculate risk-to-reward ratios, and communicate trade outcomes.",
  "common_mistakes": [
    "Assuming a pip always equals 0.0001, forgetting that JPY pairs use 0.01 as a pip",
    "Overcomplicating pip calculations by not recognizing the difference in decimal placement among pairs"
  ],
