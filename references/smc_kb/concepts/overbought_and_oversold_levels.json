{
  "card_id": "overbought_and_oversold_levels",
  "type": "merged_concept",
  "canonical_term": "Overbought and Oversold Levels",
  "aliases": [
    "overbought/oversold",
    "Overbought/Oversold"
  ],
  "school": "Indicator-Based",
  "definition": "Price overextension levels used with the Stochastic RSI indicator: overbought when the indicator value exceeds 80, oversold when it falls below 20. These levels indicate momentum may be extreme, potentially preceding a reversal or pullback.",
  "identification_rules": [
    "Stochastic RSI %K and %D lines rise above 80 to signal overbought condition.",
    "Stochastic RSI %K and %D lines fall below 20 to signal oversold condition.",
    "The Stochastic RSI can spend extended periods in overbought/oversold zones, so sustained readings do not confirm an imminent reversal."
  ],
  "trading_implication": "Overbought suggests a potential downturn; oversold suggests a potential upturn. However, because the Stochastic RSI frequently resides in these zones for prolonged periods, traders should not treat overbought/oversold as immediate reversal signals but rather as an alert for possible reversals or momentum shifts.",
  "common_mistakes": [
    "Treating overbought/oversold as automatic reversal signals—the Stochastic RSI often remains in these territories for extended durations.",
    "Applying standard RSI overbought/oversold levels (70/30) to the Stochastic RSI, when the correct thresholds are 80/20."
  ],
