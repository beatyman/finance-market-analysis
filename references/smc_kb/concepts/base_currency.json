{
  "card_id": "base_currency",
  "type": "merged_concept",
  "canonical_term": "Base Currency",
  "aliases": [],
  "school": "General",
  "definition": "In currency trading, the base currency is the first currency listed in a pair. It is the unit being valued against the second currency (the quote currency). For example, in EUR/USD, EUR is the base, indicating how many US dollars equal one Euro. Trading involves buying or selling the base currency.",
  "identification_rules": [
    "In any currency pair, the base currency is always the first currency listed (e.g., EUR in EUR/USD).",
    "The exchange rate expresses the value of one unit of the base currency in terms of the quote currency.",
    "A long position means buying the base currency; a short position means selling the base currency."
  ],
  "trading_implication": "The base currency determines which currency you are speculating on. If you go long on a pair like EUR/USD, you expect the base (EUR) to appreciate against the quote (USD), profiting from the rise. Understanding this is fundamental to analyzing price movements and executing directional trades.",
