{
  "card_id": "confluence",
  "type": "merged_concept",
  "canonical_term": "Confluence",
  "aliases": [
    "confirmation signals",
    "Confluence key",
    "confluence key",
    "confluences",
    "matching levels",
    "overlapping projections"
  ],
  "school": "ICT",
  "definition": "Confluence occurs when multiple independent technical analysis tools (e.g., standard deviation projections, order blocks, fair value gaps, Fibonacci levels) align at the same price area, increasing the probability of a successful trade. In ICT/SMC contexts, it often involves projections from different manipulation legs overlapping with PD array elements within the discount or premium zone.",
  "identification_rules": [
    "Identify two or more independent standard deviation projections from different manipulation legs and observe if specific levels (e.g., -2, -2.5, -4) intersect at the same price area.",
    "Check if PD array elements (e.g., FVG, order blocks, equal highs/lows, liquidity) coincide with standard deviation projections.",
    "Identify the true external market structure with clear swing highs and lows to determine trend direction.",
    "Draw a Fibonacci retracement from swing low to swing high (for bullish) to define the discount zone (below 0.5).",
    "Locate order blocks (three-candle formation: bearish candle then aggressive bullish move) within the discount.",
    "Locate fair value gaps (gap between wicks of three consecutive bullish candles) within the discount.",
    "Wait for price to reach the confluence level inside the discount before considering an entry.",
    "Seek additional confirmation from at least one other tool such as a candlestick pattern, indicator, or chart pattern."
  ],
  "trading_implication": "Confluence areas represent high-probability target or reversal/retracement zones. When standard deviation projections overlap with PD arrays (e.g., sell-side liquidity, order blocks, equal highs), the area becomes a 'low hanging fruit' for entries. Traders can use multiple projections to confirm targets and place tighter stops below the confluence level, improving risk-to-reward. Confluence acts as a trade filter: the more confirming signals, the higher the confidence.",
  "common_mistakes": [
    "Relying on a single projection or tool without additional confirmation from other PD arrays or tools.",
    "Confusing projections from different timeframes and failing to identify cross-timeframe confluence.",
    "Overinterpreting slight price proximity; clear overlap is required, not approximate alignment.",
    "Using multiple confluences in the same price leg and guessing which one to use, leading to indecision.",
    "Taking a trade at the first sign of a confluence without confirming price is in the discount.",
    "Ignoring true market structure and trading confluences against the overall trend.",
    "Placing stops at the swing low instead of below the confluence, risking larger losses.",
    "Assuming every support/resistance flip will hold without verifying confluences."
  ],
  "related_concepts": [],
  "merge_strategy": "llm_synthesis",
  "merge_model": "deepseek/deepseek-chat",
  "merge_notes": "School conflict: ICT (2 cards) vs General (1 card); picked ICT by majority. The ICT card emphasizes standard deviation projections and PD arrays, while the General card uses broader technical tools. The SMC-Extra-Supplement card adds Fibonacci discount zone and specific OB/FVG identification. All nuances preserved.",
  "warnings": [
    "school_conflict: ['General', 'ICT']"
  ],
