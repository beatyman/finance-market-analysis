{
  "card_id": "accumulation_phase",
  "type": "merged_concept",
  "canonical_term": "Accumulation Phase",
  "aliases": [],
  "school": "Smart Money Concepts (SMC)",
  "definition": "A consolidation period with equal highs and equal lows forming support and resistance, building buyside and sellside liquidity pools above and below from retail stop-losses and pending orders. It precedes a directional markup or markdown breakout after smart money sweeps one liquidity side.",
  "identification_rules": [
    "Identify a ranging market with price repeatedly testing the same high and low levels, creating equal highs and equal lows.",
    "Locate a clear horizontal resistance zone at the top of the range and a support zone at the bottom.",
    "Confirm multiple touches of both levels without a breakout, indicating sideways accumulation.",
    "Look for resting liquidity above the resistance (buyside) and below the support (sellside) as stop-losses and pending orders cluster."
  ],
  "trading_implication": "Accumulation indicates smart money is building positions before a directional move. Wait for a liquidity sweep at one extreme (triggers retail stops) followed by a reversal. Enter in the opposite direction of the sweep, targeting a breakout toward the other liquidity pool. This aligns with institutional order flow and offers high-probability entries.",
  "common_mistakes": [
    "Buying at support or selling at resistance within the accumulation and placing stop-losses just beyond, making them easy targets for liquidity sweeps.",
    "Entering a breakout trade immediately upon a level breach without waiting for a liquidity sweep and reversal, often getting caught in a false breakout."
  ],
