{
  "card_id": "drawdown",
  "type": "merged_concept",
  "canonical_term": "Drawdown",
  "aliases": [
    "drawdown limit",
    "Drawdown Limit",
    "max drawdown",
    "Max Drawdown"
  ],
  "school": "Risk Management",
  "definition": "Drawdown is the decline from the peak value of a trading account to its lowest point during a specific period, measuring loss before recovery. In prop firm contexts, it specifically refers to the maximum loss allowance on an account, which represents the true risk capital for position sizing.",
  "identification_rules": [
    "Identify the prop firm's stated maximum loss limit (e.g., $1,500 drawdown on a 25K account) as the drawdown figure.",
    "Treat the drawdown amount, not the nominal account size, as the actual capital at risk.",
    "Calculate risk per trade as a percentage of the drawdown amount rather than as a percentage of the nominal account size.",
    "Target a risk per trade between 7% and 10% of the drawdown, allowing 10–15 consecutive losing trades before the account is blown.",
    "Identify the highest account equity point before a decline as the peak.",
    "Determine the lowest subsequent account equity point as the trough.",
    "Calculate drawdown as the percentage drop from peak to trough."
  ],
  "trading_implication": "Drawdown determines real position sizing on prop firm accounts; risk as a percentage of drawdown (7-10%) to survive 10-15 consecutive losses. For general trading, large drawdowns require disproportionately larger gains to recover (e.g., 50% loss needs 100% gain). Avoid deep drawdowns by being defensive and adjusting risk during losing periods.",
  "common_mistakes": [
    "Sizing position as a percentage of the nominal account size instead of the drawdown amount, leading to oversized risk.",
    "Risking 1% of the nominal account when it actually equates to ~17% of the drawdown, blowing the account after 6-7 losing trades.",
    "Failing to lower risk after passing the evaluation phase, missing the opportunity to build a cushion on the funded account.",
    "Assuming small percentage losses are easily recovered without recognizing the exponential difficulty.",
    "Trading more aggressively during drawdowns to recoup losses quickly, worsening the situation.",
    "Neglecting to reduce position size or risk during high-volatility periods, leading to larger drawdowns."
  ],
  "related_concepts": [],
  "merge_strategy": "llm_synthesis",
  "merge_model": "deepseek/deepseek-chat",
  "merge_notes": "Both cards agree on school (Risk Management). The first card focuses on prop firm drawdown as risk capital; the second on general peak-to-trough decline. Unified definition combines both perspectives.",
