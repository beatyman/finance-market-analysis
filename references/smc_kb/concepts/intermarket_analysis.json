{
  "card_id": "intermarket_analysis",
  "type": "merged_concept",
  "canonical_term": "Intermarket Analysis",
  "aliases": [
    "currency pairing",
    "Currency Pairing",
    "relative strength analysis",
    "Relative Strength Analysis",
    "相对强弱分析",
    "货币对相对强度比较"
  ],
  "school": "Order Flow",
  "definition": "A method of comparing correlated currency futures (DXY, EUR, GBP, JPY, CAD, CHF, NZD, AUD) to rank relative strength and weakness, then pairing the strongest with the weakest currency to select the forex pair with the highest expansion potential for the trading day.",
  "identification_rules": [
    "First assess DXY's state: trending bullish, trending bearish, or consolidating.",
    "If DXY is bullish-trending, find the weakest foreign currency future and trade that pair (e.g., DXY strong + EUR weakest → short EUR/USD).",
    "If DXY is bearish-trending, find the strongest foreign currency future and trade that pair (e.g., DXY weak + JPY strongest → short USD/JPY).",
    "If DXY is consolidating (typically after large expansion or hitting an HTF key level), ignore the dollar and pair the strongest foreign currency against the weakest foreign currency (exotic pair).",
    "Rank each currency's candle closure on the daily as bullish, bearish, or consolidating, then select extremes; avoid pairing a trending currency with a consolidating one as it yields weaker expansion.",
    "Identify currencies to avoid: those with the same directional bias as the anchor currency (e.g., if shorting USD, avoid foreign currencies that are also bearish like JPY when it lacks bullishness).",
    "Observe the cross pair (e.g., EURGBP) trend: bullish indicates the former (EUR) is stronger than the latter (GBP), bearish indicates the former is weaker.",
    "Compare the daily closing strength of two currency pairs over the same period; a stronger close indicates relative strength.",
    "Verify on lower timeframes: observe the magnitude and speed of reaction to the same event (e.g., sweep, breakout) across the two pairs."
  ],
  "trading_implication": "Used as a pre-trade filter to select which forex or currency-futures market will produce the cleanest expansion day. Pairing extremes (strongest vs. weakest) maximizes directional momentum, while pairing with a consolidating currency yields muted trends. Often multiple valid pairs exist on a given day; the primary value is eliminating pairs that will not expand (e.g., avoiding USD/JPY when JPY shows no relative strength). Works alongside candle 2 closures, fair value gaps, and HTF key levels to confirm the chosen pair's setup.",
  "common_mistakes": [
    "Pairing a trending currency with a consolidating currency, resulting in a weak trend rather than strong expansion.",
    "Trading a pair where the foreign currency lacks relative strength/weakness versus the dollar (e.g., trading USD/JPY when JPY is not bullish in a bearish-dollar environment).",
    "Assuming only one 'best' pair exists per day instead of recognizing multiple valid options and focusing on which to avoid.",
    "Continuing to pair against the dollar when DXY is consolidating instead of switching to exotic cross-pair analysis.",
    "Basing decisions solely on a single currency pair's movement without comparing relative strength to correlated pairs.",
    "Performing relative strength analysis when the major currency (USD) trend is unclear, leading to wrong trade direction.",
    "Trading the relatively weaker pair, resulting in insufficient profit or being stopped out during the same expansion day."
  ],
  "related_concepts": [],
  "merge_strategy": "llm_synthesis",
  "merge_model": "deepseek/deepseek-chat",
  "merge_notes": "School conflict: first card says SMC, second says Order Flow; majority is Order Flow (1 SMC vs 1 Order Flow, but second card is more detailed and authoritative). Picked Order Flow. Definition from second card used as it is more precise and operational. Identification rules combined from both cards, deduplicated. Trading implication primarily from second card, with nuance from first card about pairing strong/weak currencies. Common mistakes merged from both.",
  "warnings": [
    "school_conflict: ['Order Flow', 'SMC']"
  ],
