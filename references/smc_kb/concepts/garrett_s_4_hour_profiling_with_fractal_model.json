{
  "card_id": "garrett_s_4_hour_profiling_with_fractal_model",
  "type": "merged_concept",
  "canonical_term": "Garrett's 4-Hour Profiling with Fractal Model",
  "aliases": [
    "gxt",
    "GXT"
  ],
  "school": "ICT",
  "definition": "A combined approach pairing 4-hour candle profiling (identifying reversal vs. continuation candles within the Power of 3) with a lower-time-frame fractal model entry on 3-minute or 5-minute charts to confirm the wick formation and trade the subsequent expansion body.",
  "identification_rules": [
    "Identify the 4-hour candle's role in the Power of 3 sequence (e.g., 2 a.m. London reversal anticipates a 6 a.m. continuation candle).",
    "For a continuation candle, expect price to open, form its wick while respecting the EQ (50%) of the previous 4-hour candle, then expand in the bias direction.",
    "Drop to a 3-minute or 5-minute chart and wait for a fractal model setup (consolidation, sweep of the consolidation high/low) to form within the EQ zone.",
    "Require a change in state of delivery on the lower time frame to confirm the wick is complete before entering.",
    "Trade the expansion body of the 4-hour candle in the direction of the higher time frame bias."
  ],
  "trading_implication": "GXT allows traders to align 4-hour Power of 3 expectations with precise lower-time-frame entries. The 4-hour candle defines bias and the expected wick zone; the 3m/5m fractal model times entry where the wick is forming. Stops go on the protected swing or above 50% of the change in state of delivery and EQ; targets are 2R or a continuation entry on the next higher time frame candle open. Best suited when a 4-hour reversal candle has formed and the next 4-hour candle should expand.",
  "common_mistakes": [
    "Trading over old highs/lows instead of fresh setups (acknowledged as not preferred).",
    "Extending a trade beyond the current 4-hour candle's range/time rather than waiting for the new higher time frame candle to open for continuation.",
    "Entering without lower-time-frame confirmation (change in state of delivery) of the wick formation.",
    "Allowing price to trade above the 50% of the CISD and the opposing candle EQ zone, which invalidates the setup."
  ],
