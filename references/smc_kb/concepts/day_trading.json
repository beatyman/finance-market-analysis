{
  "card_id": "day_trading",
  "type": "merged_concept",
  "canonical_term": "Day Trading",
  "aliases": [],
  "school": "Smart Money Concepts (SMC)",
  "definition": "A trading style where positions are opened and closed within the same trading day, avoiding overnight risk and capturing short-term price movements. It balances frequency and risk between swing trading and scalping, complementing Smart Money Concepts for precision entries.",
  "identification_rules": [
    "All positions are opened and closed within the same trading session; no trades are held overnight.",
    "Uses intraday time frames (e.g., 1H, 15min) to capture short-term moves, as opposed to daily or weekly charts typical of swing trading."
  ],
  "trading_implication": "Day trading offers frequent opportunities without extreme scalping fluctuations or overnight exposure. It allows traders to apply Smart Money Concepts—such as order blocks, fair value gaps, and liquidity sweeps—on intraday charts for precise entries, aiming to capture moves within a single session.",
  "common_mistakes": [
    "Entering day trades without a solid, rule-based trading plan, leading to emotional or inconsistent decisions.",
    "Holding positions overnight, which contradicts the day trading principle and exposes the trader to overnight gaps."
  ],
