{
  "card_id": "bullish_engulfing",
  "type": "merged_concept",
  "canonical_term": "Bullish Engulfing",
  "aliases": [
    "bullish engulfing pattern"
  ],
  "school": "Price Action",
  "definition": "A two-candle bullish reversal pattern where a large green candle completely engulfs the body of the preceding red candle, signaling a potential upward price reversal. It forms after a downtrend or pullback.",
  "identification_rules": [
    "The pattern forms after a preceding downward move (downtrend or pullback in an uptrend).",
    "The first candle is a bearish (red) candle with a real body, preferably small.",
    "The second candle is a large bullish (green) candle.",
    "The green candle's real body completely engulfs the red candle's real body, ignoring wicks. Specifically, it opens below (or at) the red candle's close and closes above the red candle's open.",
    "The pattern is confirmed only after the green candle closes."
  ],
  "trading_implication": "A buy signal indicating a potential upward reversal. Traders often enter long at the close of the green candle, place a stop loss below the pattern's lowest point or nearest support level, and target a favorable risk-to-reward ratio (e.g., 1:2). Effectiveness increases when the pattern forms at key support levels, Fibonacci retracement zones, or after pullbacks. Some traders also await confirmation from subsequent bullish price action.",
  "common_mistakes": [
    "Entering before the green candle closes, thus not waiting for pattern confirmation.",
    "Trading the pattern without considering whether it occurs at a key support level or prior market structure.",
    "Placing a stop loss without considering nearby support levels."
  ],
