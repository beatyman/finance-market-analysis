{
  "card_id": "trend_trading_with_support_and_resistance",
  "type": "merged_concept",
  "canonical_term": "Trend Trading with Support and Resistance",
  "aliases": [],
  "school": "Price Action",
  "definition": "A trend-following strategy that enters positions after a key support or resistance level breaks; in an uptrend, traders go long when former resistance flips to support, and in a downtrend, they go short when former support flips to resistance, using additional confirmation to validate entries.",
  "identification_rules": [
    "Determine the trend: an uptrend consists of higher highs and higher lows with key lows holding; a downtrend has lower highs and lower lows.",
    "Identify the most recent broken resistance (in uptrend) or broken support (in downtrend) that led to a new high or low.",
    "Wait for price to pull back and test the broken level, which is expected to flip role (resistance becomes support, support becomes resistance).",
    "Look for confirmation of the role flip through candlestick patterns, indicator signals, or chart patterns before entering.",
    "Enter long in an uptrend on a confirmed bounce off the new support; enter short in a downtrend on a confirmed rejection from the new resistance.",
    "The trade remains valid as long as the trend-defining low (uptrend) or high (downtrend) is not breached."
  ],
  "trading_implication": "This strategy allows traders to align entries with the prevailing trend at high-probability zones where prior key levels are retested. It offers favorable risk-to-reward ratios by entering near support in uptrends and near resistance in downtrends, but confirmation is essential to avoid false signals.",
  "common_mistakes": [
    "Entering a trade immediately upon the level break without waiting for a pullback and confirmation, leading to failed trades.",
    "Exiting prematurely on a minor dip below the flipped support in an uptrend, even though the overall trend-defining low remains intact.",
    "Ignoring the trend context (e.g., buying a support flip in a broader downtrend)."
  ],
