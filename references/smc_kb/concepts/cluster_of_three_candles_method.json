{
  "card_id": "cluster_of_three_candles_method",
  "type": "merged_concept",
  "canonical_term": "Cluster of Three Candles Method",
  "aliases": [],
  "school": "Smart Money Concepts (secondary)",
  "definition": "A technique for drawing supply and demand zones by selecting the three candlesticks immediately before a strong impulsive move and enclosing them within a rectangle to serve as a potential reversal area.",
  "identification_rules": [
    "Identify a clear impulsive move (aggressive buying for demand or selling for supply) on the chart.",
    "Count three candlesticks backward from the start of the impulsive move.",
    "Using a rectangle tool, draw a zone that spans from the lowest point to the highest point of those three candles, ensuring the entire cluster is inside.",
    "Extend the rectangle to the right to project the zone into the future for potential price reactions."
  ],
  "trading_implication": "The zone created by this method acts as a supply or demand area where price is likely to reverse. Traders use it to anticipate entries, set stop losses, and take profits. The three-candle cluster provides a more refined and often more accurate zone than using only the last candle before the move.",
  "common_mistakes": [
    "Failing to adjust the zone when multiple supply/demand shifts occur in the same area, leading to incorrectly positioned zones.",
    "Not considering previous supply/demand zones and price action reactions when deciding where to start the cluster.",
    "Rigidly applying the three-candle rule without evaluating whether a larger or smaller cluster better captures the origin of the move."
  ],
