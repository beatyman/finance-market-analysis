{
  "card_id": "time_frame_combination",
  "type": "merged_concept",
  "canonical_term": "Time Frame Combination",
  "aliases": [
    "Multi-Timeframe Combination",
    "multi-timeframe combination",
    "Time Frame Pairing"
  ],
  "school": "Price Action",
  "definition": "Selecting three time frames (high, medium, low) for multi-timeframe analysis where the ratio between consecutive frames is between 4:1 and 8:1, ensuring a coherent top-down view. Common examples: daily/4-hour/30-minute for swing trading and 1-hour/15-minute/3-minute for day trading.",
  "identification_rules": [
    "Choose three time frames: one high, one medium, and one low, corresponding to long-term, intermediate, and short-term perspectives.",
    "The ratio between the higher and medium time frame must be between 4:1 and 8:1 (e.g., daily to 4-hour is 6:1).",
    "The ratio between the medium and lower time frame must also be between 4:1 and 8:1 (e.g., 4-hour to 30-minute is 8:1).",
    "Select time frames that align with the trading style: swing trading uses daily/4-hour/30-minute (or 1-hour); day trading uses 1-hour/15-minute/3-minute."
  ],
  "trading_implication": "This combination enables a structured top-down analysis: the high time frame identifies the broader trend, the medium refines it, and the low provides entry precision. It balances detail and noise, helping traders make higher-probability decisions by ensuring multiple time frames corroborate the trade idea.",
  "common_mistakes": [
    "Using time frames with ratios well outside 4:1 to 8:1, leading to disjointed signals or excessive noise.",
    "Applying a swing trading combination (e.g., daily/4-hour/30-minute) for very short-term scalping without adjusting the ratio."
  ],
