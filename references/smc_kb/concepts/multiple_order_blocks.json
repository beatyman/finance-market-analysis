{
  "card_id": "multiple_order_blocks",
  "type": "merged_concept",
  "canonical_term": "Multiple Order Blocks",
  "aliases": [
    "multiple obs",
    "Multiple OBs"
  ],
  "school": "ICT",
  "definition": "A strategy of trading every consecutive order block that forms in the trend direction before price reaches the higher time frame target, provided each offers a reasonable risk-to-reward ratio. Trades are taken with reduced risk (no more than 2% total capital at risk) and limited to three concurrent positions.",
  "identification_rules": [
    "Determine the higher time frame target (e.g., recent swing high/low) and ensure the overall trend direction is confirmed.",
    "Zoom into a lower time frame and wait for a valid reversal signal (e.g., a change of character / CHoCH) to confirm the short-term trend has shifted.",
    "As price prints bullish/bearish order blocks in the newly established trend direction, identify each order block that respects the trend.",
    "For each qualifying order block, evaluate if the risk-to-reward ratio is acceptable based on the distance to stop and target.",
    "Enter a position at each order block without canceling prior entries, provided the total number of active trades does not exceed three."
  ],
  "trading_implication": "This approach increases the probability of participating in the full move, as price may not retrace to the first order block. It distributes entries across multiple potential reversal points. Strict position sizing is essential: no single trade should risk more than a fraction of the account, and total exposure across all concurrent trades must stay below 2% to manage losing streaks.",
  "common_mistakes": [
    "Using full risk on each individual order block instead of distributing risk across all potential entries.",
    "Exceeding three active trades at the same time, leading to overexposure.",
    "Entering order blocks that do not offer a reasonable risk-to-reward ratio.",
    "Failing to confirm a valid trend reversal (CHoCH) before taking multiple entries."
  ],
  "related_concepts": [],
