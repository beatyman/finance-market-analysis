{
  "card_id": "time_frame_ratio",
  "type": "merged_concept",
  "canonical_term": "Time Frame Ratio",
  "aliases": [],
  "school": "General",
  "definition": "A guideline for selecting consecutive time frames in multi-timeframe analysis, requiring a ratio between 4:1 and 8:1 (e.g., daily to 4-hour is 6:1). This ensures each frame provides distinct yet coherent perspectives, avoiding redundancy or misalignment.",
  "identification_rules": [
    "Calculate the ratio by dividing the larger time frame's duration (in minutes) by the smaller one (e.g., 240 min / 30 min = 8:1).",
    "Confirm the resulting ratio falls between 4:1 and 8:1 inclusive.",
    "Apply the rule to each adjacent pair in the selected three-time-frame setup."
  ],
  "trading_implication": "It enables effective top-down analysis by bridging long-term, medium-term, and short-term views. Adhering to the ratio helps traders align trends across frames, refine entries, and improve trade probability, especially in day trading, swing trading, or scalping.",
