{
  "card_id": "golden_pocket",
  "type": "merged_concept",
  "canonical_term": "Golden Pocket",
  "aliases": [],
  "school": "General",
  "definition": "The Fibonacci retracement zone between 0.618 and 0.65, a deeper and smaller area compared to the golden zone. The 0.65 level is arbitrary and lacks mathematical basis, so it should be used with caution.",
  "identification_rules": [
    "Draw Fibonacci retracement levels on a price swing high and swing low.",
    "The golden pocket is the zone between the 0.618 and 0.65 retracement levels.",
    "Note that the default Fibonacci tool does not include 0.65, so it must be manually added."
  ],
  "trading_implication": "It is considered a potential reversal zone where price may find support or resistance. However, because 0.65 is arbitrary, its reliability is questionable; traders should test it with paper trading and apply strict risk management before using it in live markets.",
  "common_mistakes": [
    "Assuming 0.65 has mathematical or geometric significance.",
    "Using the golden pocket blindly without backtesting or paper trading.",
    "Neglecting risk management when trading based on this zone."
  ],
