{
  "card_id": "static_and_dynamic_liquidity",
  "type": "merged_concept",
  "canonical_term": "Static and Dynamic Liquidity",
  "aliases": [],
  "school": "Smart Money Concepts (SMC)",
  "definition": "Static liquidity: zones of resting orders (stop-losses, pending orders) such as equal highs/lows, order blocks, support/resistance. Dynamic liquidity: internal and external range factors that drive market direction. Price moves between these liquidity types to generate momentum.",
  "identification_rules": [
    "Static liquidity: locate areas below equal lows and swing lows, above equal highs and swing highs, dynamic trend lines, order blocks, support/resistance levels, Fibonacci retracement levels, and daily candle bodies/shadows.",
    "Dynamic liquidity: identify internal range (minor swing points) and external range (major swing points); price oscillates between internal and external liquidity in a continuous cycle."
  ],
  "trading_implication": "Use static liquidity sweeps as a confluence factor before entering at a point of interest. A failure to sweep liquidity before reaching a zone increases the risk of the zone being used as fuel. Dynamic liquidity clarifies market direction by showing whether price is moving from internal to external range or vice versa.",
  "common_mistakes": [
    "Entering a trade at a point of interest without a prior liquidity sweep, causing the zone to be consumed as liquidity for the next move."
  ],
