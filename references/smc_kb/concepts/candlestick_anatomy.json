{
  "card_id": "candlestick_anatomy",
  "type": "merged_concept",
  "canonical_term": "Candlestick Anatomy",
  "aliases": [],
  "school": "General",
  "definition": "A candlestick represents price movement over a specific time period, defined by four points: open (first trade), close (last trade), high (peak), and low (trough). In a bullish candle, close is above open; in a bearish candle, close is below open. The body shows the range between open and close, while wicks show rejected extremes.",
  "identification_rules": [
    "For any candlestick, identify the open as the first traded price and close as the last traded price of the period.",
    "The high is the maximum price reached, and the low is the minimum price reached, regardless of the body.",
    "In a bullish candle, the open is at the bottom of the body and close at the top; the high and low extend as wicks above and below.",
    "In a bearish candle, the open is at the top of the body and close at the bottom; wicks extend to high and low.",
    "A green body indicates bullish (close > open), a red body indicates bearish (close < open)."
  ],
  "trading_implication": "Candlestick anatomy is the foundation for reading order flow and market sentiment. The close relative to open reveals intra-period momentum, while wicks show price rejection. Comparing close to previous levels confirms market acceptance or rejection, aiding in identifying true breaks of structure and avoiding false signals. It enables traders to gauge buying and selling pressure behind each price move.",
  "common_mistakes": [
    "Mistaking a wick beyond a key level as a valid break, without waiting for a close above/below the level.",
    "Assuming a long upper wick on a bullish candle indicates continuation of the uptrend, when it may signal rejection.",
    "Ignoring the close and focusing only on the high/low, leading to misreading market structure.",
    "Treating all candles with large wicks as reversals without context from subsequent candles and closes."
  ],
