{
  "card_id": "higher_low",
  "type": "merged_concept",
  "canonical_term": "Higher Low",
  "aliases": [],
  "school": "Price Action",
  "definition": "A swing low that is higher than the preceding swing low, confirming an uptrend when paired with higher highs. It signals that buyers are stepping in at elevated levels, maintaining upward momentum.",
  "identification_rules": [
    "Locate the most recent swing low.",
    "Compare it to the previous swing low: the current low must be above the prior low.",
    "Confirm that price has made a higher high between the two lows.",
    "Use daily timeframe and mechanical rules: after an impulsive move breaks a prior high, the uptrend holds as long as price stays above the low of the subsequent pullback."
  ],
  "trading_implication": "A higher low confirms that an uptrend remains intact. Traders view pullbacks to a higher low as potential entry points for long positions, with the expectation that the trend will continue and produce another higher high.",
