{
  "card_id": "dumb_money",
  "type": "merged_concept",
  "canonical_term": "Dumb Money",
  "aliases": [
    "dummy money",
    "Dummy Money",
    "retail traders",
    "Retail Traders"
  ],
  "school": "ICT",
  "definition": "Dumb money refers to retail traders who follow simple, pattern-based strategies like trendlines, support/resistance, and double tops/bottoms. Their predictable order placements, stop losses, and take profits create liquidity pools that are routinely targeted and exploited by smart money.",
  "identification_rules": [
    "Identify obvious trendlines connecting swing points where retail traders would expect price reactions and place orders.",
    "Locate equal highs or lows that form double tops/bottoms, indicating levels where retail traders cluster entries and stops.",
    "Find support/resistance levels drawn from past price extremes, as retail traders likely use them for entry and exit decisions.",
    "Observe areas just beyond recent swing points where retail traders logically place protective stop-loss orders."
  ],
  "trading_implication": "Dumb money liquidity reveals where smart money is likely to engineer price moves to sweep stops and trap traders before the real trend. Rather than trading with the crowd, a trader should anticipate these liquidity grabs and align entries with the smart money direction, often after a manipulation phase.",
  "common_mistakes": [
    "Trading solely based on liquidity zones without considering overall market structure and trend context.",
    "Assuming that the presence of liquidity means price will move there immediately, ignoring higher-timeframe direction.",
    "Misinterpreting a liquidity sweep as a genuine breakout and entering in the wrong direction."
  ],
