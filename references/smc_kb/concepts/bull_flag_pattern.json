{
  "card_id": "bull_flag_pattern",
  "type": "merged_concept",
  "canonical_term": "Bull Flag Pattern",
  "aliases": [
    "Bull Flag",
    "bull flag"
  ],
  "school": "Price Action",
  "definition": "A bullish continuation pattern formed by a sharp impulsive advance followed by a tight, shallow consolidation (the flag) composed of small candles, often with lower highs and lows. It signals a brief pause before the uptrend resumes.",
  "identification_rules": [
    "Identify a strong impulsive move upward with large, momentum candles.",
    "Observe a subsequent pullback or consolidation that moves against the trend, forming a flag with small candles and often minor lower highs and lows.",
    "The flag should be tight and shallow, indicating a temporary pause rather than a reversal.",
    "Enter on the close of a strong candle that breaks above the flag's upper boundary.",
    "Alternatively, identify a false breakout candle that briefly dips below flag support and then closes back above for an early entry."
  ],
  "trading_implication": "The bull flag signals a high-probability continuation trade. Traders enter long on the breakout candle close or on a false breakout at flag support. Stop loss is placed just below the flag's lowest point. Profit targets are set using a risk/reward ratio (e.g., 1:2) or by measuring the prior impulsive move and projecting from the flag low. Strong prior momentum and tight flag consolidation increase the likelihood of success.",
  "common_mistakes": [
    "Entering on a flag after a weak, low-momentum prior advance; the impulsive move must be strong.",
    "Expecting all flags to show textbook lower highs and lows; many valid flags are simple, shallow pullbacks.",
    "Placing the stop loss exactly at the flag low instead of slightly below to allow for a potential support bounce.",
    "Entering on a breakout without waiting for a strong confirming candle close."
  ],
