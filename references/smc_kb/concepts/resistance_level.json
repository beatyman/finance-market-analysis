{
  "card_id": "resistance_level",
  "type": "merged_concept",
  "canonical_term": "Resistance Level",
  "aliases": [
    "resistance",
    "Resistance",
    "Resistance Area",
    "resistance area"
  ],
  "school": "General",
  "definition": "A price area where selling pressure repeatedly halts upward movement and causes the price to reverse downward, acting as a ceiling. It is confirmed by multiple failures to break higher and often strengthens with each rejection.",
  "identification_rules": [
    "Identify a horizontal price zone where upward movement has halted and reversed downward at least twice from similar highs.",
    "The level is viewed as a zone rather than a precise line; multiple touches can occur within the area.",
    "Look for strong momentum candles moving into the zone and bearish reversal candlestick patterns (e.g., shooting star) moving away as confirmation.",
    "After a support level is broken, that same level often flips to act as resistance upon a retest.",
    "A cluster of rejections or an increasing number of touches strengthens the resistance."
  ],
  "trading_implication": "Resistance levels act as potential zones for short entries or exits on longs. Traders watch for bearish candlestick patterns or indicator divergence as confirmation, placing stops just above the zone with favorable risk-reward targets. A breakout above resistance, especially with high volume, signals bullish continuation, with the level flipping to support. In uptrends, breakouts offer buying opportunities, while in downtrends resistance provides entry areas for shorts.",
  "common_mistakes": [
    "Treating resistance as an exact price point or line rather than a flexible zone.",
    "Using resistance levels in isolation without additional confirmation from indicators or candlestick patterns.",
    "Ignoring signs of weakening resistance before a breakout, such as multiple touches with less violent rejections.",
    "Ignoring the role reversal where broken support becomes resistance.",
    "Treating a single touch as a confirmed resistance level without multiple tests.",
    "Assuming that slow, grinding moves into resistance are as significant as sharp momentum moves; slow moves are easier for price to break through."
  ],
