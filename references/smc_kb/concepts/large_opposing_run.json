{
  "card_id": "large_opposing_run",
  "type": "merged_concept",
  "canonical_term": "Large Opposing Run",
  "aliases": [
    "Large Wick",
    "large wick",
    "reversal candle wick",
    "Reversal Candle Wick"
  ],
  "school": "Price Action",
  "definition": "A significant counter-directional move within a candle (typically candle 2) that extends well beyond the prior candle's range before reversing, forming a large wick. It signals a reversal candle that does not support continuation expansion within the same candle.",
  "identification_rules": [
    "Candle opens and makes a large move against the intended trading direction before returning back into range.",
    "The resulting wick is disproportionately large relative to the candle body, classifying it as a reversal candle rather than expansion.",
    "No change in state of delivery occurs to confirm a protected swing during the initial shallow run, allowing price to extend further against direction.",
    "Price ultimately closes back inside the prior candle's range, forming a reversal closure (e.g., candle 2 closure)."
  ],
  "trading_implication": "A large opposing run within candle 2 invalidates trading expansion in that same higher-time-frame candle. Wait for candle 2 to close as a reversal candle, then trade the continuation expansion on candle 3, which should open and form only a shallow opposing run with a change in state of delivery (protected swing) before expanding in the intended direction. Stop loss is placed below the candle 3 protected low, targeting prior day high or relevant draw on liquidity.",
  "common_mistakes": [
    "Attempting to trade expansion within the same candle that printed the large opposing run rather than waiting for candle 3.",
    "Confusing a large opposing run with a shallow opposing run and entering before a protected swing forms.",
    "Trying to catch a reversal late in the candle once the range has already extended too far, instead of requiring expansion met with expansion plus CSD."
  ],
  "related_concepts": [],
