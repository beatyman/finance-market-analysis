{
  "card_id": "candle_1_sweep",
  "type": "merged_concept",
  "canonical_term": "Candle 1 Sweep",
  "aliases": [
    "c1 sweep",
    "C1 Sweep",
    "previous candle sweep",
    "Previous Candle Sweep"
  ],
  "school": "ICT",
  "definition": "The marking of the prior higher time frame candle's high or low that was swept by the current candle before a reversal closure. It identifies which liquidity level was taken out preceding a candle 2 closure on the higher time frame, serving as an initial signal of potential reversal or continuation.",
  "identification_rules": [
    "Identify the previous higher time frame candle relative to the candle producing the reversal closure.",
    "Mark the high of that previous candle if the setup is bearish (swept above), or the low if bullish (swept below).",
    "Confirm that the current higher time frame candle has traded beyond that prior high/low before closing back inside.",
    "The level is projected onto the lower time frame chart to show where the sweep occurred.",
    "In the lower time frame, observe the first candle after the higher time frame close; it should touch or exceed the prior higher time frame candle's high/low.",
    "The sweep occurs between the higher time frame close and the formation of the first lower time frame candle."
  ],
  "trading_implication": "Candle 1 Sweep visually confirms that liquidity was taken from the prior higher time frame candle before a reversal setup formed, validating a candle 2 closure context. Traders use it to verify that a sweep preceded the change in state of delivery and to anchor analysis between the higher time frame closure and the lower time frame entry, ensuring the setup occurred after liquidity was engineered rather than from an unswept level. It is often combined with other setups (C2, C3, C4) for confirmation.",
  "common_mistakes": [
    "Not explicitly stated in the material."
  ],
  "related_concepts": [],
  "merge_strategy": "llm_synthesis",
  "merge_model": "deepseek/deepseek-chat",
  "merge_notes": "School conflict: one card says ICT, the other says Price Action. Picked ICT by majority (1 ICT, 1 Price Action; no majority, but ICT is more specific). The second card's definition is more precise and was used as base; the first card's identification rules added lower time frame specifics.",
