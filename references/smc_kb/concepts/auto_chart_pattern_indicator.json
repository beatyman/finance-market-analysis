{
  "card_id": "auto_chart_pattern_indicator",
  "type": "merged_concept",
  "canonical_term": "Auto Chart Pattern Indicator",
  "aliases": [
    "all chart patterns indicator",
    "All Chart Patterns Indicator"
  ],
  "school": "Indicator-Based",
  "definition": "A TradingView built-in indicator that automatically detects common chart patterns (e.g., head and shoulders, wedges) on price charts and projects price targets upon pattern breakouts.",
  "identification_rules": [
    "Open TradingView and search for 'all chart patterns' in the indicators tab.",
    "Select the 'All Chart Patterns' indicator.",
    "In settings, choose desired patterns (e.g., double top, double bottom) and optionally enable 'in progress' to show forming patterns.",
    "Set visibility to 'all' to display every pattern or keep 'most recent' for only the latest; toggle price target lines on/off.",
    "Patterns appear automatically as shaded zones with labels and horizontal target lines."
  ],
  "trading_implication": "Helps traders automatically spot chart patterns and breakout targets, which can confirm trend continuation or reversal. Best used in combination with other technical indicators (e.g., trend analysis, support/resistance) to increase trade probabilities.",
  "common_mistakes": [
    "Relying solely on auto-detected patterns without additional technical confirmation.",
    "Enabling all patterns and in-progress patterns simultaneously, causing chart clutter and analysis paralysis."
  ],
