{
  "card_id": "doji_candlestick",
  "type": "merged_concept",
  "canonical_term": "Doji Candlestick",
  "aliases": [
    "Doji",
    "Doji Candle",
    "doji candle"
  ],
  "school": "Price Action",
  "definition": "A candlestick with a very small or nonexistent real body, where the open and close are equal or nearly equal, indicating market indecision. The position of the small body relative to the wicks modifies the bias from neutral to bullish or bearish.",
  "identification_rules": [
    "The real body must be extremely small, ideally just a thin line, though a very slight body is acceptable.",
    "Classic doji: the small body is near the middle of the candle, with upper and lower wicks of similar length.",
    "Long-legged doji: the body is slightly off-center; a body higher in the range is more bullish, lower is more bearish.",
    "Dragonfly doji: the real body is at the top of the candle, with a long lower wick and little to no upper wick (open and close near the high).",
    "Gravestone doji: the real body is at the bottom, with a long upper wick and little to no lower wick (open and close near the low).",
    "Four-price doji: the open, high, low, and close are all equal or nearly so, resulting in a horizontal line with no wicks."
  ],
  "trading_implication": "Doji candles signal indecision or potential reversal, but context is crucial. A classic doji indicates uncertainty. A dragonfly doji after a downtrend is a bullish reversal signal, similar to a hammer. A gravestone doji after an uptrend is bearish. Long-legged dojis become more bullish if the body is high in the range, bearish if low. Four-price dojis indicate extreme uncertainty and are often considered untradeable. Always confirm with the preceding trend and price action.",
  "common_mistakes": [
    "Ignoring the preceding trend: a dragonfly doji after an uptrend lacks strong bullish reversal significance.",
    "Trading a four-price doji without recognizing that it often signals extreme uncertainty and is best avoided."
  ],
