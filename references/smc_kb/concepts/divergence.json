{
  "card_id": "divergence",
  "type": "merged_concept",
  "canonical_term": "Divergence",
  "aliases": [
    "macd divergence",
    "MACD Divergence"
  ],
  "school": "Indicator Based",
  "definition": "Divergence occurs when price and an oscillator (e.g., RSI, MACD) move in opposite directions. Regular divergence (bullish/bearish) signals potential reversal: price makes lower low/higher high while oscillator makes higher low/lower high. Hidden divergence signals continuation: price makes higher low/lower high while oscillator makes lower low/higher high.",
  "identification_rules": [
    "Regular bullish divergence: price forms a lower swing low while the oscillator forms a higher swing low over the same period.",
    "Regular bearish divergence: price forms a higher swing high while the oscillator forms a lower swing high over the same period.",
    "Hidden bullish divergence: price forms a higher swing low while the oscillator forms a lower swing low over the same period.",
    "Hidden bearish divergence: price forms a lower swing high while the oscillator forms a higher swing high over the same period.",
    "Use two consecutive, clearly separated swing points to avoid noise and false signals.",
    "Divergence can be identified on oscillators such as RSI, MACD (line or histogram), MFI, etc.",
    "Prefer manual identification focusing on significant price swings; if using automated detection, adjust pivot lookback settings to balance signal timeliness and false positives."
  ],
  "trading_implication": "Divergence warns of weakening momentum and potential trend reversal (regular divergence) or continuation (hidden divergence). Bullish divergence suggests entering long trades or exiting shorts; bearish divergence suggests entering short trades or exiting longs. For higher probability, confirm signals with price action, market structure, support/resistance, or other indicators. Use higher time frames for more reliable signals. Divergence is a leading indicator but can produce false signals, especially with aggressive oscillator settings, so confirmation is recommended.",
  "common_mistakes": [
    "Assuming divergences lead to immediate reversals without confirmation from price action, market structure, or support/resistance.",
    "Relying on automatic divergence indicators without manual verification or ignoring indicator settings (e.g., pivot lookback) that can produce false signals.",
    "Confusing which peaks to compare: using highs for bullish divergence or lows for bearish divergence.",
    "Misinterpreting hidden divergence as regular divergence (or vice versa).",
    "Treating weakly connected or overlapping price swings as valid divergence setups.",
    "Confusing MACD line divergence with MACD histogram divergence.",
    "Relying solely on oscillator overbought/oversold levels for reversal signals instead of divergences."
  ],
