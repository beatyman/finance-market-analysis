{
  "card_id": "valid_separation",
  "type": "merged_concept",
  "canonical_term": "Valid Separation",
  "aliases": [
    "adequate distance between swing points",
    "Sufficient Separation",
    "sufficient separation"
  ],
  "school": "Price Action",
  "definition": "The minimum distance required between a swing point and its preceding adjacent swing for the newer swing to qualify as a relevant high or low. With valid separation, a reaction at that swing can be trusted as a tradable reversal level rather than a failure swing.",
  "identification_rules": [
    "Locate the swing point (a low with higher lows on both sides, or a high with lower highs on both sides) and measure its distance to the previous adjacent swing of the same type.",
    "If the swing sits very close to the prior swing low/high, classify it as a failure swing with insufficient separation and not relevant for reversal trading.",
    "If there is a clear range/gap between the new swing and the prior swing, classify it as valid separation and treat that swing as a relevant high or low.",
    "Only consider swings within the look-back period of three higher-time-frame candles (including the current one) when judging relevance.",
    "When separation is borderline, require the prior adjacent swing to first be taken out and confirmed before trusting the newer swing as relevant.",
    "Judgment requires trader experience and discernment; no mechanical formula."
  ],
  "trading_implication": "Valid separation determines which swing highs and lows are eligible reversal levels. Reactions at swings with valid separation are tradable using a fractal model entry (candle 2 or candle 3 closure with wick/EQ respect). Swings without valid separation are treated as failure swings and used as liquidity targets instead of reversal points. Targets after a reversal off a relevant swing are typically the other side of the range or the failure swings sitting beyond it.",
  "common_mistakes": [
    "Trading reversals off swings that sit too close to the prior swing high/low, which are failure swings rather than relevant levels.",
    "Trying to apply a mechanical rule for separation rather than developing discernment through chart practice.",
    "Trading away from a marginally-separated swing before the adjacent swing has been taken out and confirmed.",
    "Ignoring the three-higher-time-frame-candle look-back period and treating old swings as still relevant.",
    "Failing to distinguish valid from invalid separation, leading to trades at untrustworthy swing points."
  ],
  "related_concepts": [],
  "merge_strategy": "llm_synthesis",
  "merge_model": "deepseek/deepseek-chat",
  "merge_notes": "Both cards agree on school (Price Action) and core definition. The updated card adds more operational rules (look-back period, borderline handling) and trading specifics (fractal model entry). No conflicts.",
