{
  "card_id": "spring",
  "type": "merged_concept",
  "canonical_term": "Spring",
  "aliases": [
    "bear trap",
    "false breakdown"
  ],
  "school": "Wyckoff",
  "definition": "A false breakdown below support during Wyckoff accumulation, where price briefly dips below the range low and then sharply reverses as smart money absorbs selling, creating a high-probability long entry opportunity.",
  "identification_rules": [
    "Price briefly moves below the lowest established support of the trading range, often below the selling climax low.",
    "The breakdown is immediately followed by a sharp bullish reversal back above the support level."
  ],
  "trading_implication": "The spring signals the end of accumulation and the start of markup. It is a bullish entry opportunity where traders go long with a stop loss placed below the spring low.",
  "common_mistakes": [
    "Mistaking the spring for a genuine breakdown and going short, resulting in a bear trap."
  ],
