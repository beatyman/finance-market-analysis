{
  "card_id": "premium_discount_array",
  "type": "merged_concept",
  "canonical_term": "Premium/Discount Array",
  "aliases": [
    "PD array",
    "PDA",
    "pd数组",
    "PD数组",
    "Premium/Discount",
    "Price Delivery Array",
    "价格结构工具集合",
    "价格驱动阵列",
    "高时间框架价格结构阵列"
  ],
  "school": "ICT",
  "definition": "A collection of structural obstacles (FVG, Order Block, Breaker Block, BPR, Inversion, etc.) arranged in an array within premium (above 50% equilibrium) or discount (below 50% equilibrium) zones. The 0.5 Fibonacci level divides the range; premium favors shorts, discount favors longs. Traders select one concept as the primary signal.",
  "identification_rules": [
    "Identify the price range from a swing high to swing low and calculate its 50% equilibrium level using Fibonacci retracement.",
    "Price above the 50% equilibrium is in premium; price below it is in discount.",
    "In the premium or discount zone, mark all structural obstacles in price order: FVG, Order Block, Breaker Block, BPR, Inversion, prior swing highs/lows, etc., forming an ordered array.",
    "Only include key levels that have been respected by prior price action and have structural significance.",
    "Treat these structures as a collective array region, not as individual support/resistance levels.",
    "Based on personal model, select one concept (e.g., OB, FVG, Breaker Block) as the primary trading signal and define its invalidation point.",
    "When price breaks through one element in the array, continue to monitor the next array element as a target.",
    "On lower timeframes, align entry setups (e.g., displacement, breaker block) with key positions in the higher timeframe PD Array."
  ],
  "trading_implication": "PD Array bridges higher timeframe macro structure and lower timeframe micro entries. After confirming HTF direction, look for long setups in discount and short setups in premium. On LTF, seek displacement, OB, or FVG within the array. If PD Array is broken, trend continues; if respected, reversal possible. Stop loss and invalidation are set based on the selected tool set.",
  "common_mistakes": [
    "Treating a single structure (e.g., FVG or OB) in isolation, ignoring the collective array effect.",
    "Mistaking a single FVG or OB for the PD Array, overlooking the key feature of multiple overlapping structures.",
    "Failing to distinguish whether price has truly entered the discount or premium zone, leading to wrong trade direction.",
    "Entering blindly just because price reaches the PD Array without LTF confirmation.",
    "Marking PD Array on LTF without confirming HTF trend direction, causing incorrect target setting.",
    "Including all price levels in the array instead of only structurally significant, respected levels.",
    "Ignoring low-resistance liquidity (uncleared swing points) that allows price to pass through array elements easily.",
    "Looking for inducement setups outside the PD Array, reducing trade probability.",
    "Entering too early before price actually reacts at the array zone.",
    "Trying to use all PD Array concepts simultaneously, causing chart clutter and signal confusion.",
    "Not clearly defining the PD Array tool set, leading to vague invalidation points.",
    "Confusing invalidation rules from different PD Array frameworks.",
    "Missing multiple entry opportunities within the array and abandoning the zone after one miss.",
    "Buying in premium in a bullish trend without additional confirmation, risking overvalued entries.",
    "Selling in discount in a bearish trend without confirmation, risking undervalued entries.",
    "Ignoring higher timeframe bias: being bullish in discount while HTF is bearish."
  ],
