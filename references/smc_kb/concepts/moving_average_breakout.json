{
  "card_id": "moving_average_breakout",
  "type": "merged_concept",
  "canonical_term": "Moving Average Breakout",
  "aliases": [],
  "school": "Indicator Based",
  "definition": "A moving average breakout occurs when price clearly crosses below or above a moving average, distinguishing from failed breakouts where price briefly pierces and reverses.",
  "identification_rules": [
    "A momentum candle appears with a real body at least twice the size of preceding candles, indicating increased momentum.",
    "The breakout candle closes far below or above the moving average, not just with a wick, showing a strong candle close.",
    "Volume is higher than previous candles, confirming broader market participation in the move.",
    "Price action confirmation is obtained by waiting for another candle to close beyond the moving average or by a break of a key market structure level."
  ],
  "trading_implication": "A moving average breakout signals a potential new trend. Traders may enter on the breakout candle or after confirmation (e.g., a second close or structure break) and can combine with volume, momentum, or retests of the moving average as support/resistance.",
  "common_mistakes": [
    "Mistaking a failed breakout, where price briefly dips and reverses above the moving average, for a true breakout.",
    "Entering a breakout without confirmation from momentum, volume, or price action."
  ],
