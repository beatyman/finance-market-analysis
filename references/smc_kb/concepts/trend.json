{
  "card_id": "trend",
  "type": "merged_concept",
  "canonical_term": "Trend",
  "aliases": [
    "Bearish Trend",
    "bearish trend",
    "Bullish Trend",
    "bullish trend"
  ],
  "school": "ICT",
  "definition": "A directional price movement where price repeatedly takes out previous day highs (bullish trend) or previous day lows (bearish trend). Trend direction determines which side of liquidity price is drawing toward and is supported by PD arrays on the corresponding side.",
  "identification_rules": [
    "If price repeatedly sweeps and closes through previous day highs across consecutive days, the trend is bullish.",
    "If price repeatedly sweeps and closes through previous day lows across consecutive days, the trend is bearish.",
    "Look back three days of price action to mark out the relevant previous day highs and lows when assessing the current trend.",
    "PD arrays (e.g. fair value gaps, order blocks) supporting price higher confirm a bullish trend; PD arrays capping price lower confirm a bearish trend.",
    "Failure to displace over previous day high biases trend continuation lower; failure to displace below previous day low biases continuation back into the range/upward.",
    "Retracements or liquidity sweeps inside a downtrend produce up-close candles forming order blocks; trend remains valid as long as subsequent candles close back below them."
  ],
  "trading_implication": "Trend direction defines the draw on liquidity: in a bullish trend, anticipate the previous day high as target; in a bearish trend, anticipate the previous day low. Once the draw is set on the daily chart, drop to a lower time frame to find a point of interest and frame an entry toward that target. Avoid framing trades during consolidations where price fails to take either side of the range.",
  "common_mistakes": [
    "Going long on a close back inside the range during a bearish trend instead of waiting for price to close below the up-close candle and validate it as an order block.",
    "Trying to frame trades during consolidations where price fails to take out either previous day high or previous day low.",
    "Assuming an entry exists every day just because a daily bias has been established — bias does not guarantee a valid lower time frame setup."
  ],
