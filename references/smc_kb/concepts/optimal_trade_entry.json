{
  "card_id": "optimal_trade_entry",
  "type": "merged_concept",
  "canonical_term": "Optimal Trade Entry",
  "aliases": [
    "OT",
    "ot",
    "OTE",
    "ote",
    "ote zone",
    "OTE Zone"
  ],
  "school": "ICT",
  "definition": "A Fibonacci retracement zone (0.618–0.786, core 0.705) drawn on a displacement leg after a market structure shift, used to enter at a discount (longs) or premium (shorts) where price is likely to retrace into a PD array confluence for tight stops and favorable risk-to-reward.",
  "identification_rules": [
    "Confirm a preceding stop raid or liquidity sweep in the opposite direction of the intended trade.",
    "Wait for a clear market structure shift or change in state of delivery with displacement closing beyond a prior swing high/low.",
    "Identify the displacement leg and draw a Fibonacci retracement from the swing low to swing high (for longs) or high to low (for shorts), marking the 0.618–0.786 retracement zone as the OTE area.",
    "Ensure the OTE zone is in the discount half (below 0.5 equilibrium) for long setups or the premium half (above 0.5) for short setups.",
    "Wait for price to retrace into the OTE zone.",
    "Confirm at least one PD array (e.g., fair value gap, order block, breaker block, mean threshold) overlaps within the OTE zone for precision entry.",
    "Optionally validate on a lower time frame by repeating the OTE process fractally off the initial swing to refine entry.",
    "Confirm that price respects the zone, typically with no candle bodies closing through it before targeting.",
    "Confirm higher-time-frame context, such as a draw on liquidity or a PD array, supporting the directional bias.",
    "Use top-down analysis to ensure entry direction aligns with higher-time-frame bias.",
    "Wait for swing high/swing low to be fully confirmed before anchoring Fibonacci.",
    "For short setups, confirm a lower high has formed; for long setups, confirm a higher low has formed as structural confirmation.",
    "Only observe entry opportunities when price touches the OTE zone within a kill zone.",
    "Place stop loss beyond the extreme of the displacement leg (above swing high for shorts, below swing low for longs).",
    "Target predetermined external liquidity levels (e.g., previous day high/low, sell side/buy side liquidity, fair value gaps)."
  ],
  "trading_implication": "OTE provides a high-probability entry after displacement, allowing entry at a discount or premium with tight stops beyond the swing extreme or PD array. It targets opposing liquidity or higher-time-frame draw on liquidity, often improving risk-to-reward from ~1.6 to ~3.43 compared to equilibrium entries. Combining OTE with PD arrays like fair value gaps or order blocks adds confluence. OTE can be used fractally across multiple timeframes.",
  "common_mistakes": [
    "Entering without a preceding stop raid or liquidity sweep in the direction of the intended trade.",
    "Entering in the OTE zone when it falls on the wrong side of equilibrium relative to bias (e.g., long in premium).",
    "Pushing entry too deep into the OTE for better risk-to-reward and missing the fill entirely.",
    "Using OTE without confirming an overlapping PD array.",
    "Ignoring PD array nuance—e.g., using the opening price of an order block when the mean threshold would be more appropriate because the opening is outside the OTE zone.",
    "Entering outside of a kill zone timing window.",
    "Placing the stop loss at the full swing extreme instead of closer to the PD array, worsening risk-to-reward.",
    "Waiting for a deeper retracement that never occurs, missing the trade.",
    "Neglecting higher-time-frame context (draw on liquidity, HTF PD array, or key level).",
    "Ignoring SMT divergence confirmation on a correlated asset.",
    "Taking entries at equilibrium (0.5) instead of deeper within the OTE zone, sacrificing risk-to-reward.",
    "Holding after candle bodies close through the OTE zone, losing respect for the level.",
    "Not waiting for liquidity sweep and displacement confirmation before entry.",
    "Using OTE on a low timeframe without higher-time-frame bias alignment.",
    "Entering at equilibrium (0.5) instead of waiting for retracement to 0.62-0.79, significantly reducing risk-to-reward.",
    "Not confirming candle body support within the OTE zone before entry.",
    "Forcing entry when order block opening price is outside OTE zone; should use mean threshold instead.",
    "Entering when price touches OTE outside kill zone.",
    "Anchoring Fibonacci before swing high/swing low is fully confirmed.",
    "Relying solely on OTE without confluence from FVG, OB, etc.",
    "Using OTE for reversal entries instead of trend continuation entries."
  ],
