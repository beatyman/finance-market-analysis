{
  "card_id": "time_based_liquidity",
  "type": "merged_concept",
  "canonical_term": "Time-based Liquidity",
  "aliases": [
    "opening session liquidity",
    "Opening session liquidity",
    "session-based liquidity",
    "Session-based liquidity"
  ],
  "school": "ICT",
  "definition": "Liquidity that accumulates around the opening times of major trading sessions (London, New York) as many traders enter positions based on the initial move, creating orders that institutions can exploit to fuel price reversals.",
  "identification_rules": [
    "Identify the exact opening times of the London and New York sessions on the chart.",
    "Look for an aggressive breakout from a consolidation range coinciding with the session open.",
    "Check for combined price-based liquidity such as equal highs/lows or support/resistance levels near the session open.",
    "Observe whether price quickly reverses after the initial breakout, indicating a liquidity sweep."
  ],
  "trading_implication": "Time-based liquidity signals a high-probability manipulation zone at session opens. Avoid trading the initial breakout; instead, wait for the reversal after the liquidity sweep and enter in the direction of the higher timeframe trend at a point of interest like an order block or fair value gap. This aligns you with institutional moves while avoiding retail traps.",
  "common_mistakes": [
    "Entering the initial FOMO breakout at session open, mistaking it for a genuine trend start.",
    "Placing stop losses at obvious levels just above/below the session high/low, which are likely to be swept.",
    "Ignoring the higher timeframe bias and taking trades against the dominant trend based solely on the session move."
  ],
