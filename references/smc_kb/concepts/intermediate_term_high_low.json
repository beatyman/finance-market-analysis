{
  "card_id": "intermediate_term_high_low",
  "type": "merged_concept",
  "canonical_term": "Intermediate Term High/Low",
  "aliases": [
    "Intermediate Term High",
    "Intermediate Term Low",
    "intermediate term low",
    "ITH",
    "itl",
    "ITL"
  ],
  "school": "ICT",
  "definition": "An intermediate term high is formed when a short-term high has a short-term high on both its left and right, or when price rebalances a fair value gap and trades away. An intermediate term low is analogous (short-term low with short-term lows on both sides, or FVG rebalance).",
  "identification_rules": [
    "For a high: locate a short-term high; confirm there is another short-term high to its left and another short-term high to its right.",
    "For a low: locate a short-term low with a short-term low on both sides.",
    "Alternatively, identify a fair value gap (FVG); when price enters the FVG and then moves away, the resulting extreme becomes an intermediate term high/low.",
    "Do not classify a swing as intermediate term until the second flanking short-term swing (or FVG rebalance) is completed."
  ],
  "trading_implication": "Intermediate term highs and lows act as strong support/resistance. They are expected to hold during a trend; a violation signals a potential structural shift. Used to confirm direction, set stops, and find entries.",
  "common_mistakes": [
    "Labeling a swing as intermediate term before the second flanking short-term swing forms.",
    "Expecting an intermediate term level to break when price should respect it; trades should align with the levels unless a clear shift occurs."
  ],
