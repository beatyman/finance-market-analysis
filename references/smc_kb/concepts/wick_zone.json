{
  "card_id": "wick_zone",
  "type": "merged_concept",
  "canonical_term": "Wick Zone",
  "aliases": [],
  "school": "Smart Money Concepts (SMC)",
  "definition": "A supply or demand zone that includes the wick of a candle that swept liquidity, expanding the zone to encompass where orders were executed, often used when risk-to-reward remains favorable.",
  "identification_rules": [
    "Identify a candle that creates a price imbalance (supply or demand zone base).",
    "Observe if a subsequent wick extends beyond the initial zone and sweeps liquidity (e.g., triggers stops below a swing low).",
    "Extend the zone boundary to include the entire wick if doing so maintains an acceptable risk-to-reward ratio and stop-loss placement below/above the wick extreme.",
    "Alternatively, if the zone becomes too large, consider only the wick itself as the supply/demand area and seek lower time frame confirmations for entry."
  ],
  "trading_implication": "The Wick Zone acknowledges that orders were executed within the wick during a liquidity sweep, so including it prevents premature stop-outs. It enlarges the entry area, potentially reducing risk-to-reward; therefore, confirmations on lower time frames or favorable R:R are needed to justify its use.",
  "common_mistakes": [
    "Extending the zone to include the wick without evaluating the resulting risk-to-reward ratio, which may make the trade unfavorable.",
    "Assuming every wick forms a Wick Zone without confirming a liquidity sweep (e.g., penetration of a swing low/high).",
    "Using a Wick Zone as the sole entry area without seeking lower time frame confirmations when the zone is too large, leading to poor entry precision.",
    "Not adjusting stop-loss placement beyond the wick's extreme, which could result in being stopped out prematurely."
  ],
  "related_concepts": [],
