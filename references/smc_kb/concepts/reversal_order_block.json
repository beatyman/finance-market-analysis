{
  "card_id": "reversal_order_block",
  "type": "merged_concept",
  "canonical_term": "Reversal Order Block",
  "aliases": [],
  "school": "Smart Money Concepts (SMC)",
  "definition": "A reversal order block is the last candle before a sharp price move that occurs after a change of character, signaling a potential trend reversal. It opposes the prior dominant trend and offers high risk-to-reward potential but lower probability compared to continuation blocks.",
  "identification_rules": [
    "Wait for a change of character (CHoCH) confirming a potential trend reversal on the timeframe of analysis.",
    "Identify the last candle before the impulsive move that broke the previous structure as the order block zone.",
    "Ensure the order block type opposes the prior trend: a supply block after an uptrend, or a demand block after a downtrend.",
    "If the order block candle is smaller than 60% of ATR, extend the zone to one ATR on both sides."
  ],
  "trading_implication": "Traders use reversal order blocks to enter counter-trend trades at the start of a new trend, targeting large risk-to-reward ratios. They typically wait for price to retest the order block after the reversal and look for LTF confirmations like fair value gaps or liquidity sweeps before entering, with stops placed beyond the block.",
  "common_mistakes": [
    "Mistaking a continuation pattern for a reversal without a confirmed change of character.",
    "Entering on small order blocks without allowing for extension, leading to stop-outs from volatility.",
    "Expecting high probability like trend-continuation blocks, ignoring the lower success rate."
  ],
