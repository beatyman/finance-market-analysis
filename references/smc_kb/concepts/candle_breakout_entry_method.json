{
  "card_id": "candle_breakout_entry_method",
  "type": "merged_concept",
  "canonical_term": "Candle Breakout Entry Method",
  "aliases": [],
  "school": "Smart Money Concepts (SMC)",
  "definition": "A trading strategy that enters on an engulfing candle breaking out of an unmitigated higher time frame supply or demand zone after price shows rejection within the zone, providing safer, higher-conformation entries with slightly lower reward-to-risk.",
  "identification_rules": [
    "Identify an unmitigated supply or demand zone on the 30-minute, 1-hour, 2-hour, or 4-hour chart.",
    "Wait for price to enter the zone with an initial candle pushing into it.",
    "Look for one or more rejection candles forming within the zone, signaling a reaction.",
    "Wait for an engulfing candle that closes outside the zone, engulfing the rejection candle(s) body and wick.",
    "Enter only after the engulfing candle closes; place stop loss above the high or low of the recent candles."
  ],
  "trading_implication": "Offers a confirmatory entry that reduces missed trades when price does not deeply retrace to pending orders. It increases reliability and avoids constant chart monitoring, best on higher time frames. The trade-off is a wider stop loss and slightly lower reward-to-risk, but it provides clearer signals and consistency when used at unmitigated supply/demand zones.",
  "common_mistakes": [
    "Applying the strategy on lower time frames, causing multiple engulfing candles without clear rejection and potential false signals.",
    "Using mitigated or non-extreme zones instead of only unmitigated points of interest.",
    "Entering before the engulfing candle closes, risking a failed breakout.",
    "Ignoring the need for a clear reaction phase (rejection candles) before the engulfing breakout."
  ],
