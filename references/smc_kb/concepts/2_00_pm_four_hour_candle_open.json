{
  "card_id": "2_00_pm_four_hour_candle_open",
  "type": "merged_concept",
  "canonical_term": "2:00 PM Four-Hour Candle Open",
  "aliases": [
    "14:00 est 4-hour open",
    "14:00 EST 4-Hour Open",
    "2 PM 4H Open",
    "2 pm 4h open"
  ],
  "school": "ICT",
  "definition": "The 2:00 PM EST opening of a new 4-hour candle, used to anticipate the final intraday 4-hour candle's OHLC (Power of 3) structure, marking the timing of retracements or continuation moves that complete the daily candle before close.",
  "identification_rules": [
    "Mark the 14:00 EST timestamp on the chart as the start of a fresh 4-hour candle (applies to index futures; Forex 4H opens differ).",
    "If bullish bias, anticipate an open-low-high-close sequence on this 4-hour candle; if bearish, anticipate open-high-low-close.",
    "Look for a retracement against the prior 10:00 AM 4-hour candle's expansion to occur at the 2:00 PM open.",
    "When the prior 4H candle's draw on liquidity has not yet been reached, expect the 2:00 PM candle to expand and sweep that level before daily close."
  ],
  "trading_implication": "Use the 2:00 PM 4-hour open as a timing anchor for the last intraday 4H Power of 3. When the 10:00 AM candle has already expanded, the 2:00 PM candle frequently delivers the retracement before continuing; when liquidity is still resting nearby, the 2:00 PM candle is expected to run it. Combine with daily OHLC anticipation, midnight/8:30 support-resistance, and 9:30 distribution timing to project where the daily candle's high or low completes.",
  "common_mistakes": [
    "Applying the same 4-hour open times to Forex, where the 4H candle boundaries differ from index futures.",
    "Expecting expansion at 2:00 PM when the prior 10:00 AM candle context calls for a retracement, or vice versa."
  ],
