{
  "card_id": "corrective_move",
  "type": "merged_concept",
  "canonical_term": "Corrective Move",
  "aliases": [
    "Correction",
    "correction",
    "Pullback",
    "Retracement"
  ],
  "school": "ICT",
  "definition": "A price move against the dominant trend, characterized by mixed-color candles with small bodies, prominent sideways wicks, and smaller push distance than the preceding impulse, representing temporary counter-trend activity or profit-taking.",
  "identification_rules": [
    "It occurs after a clear impulsive move in the opposite direction.",
    "The move consists of candles with alternating colors, small real bodies, and prominent wicks (especially sideways or equal-length wicks), covering a shorter distance than the preceding impulsive move.",
    "The entire corrective move remains within the high-low range of the preceding impulsive wave, not breaking its origin.",
    "A valid corrective move must retrace at least to the 38.2% Fibonacci level of the preceding impulse; shallower moves are considered internal volatility/noise.",
    "It creates a higher low in an uptrend or a lower high in a downtrend, which should hold; breaking these levels may signal a potential trend reversal."
  ],
  "trading_implication": "A corrective move provides an opportunity to enter a trade in the direction of the dominant trend at a favorable price (discount in uptrend, premium in downtrend). Traders often wait for confirmation of its completion (e.g., change of character, liquidity sweep) and use the 38.2% Fibonacci retracement as a minimum filter to distinguish valid corrections from noise. A break of the corrective swing point may signal a trend reversal, prompting an exit or reversal trade.",
  "common_mistakes": [
    "Entering too early before the correction completes, leading to stop-outs during deeper retracements.",
    "Waiting for an excessively deep correction and missing the trade when the move resumes early.",
    "Misinterpreting a corrective move as a full trend reversal and trading against the prevailing trend.",
    "Treating shallow pullbacks (less than 38.2% retracement) as valid corrections, leading to false signals.",
    "Failing to distinguish between a corrective move and internal volatility, causing premature reversal expectations."
  ],
