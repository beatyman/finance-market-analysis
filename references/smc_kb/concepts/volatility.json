{
  "card_id": "volatility",
  "type": "merged_concept",
  "canonical_term": "Volatility",
  "aliases": [],
  "school": "General",
  "definition": "Volatility is the degree of variation in an asset's price over time, reflecting expected price range and momentum. Low volatility involves small, stable price changes (e.g., ≤1% daily), often indicated by narrow Bollinger Bands and tightening RSI ranges. High volatility features sharp, rapid, large price movements, signaled by wide Bollinger Bands and RSI extremes. It influences trading difficulty and profit potential.",
  "identification_rules": [
    "Low volatility is indicated by small daily price changes, typically ≤1%, and minimal price movement.",
    "High volatility is indicated by sharp, rapid, and large price fluctuations.",
    "Monitor Bollinger Bands width on RSI: tightening bands signal low expected volatility, widening bands signal high expected volatility.",
    "RSI price movement outside the upper or lower Bollinger Band indicates extreme momentum and high volatility.",
    "A sequence of small-range candles (low volatility) followed by a momentum candle often triggers Bollinger Band expansion, signaling a shift to higher volatility."
  ],
  "trading_implication": "Volatility informs market selection and trading approach. Low volatility suggests an impending large move but with uncertain direction; beginners should avoid or use caution, while advanced traders may prepare for breakout opportunities. High volatility confirms strong momentum, offering profit potential when combined with price action confluence. Overall, volatility aids in risk management by matching trader experience to market conditions.",
  "common_mistakes": [
    "Assuming that extreme momentum (RSI outside bands) automatically signals a continuation without additional confirmation.",
    "Trading immediately during low volatility without waiting for a clear breakout direction."
  ],
