{
  "card_id": "demand_zone",
  "type": "merged_concept",
  "canonical_term": "Demand Zone",
  "aliases": [
    "Demand Area",
    "demand area",
    "demand level",
    "Demand Level"
  ],
  "school": "Smart Money Concepts (SMC)",
  "definition": "A price zone where aggressive buying previously triggered a sharp bullish move, leaving behind inefficiency (fair value gaps). It acts as support when price returns, especially if unmitigated, aligned with higher-timeframe order blocks, and confirmed by a break of structure or liquidity sweep.",
  "identification_rules": [
    "Identify a strong bullish impulse on a higher timeframe (e.g., 1H–4H) that breaks above a recent swing high (Break of Structure) or begins from a significant low.",
    "Mark the demand zone as the price range of the last bearish candle or consolidation base immediately before the impulse.",
    "Ensure the zone contains a Fair Value Gap (imbalance) left by the impulsive move, where wicks of surrounding candles do not overlap.",
    "Confirm the zone is unmitigated—that is, price has not yet returned to it since the impulse.",
    "Verify that the push distance from the zone is significantly larger than prior corrective swings, indicating strong demand.",
    "Align the zone with higher-timeframe demand zones or order blocks for greater reliability.",
    "Look for a liquidity sweep (stop hunt) of sell-side liquidity below the zone as extra confirmation before entry.",
    "Identify a demand shift consisting of two or more strong green momentum candles.",
    "The origin of the demand shift should completely engulf the preceding candles (cluster of candles method).",
    "Draw the demand zone from the base of the demand shift, extending horizontally to the right.",
    "Wait for price to pull back and re-enter the drawn demand zone.",
    "Confirm entry after a clear reaction from the zone, such as a wick down followed by a strong green candle."
  ],
  "trading_implication": "Demand zones are high-probability buy areas where price is expected to reverse upward upon retest, especially after a liquidity sweep clears sell-side stops. Traders wait for a bullish confirmation signal (e.g., engulfing candle, rejection wick) before entering long, placing a stop-loss just below the zone or recent swing low. Profit targets are set at prior swing highs or liquidity pools, or using a fixed risk/reward ratio (e.g., 2:1). Unmitigated zones with break of structure, fair value gaps, and confluence with higher-timeframe levels yield more reliable trades.",
  "common_mistakes": [
    "Using demand zones that have already been mitigated (price has returned to the zone), reducing reliability.",
    "Entering without checking higher timeframe direction, risking counter-trend trades.",
    "Expecting price to reverse perfectly from the zone every time; pullbacks may be shallow or deep, resulting in missed entries or premature stop-outs.",
    "Entering prematurely without waiting for a clear bullish reversal signal (e.g., rejection wick, engulfing candle, break of structure).",
    "Treating any prior low or area where price rose as a valid demand zone without confirming a strong bullish impulse, fair value gap, break of structure, and unmitigated status.",
    "Misplacing the zone by not marking the last bearish candle or the first candle of the impulse move.",
    "Extending the demand zone excessively to include wicks without considering risk-to-reward deterioration.",
    "Mistaking an inducement area for a demand zone, or entering without a confirming liquidity sweep.",
    "Applying lower timeframe analysis where signals are less reliable, leading to multiple false engulfing candles without clear rejection.",
    "Entering a long trade before price shows a confirmed reaction (e.g., a strong green candle) from the demand zone.",
    "Failing to adjust the demand zone boundaries as new price data becomes available."
  ],
