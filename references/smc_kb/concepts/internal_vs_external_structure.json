{
  "card_id": "internal_vs_external_structure",
  "type": "merged_concept",
  "canonical_term": "Internal vs External Structure",
  "aliases": [
    "Internal/External Structure",
    "internal/external structure",
    "true market structure",
    "True Market Structure"
  ],
  "school": "ICT",
  "definition": "The distinction between price swings that establish the overall market direction (external) and smaller movements within an established range (internal). External structure defines the true trend via unbroken swing highs/lows; internal structure consists of swings inside that range, often trapping traders into false signals.",
  "identification_rules": [
    "Identify the most recent higher high and higher low (bullish) or lower high and lower low (bearish) that remain unbroken—these are the external swing points.",
    "Draw a range box from the external high to external low; all price action that forms and closes entirely within this box is internal structure.",
    "An external break of structure occurs only when price breaks and holds beyond the high or low of the range box.",
    "A lower low or lower high that develops entirely inside the external range does not signal a trend change—it is internal movement."
  ],
  "trading_implication": "Internal vs external structure prevents false entries by ensuring traders only act on confirmed breaks of the true range. Trading decisions should align with the external trend, using internal swings as pullbacks within the range. Ignoring this distinction leads to buying/selling against the real market direction and stop-outs.",
  "common_mistakes": [
    "Mistaking an internal lower low or higher high for a trend reversal and trading against the established external direction.",
    "Placing stop-losses at external swing points while entering on internal signals, causing unnecessary losses.",
    "Entering a trade on an internal breakout without waiting for an external break of structure, resulting in trapped positions."
  ],
