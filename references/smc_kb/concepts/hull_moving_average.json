{
  "card_id": "hull_moving_average",
  "type": "merged_concept",
  "canonical_term": "Hull Moving Average",
  "aliases": [
    "HMA",
    "hma"
  ],
  "school": "Indicator Based",
  "definition": "A moving average developed by Alan Hull that improves responsiveness and smoothness compared to SMA and EMA. It reacts faster to price changes while producing a smoother line with less lag and fewer minor wiggles, useful for short-term trading but prone to false signals.",
  "identification_rules": [
    "In TradingView, search for 'Hull' and add the Hull Moving Average indicator.",
    "Increase the default period from 9 to a longer lookback (e.g., 50) to prevent the line from hugging price too closely.",
    "When compared to EMA and SMA of the same period, the HMA turns in the direction of price changes earlier at reversals and exhibits a smoother trajectory with fewer minor wiggles and back-and-forth jitter during trends."
  ],
  "trading_implication": "The HMA benefits short-term traders by providing early trend change signals due to its fast reaction to price movements. However, this speed also generates many false breakouts and whipsaws. It should not be used in isolation; combining HMA signals with market structure and price action analysis is recommended to filter noise and improve trade reliability.",
  "common_mistakes": [
    "Using the default period of 9, which makes the line hug price and renders it useless.",
    "Relying solely on HMA without combining market structure or price action analysis.",
    "Treating every HMA crossover or breakout as a valid signal without additional confirmation, leading to whipsaws and false breakouts.",
    "Assuming that a more responsive moving average is always better, ignoring the trade-off of increased false signals."
  ],
