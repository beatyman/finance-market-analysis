{
  "card_id": "inversely_correlated_pairs",
  "type": "merged_concept",
  "canonical_term": "Inversely Correlated Pairs",
  "aliases": [
    "inversely correlated assets",
    "Inversely Correlated Assets",
    "inverter correlated pairs",
    "Inverter Correlated Pairs",
    "反向相关资产对",
    "负相关交易对"
  ],
  "school": "SMC",
  "definition": "Two assets that move in opposite directions (e.g., EUR/USD vs DXY), where a high on one should correspond to a low on the other. Divergence from this expected inverse structure on swing points forms an SMT signal.",
  "identification_rules": [
    "Confirm the two assets are inversely correlated (e.g., EUR/USD vs DXY) and chart them side by side.",
    "Mark equivalent swing points: a high on asset A should align with a low on asset B; a higher high on A should align with a lower low on B.",
    "When asset A makes a higher high but asset B fails to make a lower low (instead making a higher low), flag this as an inverse SMT divergence.",
    "Apply the same logic to lows: a lower low on A without a higher high on B is a divergence.",
    "Use the divergent swing point as a potential reversal level; the asset that swept liquidity is preferred for the entry."
  ],
  "trading_implication": "Inversely correlated pairs are read in mirror image to confirm or invalidate swing points across markets. When the expected inverse structure breaks, it signals SMT and a potential reversal, allowing entries at the divergent swing high/low. Traders flip the standard SMT logic: look for a new high on one asset when expecting a new low on the other. The asset that swept liquidity is typically chosen for entry, with stops placed above/below the high-resistance liquidity sweep.",
  "common_mistakes": [
    "Applying directly correlated SMT logic (looking for matching highs/lows) instead of flipping the structure for inverse pairs.",
    "Misreading a higher low on the inverse asset as confirmation when it actually represents a divergence.",
    "Only analyzing structure on a single asset, ignoring the corresponding performance of the inversely correlated pair.",
    "Confusing direction: on inversely correlated assets, one should do the opposite operation (one bearish implies the other bullish).",
    "Failing to correctly identify the specific form of SMT, misjudging the correspondence of highs/lows."
  ],
  "related_concepts": [],
  "merge_strategy": "llm_synthesis",
  "merge_model": "deepseek/deepseek-chat",
  "merge_notes": "Both input cards are from SMC school; no conflict. The second card provides more operational identification rules and trading implications, which are adopted. The first card's aliases and some common mistakes are merged.",
