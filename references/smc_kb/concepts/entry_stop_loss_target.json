{
  "card_id": "entry_stop_loss_target",
  "type": "merged_concept",
  "canonical_term": "Entry, Stop Loss, Target",
  "aliases": [],
  "school": "ICT / Smart Money Concepts (SMC)",
  "definition": "A trade management plan for demand zones: enter on the close of the confirming candle, place stop loss below the pattern low or demand zone, and set profit target above the break of structure or just below prior swing high to lock in gains before potential resistance reversal.",
  "identification_rules": [
    "Enter at the candle close of the candlestick pattern or momentum candle that confirms the demand zone.",
    "Set the stop loss below the lowest point of the confirming candlestick pattern or just below the demand zone.",
    "Take profit above the break of structure (BoS) or just below the previous swing high, especially if that high shows multiple touches acting as resistance."
  ],
  "trading_implication": "Provides a structured, rule-based method for executing and managing longs from demand zones in an uptrend. It ensures confirmation before entry, protects capital with a logical stop, and secures profit before a likely resistance reversal, aligning with smart money concepts of buying into demand and selling before supply re-enters.",
  "common_mistakes": [
    "Aiming for a target above the break of structure without considering nearby resistance that may cause a reversal, leading to missed profit-taking and potential losses."
  ],
