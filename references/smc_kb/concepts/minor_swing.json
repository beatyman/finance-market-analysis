{
  "card_id": "minor_swing",
  "type": "merged_concept",
  "canonical_term": "Minor Swing",
  "aliases": [],
  "school": "Smart Money Concepts (SMC)",
  "definition": "A swing high or low that fails to satisfy one or more major swing criteria: it does not originate a valid break of structure, lacks an associated fair value gap, or does not push sufficient distance relative to the preceding impulse. It is secondary in trend analysis and its breach does not confirm a reversal.",
  "identification_rules": [
    "The swing point does not break a recent structure level (i.e., it stays within the prior major high/low boundary).",
    "No fair value gap (imbalance) forms in its creation; the price action lacks a buy- or sell-side efficiency gap.",
    "The distance it covers from origin to extreme is less than 50% of the previous impulsive move.",
    "Breaking below a minor swing low in an uptrend or above a minor swing high in a downtrend does not qualify as a change of character.",
    "On a star rating system (BOS, FVG, distance), it receives zero or one star, confirming it is minor."
  ],
  "trading_implication": "Breaching a minor swing signals only temporary weakness, not a trend reversal. It often represents a liquidity sweep or pullback. Counter-trend entries based solely on minor swing breaks are risky; safer entries align with the major trend at major swing zones. If combined with a higher‑timeframe key level or liquidity sweep, a minor swing break may offer a short‑term counter‑trend opportunity targeting the next major swing.",
  "common_mistakes": [
    "Treating a break of a minor swing as a valid change of character and reversing the bias prematurely.",
    "Taking counter‑trend trades based on minor swing breaks without additional confirmation (e.g., liquidity sweep, higher‑timeframe POI).",
    "Ignoring that minor swings often represent stop‑hunting and liquidity grabs, not genuine directional shifts."
  ],
