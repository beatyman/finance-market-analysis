{
  "card_id": "algorithmic_price_delivery",
  "type": "merged_concept",
  "canonical_term": "Algorithmic Price Delivery",
  "aliases": [],
  "school": "Smart Money Concepts (SMC)",
  "definition": "Engineered market movements by institutions to optimize trade execution and enhance liquidity, often exploiting or trapping other participants by targeting stop-loss levels and liquidity pools, leading to reversals after sweeping key highs or lows.",
  "identification_rules": [
    "Look for clusters of equal highs or swing highs where liquidity (stop-loss orders) is likely resting above.",
    "Watch for a price move that sweeps above those highs, triggering buy stops and then immediately reversing (buyside delivery signals a potential short).",
    "Look for clusters of equal lows or swing lows where liquidity is resting below.",
    "Watch for a price move that sweeps below those lows, triggering sell stops and then immediately reversing (sellside delivery signals a potential long)."
  ],
  "trading_implication": "Algorithmic price delivery suggests that price often seeks liquidity before reversing. Traders can anticipate reversals by identifying liquidity pools above equal highs or below equal lows. After a liquidity sweep (e.g., breakout above highs followed by sharp rejection), a trade in the opposite direction can be taken, targeting the opposing liquidity.",
  "common_mistakes": [
    "Assuming institutions only target retail traders; they also trap other institutions.",
    "Failing to distinguish between general liquidity and the specifically targeted stop-loss liquidity.",
    "Entering prematurely before the sweep completes and the reversal is confirmed, leading to being trapped."
  ],
