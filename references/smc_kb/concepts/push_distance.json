{
  "card_id": "push_distance",
  "type": "merged_concept",
  "canonical_term": "Push Distance",
  "aliases": [],
  "school": "Smart Money Concepts (SMC)",
  "definition": "The distance price travels away from a supply or demand zone before returning; a larger push distance signals a more significant rejection, making the zone stronger and more reliable for future trades.",
  "identification_rules": [
    "Identify the supply or demand zone from the origin of a sharp, impulsive move.",
    "Measure the price distance from the zone boundary to the farthest point reached before the first meaningful retracement back to the zone.",
    "Compare the push distance to recent impulsive moves to assess relative strength; a notably larger distance indicates stronger rejection.",
    "Combine push distance with inefficiency (e.g., fair value gaps) and break of structure to confirm zone validity."
  ],
  "trading_implication": "A larger push distance indicates stronger institutional rejection from a zone, increasing the probability that price will react from the zone on a revisit. Traders should prioritize zones with significant push distance when planning entries and setting stop losses.",
