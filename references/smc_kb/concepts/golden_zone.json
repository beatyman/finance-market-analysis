{
  "card_id": "golden_zone",
  "type": "merged_concept",
  "canonical_term": "Golden Zone",
  "aliases": [
    "Golden Pocket"
  ],
  "school": "Indicator Based",
  "definition": "The Fibonacci retracement zone between the 0.5 and 0.618 levels, often highlighted in gold. It is considered a high-probability area where price is likely to reverse during a pullback, used to identify potential entry points in a trend.",
  "identification_rules": [
    "Configure the Fibonacci retracement tool to display only the 0.5 and 0.618 levels, unchecking all other levels.",
    "Highlight the 0.618 level in a gold or yellow color to visually define the golden zone.",
    "Draw the Fibonacci from a swing low to a swing high in an uptrend, or swing high to swing low in a downtrend, using candle real bodies.",
    "Identify the zone between the 0.5 and 0.618 retracement lines as the golden zone."
  ],
  "trading_implication": "The golden zone signals a potential reversal area during a trend pullback. Traders watch for price to enter this zone and show reversal signs, then enter in the direction of the trend with a stop loss below the zone (in an uptrend) or above (in a downtrend). It provides a high reward-to-risk entry point.",
