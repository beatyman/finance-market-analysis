{
  "card_id": "stochastic_relative_strength_index",
  "type": "merged_concept",
  "canonical_term": "Stochastic Relative Strength Index",
  "aliases": [
    "stoch rsi",
    "Stoch RSI",
    "Stochastic RSI",
    "stochastic rsi"
  ],
  "school": "Indicator Based",
  "definition": "Stochastic RSI applies the stochastic oscillator formula to RSI values, measuring where the RSI falls within its recent range (typically 14 periods). It oscillates between 0 and 100, with overbought above 80 and oversold below 20. Comprising %K and %D lines, it identifies momentum shifts via crossovers, overbought/oversold extremes, and divergence between %D and price to anticipate reversals or continuations.",
  "identification_rules": [
    "The Stochastic RSI consists of two lines: %K and %D, where %D is a 3-period simple moving average of %K.",
    "%K reflects the RSI's position relative to its highest and lowest values over the lookback period (typically 14).",
    "A reading of 100 means the RSI is at its highest point in that period.",
    "Overbought condition is present when either line is above 80; oversold when below 20.",
    "A bullish crossover occurs when %K crosses above %D, signaling upward momentum; a bearish crossover when %K crosses below %D.",
    "Sharp price moves drive the indicator to extremes: strong uptrends push readings toward 100, strong downtrends toward 0.",
    "Potential reversal signals appear when the indicator exits overbought or oversold territory after a crossover.",
    "Regular bullish divergence: price forms a lower low while the %D line forms a higher low. Only compare lows, ignore highs.",
    "Hidden bullish divergence: price forms a higher low while the %D line forms a lower low. Only compare lows, ignore highs.",
    "Regular bearish divergence: price forms a higher high while the %D line forms a lower high. Only compare highs, ignore lows.",
    "Hidden bearish divergence: price forms a lower high while the %D line forms a higher high. Only compare highs, ignore lows.",
    "Setting Percentage K to 1 makes the %K line directly reflect the RSI's rank within its range, resulting in a highly responsive line.",
    "Setting Percentage K to 3 (standard) applies a 3-period moving average to the stochastic value, smoothing the %K line."
  ],
  "trading_implication": "Stochastic RSI helps identify momentum shifts and potential trade entries. Overbought (>80) and oversold (<20) levels signal extremes; crossovers of %K and %D provide entry signals, especially after exiting extremes. Divergences between %D and price anticipate reversals (regular divergence) or trend continuation (hidden divergence). Standard settings (14,3,3) balance sensitivity; lower K values increase responsiveness but raise false signal risk. In strong trends, the indicator can stay extreme, so confirm with other tools.",
  "common_mistakes": [
    "Using the %K line instead of %D for divergence detection, which frequently hits extremes and obscures clear divergence signals.",
    "Comparing the wrong price‑oscillator extremes (e.g., highs for bullish divergence or lows for bearish divergence) instead of matching lows with lows and highs with highs.",
    "Acting on ambiguous divergence where the oscillator swing is not clearly distinct from the prior swing.",
    "Treating overbought/oversold levels as immediate reversal signals, ignoring that the indicator can remain at extremes during strong trends.",
    "Applying standard RSI overbought/oversold thresholds (70/30) instead of the correct 80/20 levels for Stochastic RSI.",
    "Believing that a more responsive Stochastic RSI (K=1) always yields better signals, ignoring the increased false signals.",
    "Misinterpreting the %K line as the raw RSI when K>1, not recognizing it as a moving average."
  ],
