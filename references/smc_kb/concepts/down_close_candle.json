{
  "card_id": "down_close_candle",
  "type": "merged_concept",
  "canonical_term": "Down-Close Candle",
  "aliases": [
    "Bearish Candle",
    "bearish candle",
    "down close candle",
    "Down Close Candle"
  ],
  "school": "Price Action",
  "definition": "A bearish candle that closes below its open. A down-close candle (or series) that sweeps a low into a point of interest becomes a bullish order block once price closes above it, used as support for higher prices.",
  "identification_rules": [
    "The candle's close must be below its open (bearish body).",
    "For a bullish order block, locate the down-close candle (or series of consecutive down-close candles) within the move that swept a short-term low into an important level or point of interest.",
    "Validation occurs only when a subsequent candle closes above the high of that down-close candle (or series).",
    "Prefer a full-bodied down-close candle into the point of interest over a small-bodied one for higher conviction.",
    "Mark the opening price of the validated down-close candle as the support reference level for entries."
  ],
  "trading_implication": "Down-close candles that sweep liquidity into a higher-time-frame point of interest are the building blocks of bullish order blocks. After a close above the down-close candle, traders mark its opening price as a support zone and look for price to retest and respect it (bodies holding above, wicks tolerated) before expansion toward buy-side liquidity targets. It is the author's favorite reversal/entry model when paired with displacement and a relevant level.",
  "common_mistakes": [
    "Using a down-close candle that did not sweep liquidity or engage a relevant point of interest, reducing setup validity.",
    "Acting on a weak-bodied down-close candle when a full-bodied sweeping candle is preferred.",
    "Treating wick penetration of the opening price as invalidation; bodies respecting the level is what matters."
  ],
