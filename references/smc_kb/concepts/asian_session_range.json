{
  "card_id": "asian_session_range",
  "type": "merged_concept",
  "canonical_term": "Asian Session Range",
  "aliases": [
    "Asia High/Low",
    "asia high/low",
    "Asia Low and High",
    "asia low and high",
    "asia range",
    "Asia Range",
    "Asia range",
    "Asian high and low",
    "asian high and low"
  ],
  "school": "ICT",
  "definition": "The high and low price boundaries established during the Asian trading session (approximately 20:00–00:00 EST). These levels serve as reference boundaries for subsequent London and New York sessions, which frequently sweep one or both sides of the range before reversing or continuing into it. In Seek and Destroy patterns, the range acts as initial reference structure for identifying deviations and liquidity targets.",
  "identification_rules": [
    "Mark the highest high and lowest low formed during the Asian session (approximately 20:00–00:00 EST) on the chart.",
    "Draw horizontal lines or a shaded rectangle spanning from the Asia session low to the Asia session high to define the range boundaries.",
    "Confirm the range is set only after the Asian session closes; do not extend or adjust it based on London or New York price action.",
    "On a 15-minute chart, identify the Asia range box using a session indicator or manually marking the first session's candles before London opens at 02:00 EST.",
    "Asian Session High is the swing high of the session, Asian Session Low is the swing low; the range between them forms the reference structure."
  ],
  "trading_implication": "The Asia Range acts as a reference boundary for evaluating London and New York session behavior. In a Seek and Destroy (indecision) profile, London sweeps both the Asia low and Asia high without sustaining a breakout, signaling consolidation. Price that exits the range is expected to trade back into it, making the range's equilibrium (50% midpoint) and the opposite boundary key intraday targets. Traders use deviations outside the Asia Range as potential entry signals to trade back inside the range, targeting equilibrium, OTE, or opposite side liquidity.",
  "common_mistakes": [
    "Attempting to trade breakouts of the Asia Range when London sweeps both sides without displacement, which signals consolidation rather than expansion.",
    "Expecting New York to produce a large directional move when London has already swept both sides of the Asia Range, as this sets up low-probability expansion conditions.",
    "Trading from inside the range outward (inside-out) during Seek and Destroy conditions instead of waiting for price to exit the range and then targeting a return back into it (outside-in).",
    "Failing to correctly mark the true high and low of the Asian session, leading to incorrect deviation identification.",
    "Confusing the Asian Session Range with the Daily Open; they are different reference levels.",
    "Ignoring the fractal nature of the range; failing to apply the same principle on lower timeframes."
  ],
  "related_concepts": [],
  "merge_strategy": "llm_synthesis",
