{
  "card_id": "entry_signal",
  "type": "merged_concept",
  "canonical_term": "Entry Signal",
  "aliases": [],
  "school": "Smart Money Concepts",
  "definition": "A trade entry confirmation formed when price retests a demand zone with multiple wicks, followed by a strong bullish candle, signaling the zone is holding and a long position can be initiated.",
  "identification_rules": [
    "Identify a clear demand zone using a method such as the cluster of candles approach (strong green candle engulfing prior candles).",
    "Wait for price to return to the demand zone after an initial impulsive move away.",
    "Observe at least two wicks penetrating the demand zone on lower timeframes.",
    "Confirm the signal when a strong green candle appears, closing above the demand zone's lower boundary.",
    "Enter a long position immediately after the strong green candle closes."
  ],
  "trading_implication": "The entry signal defines the precise timing to execute a long trade after a demand zone retest, with a stop loss placed just below the reaction low or the entire demand zone. Targets are set at previous supply zones or using a risk-to-reward ratio (e.g., 2:1).",
  "common_mistakes": [
    "Entering on the first wick without waiting for the strong green candle confirmation.",
    "Failing to adjust the demand zone based on new price action before the retest.",
    "Misidentifying a small or mixed candle as a valid strong candle entry signal."
  ],
