{
  "card_id": "relative_strength_index",
  "type": "merged_concept",
  "canonical_term": "Relative Strength Index",
  "aliases": [
    "rsi",
    "RSI"
  ],
  "school": "Indicator Based",
  "definition": "A momentum oscillator that measures the speed and change of price movements on a scale of 0 to 100, typically using a 14-period calculation of average gains vs. average losses. Readings above 70 signal overbought conditions, below 30 oversold. Divergences with price indicate potential reversals.",
  "identification_rules": [
    "Add the RSI indicator to a chart via the TradingView Indicators tab; it is plotted in a separate panel below price with a fixed scale of 0 to 100 as a single line.",
    "The default RSI calculation uses 14 periods, comparing average gains to average losses.",
    "RSI typically oscillates between 30 and 70; values above 70 indicate overbought conditions, values below 30 indicate oversold conditions.",
    "Identify the prevailing trend using price action before interpreting RSI signals; in strong trends, RSI may remain in overbought/oversold territory for extended periods.",
    "Overlay Bollinger Bands on RSI to gauge volatility; RSI closing outside the bands indicates extreme momentum.",
    "Bearish divergence occurs when price makes a higher high while RSI makes a lower high, signaling potential downside reversal."
  ],
  "trading_implication": "RSI gauges momentum strength. Overbought/oversold readings may signal potential reversals but should not be used in isolation; in strong trends, extremes can persist. Divergences (e.g., bearish divergence) can provide early reversal signals when confirmed by price patterns. RSI breakouts from Bollinger Bands indicate extreme momentum and volatility expansion, requiring caution. Always combine with other confirmation techniques.",
  "common_mistakes": [
    "Entering trades solely based on overbought or oversold conditions, leading to losses when price remains in those zones for extended periods.",
    "Ignoring the prevailing trend when interpreting RSI readings.",
    "Assuming that an extreme RSI reading (e.g., outside Bollinger Bands) guarantees immediate trend continuation; the subsequent direction is often uncertain."
  ],
