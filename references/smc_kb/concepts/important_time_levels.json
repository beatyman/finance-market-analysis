{
  "card_id": "important_time_levels",
  "type": "merged_concept",
  "canonical_term": "Important Time Levels",
  "aliases": [
    "Key Intraday Times",
    "key intraday times",
    "Key Time Levels",
    "key time levels"
  ],
  "school": "ICT",
  "definition": "Specific intraday times (e.g., 8:30, 9:30, 10:00 AM ET) during the New York session where price frequently reacts with reversals, continuations, or retracements, often coinciding with session opens, economic news, or candle closes.",
  "identification_rules": [
    "Mark the times 8:30 AM (news), 9:30 AM (NYSE open), and 10:00 AM (4‑hour candle close/open) on the chart.",
    "Look for a London reversal (between 2–5 AM) establishing the directional bias ahead of the New York session.",
    "At the specified time, wait for a change in state of delivery (e.g., close over down-close candles) to form an order block.",
    "Enter on the retest of that order block with a stop placed on the manipulation high/low, targeting at least 2R."
  ],
  "trading_implication": "These time levels act as entry windows during the New York session. For example, after a London reversal, an 8:30 manipulation often provides the order block for a continuation entry at 9:30, while 10:00 can serve as a target or additional continuation point, aligning with the daily OHLC profile.",
  "common_mistakes": [
    "Entering before the time level without confirmation of a change in state of delivery.",
    "Assuming every 8:30 or 9:30 time will produce a tradeable move without a prior London reversal.",
    "Ignoring higher‑timeframe context and treating all time levels as uniformly actionable."
  ],
