{
  "card_id": "turning_points",
  "type": "merged_concept",
  "canonical_term": "Swing Points",
  "aliases": [
    "turning points"
  ],
  "school": "Smart Money Concepts (SMC)",
  "definition": "Areas where price changes direction after a long-term trend, often viewed as overbought or oversold levels with significant liquidity, increasing the likelihood of a reaction when price revisits them.",
  "identification_rules": [
    "Identify the highest price peak or lowest price trough following a sustained trend, where price subsequently reverses direction.",
    "The turning point is confirmed after a clear reversal in market structure, such as a break of structure or change of character."
  ],
  "trading_implication": "Turning points act as potential reversal zones due to concentrated liquidity; when price returns, a reaction is likely. Traders look for entry signals such as demand/supply zones or order blocks after a liquidity sweep at these levels, aiming to trade the reversal with confirmation.",
  "common_mistakes": [
    "Entering immediately at a turning point without waiting for a liquidity sweep or reversal confirmation.",
    "Assuming every turning point will hold as support/resistance, ignoring the possibility of further liquidity collection."
  ],
