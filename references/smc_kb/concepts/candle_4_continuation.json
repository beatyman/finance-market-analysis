{
  "card_id": "candle_4_continuation",
  "type": "merged_concept",
  "canonical_term": "Candle 4 Continuation",
  "aliases": [
    "C4",
    "c4",
    "C4 Continuation",
    "c4 continuation",
    "candle 4",
    "Candle 4"
  ],
  "school": "ICT",
  "definition": "A continuation candle in the fractal model that follows a candle 3 closure strongly outside candle 2's range, confirming directional delivery. Candle 4 is always a continuation and is traded only when the drawn liquidity has not yet been reached. The C4 close confirms the setup remains valid; if it closes opposite to bias, the setup is invalidated.",
  "identification_rules": [
    "Identify C2 and C3, then observe the close of the fourth higher timeframe candle (C4).",
    "Candle 3 must close strongly outside candle 2's range, confirming directional delivery before candle 4 forms.",
    "The drawn liquidity (e.g., previous day low/high or formation liquidity) has not yet been reached at the close of candle 3.",
    "If C4 closes in the direction of the setup (e.g., bearish setup: close below open), it confirms continuation.",
    "If C4 closes through the opposing key level (e.g., bearish setup: close above the opposing candle high), the setup is invalidated (turns red).",
    "A change in state of delivery occurs as price closes through a series of opposing candles within C4's formation, aligned with higher timeframe bias.",
    "The C4 t-spot area should hold; price should not close back through the opposing-candle level.",
    "Indicator label colors: gray C4 = setup remains valid within C4; red C4 = invalidated after first candle; orange C4 = invalidated after second candle."
  ],
  "trading_implication": "C4 continuation confirms the setup, allowing entry on a lower timeframe change in state of delivery within the C4 t-spot, often at the open due to rare deep retracements. Stop beyond the protected swing low/high formed at the start of C4. Target minimum 2R toward formation liquidity or standard deviation projections. If price closes back through the opposing-candle level, the continuation is invalidated. C4 failure (red/orange) is an early warning to abandon or adjust the trade.",
  "common_mistakes": [
    "Entering before C4 close, not waiting for full confirmation.",
    "Confusing C4 close with lower timeframe candle close, leading to misjudgment.",
    "Ignoring C4 red/orange warning and continuing to hold, causing losses.",
    "Trading C4 continuation when drawn liquidity has already been reached, eliminating the directional target.",
    "Looking for C4 continuation when price has already closed over the opposing-candle level, invalidating the setup.",
    "Waiting for a deep retracement on aggressive continuations, which often does not occur and causes missed entries.",
    "Relying solely on C4 without combining with Formation Liquidity and T-Spot."
  ],
