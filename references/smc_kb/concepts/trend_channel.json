{
  "card_id": "trend_channel",
  "type": "merged_concept",
  "canonical_term": "Trend Channel",
  "aliases": [],
  "school": "Indicator Based",
  "definition": "A pair of parallel lines drawn along swing highs and lows to contain price movement within an uptrend or downtrend, visually representing the trend's direction and boundaries.",
  "identification_rules": [
    "The indicator draws colored zones: green for uptrend channels and red for downtrend channels, based on pivot points.",
    "Channel breakouts are signaled with 'Break Up' and 'Break Down' labels when price closes beyond the channel boundary.",
    "The channel can be calculated using either candlestick bodies or wicks, selectable in settings.",
    "The pivot length parameter controls the sensitivity of channel detection; shorter lengths capture smaller trends."
  ],
  "trading_implication": "Trend channels help identify the prevailing trend direction and potential trade entries. A break of the channel can signal a trend reversal or continuation, and can be combined with candlestick patterns (e.g., bearish engulfing near channel bottom) for confirmation. Use breakout signals (on close or high/low) to time entries.",
  "common_mistakes": [
    "Relying solely on the indicator without confirming with additional technical factors like candlestick patterns.",
    "Using default indicator settings without testing suitability for the specific asset and timeframe.",
    "Entering on every channel breakout without considering false breaks or waiting for confirmation on close."
  ],
