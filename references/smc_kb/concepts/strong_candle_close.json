{
  "card_id": "strong_candle_close",
  "type": "merged_concept",
  "canonical_term": "Strong Candle Close",
  "aliases": [],
  "school": "Price Action",
  "definition": "A candle that closes significantly below a moving average for a downside breakout or significantly above for an upside breakout, indicating a higher probability of a sustained breakout.",
  "identification_rules": [
    "The candle's close must be clearly far below the moving average for a bearish breakout or far above for a bullish breakout.",
    "The distance between the closing price and the moving average should be noticeably larger than that of preceding candles that merely touch or cross.",
    "The candle body should not have a long wick retracing inside the moving average; the close should be decisive beyond the moving average."
  ],
  "trading_implication": "A strong candle close increases confidence that a breakout is genuine and not a false move. It suggests strong momentum and commitment from market participants, often used as a confirmation signal before entering a breakout trade.",
  "common_mistakes": [
    "Assuming any close beyond the moving average qualifies as a strong close, ignoring the need for a substantial gap.",
    "Confusing a candle with a long wick that briefly penetrates the moving average but closes near it as a strong close."
  ],
