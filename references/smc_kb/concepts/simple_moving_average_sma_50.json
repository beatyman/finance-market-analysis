{
  "card_id": "simple_moving_average_sma_50",
  "type": "merged_concept",
  "canonical_term": "Simple Moving Average (SMA 50)",
  "aliases": [
    "SMA 50",
    "sma 50"
  ],
  "school": "Indicator-Based",
  "definition": "A 50-period simple moving average that smooths price data to identify trend direction. Used as a filter to reduce false signals from candlestick pattern indicators.",
  "identification_rules": [
    "Calculate the average closing price of the last 50 periods and plot as a line on the chart.",
    "If price is above the SMA 50, the trend is considered up; if below, the trend is down.",
    "In the candlestick pattern indicator, set trend detection to 'SMA 50' to automatically filter patterns against the trend."
  ],
  "trading_implication": "The SMA 50 acts as a trend filter: only candlestick patterns that align with the prevailing trend (as indicated by SMA 50) are considered valid, helping avoid many false signals that occur when patterns form against the trend.",
  "common_mistakes": [
    "Disabling the SMA 50 trend filter, which results in many false signals from the candlestick pattern indicator."
  ],
  "related_concepts": [],
