{
  "card_id": "strong_level_criteria",
  "type": "merged_concept",
  "canonical_term": "Strong Level Criteria",
  "aliases": [],
  "school": "Smart Money Concepts (SMC)",
  "definition": "Five characteristics that make a market structure level more significant and likely to trigger a strong price reaction: having acted as both support and resistance, a drastic prior move away, multiple historical rejections, being a turning point, and being recently respected.",
  "identification_rules": [
    "The level has previously functioned as both support and resistance.",
    "Price moved away from the level drastically in the past, indicating strong prior interest.",
    "The level shows multiple historical rejections, with price touching and reversing multiple times.",
    "The level is a past turning point where the trend reversed, signaling overbought/oversold conditions.",
    "The level has been recently respected or is newly formed, giving it more current relevance."
  ],
  "trading_implication": "These criteria help traders identify high-probability market structure levels on higher timeframes (e.g., weekly) where price is expected to react strongly. Such levels are treated as zones rather than precise lines and guide lower-timeframe entries for trades aligned with the dominant trend.",
  "common_mistakes": [
    "Failing to prioritize recently respected or newly formed levels over older ones.",
    "Drawing levels as exact lines instead of zones that capture the most price touches.",
    "Assuming a level will hold simply because of multiple past rejections without a break and retest confirmation."
  ],
