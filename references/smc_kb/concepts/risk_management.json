  "school": "Risk Management",
  "definition": "The discipline of protecting trading capital by controlling leverage, using small position sizes, and never risking more than one can afford to lose.",
  "identification_rules": [
    "Begin with small position sizes before scaling up.",
    "Never risk more than you can afford to lose on any trade.",
    "Avoid using high leverage to prevent amplified losses.",
    "Practice on a demo account before trading with real money."
  ],
  "trading_implication": "Proper risk management is essential for long-term success in Forex trading; it prevents catastrophic losses and helps maintain discipline by keeping positions small and controlled.",
  "common_mistakes": [
    "Trading without any risk management plan.",
    "Using excessive leverage.",
    "Having unrealistic profit expectations.",
    "Letting emotions drive trading decisions."
