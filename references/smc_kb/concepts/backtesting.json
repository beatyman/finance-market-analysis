{
  "card_id": "backtesting",
  "type": "merged_concept",
  "canonical_term": "Backtesting",
  "aliases": [
    "back test",
    "历史数据验证",
    "回测"
  ],
  "school": "General",
  "definition": "The process of applying a trading strategy to historical price data to simulate past performance, evaluating profitability and risk. It involves replaying market data, executing trades based on predefined rules, and analyzing key metrics like win rate and risk-reward ratio.",
  "identification_rules": [
    "In backtesting tools like FX Replay, create a strategy and specify a test period (e.g., July to mid-August).",
    "Set initial account balance, trading instrument, and time frame parameters.",
    "Play historical price data bar by bar or in segments, manually or automatically executing trade signals.",
    "Record entry, stop loss, target, and actual outcome for each trade.",
    "Calculate total trades, win rate, average risk-reward ratio, total return, and other key metrics.",
    "Backtested performance is explicitly labeled as derived from historical data, as seen in the AI strategy disclaimer."
  ],
  "trading_implication": "Backtesting is essential for validating a strategy's feasibility. It helps assess performance under various market conditions (e.g., 45 days, 15 trades, 5:1 risk-reward, 44.4% return). However, past performance does not guarantee future results; traders should use backtested data cautiously and consider disclaimers before committing capital.",
  "common_mistakes": [
    "Small sample size leading to non-representative conclusions (e.g., only 45 days and 15 trades).",
    "Over-optimizing strategy parameters to fit historical data, causing overfitting.",
    "Ignoring subjective judgment during backtesting (e.g., selective interpretation of price action).",
    "Neglecting real-world costs like slippage and commissions.",
    "Assuming backtested performance will repeat exactly in the future.",
    "Not reading disclaimers that explain limitations of backtested data."
  ],
