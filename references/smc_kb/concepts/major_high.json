{
  "card_id": "major_high",
  "type": "merged_concept",
  "canonical_term": "Major High",
  "aliases": [
    "major swing high",
    "Major Swing High"
  ],
  "school": "Smart Money Concepts (SMC)",
  "definition": "The highest price point before a retracement that initiates a valid break of structure (BOS) in an uptrend, or the last extreme high before a bearish push that breaks a major low in a downtrend; it defines the upper boundary of the external structure.",
  "identification_rules": [
    "In an uptrend, locate the peak that forms before price retraces and later breaks above it with a valid BOS (body close).",
    "In a downtrend, after a bearish BOS, identify the highest internal high formed just before the price initiates the strong move that breaks the recent major low.",
    "A major high must be the origin of a valid break of structure; if the break is only by wick without body close, it is not a new major high.",
    "The major high, together with the major low, constitutes the external structure; all price action between them is internal."
  ],
  "trading_implication": "In an uptrend, a body close above the major high signals trend continuation. In a downtrend, if price breaks above the major high, it indicates a potential trend reversal (change of character). The major high acts as a key resistance; as long as price stays below it in a downtrend, the bearish bias remains.",
  "common_mistakes": [
    "Confusing internal highs that do not lead to a BOS with major highs.",
    "Considering a wick break above a major high as a valid BOS, without a subsequent body close confirmation, leading to false trend continuation or reversal signals."
  ],
