{
  "card_id": "es_nq_ratio_reversal",
  "type": "merged_concept",
  "canonical_term": "ES/NQ Ratio Reversal",
  "aliases": [
    "ESNQ Reversal",
    "esnq reversal",
    "Ratio Reversal",
    "ratio reversal"
  ],
  "school": "ICT",
  "definition": "A reversal on the ES/NQ ratio chart, where the ratio sweeps a prior high or low and closes back inside the range, signaling a shift in relative strength correlation. This often precedes an actual reversal on the ES or NQ price charts, acting as a leading indicator.",
  "identification_rules": [
    "Plot the ES price divided by NQ price on a separate chart to isolate relative strength movements.",
    "Identify when the ratio sweeps a recent swing high or low and then closes back inside the prior range, forming a reversal structure.",
    "Compare the timing of the ratio reversal to the actual price action on ES and NQ; a leading reversal occurs before the turn on the individual index charts.",
    "Look for additional confluence from price-based signals such as a change in state of delivery or an SMT divergence to increase confidence."
  ],
  "trading_implication": "When the ES/NQ ratio reverses, it indicates a change in the relative strength: a ratio turning up suggests ES is becoming stronger than NQ, favoring long ES and short NQ setups, and vice versa. It can provide early warning of an impending directional shift on the actual price charts, allowing traders to anticipate and position ahead of the move.",
  "common_mistakes": [
    "Assuming every ratio reversal will be followed by a price reversal on ES/NQ without additional confirmation.",
    "Taking the ratio reversal alone as a trade signal without aligning it with higher-timeframe bias or key price levels."
  ],
