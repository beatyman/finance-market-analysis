{
  "card_id": "stop_loss_placement",
  "type": "merged_concept",
  "canonical_term": "Stop Loss Placement",
  "aliases": [
    "Invalidation",
    "Invalidation Placement",
    "invalidation placement",
    "Stop Loss",
    "stop placement",
    "Stop Placement",
    "止损位置",
    "止损设置"
  ],
  "school": "Risk Management",
  "definition": "A method for setting stop-loss levels based on market structure, such as beyond breaker blocks, fair value gaps, order blocks, or swing highs/lows. Placement considers risk-to-reward ratio, with tighter stops (e.g., beyond breaker block) improving R:R but risking premature sweeps, while wider stops (swing points) offer safety but require larger moves. For order blocks, stop distance adapts to block size.",
  "identification_rules": [
    "For short trades, use the high of the candle forming the FVG or a short-term swing high as stop.",
    "For long trades, use the low of the candle forming the OB or a short-term swing low as stop.",
    "Place stop just beyond the breaker block (and overlapping FVG) for entries at breaker blocks.",
    "For protected swings, place stop beyond the swing high/low after price has reached an important level (sweep or FVG) and closed through opposing candles.",
    "If the stop distance does not allow a 2R target, tighten the stop to the 50% body (mean threshold) of the opposing candle series.",
    "If neither full structural stop nor body-based stop yields 2R, wait for a continuation entry.",
    "For PD arrays like breaker, FVG, or inversion (not order blocks), define invalidation as a close back through that array.",
    "For projection-based targets, anchor the stop just beyond the breaker to ensure favorable R multiples.",
    "Measure the size of the order block zone on the lower time frame; if small, set stop at a larger zone beyond; if large, use a smaller zone below or place entry at midpoint."
  ],
  "trading_implication": "Stop placement dictates risk size and whether a trade meets minimum 2R target. Tighter stops (beyond breaker block or mean threshold) improve R:R but risk premature sweeps; wider stops (swing high/low) offer safety but require larger moves. If no placement yields 2R, wait for continuation entries. For multiple order blocks, trade each individually with reduced risk, never exceeding 2% capital risk and three active trades.",
  "common_mistakes": [
    "Defaulting to swing high/low as stop when a tighter breaker-block stop yields better R:R.",
    "Setting take-profit at 2R from a swing-based stop and getting stopped out because price nearly reached a closer target achievable with a breaker stop.",
    "Entering on a reversal when the protected-swing stop does not yield 2R, instead of waiting for a continuation entry.",
    "Treating a swing as protected without confirming a close through opposing candles or without an important level (FVG or liquidity sweep).",
    "Using body/mean-threshold stops on V-shape moves where a return into the body likely invalidates the setup.",
    "Applying order-block invalidation rules to other PD arrays (breaker, FVG, inversion) without redefining invalidation.",
    "Trusting a closure 'just over' an opposing candle rather than a full close over the candle body.",
    "Using a uniform stop distance for all order blocks without considering their size, leading to excessive risk or premature exits.",
    "Placing the stop below the entire large order block without adjusting entry, resulting in a disproportionately large stop loss.",
    "Mechanically selecting stop position without adjusting for market structure and risk-to-reward ratio.",
    "Moving stop prematurely before market structure is clearly broken (MSS)."
  ],
