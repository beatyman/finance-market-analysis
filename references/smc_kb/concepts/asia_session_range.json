{
  "card_id": "asia_session_range",
  "type": "merged_concept",
  "canonical_term": "Asia Session Range",
  "aliases": [
    "Asia Range",
    "asian range",
    "Asian Range"
  ],
  "school": "ICT",
  "definition": "The high and low established during the Asian trading session, used as an external liquidity reference and intraday bias gauge. London and New York sessions typically interact with one or both sides of this range, either sweeping for liquidity or consolidating within it.",
  "identification_rules": [
    "Mark the highest high and lowest low formed during the Asia session hours on an intraday time frame (e.g. 15-minute).",
    "Extend the Asia high and Asia low as horizontal lines forward across the London and New York sessions.",
    "Observe whether London displaces beyond one side of the range or sweeps both sides without displacement (Seek and Destroy condition).",
    "Treat the range high as buy-side liquidity and the range low as sell-side liquidity for subsequent sessions."
  ],
  "trading_implication": "The Asia range provides external liquidity references that London and New York frequently target. When London sweeps both sides of the Asia range without displacement, it signals Seek and Destroy / consolidation conditions, suggesting trades from outside the range back to equilibrium rather than breakout entries. When price deviates beyond the Asia range without displacement, the range acts as a magnet, drawing price back inside for rebalancing. Used to gauge whether expansion or consolidation conditions are likely intraday.",
  "common_mistakes": [
    "Anticipating breakout/expansion when London has already swept both sides of the Asia range, when consolidation back into the range is more probable.",
    "Failing to recognize Seek and Destroy conditions and continuing to trade out of the range instead of from outside back in."
  ],
