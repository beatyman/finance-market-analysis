{
  "card_id": "order_block_entry_types",
  "type": "merged_concept",
  "canonical_term": "Order Block Entry Types",
  "aliases": [
    "OB Entry Types",
    "ob entry types"
  ],
  "school": "Smart Money Concepts (SMC)",
  "definition": "Four methods to enter trades using order blocks: wick entry places order on candle wick, body entry on candle body, midpoint entry at order block's midpoint, and body entry with stop inside. Each offers different risk/reward and probability profiles.",
  "identification_rules": [
    "For wick entry, place buy/sell orders at the extreme wick of the valid order block.",
    "For body entry, place buy/sell orders at the body (open/close) of the valid order block candle.",
    "For midpoint entry, place orders at the 50% level of the order block price zone.",
    "For body entry with stop inside, place entry at the body and set stop loss within the order block zone, touching the higher wick."
  ],
  "trading_implication": "These entry types allow traders to tailor risk/reward and probability. Wick entry gives higher trigger chance but wider stop, reducing R:R. Body entry improves R:R but risks missing the trade if price only touches the wick. Midpoint entry offers at least double the R:R of regular types due to refined entry and tighter stop. Body entry with tight stop inside the order block increases the risk of stop-outs.",
  "common_mistakes": [
    "Expecting high risk-to-reward with wick entry, which inherently offers a wider stop.",
    "Using body entry without acknowledging that price may only touch the wick, causing missed trades.",
    "Employing the fourth entry type without considering the increased risk of stop-loss being triggered by a full order block reversal."
  ],
