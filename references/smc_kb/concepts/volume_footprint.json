{
  "card_id": "volume_footprint",
  "type": "merged_concept",
  "canonical_term": "Volume Footprint",
  "aliases": [],
  "school": "Volume Analysis",
  "definition": "A chart type that displays net buying and selling volume at each price level, with a delta setting showing green for net buying and red for net selling; used to confirm breakout strength via increased net buying volume.",
  "identification_rules": [
    "Apply the Volume Footprint chart type and set the type to 'delta' to display net buying (green) and net selling (red) volume at each price level.",
    "For an upside move, look for green boxes indicating net buying volume to confirm strength.",
    "On a breakout of a key resistance or support level, look for a significant increase in net buying volume (green) to validate the breakout."
  ],
  "trading_implication": "It confirms breakout strength by showing whether moves are supported by institutional buying or selling. A surge in net buying volume on an upside breakout reduces the chance of a false breakout and signals sustainment. Traders use it to assess order flow and time entries.",
  "common_mistakes": [
    "Using the 'buy and sell' setting instead of 'delta', which shows separate buy/sell volume rather than net pressure, making directional strength harder to gauge.",
    "Not checking for increased net buying volume on breakouts, leading to potential false signals."
  ],
  "related_concepts": [],
