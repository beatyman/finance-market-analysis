{
  "card_id": "strong_and_weak_price_levels",
  "type": "merged_concept",
  "canonical_term": "Strong and Weak Price Levels",
  "aliases": [
    "strong highs and lows",
    "Strong Highs and Lows",
    "Weak Highs and Lows",
    "weak highs and lows"
  ],
  "school": "ICT / Smart Money Concepts (SMC)",
  "definition": "Strong levels originate from moves that break market structure, indicating institutional conviction. Weak levels come from moves that fail to break structure, signaling a lack of momentum and potential reversal.",
  "identification_rules": [
    "Locate a break of structure (e.g., new high in uptrend or new low in downtrend). Trace back to the start of the move that caused the break; that starting point is a strong level.",
    "Identify a move that attempted but failed to break structure (did not exceed the swing high/low required to change trend). The origin of that failed move is a weak level.",
    "In an uptrend, a low that precedes a successful new high is a strong low; a high that fails to exceed the prior high is a weak high (and vice versa for downtrends)."
  ],
  "trading_implication": "Strong levels serve as high-probability support/resistance zones where price is likely to react because they represent committed institutional activity. Weak levels indicate exhaustion or false attempts, often leading to reversals; traders use them to anticipate break failures or avoid false breakouts.",
