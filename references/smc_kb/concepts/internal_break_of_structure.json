{
  "card_id": "internal_break_of_structure",
  "type": "merged_concept",
  "canonical_term": "Internal Break of Structure",
  "aliases": [
    "iBOS",
    "ibos",
    "minor break of structure"
  ],
  "school": "ICT / Smart Money Concepts (SMC)",
  "definition": "A break of structure on a lower timeframe within the context of the higher timeframe trend; signals potential pullback initiation and provides early entry signals.",
  "identification_rules": [
    "Confirm the higher timeframe trend is bullish (uptrend) or bearish (downtrend).",
    "On a lower timeframe, locate a break of a swing high in an uptrend or a swing low in a downtrend.",
    "Ensure the lower timeframe break does not violate the higher timeframe's last major swing low (uptrend) or swing high (downtrend) — i.e., it does not cause an external change of character."
  ],
  "trading_implication": "An internal break of structure indicates that a pullback is likely beginning on the higher timeframe, allowing traders to anticipate counter-trend moves and potentially enter trades aligned with the higher timeframe trend once the pullback concludes.",
  "common_mistakes": [
    "Mistaking an internal break of structure for an external break of structure, leading to premature trend reversal expectations.",
    "Interpreting an internal break of structure as a change of character on the higher timeframe without confirming the break of the last major swing low/high."
  ],
