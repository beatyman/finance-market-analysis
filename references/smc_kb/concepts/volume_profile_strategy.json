{
  "card_id": "volume_profile_strategy",
  "type": "merged_concept",
  "canonical_term": "Volume Profile Strategy",
  "aliases": [],
  "school": "Volume Analysis",
  "definition": "A trading strategy that uses the Volume Profile indicator to identify key levels where price may accelerate. It focuses on low volume areas (fast historical moves) and places resistance just above high volume nodes, as breakouts often occur above heavy volume zones, leading to rapid price movement.",
  "identification_rules": [
    "Apply the Visible Range Volume Profile to the chart, showing volume by price.",
    "Identify high volume nodes (tall horizontal bars) indicating areas of heavy trading activity.",
    "Identify low volume areas (short or no bars) that represent historical fast price moves.",
    "Place horizontal resistance lines just above high volume nodes, and support lines just below.",
    "Look for price breakouts at these levels; the low volume areas serve as potential fast-move zones."
  ],
  "trading_implication": "The strategy helps traders anticipate where price may accelerate after breaking key levels derived from volume distribution. Instead of treating high volume areas themselves as support/resistance, these areas are seen as ranges that, once breached, often lead to rapid moves through low volume zones, offering high-reward opportunities.",
  "common_mistakes": [
    "Mistaking high volume areas as immediate support/resistance, when they are more like trading ranges and true key levels lie just above or below them.",
    "Failing to adjust the Volume Profile's visible range to match the trading timeframe, which can misrepresent volume distribution."
  ],
