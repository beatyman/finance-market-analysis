{
  "card_id": "ote_optimal_trade_entry",
  "type": "merged_concept",
  "canonical_term": "OTE (Optimal Trade Entry)",
  "aliases": [
    "Optimal Trade Entry",
    "OTE of a range",
    "ote of a range",
    "最优交易入场",
    "最优交易入场点",
    "最优入场点",
    "高概率入场区域"
  ],
  "school": "ICT",
  "definition": "OTE is a high-probability entry zone within the discount (for longs) or premium (for shorts) area, identified by applying Fibonacci retracement levels (0.5, 0.618, 0.625, 0.705, 0.786) from a complete displacement leg. It must overlap with PD arrays like FVG or order blocks, confirmed on higher timeframes, with entry triggered on lower timeframes.",
  "identification_rules": [
    "Identify a complete displacement or impulse leg, marking its start (low/high) and end (high/low).",
    "Apply Fibonacci retracement from leg start to end, focusing on levels 0.5, 0.618, 0.625, 0.705, 0.786.",
    "Determine the dealing range high/low; use 0.5 equilibrium as boundary: discount below (for longs) and premium above (for shorts).",
    "OTE zone must overlap with FVG, order block, or other PD array elements for confluence.",
    "On higher timeframe (e.g., 4H, 1H), mark OTE zone; then switch to lower timeframe (15m, 5m, 1m) for entry triggers like displacement, FVG, candlestick reversal, or market structure shift.",
    "Confirm price has not closed within the interest point (zone not swept) and OTE lies within multiple structural discount/premium zones.",
    "Verify risk-reward ratio from OTE stop to first target is favorable.",
    "On higher timeframe, confirm displacement, market structure shift (MSS), and imbalance to determine trend direction.",
    "In OTE zone, look for PD array (FVG, OB) as specific entry trigger.",
    "Wait for structural confirmation on lower timeframe (e.g., displacement, structure break, hammer/shooting star wick) after price retraces to OTE zone.",
    "Ensure price respects OTE zone (no candle close through it) and observe internal liquidity to avoid being swept.",
    "Target should point to clear liquidity zones (swing highs/lows, FVG, equal highs/lows)."
  ],
  "trading_implication": "OTE bridges higher timeframe macro bias to lower timeframe micro execution. First confirm displacement range, discount/premium direction, and main targets on HTF. Then on LTF, wait for price to retrace into OTE zone and trigger entry via FVG, OB, or displacement. Missed first OTE can be followed by secondary opportunities. OTE also serves as target or take-profit zone for counter-trend trades. Compared to equilibrium entry, OTE can improve risk-reward from ~1.6:1 to over 3:1. After entry, trail stop to protected swing points on structure breaks.",
  "common_mistakes": [
    "Not calculating Fibonacci from a complete displacement leg, leading to inaccurate OTE zone.",
    "Not confirming displacement, MSS, and imbalance on higher timeframe before seeking OTE on lower timeframe.",
    "Taking long in premium zone or short in discount zone, opposite to OTE direction.",
    "Relying solely on Fibonacci levels without confluence from FVG, order block, or other PD arrays.",
    "Entering when price has already closed within the interest point (zone swept).",
    "Entering OTE zone without waiting for a clear lower timeframe trigger (displacement, FVG, structure break).",
    "Confusing OTE with equilibrium (0.5): 0.5 is the boundary, not the entry point itself.",
    "Confusing OTE with FVG: OTE is a Fibonacci-based zone, FVG is a specific price gap structure.",
    "Treating too large a price range as a single OTE, losing entry precision.",
    "Ignoring internal liquidity positions, leading to immediate stop-out.",
    "Moving stop prematurely without structure break confirmation.",
    "Missing secondary OTE opportunities after missing the primary entry."
  ],
