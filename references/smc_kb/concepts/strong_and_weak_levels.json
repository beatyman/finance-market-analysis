{
  "card_id": "strong_and_weak_levels",
  "type": "merged_concept",
  "canonical_term": "Strong and Weak Levels",
  "aliases": [],
  "school": "ICT / Smart Money Concepts (SMC)",
  "definition": "Strong levels originate from price moves that break market structure (Break of Structure) or change character (Change of Character), indicating decisive momentum. Weak levels come from moves that fail to break structure, suggesting indecision. Strong levels act as key support/resistance zones; weak levels are less reliable.",
  "identification_rules": [
    "Identify a price move that breaks a previous swing high (in an uptrend) or swing low (in a downtrend) — the start of that move is a strong level.",
    "Identify a price move that fails to break a previous swing high or low — the start of that move is a weak level.",
    "Both Break of Structure (BoS) and Change of Character (CHoCH) moves produce strong levels; only moves that neither break structure nor change character are weak."
  ],
  "trading_implication": "Strong and weak levels help identify key support and resistance zones. Strong levels, backed by structural breaks, are more likely to hold and produce reversals, while weak levels are prone to being broken. Traders use them to set entries, stops, and targets.",
  "common_mistakes": [
    "Assuming a level is strong simply because it is a swing high or low, without checking if the move broke structure.",
    "Misidentifying a weak level as strong because it appears as a support/resistance without analyzing the structural context."
  ],
