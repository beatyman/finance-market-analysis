{
  "card_id": "forex_trading",
  "type": "merged_concept",
  "canonical_term": "Forex Trading",
  "aliases": [
    "Foreign Exchange Trading",
    "foreign exchange trading"
  ],
  "school": "General",
  "definition": "Simultaneously buying one currency and selling another with the goal of profiting from exchange rate changes.",
  "identification_rules": [
    "Currencies are always quoted in pairs, with the first currency (base) and the second (quote).",
    "Forex market operates 24 hours a day from Monday to Friday (closed weekends), distinguishing it from exchange-limited markets.",
    "Price movements are measured in pips: for most pairs 0.0001, for JPY pairs 0.01."
  ],
  "trading_implication": "Forex trading allows speculation on exchange rate direction through long and short positions, amplified by leverage. Success requires understanding currency pairs, market hours, and risk management. It is a skill developed over time, not a get-rich-quick scheme.",
  "common_mistakes": [
    "Over-leveraging trades, which amplifies both profits and losses beyond tolerance.",
    "Neglecting risk management, such as not using stop-loss orders or risking too much capital.",
    "Having unrealistic expectations and allowing emotions to drive trading decisions."
  ],
