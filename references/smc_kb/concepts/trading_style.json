{
  "card_id": "trading_style",
  "type": "merged_concept",
  "canonical_term": "Trading Style",
  "aliases": [],
  "school": "General",
  "definition": "A classification of trading approaches based on holding period: day trading (intraday, low timeframes), swing trading (days to weeks, medium timeframes), and long-term investing (months to years, high timeframes).",
  "identification_rules": [
    "Day trading involves buying and selling within the same day using time frames from 1 hour down to 1 minute (low time frame).",
    "Swing trading holds positions from a few days to a few weeks using time frames from daily down to 1 hour (medium time frame).",
    "Long-term investing holds positions from months to years using time frames from monthly down to daily (high time frame)."
  ],
  "trading_implication": "The trading style determines the time frame selection for top-down analysis and dictates the appropriate high, medium, and low time frame combination (e.g., day traders may use 1h, 15min, 3min while swing traders use daily, 4h, 30min).",
