{
  "card_id": "trading_range",
  "type": "merged_concept",
  "canonical_term": "Trading Range",
  "aliases": [],
  "school": "General",
  "definition": "A horizontal price movement where price oscillates between well-defined support and resistance levels, indicating consolidation and equilibrium between buying and selling pressure.",
  "identification_rules": [
    "Price moves sideways, confined between a horizontal support and a horizontal resistance level.",
    "Both support and resistance must be tested at least twice to confirm their validity.",
    "The range should persist for a sufficient number of bars (e.g., 20) to avoid false signals.",
    "Higher lows near resistance or lower highs near support increase the likelihood of an impending breakout."
  ],
  "trading_implication": "Trading ranges identify consolidation phases. Within the range, traders can buy at support and sell at resistance. When price breaks out, traders can enter in the direction of the breakout, preferably confirmed by price action signals such as higher lows at resistance for an upside breakout.",
  "common_mistakes": [
    "Using too few bars to confirm a range, leading to many false trading ranges.",
    "Failing to combine breakout signals with price action confirmation (e.g., higher lows at resistance), reducing trade reliability."
  ],
  "related_concepts": [],
