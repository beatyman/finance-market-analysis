{
  "card_id": "broadening_formation",
  "type": "merged_concept",
  "canonical_term": "Broadening Formation",
  "aliases": [
    "broadening",
    "Broadening",
    "Broadening Pattern",
    "broadening pattern",
    "Broading Formation",
    "broading formation",
    "range expansion",
    "Range Expansion",
    "扩大形态",
    "扩张区间",
    "扩张形态"
  ],
  "school": "ICT",
  "definition": "A pattern where price repeatedly takes out one side of a consolidation range then the other, failing to break out each time, causing the range to expand over time. It forms an expanding channel with diverging trendlines connecting successive higher highs and lower lows.",
  "identification_rules": [
    "Start with a consolidation range.",
    "Price sweeps one side of the range (e.g., takes out prior highs) but fails to displace and closes back inside the range.",
    "Price then sweeps the opposite side (e.g., takes out prior lows) and again fails to break out.",
    "Draw trendlines connecting successive highs that took out prior highs (upper line) and successive lows that took out prior lows (lower line), forming an expanding channel.",
    "On a higher time frame, the broadening formation appears as an outside bar that takes out both the previous candle's high and low.",
    "At least one higher high and one lower low must be confirmed to draw valid expanding lines.",
    "Identify nested formations on lower time frames."
  ],
  "trading_implication": "Use the expanding trendlines as points of interest for reversals or entries. When price touches one boundary and shows failure (e.g., with SMT divergence), anticipate a move to the opposite boundary. Combine with Power of Three and Box Setup for entries. In daily profiles, if London sweeps Asia high and low, the formation frames New York session POIs. Also used as liquidity targets.",
  "common_mistakes": [
    "Not confirming that the high/low actually broke the prior high/low (left-to-right confirmation).",
    "Identifying the pattern with only one-sided breakout (only higher highs or only lower lows).",
    "Not waiting for a clear consolidation range before identifying the formation.",
    "Confusing broadening formation with converging patterns (e.g., triangle).",
    "Ignoring nested formations on lower time frames.",
    "Over-relying on a single tool; should combine with SMT, Power of Three, premium/discount."
  ],
