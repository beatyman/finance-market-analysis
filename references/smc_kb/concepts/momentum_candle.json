{
  "card_id": "momentum_candle",
  "type": "merged_concept",
  "canonical_term": "Momentum Candle",
  "aliases": [
    "bullish momentum candle",
    "Bullish Momentum Candle",
    "Bullish Momentum Pattern",
    "bullish momentum pattern",
    "large candle",
    "Momentum Pattern",
    "momentum pattern",
    "strong momentum candle"
  ],
  "school": "Price Action",
  "definition": "A candlestick whose real body is at least twice the size of the preceding candles (typically the prior 3–5), ideally with small or no wicks, signaling strong directional momentum. A green candle indicates strong buying pressure; a red candle indicates strong selling pressure. It often appears near key levels, validating trend continuation or reversal.",
  "identification_rules": [
    "The real body must be at least twice the size of the real bodies of the preceding candles (typically measured against the largest body among the previous 3–5 candles).",
    "For a stronger signal, the ideal real body is three to five times larger than the preceding candles' bodies.",
    "A green (bullish) candle signals strong buying pressure; a red (bearish) candle signals strong selling pressure.",
    "Only the real body size matters for classification; wicks are ignored, though small or no wicks are typical in strong momentum moves.",
    "The candle typically appears after consolidation or near key support/resistance levels, and not within an existing strong trend where candles are already large."
  ],
  "trading_implication": "Momentum candles signal strong directional pressure, confirming support/resistance or breakouts. They indicate high-probability entry points for trend continuation or reversal. Traders often enter on the candle close, placing a stop-loss below the recent swing low (bullish) or above the recent high (bearish), and target using a risk/reward ratio. The candle's range may act as support/resistance. Confirmation with volume and price action increases reliability. Lack of momentum candles suggests a weak level.",
  "common_mistakes": [
    "Assuming a large candle is a momentum candle without verifying its real body is at least twice the size of the preceding candles' bodies.",
    "Ignoring market context: accepting any large candle as a momentum candle without considering whether it appears after consolidation or near key levels, or within an already strong trend with similar large candles.",
    "Mistaking slow, grinding price action near a level as momentum.",
    "Comparing only one or two previous candles instead of a sufficient sample of 3–5 to assess the size ratio.",
    "Misclassifying reversal patterns (e.g., hammers, shooting stars) as momentum candles due to small real bodies.",
    "Using the momentum candle as a standalone signal without additional confirmation (e.g., volume, market structure, breakout validation)."
  ],
