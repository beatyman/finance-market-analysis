{
  "card_id": "higher_timeframe_analysis",
  "type": "merged_concept",
  "canonical_term": "Higher Timeframe Analysis",
  "aliases": [
    "daily chart analysis",
    "Daily Chart Analysis",
    "HTF Analysis",
    "htf analysis"
  ],
  "school": "Smart Money Concepts (SMC)",
  "definition": "Higher timeframe analysis examines a longer timeframe chart (e.g., daily) to mark key levels—opposite-colored candles, fair value gaps, multiple rejections, major structure—and assess the empty space before the next key level, in order to understand the bigger picture and avoid trading blindly on lower timeframes.",
  "identification_rules": [
    "Mark opposite-colored candles within impulsive moves as potential support or resistance levels.",
    "Identify fair value gaps (FVGs) where price moved aggressively; these areas often trigger future reactions.",
    "Note levels with multiple rejections; more rejections strengthen the level but do not guarantee it will hold.",
    "Identify major market structure levels that have been rejected multiple times, acted as both support and resistance, and been recently respected.",
    "Determine the empty space between the current price and the next key level; prioritize trading in these empty spaces.",
    "Use the marked key levels to assess risk and potential barriers for lower timeframe entries."
  ],
  "trading_implication": "Trading in empty spaces on higher timeframes provides higher success rates because price manipulations frequently occur near key levels. Higher timeframe analysis aligns lower timeframe entries with the dominant trend and helps avoid fakeouts and traps around major support/resistance zones.",
  "common_mistakes": [
    "Trading blindly on lower timeframe charts without understanding the higher timeframe context.",
    "Entering trades very close to a higher timeframe key level, where manipulation and fakeouts are common.",
    "Ignoring the amount of empty space before the next key level, leading to premature exits or unexpected rejections."
  ],
