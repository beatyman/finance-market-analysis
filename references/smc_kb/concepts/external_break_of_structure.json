{
  "card_id": "external_break_of_structure",
  "type": "merged_concept",
  "canonical_term": "External Break of Structure",
  "aliases": [
    "ebos",
    "eBOS"
  ],
  "school": "ICT / Smart Money Concepts (SMC)",
  "definition": "A break of structure occurring on a higher timeframe chart, where price breaks a swing high in an uptrend or a swing low in a downtrend, confirming the primary trend's continuation.",
  "identification_rules": [
    "Identify the trend on the higher timeframe (uptrend: higher highs and higher lows; downtrend: lower highs and lower lows).",
    "For a bullish external break of structure, price must break above the most recent swing high in an uptrend on the higher timeframe.",
    "For a bearish external break of structure, price must break below the most recent swing low in a downtrend on the higher timeframe.",
    "The break must occur on the higher timeframe line (e.g., daily), not the lower timeframe (e.g., 1-hour)."
  ],
  "trading_implication": "Confirms trend continuation on the primary timeframe, offering a high-probability entry or add-on signal aligned with the overall market structure. Traders can use it to follow the direction of institutional flow.",
  "common_mistakes": [
    "Mistaking an internal break of structure on a lower timeframe for an external break.",
    "Assuming a lower timeframe break changes the higher timeframe trend when it's only a pullback.",
    "Confusing an external break of structure with a change of character, which indicates a potential reversal."
  ],
