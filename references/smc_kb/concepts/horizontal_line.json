{
  "card_id": "horizontal_line",
  "type": "merged_concept",
  "canonical_term": "Horizontal Line",
  "aliases": [],
  "school": "General",
  "definition": "A charting tool used to mark key support and resistance levels by drawing a straight horizontal line at a chosen price level where price has historically reacted.",
  "identification_rules": [
    "Identify a price level where the market has reversed direction at least twice, such as a swing high or low.",
    "Select the Horizontal Line tool and click on the chart at that price level to draw the line.",
    "Multiple touches or reactions confirm the line as a significant support or resistance level."
  ],
  "trading_implication": "The horizontal line highlights potential reversal or breakout zones. A sustained break above resistance can signal a bullish move, while a break below support may indicate bearish momentum. Traders often use these lines to plan entries, exits, and stop-loss placements.",
  "common_mistakes": [
    "Treating support and resistance as exact price points rather than broader zones, leading to false signals when price slightly overshoots or undershoots the drawn line."
  ],
