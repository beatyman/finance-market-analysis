{
  "card_id": "major_change_of_character",
  "type": "merged_concept",
  "canonical_term": "Major Change of Character",
  "aliases": [
    "Major CHoCH",
    "major choch"
  ],
  "school": "Smart Money Concepts (SMC)",
  "definition": "In a bullish trend, a valid reversal signal when price breaks and closes below the last major low that initiated the upward movement. In a bearish trend, when price breaks and closes above the last major high. The close must be with the candle body, not just a wick.",
  "identification_rules": [
    "Determine the prevailing market trend (uptrend or downtrend).",
    "Identify the most recent major swing low in an uptrend or major swing high in a downtrend that originated the valid break of structure.",
    "Wait for price to break that major level with a candle body close beyond it (below the low in bullish, above the high in bearish).",
    "Reject any break where only the wick or shadow penetrates the level but the body closes within the range.",
    "After a valid break, update the major swing high/low to reflect the new structural shift."
  ],
  "trading_implication": "Major change of character signals a potential trend reversal, indicating that the prior trend's momentum has exhausted. It provides a high-probability entry opportunity in the new direction. Traders may use it to confirm a bias shift and plan trades aligned with the emerging trend, often after a liquidity sweep or pullback to a key zone.",
  "common_mistakes": [
    "Mistaking a minor change of character (break of internal structure) for a major change of character, leading to premature reversal trades and stop-loss hunting.",
    "Accepting a wick or shadow penetration beyond the major level as a valid change of character, when the body does not close beyond it.",
    "Entering a reversal trade without waiting for a full candle body close beyond the major structure, resulting in false breakouts."
  ],
