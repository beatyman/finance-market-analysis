{
  "card_id": "short_term_high_low",
  "type": "merged_concept",
  "canonical_term": "Short-Term High/Low",
  "aliases": [
    "STH",
    "STL",
    "短期目标",
    "近期摆动高/低点"
  ],
  "school": "ICT",
  "definition": "A short-term low is a swing low with a higher low on each side; a short-term high is a swing high with a lower high on each side. They are the basic building blocks of market structure, used to construct intermediate and long-term swing points. When a continuation sweep occurs through these levels, it often signals manipulation rather than a true breakout.",
  "identification_rules": [
    "For a short-term low, identify a price low where the immediately preceding and following lows are both higher.",
    "For a short-term high, identify a price high where the immediately preceding and following highs are both lower.",
    "These are identified on the current analysis time frame (e.g., 1-minute or 5-minute chart).",
    "Distinguish from higher time frame targets (HTF target) or liquidity pools (Buyside/Sellside Liquidity).",
    "When price breaks these levels, observe if a continuation pattern forms or if it is merely manipulation."
  ],
  "trading_implication": "A sweep of a short-term high/low followed by a new short-term swing on the opposite side confirms an intermediate-term high/low. In the absence of clean fair value gaps, a short-term high can serve as a precise entry point for a short trade, with a stop placed above the long-term high. When a continuation pattern sweeps a short-term high/low, it often signals manipulation, so wait for additional confirmation before entering.",
  "common_mistakes": [
    "Entering immediately when a continuation sweeps a short-term high/low, ignoring that it may be manipulation.",
    "Confusing short-term highs/lows with more significant liquidity pools (buyside/sellside liquidity), leading to poor risk management.",
    "Failing to check both conditions: sweep of short-term high/low and formation of continuation pattern.",
    "Ignoring potential reverse market structure change (bearish/bullish change in state of delivery) after a sweep."
  ],
  "related_concepts": [],
  "merge_strategy": "llm_synthesis",
  "merge_model": "deepseek/deepseek-chat",
  "merge_notes": "Both cards are from ICT school; no conflict. The first card emphasizes the manipulation aspect when continuation sweeps these levels, while the second provides precise structural definitions. Both are preserved.",
