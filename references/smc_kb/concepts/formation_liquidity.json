{
  "card_id": "formation_liquidity",
  "type": "merged_concept",
  "canonical_term": "Formation Liquidity",
  "aliases": [
    "Nearby Liquidity",
    "nearby liquidity",
    "previous candle lows/highs",
    "Previous Candle Lows/Highs"
  ],
  "school": "ICT",
  "definition": "Previous candle lows or highs on the operating time frame that have not yet been swept, displayed by the fractal model indicator as dotted lines. They represent nearby resting liquidity that price is expected to reach as part of its delivery cycle, used to identify smart money targets.",
  "identification_rules": [
    "Identify prior candle highs or lows on the relevant time frame whose levels have not yet been traded through.",
    "On the fractal model indicator, these untaken levels appear as dotted lines on the chart.",
    "If a prior candle low/high has already been swept, it is no longer formation liquidity; only untaken levels remain marked.",
    "Align the direction of the formation liquidity with the current bias (e.g., bearish closure → look for untaken previous lows below).",
    "Dotted lines extend horizontally across multiple time frames."
  ],
  "trading_implication": "Formation liquidity is used as a draw on liquidity and a target for trades aligned with the higher time frame bias. After a candle 2 closure or change in state of delivery, price is expected to expand toward the nearest untaken previous candle low/high, often in confluence with standard deviation projections and previous day high/low levels. Traders use these dotted lines to set or confirm take-profit targets within the fractal model's delivery cycle.",
  "common_mistakes": [
    "Targeting a prior low/high that has already been swept, instead of the next untaken formation liquidity level.",
    "Ignoring formation liquidity as a target and exiting before price reaches the nearest untaken previous candle extreme.",
    "Neglecting to check each marked low/high for whether it has been swept.",
    "Overlooking time frame differences; formation liquidity markings may differ across time frames."
  ],
  "related_concepts": [
    {
      "term": "Nearby Liquidity"
    },
    {
      "term": "Previous Candle Lows/Highs"
    }
  ],
