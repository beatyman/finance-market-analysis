{
  "card_id": "inverted_fair_value_gap",
  "type": "merged_concept",
  "canonical_term": "Inverted Fair Value Gap",
  "aliases": [
    "FVG Inversion",
    "IFVG",
    "Inversion",
    "Inversion Fair Value Gap",
    "inversion gap",
    "Inversion Gap"
  ],
  "school": "ICT",
  "definition": "A fair value gap that price has fully closed beyond, causing the former gap to reverse polarity and act as support (if a bullish gap is violated) or resistance (if a bearish gap is violated). It signals a potential change in order flow or reversal earlier than a market structure shift, indicating the prior imbalance has been repriced.",
  "identification_rules": [
    "Identify a clear bullish or bearish fair value gap formed during a directional move.",
    "Wait for price to return to the gap and produce a full body close completely beyond the gap (not just a wick or a 50% consequent encroachment).",
    "Once fully closed, treat the prior bullish fair value gap as resistance and the prior bearish fair value gap as support on the subsequent retest.",
    "Look for price to retrace to the inverted gap and show a reaction that respects it as the new support or resistance.",
    "For stronger validation, confirm with a change in state of delivery or displacement on the same or following candle.",
    "Identify a fair value gap that is opposite to the most recent impulsive move (e.g., a bearish FVG during a bullish pullback).",
    "Ensure it aligns with the premium zone when looking for short trades (or discount for longs).",
    "Confirm that market structure has shifted or a change of character has occurred before considering the IFVG as an entry zone.",
    "Wait for price to retest the IFVG and then seek lower timeframe confirmation (e.g., a shift in market structure on a 1-minute chart) before entering."
  ],
  "trading_implication": "Inverted fair value gaps provide early entry signals before a market structure shift, indicating a potential order flow reversal. They offer stronger confirmation than a turtle soup but less than a change in state of delivery. Traders can enter on the retest of the flipped support/resistance, often combined with an order block or displacement for confluence. Entries carry higher risk since the broader trend has not yet confirmed. Use lower timeframe confirmation (e.g., 1-minute MSS) before entering, and place stops beyond the gap, targeting previous structure levels for high risk-to-reward setups.",
  "common_mistakes": [
    "Treating a wick or partial close (e.g., 50% consequent encroachment) as a full gap closure, leading to false inversion signals.",
    "Acting on the inverted fair value gap without additional confluence such as a change in state of delivery, order block, or broader market structure confirmation.",
    "Delaying entry until a full market structure shift occurs, thereby missing the early opportunity provided by the inversion.",
    "Entering on a weak retest that lacks aggressive displacement or a prior liquidity sweep.",
    "Failing to confirm a full-body close beyond the gap and assuming an inversion has occurred prematurely.",
    "Entering at the IFVG without lower timeframe confirmation, leading to guessing between multiple confluences and reduced accuracy.",
    "Confusing IFVG with a regular fair value gap and misidentifying the market direction or context."
  ],
