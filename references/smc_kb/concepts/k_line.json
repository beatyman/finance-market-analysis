{
  "card_id": "k_line",
  "type": "merged_concept",
  "canonical_term": "%K Line",
  "aliases": [
    "fast stochastic line",
    "Fast Stochastic Line",
    "Percentage K Line",
    "percentage k line"
  ],
  "school": "Indicator Based",
  "definition": "The %K line, also called the fast stochastic line, is a component of the Stochastic RSI. It indicates the current RSI value relative to its 14-period range, oscillating between 0 and 100. A reading of 100 means the RSI is at its highest in 14 periods.",
  "identification_rules": [
    "It is the faster moving line, often colored blue, that reacts quickly to price changes.",
    "It reaches 100 when the RSI achieves a new 14-period high and 0 when at a new 14-period low.",
    "It fluctuates between 0 and 100, with extreme levels at 80 (overbought) and 20 (oversold)."
  ],
  "trading_implication": "The %K line is used to gauge momentum shifts and identify overbought or oversold conditions. Crossovers with the slower %D line can generate buy/sell signals: a bullish signal when %K crosses above %D, bearish when crossing below. It works for both reversal and continuation trades.",
  "common_mistakes": [
    "Treating overbought/oversold as above 70/below 30 like the standard RSI, instead of above 80/below 20 for Stochastic RSI.",
    "Assuming that extended stays in overbought/oversold territory automatically signal an immediate reversal."
  ],
