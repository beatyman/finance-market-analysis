{
  "card_id": "candle_close_confirmation",
  "type": "merged_concept",
  "canonical_term": "Candle Close Confirmation",
  "aliases": [],
  "school": "ICT",
  "definition": "The requirement that price must close above or below a key level to confirm a breakout; a wick beyond the level without a close indicates market rejection and disagreement, not a true structural break.",
  "identification_rules": [
    "Wait for the candle to fully close before assessing whether a level has been broken.",
    "A close above a previous swing high confirms bullish continuation; a close below a previous swing low confirms bearish continuation.",
    "If price wicks beyond a level but closes back inside the prior range, it is a rejection, not a break."
  ],
  "trading_implication": "Use candle close confirmation to validate breakouts, avoid false entries from liquidity sweeps, and align with market structure. Closing beyond a high signals buyer control and potential long opportunities; closing below a low signals seller control and short opportunities. Never enter based on wicks alone.",
  "common_mistakes": [
    "Treating a wick that briefly surpasses a high/low as a valid break of structure.",
    "Entering trades based on intra-candle price action without waiting for the close.",
    "Assuming a wick indicates market strength when it actually signals a rejection."
  ],
  "related_concepts": [],
  "illustrated_by_cases": [
