{
  "card_id": "optimal_trading_entry",
  "type": "merged_concept",
  "canonical_term": "Optimal Trading Entry",
  "aliases": [
    "OTE"
  ],
  "school": "Smart Money Concepts (SMC)",
  "definition": "The price area within the discount zone for longs or premium zone for shorts, identified using order blocks or fair value gaps, offering favorable risk-to-reward by entering near a pullback extreme.",
  "identification_rules": [
    "Draw Fibonacci retracement from the start to end of the impulsive move to define premium (above 50%) and discount (below 50%) zones.",
    "For longs, wait for price to pull back into the discount zone; for shorts, wait for price to pull back into the premium zone.",
    "Within the appropriate zone, mark a fair value gap or order block as the optimal entry area.",
    "Ensure the optimal entry area lies inside the discount (buy) or premium (sell) zone.",
    "Seek additional confirmation via a change of character or liquidity sweep on a lower timeframe within the optimal entry area."
  ],
  "trading_implication": "OTE provides a high-probability entry with improved risk-to-reward by entering where price is likely to reverse, minimizing drawdown. It aligns entry with the higher timeframe trend and market structure, allowing traders to capitalize on pullback extremes.",
  "common_mistakes": [
    "Entering before price reaches the discount (for longs) or premium (for shorts), causing premature entries and larger drawdowns.",
    "Failing to wait for confirmation (CHoCH or liquidity sweep) within the OTE, leading to trades against the reversal.",
    "Using OTE without aligning with the higher timeframe trend and market structure.",
    "Buying in the premium zone or selling in the discount zone, resulting in poor risk-to-reward."
  ],
