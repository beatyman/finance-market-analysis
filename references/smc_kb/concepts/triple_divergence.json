{
  "card_id": "triple_divergence",
  "type": "merged_concept",
  "canonical_term": "Triple Divergence",
  "aliases": [],
  "school": "Indicator Based",
  "definition": "A divergence pattern where price and an oscillator form three consecutive regular divergences, strengthening the reversal signal. In a triple regular bullish divergence, price prints three lower lows while the oscillator prints three higher lows, indicating strong momentum exhaustion.",
  "identification_rules": [
    "For triple regular bullish divergence, identify three distinct swing lows in price that are successively lower, while the oscillator (e.g., MACD histogram) prints three successively higher lows.",
    "For triple regular bearish divergence, identify three distinct swing highs in price that are successively higher, while the oscillator prints three successively lower highs.",
    "Ensure the oscillator troughs (bullish) or peaks (bearish) are clearly separated on the histogram; merged or overlapping swings reduce pattern clarity."
  ],
  "trading_implication": "Triple divergence signals a strong impending reversal. Repeated failure of momentum to align with price direction increases reversal probability. Traders use it as a high-confidence entry signal, ideally combining with support/resistance breaks, price action confirmations, or market structure shifts.",
  "common_mistakes": [
    "Assuming any three oscillator movements constitute a triple divergence without verifying that price and oscillator are forming consecutive regular divergences.",
    "Ignoring the need for clear separation between oscillator swings; overlapping mountains weaken the pattern's reliability."
  ],
