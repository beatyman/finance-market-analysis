{
  "card_id": "change_of_character",
  "type": "merged_concept",
  "canonical_term": "Change of Character",
  "aliases": [
    "change of character (choch)",
    "Change of Character (CHoCH)",
    "Change of Character Plus",
    "change of character plus",
    "choch",
    "CHoCH",
    "choch plus",
