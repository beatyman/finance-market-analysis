{
  "card_id": "structural_target",
  "type": "merged_concept",
  "canonical_term": "Structural Target",
  "aliases": [],
  "school": "ICT",
  "definition": "Taking profit at a pre-identified structural level (swing low/high, fair value gap, or consolidation) where price is likely to reverse, rather than using a fixed 1:1 risk-to-reward ratio, aiming for a minimum 2R return.",
  "identification_rules": [
    "Identify a draw on liquidity (previous swing high/low) as the directional target.",
    "Use a fair value gap or previous swing point in the discount/premium zone as the structural target.",
    "Ensure the target provides at least a 2R risk-to-reward multiple from the entry.",
    "Place the target before a point where price would logically reverse (e.g., a protected swing or order block)."
  ],
  "trading_implication": "Setting profit targets at structural levels aligns with institutional order flow, where price seeks liquidity. It improves risk-to-reward beyond fixed 1:1 exits, increasing profitability when combined with a consistent stop placement strategy. Targets are chosen based on logical reversal points rather than arbitrary ratios.",
  "common_mistakes": [
    "Exiting at a fixed 1:1 instead of holding to the structural target, leaving potential R multiples unrealized.",
    "Targeting a level that does not offer at least 2R risk-to-reward.",
    "Ignoring that lower time frame targets may get briefly swept before reversal, requiring a slightly deeper target placement."
  ],
