{
  "card_id": "basic_order_block_entry",
  "type": "merged_concept",
  "canonical_term": "Basic Order Block Entry",
  "aliases": [],
  "school": "ICT",
  "definition": "An ICT trade entry technique using a fresh order block formed by a sharp imbalance with a fair value gap that breaks structure. Entry is placed a spread above the order block, stop below the swing low, first target at 2:1 risk-to-reward, second target the next key level, traded only with trend direction.",
  "identification_rules": [
    "Identify a fresh order block that recently formed with a fair value gap and a break of structure.",
    "Confirm the order block shows obvious inefficiency with a fair value gap between wicks.",
    "Ensure the trade aligns with the dominant trend direction for trend continuation.",
    "Check higher timeframe key levels to gauge room before the next potential reversal zone.",
    "Analyze the left side of the chart to avoid liquidity traps, overlapping order blocks, or gaps that increase risk."
  ],
  "trading_implication": "Provides a high-probability trend-following entry after a retracement to a fresh order block. The trader scales out half at 2:1 risk-to-reward and lets the rest run to the next structural level, with a stop below the swing low. The method enforces disciplined entries aligned with institutional order flow and robust risk management.",
  "common_mistakes": [
    "Entering on an order block without a clear fair value gap or break of structure.",
    "Trading against the prevailing trend, reducing probability.",
    "Ignoring higher timeframe levels that could cause reversals.",
    "Failing to check the left side for liquidity grabs or overlapping order blocks, leading to stop-outs."
  ],
