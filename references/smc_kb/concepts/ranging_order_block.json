{
  "card_id": "ranging_order_block",
  "type": "merged_concept",
  "canonical_term": "Ranging Order Block",
  "aliases": [],
  "school": "ICT",
  "definition": "An order block formed during a consolidation range before a breakout, identified by at least four consecutive candles closing inside the range. Price is expected to reject this zone upon return.",
  "identification_rules": [
    "The market must be in a visible consolidation range (price appears trapped in a box).",
    "At least four consecutive candles must close inside the range to confirm the zone.",
    "The order block zone is the last candlestick (or group of candles) before a drastic breakout from the range.",
    "Price is expected to return and react at this zone after the breakout."
  ],
  "trading_implication": "When price returns to the ranging order block zone, traders anticipate a rejection and continuation in the breakout direction, making it a potential entry point with a stop-loss placed beyond the range. It aligns with the overall market structure for higher-probability trades.",
  "common_mistakes": [
    "Assuming any small consolidation is a ranging order block without requiring the four consecutive candles closing inside the range."
  ],
