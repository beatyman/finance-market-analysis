{
  "card_id": "sideways_market",
  "type": "merged_concept",
  "canonical_term": "Sideways Market",
  "aliases": [
    "Consolidation"
  ],
  "school": "General",
  "definition": "A market state where price fails to establish consecutive higher highs and higher lows (uptrend) or consecutive lower lows and lower highs (downtrend), resulting in non-trending, range-bound movement.",
  "identification_rules": [
    "Verify the absence of consecutive higher highs and higher lows to rule out an uptrend.",
    "Verify the absence of consecutive lower lows and lower highs to rule out a downtrend.",
    "Check for overlapping swings, such as a higher high followed by a lower high, or simultaneous higher highs and lower lows, or consecutive lower highs and higher lows."
  ],
  "trading_implication": "During a sideways market, trending strategies are ineffective. Traders may use range-bound approaches (buying near support, selling near resistance) or wait for a breakout to signal the next trend direction.",
  "common_mistakes": [],
