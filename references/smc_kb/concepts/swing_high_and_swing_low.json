{
  "card_id": "swing_high_and_swing_low",
  "type": "merged_concept",
  "canonical_term": "Swing High and Swing Low",
  "aliases": [
    "Swing High",
    "Swing Low",
    "swing points",
    "turning points",
    "局部高低点",
    "摆动点",
    "摆动高点和摆动低点"
  ],
  "school": "ICT",
  "definition": "A swing high is a three-candle pattern where the middle candle's high exceeds the highs of both adjacent candles; a swing low has the middle candle's low below both adjacent lows. Confirmed only when the third candle closes. These points mark local turning points in price, used to identify market structure, liquidity zones, and Fibonacci anchors.",
  "identification_rules": [
    "Swing high: a candle whose high is higher than the highs of both adjacent candles; swing low: a candle whose low is lower than the lows of both adjacent candles.",
    "Pattern is valid only after the third candle closes; do not mark before confirmation.",
    "Optionally, use a five-candle pattern with the middle candle having the highest high or lowest low among all five for stronger signals.",
    "Breakout validity is judged by close outside the swing point; a touch without close is not a valid break.",
    "Swing points can be identified on any timeframe; higher timeframe swings are more reliable.",
    "Swing highs may have buyside liquidity above; swing lows may have sellside liquidity below.",
    "When comparing related assets, mark swing points on the same date/price level to assess relative strength."
  ],
  "trading_implication": "Swing highs and lows define market structure and key turning points. They serve as reference levels for drawing trendlines, identifying liquidity zones, and spotting equal highs/lows where stop-losses cluster. Valid breaks confirm trend shifts; failed breaks (no close outside) often lead to reversals (Next Candle Model). Use Fibonacci from swing high to swing low to find OTE entry zones (0.62-0.79). Higher timeframe swings guide lower timeframe action.",
  "common_mistakes": [
    "Identifying a swing high or low before the third candle closes, leading to premature trading decisions.",
    "Confusing a touch of a swing point with a valid break; must close outside.",
    "Over-relying on low timeframe swings without higher timeframe context.",
    "Ignoring the five-candle pattern option, which can filter false swings on lower timeframes.",
    "Failing to consider liquidity around swing points (buyside/sellside).",
    "Not comparing swing points across correlated assets for relative strength analysis.",
    "Confusing swing points with order blocks; swing points are for liquidity and structure, not direct support/resistance."
  ],
