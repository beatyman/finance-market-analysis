{
  "card_id": "high_low_probability_order_block",
  "type": "merged_concept",
  "canonical_term": "High/Low Probability Order Block",
  "aliases": [],
  "school": "ICT",
  "definition": "A classification of order blocks based on candle body and wick size. High probability order blocks have large bodies and small wicks, allowing entry at the opening price. Low probability order blocks have small bodies, requiring entry from wick to opening price or mean threshold, used only in trending markets when no better block exists.",
  "identification_rules": [
    "High probability order block: the relevant candle has a large body and small wicks (full-bodied candle).",
    "Low probability order block: the relevant candle has a small body relative to its overall range.",
    "Only consider a low probability order block when it is the sole up-close (bearish) or down-close (bullish) candle within the range during a trend.",
    "For a bearish order block, identify the up-close candle(s) that swept buy-side liquidity before the break of structure down.",
    "For a bullish order block, identify the down-close candle(s) that swept sell-side liquidity before the break of structure up."
  ],
  "trading_implication": "High probability order blocks allow precise entry at the opening price, offering tighter stops and better risk-to-reward. Low probability order blocks require a wider entry zone (wick to open) and are only used when no high probability block formed, ensuring a valid reference point even in imperfect conditions.",
  "common_mistakes": [
    "Selecting a small-bodied candle as the order block when a larger full-bodied candle from the same sweep exists.",
    "Using the opening price entry method on a low probability order block instead of the wick-to-open or mean threshold area."
  ],
