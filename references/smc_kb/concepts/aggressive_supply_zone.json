{
  "card_id": "aggressive_supply_zone",
  "type": "merged_concept",
  "canonical_term": "Aggressive Supply Zone",
  "aliases": [],
  "school": "Smart Money Concepts",
  "definition": "A supply zone created by a strong bearish engulfing candle that signals heavy selling pressure from smart money, often leading to a sharp price decline; price is expected to reject from this zone again, sometimes after a false breakout.",
  "identification_rules": [
    "Identify a large red candle that engulfs the bodies of multiple preceding candles (typically 2–3), indicating a strong supply shift.",
    "Confirm the candle is followed by continued downward momentum (follow-through).",
    "Draw a horizontal zone to the right of the engulfing candle, covering its high and low."
  ],
  "trading_implication": "When price retests the aggressive supply zone, traders anticipate a bearish rejection and potential short entry. A common entry signal is a false breakout (failure test) above the zone followed by a strong bearish move. Stop loss may be placed above the zone's high.",
  "common_mistakes": [
    "Entering a short trade immediately upon price touching the zone without waiting for confirmation like a false breakout or reversal pattern.",
    "Misidentifying a single large red candle without engulfing behavior or follow-through as an aggressive supply zone."
  ],
