{
  "card_id": "liquidity_zones",
  "type": "merged_concept",
  "canonical_term": "Liquidity Zones",
  "aliases": [],
  "school": "ICT / Smart Money Concepts (SMC)",
  "definition": "Areas with a high concentration of orders (e.g., stop-loss or buy orders) waiting to be triggered, often located around clear support/resistance levels. Smart money targets these zones to create liquidity for their own positions by triggering these orders and then reversing the price.",
  "identification_rules": [
    "Identify clear, visible support or resistance levels on the chart.",
    "Anticipate liquidity zones just beyond these levels where stop-loss orders are likely clustered (e.g., below support, above resistance).",
    "Look for a price move that briefly breaks the level (a wick) and quickly reverses, indicating a liquidity grab.",
    "Confirm the grab with a candlestick pattern like a hammer that wicks into the zone and closes back above/below the level."
  ],
  "trading_implication": "Traders watch liquidity zones for potential liquidity grabs, which often lead to sharp reversals. Entry is taken after the grab candle closes, with a stop-loss placed beyond the grab candle's extreme. Targets are set using risk-to-reward ratios, making it a strategy with manageable risk and clear invalidation.",
  "common_mistakes": [
    "Confusing a liquidity grab with a true change of character; a grab only briefly breaks and reverses, while a change of character requires a confirmed close beyond the level.",
    "Entering a trade before the grab candle closes and price confirms the reversal."
  ],
