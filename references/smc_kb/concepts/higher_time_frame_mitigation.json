{
  "card_id": "higher_time_frame_mitigation",
  "type": "merged_concept",
  "canonical_term": "Higher Time Frame Mitigation",
  "aliases": [
    "htf mitigation",
    "HTF Mitigation"
  ],
  "school": "ICT",
  "definition": "A condition for a valid Change of Character: price must reverse from a higher time frame supply or demand zone before breaking structure. Without this origin, any apparent reversal is likely false.",
  "identification_rules": [
    "Locate an unmitigated supply or demand zone on a higher time frame chart.",
    "Confirm price has touched and reversed from that higher time frame zone.",
    "Ensure the Change of Character only occurs after this interaction with the HTF zone."
  ],
  "trading_implication": "Higher Time Frame Mitigation validates a potential reversal. Only consider a Change of Character if it originates from an HTF zone, as this filters out false signals and indicates institutional order flow, improving trade probability.",
  "common_mistakes": [
    "Assuming a Change of Character is valid without checking for origin from a higher time frame zone.",
    "Entering long on a demand zone formed after a false Change of Character that only swept liquidity from a nearby supply zone."
  ],
  "related_concepts": [],
