{
  "card_id": "currency_futures_pairing_strategy",
  "type": "merged_concept",
  "canonical_term": "Currency Futures Pairing Strategy",
  "aliases": [
    "dxy pairing strategy",
    "DXY Pairing Strategy",
    "Strongest vs Weakest Currency Pairing",
    "strongest vs weakest currency pairing"
  ],
  "school": "Order Flow",
  "definition": "A forex/currency-futures selection framework that pairs the strongest currency with the weakest to maximize trend expansion. When DXY trends, pair it with the opposite-direction extreme; when DXY consolidates, pair two non-dollar currencies with opposing directional bias to isolate the highest-probability expansion pair.",
  "identification_rules": [
    "Assess DXY first: classify it as bullish trending, bearish trending, or consolidating.",
    "If DXY is bullish trending, identify the most bearish foreign currency and pair them (e.g., DXY + weak EUR → trade EUR/USD short).",
    "If DXY is bearish trending, identify the strongest bullish foreign currency and pair them (e.g., DXY + strong JPY → trade USD/JPY short).",
    "If DXY is consolidating, ignore the dollar and pair the strongest non-dollar currency with the weakest non-dollar currency (e.g., bullish EUR vs. bearish JPY → EUR/JPY long).",
    "If all currencies trend the same direction with no opposing extreme, pair the trending currency with a consolidating one (acceptable but weaker expansion).",
    "For futures-only traders: when DXY trends, simply trade the single opposite-direction currency future that is strongest/weakest; when DXY consolidates, long the strongest and short the weakest as separate trades."
  ],
  "trading_implication": "Used to filter the forex/currency-futures universe down to the single highest-probability pair for expansion. Pairing strong vs. weak produces the cleanest directional trends; pairing trend vs. consolidation produces weaker trends. The framework determines which symbol to apply entry models on, ensuring the chosen instrument has maximum directional fuel from both legs of the pair.",
  "common_mistakes": [
    "Pairing two trending currencies of the same strength, which leaves a consolidation rather than a trend.",
    "Pairing a strong or weak currency with a consolidating one when a true opposite-extreme is available — produces a weaker trend than the optimal pairing.",
    "Continuing to pair with the dollar when DXY itself is consolidating instead of switching to non-dollar cross pairs."
  ],
