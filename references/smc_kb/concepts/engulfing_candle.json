{
  "card_id": "engulfing_candle",
  "type": "merged_concept",
  "canonical_term": "Engulfing Candle",
  "aliases": [
    "Engulfing Candle Breakout",
    "engulfing candle breakout",
    "包含形态",
    "吞没形态"
  ],
  "school": "Price Action",
  "definition": "A candlestick pattern where the current candle's body completely engulfs the body and wicks of the preceding candle(s), signaling strong momentum shift and breakout of a key level. Used to assess trend continuation strength and directional momentum in relative strength analysis.",
  "identification_rules": [
    "The current candle's open and close range must fully contain the previous candle's open and close range (body engulfing).",
    "The engulfing candle must fully cover the body and wicks of one or more prior reaction candles.",
    "It must break out of an unmitigated higher-timeframe supply or demand zone (point of interest).",
    "It forms after an initial candle enters the zone and a subsequent reaction candle shows rejection from the zone.",
    "Valid primarily on higher time frames (30-minute, 1-hour, 2-hour, 4-hour) for clearer signals.",
    "The pattern requires a breakout of the zone; the engulfing candle closes beyond the zone's boundary.",
    "Can be observed on multiple timeframes to confirm trend direction; requires low timeframe check for true reversal signal."
  ],
  "trading_implication": "Confirms a breakout from a key supply/demand zone, providing a safe, confirmatory entry. In relative strength analysis, a bullish engulfing in EURGBP indicates GBP weakness vs EUR, confirming which pair to short in USD strength. Enter on engulfing candle close, stop above recent swing high (short) or below swing low (long), target nearby fair value gaps or liquidity pools. Verify on low timeframe to avoid false signals.",
  "common_mistakes": [
    "Judging reversal solely on engulfing pattern without low timeframe confirmation of true reversal.",
    "Ignoring relative strength analysis, trading correct idea on wrong asset, missing expansion.",
    "Taking signals at mitigated zones instead of waiting for unmitigated points of interest.",
    "Applying the pattern on lower time frames where multiple false engulfing candles occur during consolidation.",
    "Entering before the engulfing candle closes, risking a failed breakout.",
    "Ignoring the need for a clear reaction candle that shows initial rejection from the zone."
  ],
  "related_concepts": [],
  "merge_strategy": "llm_synthesis",
