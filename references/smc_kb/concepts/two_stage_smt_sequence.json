{
  "card_id": "two_stage_smt_sequence",
  "type": "merged_concept",
  "canonical_term": "Two-Stage SMT Sequence",
  "aliases": [
    "Two-Stage PSP",
    "two-stage psp",
    "Two-Stage SMT"
  ],
  "school": "ICT",
  "definition": "A reversal confirmation pattern where a first-stage SMT divergence (at a key level or between candles 1 and 2) is immediately followed by a second-stage SMT divergence (between candles 2 and 3, or via a precision swing point). Considered the highest-probability reversal signature.",
  "identification_rules": [
    "Identify a first-stage SMT: a divergence between correlated assets occurring either at a key level (fair value gap, range high/low) or as a failure swing between candle 1 and candle 2.",
    "Confirm a second-stage SMT immediately following the first: either an SMT divergence between candle 2 and candle 3 (cracking correlation), or a precision swing point (PSP) where the two correlated candles close in opposite directions.",
    "Both stages must occur sequentially without an intervening invalidation, and must be paired with a key level (fair value gap, internal/external range liquidity, or swing high/low).",
    "The highest-probability variant requires a first-stage SMT at a key level, followed by a PSP, then a cracking-correlation SMT between swing points (two-stage PSP plus key-level SMT)."
  ],
  "trading_implication": "Used to confirm reversals at key levels before taking a candle 3 continuation trade toward the opposing side of the range. After both SMT stages print, the trader enters in the direction of the reversal targeting external range liquidity. Pairing the sequence with universal models (IRL-to-ERL, ERL-to-IRL, fair value gap reactions) filters lower-probability setups and provides defined entries with clear invalidation at the swing point that produced the divergences.",
  "common_mistakes": [
    "Treating a single SMT divergence as a reversal confirmation without waiting for the second-stage SMT or PSP.",
    "Acting on a key-level reaction that lacks SMT at the level without confirming via a subsequent swing-point SMT or PSP.",
    "Confusing a continuation PSP (which forms during expansion away from a reversal) with a reversal two-stage PSP."
  ],
