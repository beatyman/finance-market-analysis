{
  "card_id": "classic_expansion_week",
  "type": "merged_concept",
  "canonical_term": "Classic Expansion Week",
  "aliases": [
    "Classic Expansion",
    "classic expansion"
  ],
  "school": "ICT",
  "definition": "A weekly profile where the high (bearish) or low (bullish) of the week forms on Monday or Tuesday via a candle 2 closure paired with an hourly change in state of delivery, followed by two to three days of directional expansion into a higher time frame key level, with Friday capping the range.",
  "identification_rules": [
    "Establish a weekly directional bias, typically after a weekly reversal candle or anticipated expansion in one direction.",
    "Wait for Monday or Tuesday to form the weekly high (bearish bias) or weekly low (bullish bias); do not predict which day in advance.",
    "Confirm the weekly extreme with a candle 2 closure on the daily time frame that sweeps the prior day and closes back inside its range.",
    "Drop to the hourly time frame inside the candle 2 wick to confirm a change in state of delivery (close through the opposing candle series).",
    "Anticipate two to three days of expansion (Tuesday–Thursday or Wednesday–Friday) toward a higher time frame key level or average weekly range.",
    "Friday caps the weekly range with a retracement once the HTF target is hit; do not seek continuation entries after targets are reached."
  ],
  "trading_implication": "Used to align weekly bias with daily entries by pairing the candle 2 closure that forms the weekly high/low with the fractal model: trade candle 3 (Wednesday) and candle 4 (Thursday) continuations in the direction of the weekly expansion. Targets are predefined higher time frame liquidity levels (e.g. equal highs/lows, swing points). Friday is avoided for continuation entries once targets are met, and the late-week retracement aligns with the TGIF profile.",
  "common_mistakes": [
    "Trying to predict which specific day (Monday vs Tuesday) will form the weekly high/low rather than letting it form and reacting.",
    "Taking the candle 2 closure without verifying an hourly change in state of delivery inside the sweep wick.",
    "Looking for continuation trades on Friday after higher time frame targets have already been hit."
  ],
