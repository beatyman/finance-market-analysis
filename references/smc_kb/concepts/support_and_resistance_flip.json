{
  "card_id": "support_and_resistance_flip",
  "type": "merged_concept",
  "canonical_term": "Support and Resistance Flip",
  "aliases": [],
  "school": "Price Action",
  "definition": "When a support level is broken, it can later act as resistance; conversely, a broken resistance can later act as support. This occurs because traders remember the level and have orders there, causing selling/buying pressure on retests.",
  "identification_rules": [
    "Confirm a well-established support or resistance level through multiple touches.",
    "Wait for a decisive break (close below support or above resistance).",
    "Look for price to retrace back to the broken level.",
    "Observe price reversing from that level, confirming the flip."
  ],
  "trading_implication": "In an uptrend, target previous resistance turning into support after a breakout for buy entries. In a downtrend, target previous support turning into resistance after a breakdown for sell entries. Combine with confirmation signals (indicators, candlestick patterns) to avoid false flips.",
  "common_mistakes": [
    "Entering a trade on a flip without confirmation signals, leading to potential losses when the flip fails.",
    "Assuming every broken level will flip; price may not retest or may break through the flipped level without reversal."
  ],
  "related_concepts": [],
