{
  "card_id": "equal_highs_equal_lows",
  "type": "merged_concept",
  "canonical_term": "Equal Highs / Equal Lows",
  "aliases": [
    "Relatively Equal Highs",
    "relatively equal lows",
    "Relatively Equal Lows",
    "相同高点/相同低点",
    "等高点/等低点"
  ],
  "school": "ICT",
  "definition": "Equal highs are two or more swing highs at similar price levels forming a buy-side liquidity cluster; equal lows are two or more swing lows forming a sell-side liquidity cluster. Price tends to sweep these levels to trigger stop orders, often aligning with standard deviation projections.",
  "identification_rules": [
    "Identify two or more swing highs (equal highs) or swing lows (equal lows) at approximately the same price level.",
    "The swing points must be separated by time, forming a visible horizontal cluster.",
    "Confirm the cluster represents a concentration of resting stop orders (buy stops above equal highs, sell stops below equal lows).",
    "These same highs/lows often appear across different timeframes or after different manipulation legs.",
    "Can be validated via standard deviation projection: equal highs/lows often coincide with the 2-2.5 or 4 standard deviation level.",
    "Equal lows can serve as 'low hanging fruit', indicating the market may easily reach that area."
  ],
  "trading_implication": "Equal highs/lows act as draw-on-liquidity targets. Price is expected to sweep these levels to trigger stop orders, providing liquidity for smart money to reverse or continue. They serve as points of interest for entries and profit targets, often paired with standard deviation projections and order blocks for entry and stop placement.",
  "common_mistakes": [
    "Mistaking isolated single highs/lows for equal highs/lows; requires multiple touches of the same level.",
    "Failing to validate equal highs/lows with standard deviation projections, reducing confluence."
  ],
  "related_concepts": [],
  "merge_strategy": "llm_synthesis",
