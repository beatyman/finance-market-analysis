{
  "card_id": "free_bar",
  "type": "merged_concept",
  "canonical_term": "Free Bar",
  "aliases": [],
  "school": "Indicator Based",
  "definition": "A candlestick whose entire high-to-low range, including wicks, lies completely outside the Bollinger Bands, indicating unusually high volatility and signaling a potential price reversal. It is an early warning sign, not a standalone trade signal.",
  "identification_rules": [
    "Plot Bollinger Bands on the chart with standard settings (e.g., 20-period, 2 standard deviations).",
    "Identify any candlestick whose entire range, including high, low, and wicks, is completely outside the bands (above the upper band or below the lower band) with no part touching or crossing the bands."
  ],
  "trading_implication": "A free bar is an early volatility-based reversal signal, not a standalone entry. It suggests potential reversal: above the upper band in an uptrend implies bearish reversal; below the lower band in a downtrend implies bullish reversal. Traders should confirm with price action patterns (e.g., candlestick reversals) and market structure shifts (e.g., break of structure) before entering. Stop-loss is often placed beyond the bar’s extreme (low for longs, high for shorts).",
  "common_mistakes": [
    "Treating a free bar as a standalone reversal signal and entering a trade without confirmation from price action or market structure.",
    "Assuming every free bar will result in a reversal; it only indicates potential, not certainty.",
    "Using excessively tight Bollinger Band settings (short length, low standard deviation) that generate too many free bars, reducing reliability."
  ],
