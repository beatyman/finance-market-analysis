{
  "card_id": "higher_timeframe_key_levels",
  "type": "merged_concept",
  "canonical_term": "Higher Timeframe Key Levels",
  "aliases": [
    "HTF Key Levels",
    "htf key levels",
    "key higher timeframe levels",
    "Key Higher Timeframe Levels"
  ],
  "school": "ICT",
  "definition": "Critical support and resistance zones on higher time frames (e.g., 4H, daily) that provide directional bias and can signal a major trend change in lower time frames when price reacts or breaks them.",
  "identification_rules": [
    "Zoom out to a higher time frame than your analysis chart (e.g., from 15min to 1H).",
    "Identify the directional bias by observing higher highs/lows for an uptrend or lower highs/lows for a downtrend.",
    "Mark key swing highs and lows where price has strongly reversed, forming demand or supply zones.",
    "Note levels where price has recently broken structure (BOS) or shown a change of character (CHoCH)."
  ],
  "trading_implication": "Align your lower time frame trades with the higher time frame bias. Wait for price to reach these key levels for potential entries or exits. A rejection confirms the trend continuation; a break and close beyond may indicate a reversal, requiring a shift in directional bias.",
  "common_mistakes": [
    "Placing trades against the higher time frame bias, such as selling at a supply zone when the higher time frame shows an overall uptrend.",
    "Ignoring small reactions at higher time frame levels that can signal an early trend change.",
    "Failing to wait for a confirmed break of the key level before switching bias."
  ],
