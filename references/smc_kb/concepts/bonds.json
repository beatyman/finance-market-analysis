{
  "card_id": "bonds",
  "type": "merged_concept",
  "canonical_term": "Bonds",
  "aliases": [],
  "school": "General",
  "definition": "A type of investment representing a loan to a government or company, paying interest over time. Bonds offer safety and predictable income, making them suitable for portfolio stability, but they typically have lower returns and limited accessibility compared to other assets.",
  "identification_rules": [
    "The investment represents a loan that provides interest payments over time.",
    "The issuer is a government or corporation, considered safe, especially in stable economies like the U.S.",
    "It offers predictable income, contributing to portfolio stability.",
    "Returns are relatively lower than stocks or cryptocurrencies.",
    "Access for retail traders may be limited compared to more commonly traded assets."
  ],
  "trading_implication": "Bonds are used for safety and stability in a portfolio, providing predictable income. They are best for conservative investors prioritizing capital preservation. Trading bonds suits long-term wealth preservation rather than short-term speculation and can serve as a hedge during volatile markets.",
  "common_mistakes": [
    "Expecting high returns comparable to stocks or cryptocurrencies.",
    "Assuming unhindered access to bond markets for all traders."
  ],
