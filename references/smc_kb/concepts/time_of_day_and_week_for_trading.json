{
  "card_id": "time_of_day_and_week_for_trading",
  "type": "merged_concept",
  "canonical_term": "Time of Day and Week for Trading",
  "aliases": [],
  "school": "Smart Money Concepts (SMC)",
  "definition": "The practice of considering timing of trades based on the day and session to avoid low-liquidity periods. Trading is discouraged during the final hour of the day, especially Fridays, the Asian session, and late hours such as 12 p.m. or 5 a.m., when momentum is low, increasing the risk of failed setups.",
  "identification_rules": [
    "Avoid trading during the final hour of the trading day, particularly on Fridays.",
    "Avoid trading during the Asian session when liquidity tends to dry up.",
    "Avoid trading during late hours such as around 12 p.m. or 5 a.m. when momentum is lacking.",
    "Assess whether the current time falls within a period of low liquidity and momentum before entering a trade."
  ],
  "trading_implication": "Used as a confluence filter to avoid entering trades during periods of low probability. By trading only when the market is active, traders increase the likelihood that price will move as anticipated, reach targets, and not be derailed by lack of momentum or wide spreads.",
  "common_mistakes": [
    "Trading a technically perfect setup without checking if the time of day or week is favorable, leading to failures due to low liquidity.",
    "Entering trades during the last hour of Friday or during Asian/late sessions, ignoring widened spreads and reduced momentum."
  ],
