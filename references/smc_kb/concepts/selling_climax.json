{
  "card_id": "selling_climax",
  "type": "merged_concept",
  "canonical_term": "Selling Climax",
  "aliases": [
    "SC",
    "sc"
  ],
  "school": "Wyckoff",
  "definition": "A sharp, panic-driven downward price move with increased volume, absorbed by smart money, marking the approximate low of an accumulation range.",
  "identification_rules": [
    "The price decline is significantly sharper and faster than the preceding downtrend.",
    "Volume increases dramatically during the move, indicating panic selling.",
    "The low of the selling climax is often near the eventual low of the accumulation trading range.",
    "Following the climax, price typically stages an automatic rally (AR)."
  ],
  "trading_implication": "Signals potential end of the downtrend and start of accumulation. The selling climax low often serves as a key support level for the range. Traders watch for subsequent secondary tests and springs to confirm accumulation and identify entry points.",
  "common_mistakes": [
    "Confusing the selling climax with the preliminary support (PS), which occurs earlier and lacks the extreme panic and sharpness."
  ],
