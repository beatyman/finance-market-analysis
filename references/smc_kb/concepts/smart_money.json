{
  "card_id": "smart_money",
  "type": "merged_concept",
  "canonical_term": "Smart Money",
  "aliases": [
    "big players",
    "institutional money",
    "Institutional Money",
    "institutional traders",
    "Institutional Traders",
    "large players",
    "Large Players"
  ],
  "school": "SMC",
  "definition": "Institutional traders (banks, hedge funds) with large capital who manipulate price to engineer liquidity, creating artificial patterns to trigger retail stop losses and entries. Their directional intent is revealed through market structure (higher highs/lows or lower highs/lows) after a liquidity sweep or grab.",
  "identification_rules": [
    "Establish market structure directional bias (HH/HL for bullish, LH/LL for bearish) as smart money's footprint.",
    "Identify obvious retail liquidity pools: trend lines, equal highs/lows, support/resistance.",
    "Watch for a sweep of a liquidity pool opposite the bias (manipulation), followed by a strong move in the bias direction (initiation).",
    "After initiation, look for a pullback to an order block or fair value gap (mitigation) as a probable smart money entry zone.",
    "Confirm a liquidity sweep—price moves beyond these levels to trigger stops before reversing.",
    "Look for a clear market structure with a break of structure, then a retracement forming equal highs/lows.",
    "Wait for price to fill an imbalance (e.g., fair value gap) after the sweep and reach a demand/supply zone.",
    "A liquidity grab occurs when price breaks a defined support/resistance with a single candlestick exhibiting a long wick, then immediately reverses back inside the prior range, forming a false breakout.",
    "A liquidity sweep involves a multi-candle push through a liquidity zone before reversing gradually, indicating position accumulation.",
    "Reversal candles often display long wicks and small bodies (e.g., hammer, shooting star) after the grab/sweep."
  ],
  "trading_implication": "Align with smart money by entering on the reversal after a confirmed liquidity grab/sweep (e.g., on candle close), placing stop-losses beyond the wick/swept level, and targeting the next structural zone with a favorable risk-to-reward ratio. Avoid entering before the sweep to prevent being trapped.",
  "common_mistakes": [
    "Ignoring market structure context and trading solely based on visible liquidity levels, entering against the true smart money direction.",
    "Assuming price must immediately move to a liquidity pool without waiting for the manipulation-initiation sequence, leading to premature stops.",
    "Entering a trade before a liquidity sweep, risking the stop-loss being taken by smart money.",
    "Treating a zone as valid without prior liquidity clearance.",
    "Believing a breakout of a trendline or equal high/low is real when smart money is creating a trap to collect liquidity.",
    "Entering prematurely during a sweep, getting trapped by the second leg of the push before the reversal.",
    "Misinterpreting a liquidity grab or sweep as a genuine breakout, trading in the direction of the initial move without awaiting reversal confirmation.",
    "Confusing a liquidity grab with a Change of Character (CHoCH) by not waiting for the candle to close beyond the structure level."
  ],
