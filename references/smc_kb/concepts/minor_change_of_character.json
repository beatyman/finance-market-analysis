{
  "card_id": "minor_change_of_character",
  "type": "merged_concept",
  "canonical_term": "Minor Change of Character",
  "aliases": [],
  "school": "Smart Money Concepts (SMC)",
  "definition": "A break of an internal swing low (in an uptrend) or internal swing high (in a downtrend) that does not confirm a market structure shift; often a retracement trap for novice traders.",
  "identification_rules": [
    "Identify the dominant market trend (bullish or bearish) using valid break of structure points.",
    "Mark the last major swing low (in bullish) or major swing high (in bearish) that originated the current trend BOS.",
    "Any swing low formed between the major low and the most recent major high (in bullish) is an internal low; breaking below it is a minor change of character.",
    "In a bearish trend, breaking above any internal swing high formed between the major high and most recent major low is a minor change of character.",
    "The break may occur with a wick or body; no candle body close beyond the level is required for a minor change of character."
  ],
  "trading_implication": "A minor change of character does not signal a trend reversal. It indicates a retracement within the existing trend. Novice traders often misinterpret it as a reversal and enter counter-trend trades, leading to losses when price resumes the primary direction. Traders should wait for a break and body close beyond the major structure (valid change of character) before considering a market structure shift.",
  "common_mistakes": [
    "Entering a counter-trend trade assuming the minor change of character is a reversal signal.",
    "Placing a stop-loss just above the internal high in a bullish trend, getting stopped out when price continues upward.",
    "Not waiting for the price to break and close beyond the major low/high with a candle body before confirming a market structure shift."
  ],
