{
  "card_id": "smart_money_manipulation",
  "type": "merged_concept",
  "canonical_term": "Smart Money Manipulation",
  "aliases": [],
  "school": "Smart Money Concepts (SMC)",
  "definition": "The practice by institutional traders to push price beyond key levels (support/resistance, swing highs/lows) triggering retail stop-losses and pending orders, creating artificial buying/selling pressure. This provides counterparty liquidity for large orders, after which price resumes the original trend direction.",
  "identification_rules": [
    "Identify concentration of stop-loss orders at equal highs/lows or swing highs/lows acting as liquidity pools.",
    "Price breaks above resistance/swing high (buyside) or below support/swing low (sellside) on lower timeframes.",
    "A sharp reversal follows the break, often leaving a Fair Value Gap (inefficiency) at the breakout point.",
    "Confirmation occurs when the reversal breaks a nearby structure (e.g., swing point) signaling a BOS in the opposite direction."
  ],
  "trading_implication": "Recognize breakout traps: do not trade the initial break; instead, wait for the reversal and confirmation (BOS). Enter in the direction of the reversal, targeting the opposite liquidity or trend continuation. This strategy aligns with institutional order flow and offers high-probability setups with tight stops and favorable risk-to-reward.",
  "common_mistakes": [
    "Mistaking the liquidity sweep for a genuine breakout and entering in the breakout direction, only to be trapped when price reverses."
  ],
