{
  "card_id": "order_book",
  "type": "merged_concept",
  "canonical_term": "Order Book",
  "aliases": [],
  "school": "General",
  "definition": "A real-time record of all pending buy (bid) and sell (ask) orders at various price levels. It shows passive limit/stop orders waiting to be triggered versus aggressive market orders that immediately consume liquidity, moving price as imbalances between supply and demand are resolved.",
  "identification_rules": [
    "The order book displays real-time bid (buy) and ask (sell) volumes at each price level, with the spread between the highest bid and lowest ask.",
    "Aggressive market orders remove liquidity from passive limit orders; when aggressive volume exceeds available passive orders at a price, price moves to the next level with sufficient volume.",
    "A candlestick's high, low, open, and close reflect the outcome of order book auctions: open is the first fill, high/low are extremes reached due to order imbalances, close is the final agreed price."
  ],
  "trading_implication": "Understanding order book dynamics allows traders to interpret candlestick formations as real auction processes, distinguishing between genuine breakouts and failed attempts (rejections). This helps gauge the balance of power between buyers and sellers, confirming trend continuation or reversal, and avoiding traps like false breakouts where price fails to close beyond a key level.",
  "common_mistakes": [
    "Mistaking a candle's wick that briefly breaches a level for a valid breakout, ignoring the close which shows the auction's true agreement.",
    "Assuming a long upper wick is always bullish manipulation rather than a sign of seller absorption."
  ],
