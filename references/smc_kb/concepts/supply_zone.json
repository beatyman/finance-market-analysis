{
  "card_id": "supply_zone",
  "type": "merged_concept",
  "canonical_term": "Supply Zone",
  "aliases": [
    "supply area",
    "Supply Area"
  ],
  "school": "Smart Money Concepts (SMC)",
  "definition": "A resistance zone formed by aggressive institutional selling, marked at the origin of a sharp bearish impulse that breaks structure and leaves a fair value gap. It represents unfilled sell orders and remains valid until retested. Identified by a bearish momentum candle engulfing several prior candles, indicating potential future resistance.",
  "identification_rules": [
    "Identify a bearish break of structure (BOS) to the downside marked by an impulsive move that leaves a fair value gap (FVG) or imbalance.",
    "Mark the supply zone from the candle that initiated the move: the last bearish candle or the first bearish candle, covering its open, close, and wicks.",
    "Ensure the zone is unmitigated—price has not yet returned to fill the gap or retest the order block.",
    "Confirm the zone aligns with a higher timeframe bearish bias, including a market structure shift (e.g., break below a demand zone) to validate seller control.",
    "Look for nearby buy-side liquidity (equal highs, trendline, stop clusters) above the zone; a liquidity sweep before reversal strengthens the setup.",
    "Wait for price to retrace into the zone and show rejection signals on lower timeframes, such as a bearish engulfing candle or change of character, before considering entry.",
    "Assess zone reliability by the distance of the impulsive push (larger distance suggests stronger zone) and its alignment with structural levels like previous swing highs or broken supports.",
    "Recognize that multiple supply zones may exist; prioritize those with a distinct fair value gap and significant structural break.",
    "Identify a strong bearish momentum candle that engulfs at least the four previous candles.",
    "Draw a horizontal zone from the highest to the lowest point of the engulfed candles and extend it to the right.",
    "Adjust the zone if new price action modifies the structural high or low of the area."
  ],
  "trading_implication": "Supply zones serve as high-probability resistance areas for short trades in a downtrend. After a liquidity sweep above the zone and confirmation of rejection (e.g., engulfing candle, lower timeframe change of character), traders enter sell orders with a stop-loss above the zone or recent swing high. Profit targets are set at nearby liquidity levels or fair value gaps, favoring a risk-to-reward ratio of at least 2:1. The setup is strongest when higher and entry timeframes are aligned bearish.",
  "common_mistakes": [
    "Trading a supply zone that has already been mitigated, as it may no longer hold as resistance.",
    "Entering a supply zone without confirming a liquidity sweep above it, risking the zone being consumed as liquidity.",
    "Mistaking a temporary break above a supply zone as a reversal rather than a possible liquidity sweep.",
    "Ignoring higher timeframe alignment, which may override the supply zone if bullish momentum dominates.",
    "Expecting a precise reversal at the first marked zone or a strict three-candle pattern instead of focusing on broader rejection signals.",
    "Entering prematurely without lower timeframe confirmation of rejection, leading to false signals.",
    "Placing full position size on a single supply zone instead of scaling in, leading to poor risk management.",
    "Marking the supply zone too narrowly (e.g., only the wick) or excessively wide, causing premature stops or poor risk-reward.",
    "Treating every strong bearish move as a supply zone without confirming an accompanying fair value gap and break of structure.",
    "Mistaking an inducement area (minor liquidity zone) for a valid supply zone, leading to premature entries.",
    "Failing to adjust the supply zone as new price bars provide updated structural information.",
    "Confusing minor pullbacks with a supply shift; only strong engulfing moves indicate a valid zone."
  ],
