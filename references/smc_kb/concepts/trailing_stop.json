{
  "card_id": "trailing_stop",
  "type": "merged_concept",
  "canonical_term": "Trailing Stop",
  "aliases": [
    "Moving Stop Loss",
    "Trail Stop",
    "trailing stop loss"
  ],
  "school": "Risk Management",
  "definition": "A stop-loss adjustment technique where the stop is moved in the direction of a winning trade as new market structure levels form, locking in profits while allowing the trade to continue running. Typically initiated after partial position closure, the stop is repositioned at each market structure shift (e.g., swing high/low or order block) to protect profits and track price.",
  "identification_rules": [
    "Initial stop set at key candle high/low or short-term structure at entry.",
    "Stop moved only after a Market Structure Shift (MSS) occurs.",
    "Each time price breaks a swing low (short trade) or swing high (long trade), reposition stop above the previous swing high or below the previous swing low.",
    "Stop progressively advances in the direction of the trade, forming a stepped trajectory.",
    "For short trades, each time price breaks below a swing low, reposition stop above the previous swing high."
  ],
  "trading_implication": "Trailing stops secure accumulated profits and protect against a winning trade turning into a loser, enabling traders to hold positions through extended trends without mentally managing the exit. Traders initiate trailing after partial position closure, repositioning the stop at each structure break to prevent premature exit while allowing trend continuation. Suitable for trends with displacement and multiple structure breaks; can be tightened by switching to a lower timeframe.",
  "common_mistakes": [
    "Moving stop before market structure is broken, causing premature exit on false breakouts.",
    "Ignoring higher timeframe structure when trailing on lower timeframe, leading to being stopped out by a retracement.",
    "Starting to trail without having taken partial profits, increasing risk of being stopped out at breakeven or loss."
  ],
  "related_concepts": [],
  "merge_strategy": "llm_synthesis",
  "merge_model": "deepseek/deepseek-chat",
  "merge_notes": "Both cards agree on school (Risk Management). Definitions are complementary: ICT card adds detail on partial closure and timeframe switching; SMC card provides concise English. Identification rules combined; no conflicts.",
