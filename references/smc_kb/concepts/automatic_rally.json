{
  "card_id": "automatic_rally",
  "type": "merged_concept",
  "canonical_term": "Automatic Rally",
  "aliases": [
    "ar",
    "AR"
  ],
  "school": "Wyckoff",
  "definition": "A rapid price bounce following a selling climax (panic selling), caused by an oversold condition where heavy selling is absorbed by institutional buyers, leading to an almost automatic upward reaction.",
  "identification_rules": [
    "Occurs immediately after a sharp, high-volume selling climax (panic sell-off).",
    "Characterized by a swift, sharp upward price movement, often with large candles.",
    "Marks the first significant rally after a prolonged downtrend, often forming the upper boundary of an accumulation range."
  ],
  "trading_implication": "The automatic rally indicates that institutional buyers are absorbing selling pressure, confirming the selling climax. It helps define the upper resistance of a potential trading range. Traders should not chase it long immediately but use it to identify the range for future Wyckoff accumulation setups like the secondary test or spring.",
  "common_mistakes": [
    "Mistaking the automatic rally for the start of a new uptrend and entering long too early.",
    "Failing to wait for a secondary test to confirm accumulation before trading.",
    "Ignoring that the automatic rally often reverses after forming the range's upper boundary."
  ],
