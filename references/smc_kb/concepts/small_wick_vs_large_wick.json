{
  "card_id": "small_wick_vs_large_wick",
  "type": "merged_concept",
  "canonical_term": "Small Wick vs Large Wick",
  "aliases": [
    "Wick Size Analysis",
    "wick size analysis"
  ],
  "school": "ICT",
  "definition": "A comparison of candle wick sizes to determine expansion potential. A small wick (shallow opposing run) forms early, allowing price to expand. A large wick (large opposing run) consumes most time and range, signaling a reversal candle that does not support expansion; targets adjust to the daily open.",
  "identification_rules": [
    "A small wick is a short opposing move from the candle's open that occurs early in the period, leaving ample time and range for expansion.",
    "A large wick is a long opposing move that uses a significant portion of the candle's time and range, producing a small body.",
    "On a higher time frame, assess the proportion of the candle's range consumed by the wick relative to the body.",
    "Confirm the wick as a reversal by a change in state of delivery (CISD) on a lower time frame; without CISD, the wick is unconfirmed."
  ],
  "trading_implication": "A small wick supports continuation trades expecting further expansion in the wick's direction after a CISD. A large wick does not support expansion; avoid trading it directly. Instead, wait for the next candle with a small wick to enter expansion. If forced to trade a large wick reversal, only target the daily open or nearby liquidity, not full expansion.",
  "common_mistakes": [
    "Attempting to trade a large wick reversal expecting immediate expansion.",
    "Not waiting for a lower time frame CISD to confirm the wick, leading to false reversals.",
    "Failing to adjust targets to the daily open or nearby liquidity when a large wick forms."
  ],
