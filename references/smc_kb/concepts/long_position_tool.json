{
  "card_id": "long_position_tool",
  "type": "merged_concept",
  "canonical_term": "Long Position Tool",
  "aliases": [],
  "school": "General",
  "definition": "A charting tool for planning a long trade by marking entry price, stop-loss level, and take-profit target, while displaying the risk/reward ratio.",
  "identification_rules": [
    "Found under 'forecasting and measurement tools' in the platform's drawing menu.",
    "Appears as a three-level annotation with a central entry point, a lower stop-loss line, and an upper target line.",
    "The green profit zone extends upward from entry, and the red stop zone extends downward; risk/reward ratio is shown as a number (e.g., 1:3)."
  ],
  "trading_implication": "Used to structure a long trade with predefined risk and reward. Helps traders visualize potential profit versus loss and maintain discipline by setting exact entry, stop, and target before entering a position.",
  "common_mistakes": [
    "Placing stop-loss too tight or too far without considering market structure.",
    "Setting arbitrary targets not aligned with actual resistance or technical levels."
  ],
  "related_concepts": [],
  "illustrated_by_cases": [
