{
  "card_id": "marking_supply_and_demand_zones",
  "type": "merged_concept",
  "canonical_term": "Marking Supply and Demand Zones",
  "aliases": [
    "Drawing Supply and Demand Zones",
    "drawing supply and demand zones"
  ],
  "school": "Smart Money Concepts (SMC)",
  "definition": "A method of identifying price zones where aggressive buying or selling initiated strong moves. Demand zones are marked from the base of a bullish impulse (often the last red candle or the first green candle); supply zones from the top of a bearish impulse. The specific candle(s) selected depend on the formation, including wicks for rejection areas.",
  "identification_rules": [
    "To mark a demand zone, identify at least three consecutive green candles with large bodies and strong upward push; mark the zone covering the range where the move began: either the first green candle, the last red candle before the move, or the wick bottom if a long wick shows rejection.",
    "For supply zones, identify at least three consecutive red candles with large bodies and strong downward push; mark the zone from the start of the impulse: the first red candle, the last green candle, or the wick top.",
    "Choose the marking method based on candlestick formation: if marking the first candle yields a very small zone, use the last opposing candle to get a more valid area.",
    "Wicks are critical: if a candle's wick shows a clear rejection, draw the zone from the wick extreme, as that is where the reversal began.",
    "The zone is a horizontal rectangle covering the high to low of the chosen candle(s), extended forward in time."
  ],
  "trading_implication": "These zones act as potential support (demand) and resistance (supply) where price is likely to react. Traders place buy limit orders at demand zones and sell limit orders at supply zones, expecting a bounce. To avoid missing trades, entry can be placed just above the demand zone or just below the supply zone to account for spread or partial touches.",
  "common_mistakes": [
    "Marking zones from slow, sideways movement instead of impulsive moves with at least three momentum candles.",
    "Choosing the wrong candle to mark the zone, resulting in a zone that is too small or invalid.",
    "Expecting price to always reverse exactly at the zone; it may react before or need a deeper retracement.",
    "Not adjusting limit orders to account for spread or partial zone touches, leading to missed entries."
  ],
