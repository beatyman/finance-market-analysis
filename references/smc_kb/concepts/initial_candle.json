{
  "card_id": "initial_candle",
  "type": "merged_concept",
  "canonical_term": "Initial Candle",
  "aliases": [],
  "school": "Smart Money Concepts (SMC)",
  "definition": "The first candle that pushes into an unmitigated supply or demand zone, initiating the mitigation process. It sets the stage for a potential reversal as price begins to interact with the zone, followed by a reaction and an engulfing breakout confirmation.",
  "identification_rules": [
    "The candle must close within or enter an unmitigated higher-timeframe point of interest (supply or demand zone).",
    "It is the first candle in a sequence that leads to a reaction phase (single or multiple candles showing rejection) and then an engulfing breakout candle.",
    "It is not a standalone trade signal; only valid as part of the Candle Breakout Entry Method."
  ],
  "trading_implication": "An initial candle indicates that price is beginning to test a key zone, alerting traders to monitor subsequent reaction and an engulfing breakout for entry. Entering prematurely on this candle is risky without confirmation.",
  "common_mistakes": [
    "Entering a trade solely based on the initial candle without waiting for the engulfing breakout.",
    "Misidentifying the initial candle when it does not actually push into the unmitigated zone."
  ],
