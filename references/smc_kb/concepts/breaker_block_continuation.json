{
  "card_id": "breaker_block_continuation",
  "type": "merged_concept",
  "canonical_term": "Breaker Block Continuation",
  "aliases": [],
  "school": "ICT",
  "definition": "A continuation trade setup where, after a trend reversal, price retraces to sweep a swing low or high, forming a bullish (low-high-lower low-higher high) or bearish (high-low-higher high-lower low) breaker block. The breaker block (up-close or down-close candles) acts as support/resistance for entries in the trend direction.",
  "identification_rules": [
    "Confirm a trend reversal via a change in state of delivery before looking for the continuation setup.",
    "Wait for price to retrace and sweep a recent swing low (bullish) or swing high (bearish) to create a lower low or higher high.",
    "After the sweep, price must then form a higher high (bullish) or lower low (bearish) to complete the breaker block pattern.",
    "Identify the breaker block as the series of up-close candles (bullish) between the first low and the high, or down-close candles (bearish) between the first high and the low.",
    "Enter the trade on a retest of this breaker block zone, with a stop placed either on the swing low/high or the other side of the breaker block.",
    "Target a minimum 2R reward or the previous range high/low, aligning with the higher-time-frame bias."
  ],
  "trading_implication": "Breaker block continuations allow traders to enter a trend after a liquidity sweep and retracement, providing a high-probability entry zone with a defined risk. The setup exploits the break of structure that traps early counter-trend traders, offering a mechanical entry aligned with the dominant trend. It is preferred over chasing price or entering during consolidation.",
  "common_mistakes": [
    "Entering before the higher high (bullish) or lower low (bearish) completes the breaker pattern, resulting in false signals.",
    "Blindly entering on the initial price move without waiting for the sweep of a swing low/high and the subsequent pattern formation.",
    "Misidentifying a simple retracement into a fair value gap as a breaker block when no sweep has occurred, unless confirmed by SMT divergence."
  ],
