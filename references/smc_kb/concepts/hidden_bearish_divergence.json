{
  "card_id": "hidden_bearish_divergence",
  "type": "merged_concept",
  "canonical_term": "Hidden Bearish Divergence",
  "aliases": [
    "hidden bearish macd divergence",
    "Hidden Bearish MACD Divergence"
  ],
  "school": "Indicator Based",
  "definition": "Hidden bearish divergence is a bearish continuation signal that occurs in a downtrend when price forms lower highs, but an oscillator (such as RSI, Stochastic, or MACD) forms higher highs at the same peaks, indicating the downtrend is likely to continue.",
  "identification_rules": [
    "Establish that the market is in a clear downtrend, with price making lower lows and lower highs.",
    "Identify two consecutive swing highs where the second high is lower than the first (lower high).",
    "At the same two swing highs, the chosen oscillator (e.g., RSI, Stochastic, MACD line/histogram) must show a higher high at the second peak compared to the first.",
    "Only compare the highs on both price and indicator; do not use lows for bearish divergence.",
    "Ensure the oscillator peaks are clearly defined and correspond to the price highs to avoid ambiguous signals.",
    "Confirm the pattern signals trend continuation; if the oscillator shows a lower high while price makes a higher high, it is regular bearish divergence (reversal), not hidden."
  ],
  "trading_implication": "Hidden bearish divergence signals that the downtrend is likely to continue, offering a potential entry or add-on opportunity for short trades. It confirms trend strength and suggests sellers remain in control. Traders often wait for additional confirmation (e.g., candlestick patterns, support breaks) before entering. A stop-loss can be placed above the recent swing high. Combining divergences with other technical factors improves reliability.",
  "common_mistakes": [
    "Confusing hidden bearish divergence with regular bearish divergence, which signals a reversal.",
    "Focusing on lows instead of highs when identifying bearish divergences.",
    "Failing to establish a clear downtrend before identifying the pattern.",
    "Using the wrong oscillator line (e.g., %K instead of %D for Stochastic) which can obscure the divergence.",
    "Trading the signal without additional confirmation from price action, candlestick patterns, or market structure.",
    "Relying on standard indicator settings (e.g., default MACD 12,26,9) that may fail to reveal the divergence.",
    "Forcing the pattern when oscillator peaks are not clearly separated, leading to false signals."
  ],
