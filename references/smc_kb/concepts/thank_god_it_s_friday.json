{
  "card_id": "thank_god_it_s_friday",
  "type": "merged_concept",
  "canonical_term": "Thank God It's Friday",
  "aliases": [
    "TGIF",
    "tgif",
    "TGIF Setup",
    "tgif setup"
  ],
  "school": "ICT",
  "definition": "A weekly profile pattern where Friday retraces a portion of the weekly range back into the range, forming the wick of the weekly candle. Requires a classic expansion week with the weekly high or low formed Monday or Tuesday and expansion through Wednesday/Thursday into a weekly objective.",
  "identification_rules": [
    "Confirm a classic expansion week where Monday or Tuesday forms the high or low of the week.",
    "Verify expansion occurred on Wednesday and Thursday in the direction away from that Monday/Tuesday extreme.",
    "Verify the weekly objective (e.g., a daily swing high/low or key liquidity level) has been reached by Thursday.",
    "On Friday, anticipate a retracement back into the weekly range to form the wick of the weekly candle.",
    "Drop to a lower time frame (e.g., 5-minute) to mark the daily open and look for a reversal back into the range."
  ],
  "trading_implication": "TGIF is used to cap the weekly range by trading Friday's retracement against the prior week's expansion. After confirming expansion hit a weekly objective by Thursday, the trader anticipates Friday reversing back into the range, often as a New York reversal. Entries are taken on lower time frames targeting failure swings and the daily open as objectives, sized with appropriate stops on the session extreme.",
  "common_mistakes": [
    "Not explicitly stated in the material"
  ],
