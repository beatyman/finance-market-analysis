{
  "card_id": "discount_premium",
  "type": "merged_concept",
  "canonical_term": "Discount / Premium",
  "aliases": [
    "Discount and Premium",
    "discount and premium",
    "discount/premium",
    "premium and discount",
    "premium/discount"
  ],
  "school": "ICT",
  "definition": "The two halves of a price range divided by the 0.5 equilibrium level: premium (upper half, overvalued) favors sell setups, while discount (lower half, undervalued) favors buy setups. Used to anticipate retracements and reversals, especially during consolidation, and to filter high-probability entries aligned with institutional order flow.",
  "identification_rules": [
    "Identify a relevant price range using a clear swing high and swing low on a given timeframe (e.g., recent swing, London or Asia session).",
    "Draw the 50% equilibrium level using a horizontal line or Fibonacci retracement tool.",
    "The area above equilibrium is premium; the area below is discount.",
    "When price extends beyond the range with a new high or low, recalculate premium/discount from the updated extremes.",
    "When price deviates outside the range, treat equilibrium as the first magnet/target for a return back inside."
  ],
  "trading_implication": "In consolidation or range-bound markets, initiate sell setups in premium and buy setups in discount, targeting equilibrium. When price deviates outside the range, anticipate a return to equilibrium and potentially the opposite boundary. Align entries with the higher timeframe trend: discount for longs, premium for shorts. Use PD arrays (e.g., fair value gaps, order blocks) in these zones for confirmation. Update zones after range expansion.",
  "common_mistakes": [
    "Expecting price to break out or travel to the opposite side after deviation, instead of rebalancing to equilibrium during consolidation.",
    "Failing to update premium and discount zones after a new high or low, using stale equilibrium levels.",
    "Applying range-trading logic on trending/expansion days when the market is not consolidating.",
    "Assuming price will reverse at discount or premium without confirmation from other factors.",
    "Using an incorrect or arbitrary price range for equilibrium calculation."
  ],
