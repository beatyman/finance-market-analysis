{
  "card_id": "preliminary_support",
  "type": "merged_concept",
  "canonical_term": "Preliminary Support",
  "aliases": [
    "ps",
    "PS"
  ],
  "school": "Wyckoff",
  "definition": "The first buying support after a prolonged downtrend or markdown, signaling initial smart money involvement through increased volume. It often appears as the last or second-to-last pullback before accumulation begins.",
  "identification_rules": [
    "Occurs after an extended downtrend or markdown phase.",
    "Shows a support level where price finds initial buying interest.",
    "Volume is higher than on preceding bars, indicating smart money accumulation.",
    "Often looks like a pullback that later becomes part of the accumulation trading range."
  ],
  "trading_implication": "Preliminary Support is an early indication that a downtrend might be ending and smart money is starting to accumulate. It is not a standalone buy signal; traders wait for subsequent events like Selling Climax, Automatic Rally, and Secondary Test to confirm accumulation before considering long positions.",
  "common_mistakes": [
    "Treating PS as a reversal signal and buying immediately without confirmation.",
    "Ignoring volume; a PS without increased volume may not indicate smart money involvement.",
    "Confusing it with a regular pullback that does not lead to accumulation."
  ],
