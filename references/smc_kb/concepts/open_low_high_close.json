{
  "card_id": "open_low_high_close",
  "type": "merged_concept",
  "canonical_term": "Open Low High Close",
  "aliases": [
    "bullish day structure",
    "bullish ohlc sequence",
    "Bullish OHLC sequence",
    "OLHC",
    "olhc pattern",
    "OLHC pattern"
  ],
  "school": "ICT",
  "definition": "A bullish intraday delivery sequence where price opens, moves down to form the low (manipulation), then expands up to form the high before closing near the high. Represents the bullish Power of 3 within a single higher time frame candle, confirming bullish structure continuation.",
  "identification_rules": [
    "Mark the open of the higher time frame candle (e.g. 4-hour or 1-hour) on the lower time frame chart.",
    "Expect price to first move below the open (manipulation/low formation) before expanding higher.",
    "Confirm the low has formed when price sweeps a swing low or reacts off a discount PD array (order block or fair value gap) and shows displacement back above the open.",
    "After displacement up, the high forms later in the candle's time window, with the close occurring near that high.",
    "Anything trading below the candle's open in a bullish delivery is considered to be at a discount.",
    "In a bullish cycle (e.g., bullish week), the pattern is identified within that context."
  ],
  "trading_implication": "Used to anticipate bullish intraday delivery by mapping a higher time frame candle's OHLC onto a lower time frame. Trader waits for the move below the open to tap a discount PD array (order block / fair value gap), then enters long on displacement targeting the candle's high or the higher time frame draw on liquidity. Enables buying at a discount with defined risk within the candle's time window.",
  "common_mistakes": [
    "Entering long before the low of the candle has formed instead of waiting for a sweep and displacement back above the open.",
    "Ignoring the higher time frame draw on liquidity and targeting only the immediate previous high.",
    "Placing stops too tight inside the order block rather than below the mean threshold, getting stopped before the expansion.",
    "Identifying the pattern outside a bullish cycle context, leading to misinterpretation."
  ],
  "related_concepts": [],
  "merge_strategy": "llm_synthesis",
  "merge_model": "deepseek/deepseek-chat",
  "merge_notes": "Both cards are from ICT school; no conflict. The updated card provides more precise identification rules and trading implication, which are preserved.",
