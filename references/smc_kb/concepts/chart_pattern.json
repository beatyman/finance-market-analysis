{
  "card_id": "chart_pattern",
  "type": "merged_concept",
  "canonical_term": "Chart Pattern",
  "aliases": [],
  "school": "Price Action",
  "definition": "Chart patterns are formations created by price movements, such as triangles formed by trendlines connecting pivot highs and lows. These patterns indicate areas of support and resistance, and often lead to strong breakouts when the price breaks the pattern boundaries, particularly after a period of compression.",
  "identification_rules": [
    "Identify pivot highs and lows using a method that marks significant turning points (e.g., pivot length of 20 candles).",
    "Connect at least two pivot highs with a trendline to define a sloping resistance.",
    "Draw a horizontal support line that aligns with multiple pivot lows.",
    "Observe price moving within the converging lines, with lower highs and flat lows forming a descending triangle.",
    "Confirm a valid breakdown when price closes below the horizontal support level, ideally with increased momentum."
  ],
  "trading_implication": "Chart patterns signal potential large directional moves. A descending triangle with tightening range suggests a strong downside breakout is likely once support breaks. Traders can anticipate the breakout and position for a significant trend move, using the pattern boundaries to set entries and stops.",
  "common_mistakes": [
    "Misidentifying random price swings as a valid pattern; ensure multiple pivot points confirm the trendlines.",
    "Entering a trade before the breakout is confirmed by a close beyond the pattern boundary.",
    "Ignoring the compression phase—breakout reliability increases when price coils tightly before the break."
  ],
