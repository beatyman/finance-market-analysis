{
  "card_id": "lower_timeframe_confirmation",
  "type": "merged_concept",
  "canonical_term": "Lower Timeframe Confirmation",
  "aliases": [
    "ltf confirmation",
    "LTF Confirmation",
    "multi‑timeframe refinement",
    "Multi‑Timeframe Refinement"
  ],
  "school": "ICT",
  "definition": "A multi-timeframe technique where after price reaches a higher timeframe area of interest (e.g., order block, FVG), the trader drops to a lower timeframe to await a structural shift (BOS or CHoCH) in the direction of the higher timeframe trend before entering. Confirmation may include a liquidity sweep and formation of a new order block on the lower timeframe.",
  "identification_rules": [
    "Identify the higher timeframe trend and mark swing points to determine bias and key confluences (OB, FVG) within the discount (long) or premium (short).",
    "Wait for price to retrace into the designated higher timeframe area of interest.",
    "On the lower timeframe, monitor price action for a structural shift that aligns with the higher timeframe direction (e.g., a bullish BOS for longs).",
    "The confirmation signal is a break of a relevant swing low (for bullish) or swing high (for bearish) on the lower timeframe within the area of interest.",
    "On the lower timeframe, identify a liquidity sweep: a move that breaks a recent swing low (for buys) or high (for sells) to trigger stops.",
    "Look for a change of character (CHoCH): price breaking above the most recent swing high (for buys) or below the most recent swing low (for sells).",
    "Await formation of a new order block on the lower timeframe after the CHoCH.",
    "Enter the trade at the start of the lower timeframe order block with a stop loss placed below it (for buys) or above it (for sells)."
  ],
  "trading_implication": "Lower timeframe confirmation enables precise entry timing, avoiding premature participation and improving risk-to-reward ratios. It resolves ambiguity when multiple higher timeframe confluences exist, as the lower timeframe shift confirms which level is likely to hold. It requires proof of a short-term reversal (liquidity sweep + CHoCH) before entering on a fresh order block, aligning trades with higher timeframe direction.",
  "common_mistakes": [
    "Entering immediately when price reaches the area of interest without waiting for lower timeframe confirmation, leading to false signals.",
    "Guessing which higher timeframe confluence to trade when multiple exist, instead of waiting for the lower timeframe to confirm the active level.",
    "Assuming a break of structure on the higher timeframe will immediately continue, ignoring the need for lower timeframe alignment.",
    "Ignoring order block size on lower timeframes, leading to inappropriate stop placement (too tight or too wide).",
    "Entering without all confirmation signals, such as missing the CHoCH or liquidity sweep.",
    "Trading multiple order blocks without reducing risk, risking overexposure and consecutive losses."
  ],
  "related_concepts": [],
