{
  "card_id": "stop_loss_order",
  "type": "merged_concept",
  "canonical_term": "Stop-Loss Order",
  "aliases": [
    "SL",
    "stop loss"
  ],
  "school": "Risk Management",
  "definition": "A risk management order that automatically exits a trade at a pre-defined price to cap losses. For long positions, placed below recent swing lows or support; for short positions, above resistance. It protects capital by limiting the maximum loss on any single trade.",
  "identification_rules": [
    "For a long trade, identify the lowest point of the most recent swing low, pattern low, or support zone, and place the stop loss slightly below this level to allow wiggle room and avoid premature exits from minor fluctuations.",
    "Alternatively, when trading from demand zones, place the stop loss below the lowest point of the entire zone to accommodate full retests.",
    "For a short trade, place the stop loss just above the identified resistance level."
  ],
  "trading_implication": "Stop-loss orders are essential for risk management, capping maximum loss per trade and protecting capital. They define the risk component of the risk/reward ratio, enabling consistent position sizing and strategy. Proper placement balances reducing premature exits from market noise against limiting potential loss. Combined with profit targets, they prevent emotional decision-making and large drawdowns.",
  "common_mistakes": [
    "Not using a stop-loss order, leaving the trade exposed to uncontrolled losses.",
    "Setting the stop loss exactly at the pattern low without wiggle room, leading to premature exit from minor fluctuations.",
    "Ignoring broader market structure and placing stops only based on the immediate pattern low.",
    "Moving or removing the stop-loss during a trade, driven by the hope that the market will reverse, which can lead to significantly larger losses."
  ],
