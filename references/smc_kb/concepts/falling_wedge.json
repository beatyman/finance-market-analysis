{
  "card_id": "falling_wedge",
  "type": "merged_concept",
  "canonical_term": "Falling Wedge",
  "aliases": [],
  "school": "Price Action",
  "definition": "A chart pattern characterized by two converging downward-sloping trendlines, with the upper line having a steeper slope than the lower. Price forms lower highs and lower lows within the wedge, which progressively tightens. It can act as either a bullish reversal after a downtrend or a bullish continuation after an uptrend, signaling a potential upward breakout.",
  "identification_rules": [
    "Two downward-sloping trendlines converge, creating a wedge shape.",
    "The upper trendline has a steeper slope than the lower trendline.",
    "Price action forms a series of lower highs and lower lows.",
    "The distance between the trendlines narrows as the pattern develops.",
    "Breakout above the upper trendline confirms the pattern."
  ],
  "trading_implication": "The falling wedge signals a bullish reversal or continuation. Enter long on a breakout above the upper trendline, preferably with a strong momentum candle, placing a stop-loss below the wedge's lowest point. Profit targets are set using the pattern's height, a measured move from the prior impulsive move, or a 2:1 risk/reward ratio. An alternative entry is a retest of a support level with a bullish hammer.",
  "common_mistakes": [
    "Using the pattern in isolation without confirming the broader uptrend or nearby support levels, reducing reliability."
  ],
