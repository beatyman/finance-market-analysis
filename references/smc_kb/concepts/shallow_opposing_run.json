{
  "card_id": "shallow_opposing_run",
  "type": "merged_concept",
  "canonical_term": "Shallow Opposing Run",
  "aliases": [
    "Shallow Opposing Wick",
    "shallow opposing wick",
    "Shallow Wick",
    "shallow wick"
  ],
  "school": "Price Action",
  "definition": "A small counter-directional move (wick) formed at the open of a candle against the intended expansion direction. When the wick is shallow, it supports continued expansion within the same higher time frame candle and allows a protected swing to form for entry.",
  "identification_rules": [
    "Observe the open of the candle being traded (e.g. candle 2 or candle 3 of the higher time frame Power of 3).",
    "Confirm the opposing run does not extend deeply against the intended direction; the wick must remain proportionally small relative to the candle body.",
    "Require a change in state of delivery (closure through the opposing series of candles) on the lower time frame to confirm the wick has completed and a protected swing has formed.",
    "Verify the shallow run respects a relevant point of interest (e.g. EQ of the previous candle, T-spot, or fair value gap) rather than violating it.",
    "Contrast with a large opposing run: if the open produces a deep counter move, the wick is not shallow and expansion within that candle is not supported."
  ],
  "trading_implication": "A shallow opposing run is the green light to trade the expansion (body) of the current higher time frame candle. Wait for the wick to form, confirm via change in state of delivery on the lower time frame, then enter the continuation in the direction of bias with stop beyond the protected swing. If the opposing run is instead large, do not trade within the current candle—wait for the next higher time frame candle to open and look for a fresh shallow wick.",
  "common_mistakes": [
    "Trying to catch the wick instead of letting it form, which leads to being continuously stopped out.",
    "Trading expansion inside a candle that printed a large opposing run rather than waiting for the next candle.",
    "Entering without a change in state of delivery confirming the protected swing on the lower time frame.",
    "Ignoring the point of interest / EQ context that validates the shallow run."
  ],
