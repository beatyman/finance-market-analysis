{
  "card_id": "bollinger_bands",
  "type": "merged_concept",
  "canonical_term": "Bollinger Bands",
  "aliases": [
    "bb on rsi",
    "BB on RSI",
    "Bollinger Bands on RSI",
    "bollinger bands on rsi"
  ],
  "school": "Indicator Based",
  "definition": "A volatility indicator consisting of a middle moving average (usually SMA) and upper/lower bands at a specified number of standard deviations. It can be applied to price or to indicators like RSI to assess volatility. When price or the indicator moves outside the bands, it signals extreme momentum and heightened volatility, often preceding large directional moves.",
  "identification_rules": [
    "Bollinger Bands consist of a middle moving average (typically SMA) and upper/lower bands at a multiple of standard deviations. For short-term trading, tighter settings (e.g., length 10, standard deviation 1.5) increase sensitivity.",
    "The bands contract during low volatility and expand during high volatility, with tightening often preceding large moves.",
    "When applied to price, a 'free bar' occurs when an entire candle (high to low) lies outside the bands, indicating unusual volatility and potential reversal.",
    "When applied to the RSI, a break above the upper band or below the lower band signals momentum stronger than expected.",
    "Band breaks or free bars must be confirmed by additional technical analysis: support/resistance levels, price action, market structure, or candlestick patterns."
  ],
  "trading_implication": "Band breaks or free bars signal extreme momentum and volatility, offering potential reversal opportunities when confirmed by market structure (e.g., failure tests), price action, or candlestick patterns. Confirmed entries at signal candle close with stops below the free bar low and a 2:1 risk/reward target are suited for short-term trading (scalping, day trading). Beginners should avoid trading unconfirmed breaks, as they may lead to false signals.",
  "common_mistakes": [
    "Trading solely on band breaks or free bars without confirmation from price action, market structure, or candlestick patterns.",
    "Assuming that a band break always leads to a continuation in the same direction.",
    "Using default settings (length 20, stddev 2) for short-term trading, missing early signals."
  ],
