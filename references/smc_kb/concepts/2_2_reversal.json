{
  "card_id": "2_2_reversal",
  "type": "merged_concept",
  "canonical_term": "2 2 Reversal",
  "aliases": [
    "2-2 reversal",
    "two-two reversal"
  ],
  "school": "Price Action",
  "definition": "两根K线构成的反转形态：第一根K线向上（看涨），第二根K线低点低于第一根K线低点，形成做空触发信号。当第二根K线跌破第一根K线低点时入场。",
  "identification_rules": [
    "在价格回撤至关键区域（如FVG）后，观察K线形态",
    "第一根K线为上涨K线（收盘高于开盘，即阳线）",
    "第二根K线低点必须低于第一根K线的低点",
    "当第二根K线向下突破第一根K线低点时，触发做空入场信号",
    "止损设置在第二根K线（触发K线）的高点之上"
  ],
  "trading_implication": "2 2 Reversal 作为ICT结构设置（流动性扫荡 + 结构突破 + FVG）中的低时间框架入场触发信号，适用于不愿在价格逆向运动时直接入场的交易者。可在15分钟、5分钟或1分钟图上寻找该形态，推荐使用5分钟或3分钟以减少假信号。目标为结构下方的流动性低点。",
  "common_mistakes": [
    "在1分钟图上使用该形态容易产生大量假信号，视频明确建议避免过度依赖1分钟图",
    "将2 2 Reversal与2 1 2 Reversal混淆，两者K线数量和结构不同"
  ],
