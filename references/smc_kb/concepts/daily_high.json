{
  "card_id": "daily_high",
  "type": "merged_concept",
  "canonical_term": "Daily High",
  "aliases": [
    "day's high",
    "Day's High"
  ],
  "school": "Smart Money Concepts (SMC)",
  "definition": "The highest price reached during the trading day, acting as a liquidity level where stop-losses and pending orders cluster. Smart money often engineers a brief break above to sweep sell-side liquidity before price reverses downward.",
  "identification_rules": [
    "Mark the highest price of the current trading day on the chart.",
    "Watch for price to briefly break above the daily high, indicating a liquidity sweep.",
    "Confirm a reversal signal such as a change of character or bearish candlestick pattern after the break.",
    "Ensure the reversal aligns with the higher timeframe trend direction."
  ],
  "trading_implication": "Price frequently breaks above the daily high to trigger sell-side stop-losses and buy orders, then reverses. Traders can enter short after confirmed reversal, place a stop just above the high, and target the next support level.",
  "common_mistakes": [
    "Entering before a confirmed reversal, mistaking a true breakout for a liquidity sweep.",
    "Ignoring the overall trend, leading to counter-trend trades.",
    "Failing to wait for additional confirmation signals like change of character."
  ],
