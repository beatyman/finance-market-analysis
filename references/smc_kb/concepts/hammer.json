{
  "card_id": "hammer",
  "type": "merged_concept",
  "canonical_term": "Hammer",
  "aliases": [
    "bullish hammer",
    "Hammer Pattern",
    "hammer pattern"
  ],
  "school": "Price Action",
  "definition": "A single-candle bullish reversal pattern characterized by a small real body near the top of the candle's range, a long lower wick at least twice the body length (preferably 3-4 times), and little to no upper wick. It forms after a downtrend or at a support level, signaling rejection of lower prices and potential upward reversal.",
  "identification_rules": [
    "The pattern consists of a single candlestick.",
    "The candle has a small real body located near the top of its overall range.",
    "The lower wick is at least twice the length of the real body (preferably three to four times).",
    "The upper wick is very small or nonexistent, shorter than the real body.",
    "The pattern appears after a clear downtrend or at a support level.",
    "The body can be green (bullish) or red (bearish), with green being considered more bullish."
  ],
  "trading_implication": "A hammer signals a potential bullish reversal after a downtrend or at support, indicating selling pressure was absorbed and buyers stepped in. Traders often enter long at the candle close with a stop-loss below its low, targeting a favorable risk/reward ratio (e.g., 1:2). In an uptrend, it may represent a liquidity grab and continuation. Not all hammers lead to reversals; failure occurs if price breaks below the low.",
  "common_mistakes": [
    "Failing to confirm a preceding downtrend or support level, leading to false signals.",
    "Misidentifying any candle with a long lower wick as a hammer, ignoring the small real body and wick-to-body ratio, or mistaking it for a momentum candle.",
    "Entering before the candle closes, potentially misreading the pattern.",
    "Assuming all hammers lead to reversals; they can fail and hit stop-losses.",
    "Confusing a hammer for a reversal when it may be a liquidity grab and continuation signal."
  ],
