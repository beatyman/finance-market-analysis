{
  "card_id": "bullish_divergence",
  "type": "merged_concept",
  "canonical_term": "Bullish Divergence",
  "aliases": [
    "bullish div",
    "Bullish RSI Divergence",
    "bullish rsi divergence",
    "regular bullish divergence",
    "Regular Bullish Divergence"
  ],
  "school": "Indicator Based",
  "definition": "Bullish divergence occurs when price records a lower low compared to a prior swing low, while a momentum oscillator (e.g., RSI, MACD, Stochastic %D) records a higher low over the same period. This signals diminishing downward momentum and often precedes a reversal to the upside.",
  "identification_rules": [
    "Identify that price is in a downtrend or pullback, with lower lows and lower highs.",
    "Locate two distinct swing lows on price, where the second low is below the first.",
    "On the exact same timeframe, identify the corresponding lows on a momentum oscillator (line such as RSI, MACD, or Stochastic %D); the oscillator's second low must be higher than its first.",
    "Compare only the lows of price and oscillator; ignore highs to avoid false signals.",
    "Use the oscillator's signal line rather than raw or secondary values (e.g., %K) for clearer divergence identification.",
    "Ensure the swing lows on both price and oscillator are clearly defined and well separated to avoid ambiguous signals."
  ],
  "trading_implication": "Bullish divergence signals weakening downward momentum and a potential reversal to the upside. Traders may use it to exit short positions or consider long entries, but typically wait for confirming price action such as a break above a prior swing high, a failure test, or bullish candlestick patterns. Combining divergence with market structure analysis or other indicators increases reliability. A common approach places a stop loss below the divergence's swing low and targets a risk-to-reward ratio of at least 2:1.",
  "common_mistakes": [
    "Looking at price/oscillator highs instead of lows.",
    "Trading divergence in isolation without additional confirmation from price action, market structure, or other indicators.",
    "Using inappropriate oscillator lines or settings (e.g., %K) that produce unclear or misleading divergences.",
    "Treating borderline cases where oscillator lows are nearly equal as valid divergences.",
    "Misinterpreting the bullish divergence as a bearish signal because of strong negative momentum on the oscillator.",
    "Confusing regular bullish divergence with hidden bullish divergence (which signals trend continuation, not reversal)."
  ],
