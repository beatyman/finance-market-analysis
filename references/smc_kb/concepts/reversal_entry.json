{
  "card_id": "reversal_entry",
  "type": "merged_concept",
  "canonical_term": "Reversal Entry",
  "aliases": [
    "Protected Swing Entry",
    "protected swing entry",
    "反转入场"
  ],
  "school": "ICT",
  "definition": "An entry taken immediately upon formation of a protected swing, confirmed by a closure through the opposing candle series (e.g., up-close candles for shorts, down-close candles for longs). The stop is placed on the protected high/low or optionally on candle bodies to improve risk-to-reward. No continuation structure has yet formed.",
  "identification_rules": [
    "Price must sweep a relevant high or low and close back inside the range, forming a potential swing point.",
    "A closure through the series of opposing candles (up-close candles for shorts, down-close candles for longs) must occur to confirm the protected swing.",
    "The entry is taken on that confirming closure, with invalidation placed on the protected high/low (or alternatively on the candle bodies to tighten the stop).",
    "No continuation structure (higher low, opposing candle at a point of interest, or candle 4 retest) has yet formed at the time of entry.",
    "Price forms a V-shaped reversal or reversal within consolidation.",
    "The low is confirmed as a protected swing."
  ],
  "trading_implication": "Reversal entries allow earliest participation in a new trend but typically yield poor risk-to-reward due to stop distance. If 2R cannot be achieved with stop on the protected swing, tighten stop to candle bodies or wait for a continuation entry (retest into FVG/POI with closure through opposing candles).",
  "common_mistakes": [
    "Taking a reversal entry when risk-to-reward to the target is below 2R instead of waiting for a continuation.",
    "Placing the stop on the protected swing extreme when a body-based invalidation would achieve required R (accepting that wicks may sweep the body stop).",
    "Entering before the closure through the opposing candle series occurs, treating an unconfirmed swing as protected.",
    "Entering based on a single candle close without sufficient confirmation.",
    "Failing to distinguish reversal entry from continuation entry, missing better risk-to-reward setups.",
    "Entering reversals without significant price levels (e.g., FVG, OB) supporting the move."
  ],
  "related_concepts": [],
  "merge_strategy": "llm_synthesis",
