{
  "card_id": "take_profit",
  "type": "merged_concept",
  "canonical_term": "Take Profit",
  "aliases": [],
  "school": "Risk Management",
  "definition": "An order that automatically closes a trade at a predetermined price level to secure profits. Take-profit targets are typically placed at key market structure levels, such as swing points (swing highs/lows) or liquidity pools, and may be combined with a trailing stop to capture extended trend moves.",
  "identification_rules": [
    "Set initial take-profit target at the nearest opposing swing point (swing low in a downtrend, swing high in an uptrend).",
    "Identify upcoming liquidity pools (sellside for shorts, buyside for longs) as potential take-profit levels.",
    "Consider the most recent fair value gap as a take-profit target if it lies within a reasonable distance.",
    "If using a trailing approach, move the stop-loss behind key structural levels to lock in profits as the trade progresses.",
    "Place take-profit levels at a distance from entry that avoids prolonged exposure and unnecessary risk."
  ],
  "trading_implication": "Take-profit orders automatically secure profits without manual intervention, reducing emotional interference and enforcing a favorable risk-to-reward ratio. Targets are strategically placed at key market structure levels (swing points, liquidity pools) where price is likely to react. When combined with trailing stops, they allow traders to capture extended moves while protecting gains.",
  "common_mistakes": [
    "Setting the take-profit level too far from entry, leading to prolonged exposure and potential reversals.",
    "Placing take-profit at arbitrary levels without considering market structure or key reaction zones."
  ],
