{
  "card_id": "hammer_shooter_candle",
  "type": "merged_concept",
  "canonical_term": "Hammer/Shooter Candle",
  "aliases": [
    "Bearish Shooting Star",
    "Hammer Candle",
    "Shooter Candle",
    "shooter candle",
    "Shooting Star",
    "shooting star",
    "射手形K线"
  ],
  "school": "Price Action",
  "definition": "A higher-time-frame candlestick pattern formed when price aggressively sweeps a low (hammer) or high (shooter) and swiftly returns into the prior range, creating a long wick and signaling potential reversal without a structural shift. The shooter has a long upper wick and small body near the low; the hammer has a long lower wick and small body near the high.",
  "identification_rules": [
    "On a higher time frame, price aggressively sweeps a prior low (for hammer) or high (for shooter), moving well beyond it.",
    "Price then aggressively returns into the previous range, leaving a long lower wick (hammer) or long upper wick (shooter) with a small real body.",
    "The candle closes well within the prior range, indicating rejection of the extreme level.",
    "No market structure shift is required; the pattern itself signals a potential reversal.",
    "For shooter: single candlestick with a small real body and a long upper wick at least twice the body length, little to no lower wick, appearing after an uptrend or at resistance.",
    "For hammer: single candlestick with a small real body and a long lower wick at least twice the body length, little to no upper wick, appearing after a downtrend or at support."
  ],
  "trading_implication": "This pattern enables reversal entries without waiting for a break of structure. After the hammer/shooter closes, traders look for a point of interest (BPR, FVG, or box setup) to enter, place stops beyond the wick extreme, and target internal liquidity levels such as previous highs/lows. For shooter, wait for bearish confirmation (e.g., bearish follow-through candle) before shorting.",
  "common_mistakes": [
    "Misidentifying a normal wick as a hammer/shooter without the aggressive sweep and return into the range.",
    "Entering before the hammer/shooter candle closes, thus risking a false rejection.",
    "Identifying a shooting star without a preceding uptrend, which invalidates the pattern.",
    "Accepting a candle with an upper wick less than twice the body length as a valid shooting star."
  ],
