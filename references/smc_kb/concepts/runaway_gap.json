{
  "card_id": "runaway_gap",
  "type": "merged_concept",
  "canonical_term": "Runaway Gap",
  "aliases": [
    "bullish runaway gap",
    "Bullish Runaway Gap"
  ],
  "school": "Price Action",
  "definition": "A bullish continuation pattern where a true gap forms between two candles in an uptrend, with no overlap of wicks, indicating strong upward momentum and a likely continuation.",
  "identification_rules": [
    "Confirm an existing uptrend before the pattern appears.",
    "Look for a true gap: a space between candles where not even the wicks touch; the high of the first candle and the low of the second candle must be clearly separated.",
    "The pattern is confirmed at the open of the candle after the gap, not at its close."
  ],
  "trading_implication": "Enter long at the open of the candle following the gap. Place a stop loss below the low of the gap to accommodate a potential gap fill without being stopped out. Set profit targets using a risk-to-reward ratio (e.g., 2:1 or 3:1), measuring from entry to the pattern's low.",
  "common_mistakes": [
    "Confusing a regular gap between real bodies (where wicks may overlap) with a true runaway gap.",
    "Waiting for the candle to close for pattern confirmation; the pattern is confirmed at the candle open after the gap."
  ],
