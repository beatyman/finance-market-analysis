{
  "card_id": "strong_and_weak_highs_and_lows",
  "type": "merged_concept",
  "canonical_term": "Strong and Weak Highs and Lows",
  "aliases": [],
  "school": "Price Action",
  "definition": "Strong highs/lows are swing points from which price breaks the prior market structure (BOS), confirming trend continuation or reversal. Weak highs/lows fail to break the preceding swing high or low, indicating a lack of momentum and potential consolidation or trend failure.",
  "identification_rules": [
    "A low is strong if the subsequent upward move breaks the previous swing high (BOS in an uptrend).",
    "A low is weak if the subsequent upward move fails to break the previous swing high and does not create a higher high.",
    "A high is strong if the subsequent downward move breaks the previous swing low (BOS in a downtrend).",
    "A high is weak if the subsequent downward move fails to break the previous swing low."
  ],
  "trading_implication": "Traders use strong highs/lows as confirmation of trend strength, often entering on pullbacks to these levels. Weak highs/lows signal potential reversals or range-bound conditions, prompting caution or exit. Distinguishing between them helps in filtering trade setups and anticipating structural shifts.",
