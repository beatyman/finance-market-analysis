{
  "card_id": "ascending_triangle",
  "type": "merged_concept",
  "canonical_term": "Ascending Triangle",
  "aliases": [],
  "school": "Price Action",
  "definition": "A bullish continuation pattern forming after an uptrend, characterized by consecutive higher lows forming a rising support line and highs around the same level forming a horizontal resistance line. The breakout typically continues the prior uptrend.",
  "identification_rules": [
    "Prior to the pattern, there must be a clear uptrend.",
    "The pattern must contain consecutive higher lows, creating an upward sloping trendline.",
    "The highs within the pattern should be approximately at the same level, forming a horizontal resistance line.",
    "The breakout candle should have a real body larger than the average real body of candles inside the triangle."
  ],
  "trading_implication": "The pattern signals a likely continuation of the prior uptrend. Enter at the close of a strong breakout candle above resistance, with a stop loss below the most recent low inside the triangle. Target a 1:2 risk-to-reward ratio. Alternatively, enter on a pullback after the breakout, either at the break of the pullback or at its support.",
  "common_mistakes": [
    "Entering on a breakout candle with a small real body, which may lack momentum and fail.",
    "Assuming all breakouts will immediately succeed; many breakouts pull back before continuing, requiring patience or alternative entry."
  ],
