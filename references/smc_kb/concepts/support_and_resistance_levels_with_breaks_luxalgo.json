{
  "card_id": "support_and_resistance_levels_with_breaks_luxalgo",
  "type": "merged_concept",
  "canonical_term": "Support and Resistance Levels with Breaks (LuxAlgo)",
  "aliases": [
    "LuxAlgo Support and Resistance",
    "luxalgo support and resistance",
    "support and resistance with breaks",
    "Support and Resistance with Breaks"
  ],
  "school": "Indicator Based",
  "definition": "A TradingView indicator by LuxAlgo that automatically plots support (blue) and resistance (red) lines based on pivot points with a 20-bar lookback, and generates buy/sell signals when price breaks these levels.",
  "identification_rules": [
    "Set indicator inputs to Left bars = 20 and Right bars = 20 to define pivot points.",
    "Resistance lines are drawn in red at pivot highs; support lines are drawn in blue at pivot lows.",
    "Buy signals appear when price crosses above a resistance level; sell signals appear when price crosses below a support level.",
    "Multiple lines may cluster, highlighting significant support/resistance zones."
  ],
  "trading_implication": "The indicator identifies key price levels and potential breakout entries. It can provide earlier breakout signals than some other indicators, but may also be delayed. Traders often use it in conjunction with other tools for confirmation and to filter false breaks.",
  "common_mistakes": [
    "Ignoring the indicator's settings: using default left/right bars instead of 20 can misalign levels.",
    "Treating every signal as valid without additional confirmation, leading to false breakouts.",
    "Assuming signals are always timely: the indicator can lag behind trendline breaks or other methods."
  ],
