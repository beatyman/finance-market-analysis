{
  "card_id": "moving_average_of_volume",
  "type": "merged_concept",
  "canonical_term": "Moving Average of Volume",
  "aliases": [],
  "school": "Volume Analysis",
  "definition": "A moving average applied to volume bars that smooths volume data to reveal underlying trends in trading activity, helping identify whether buying or selling conviction is strengthening or weakening.",
  "identification_rules": [
    "The indicator is displayed as a line overlaying the volume histogram, with a configurable length (e.g., 14 periods).",
    "Falling volume (volume bars consistently below the moving average) during a downtrend signals diminishing selling pressure and a potential upside reversal.",
    "Rising volume (volume bars consistently above the moving average) during a trend confirms conviction in the move."
  ],
  "trading_implication": "Used to confirm trend strength: rising volume supports continuation, while declining volume warns of fading momentum and possible reversals. In a downtrend, decreasing volume foreshadowed a bullish reversal in the example; conversely, an uptrend with falling volume could indicate a bearish reversal.",
  "common_mistakes": [
    "Assuming falling volume alone signals an immediate reversal without considering price action and market structure.",
    "Relying solely on the moving average line instead of understanding raw volume patterns, as the line only smooths the data."
  ],
