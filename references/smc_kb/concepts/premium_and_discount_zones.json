{
  "card_id": "premium_and_discount_zones",
  "type": "merged_concept",
  "canonical_term": "Premium and Discount Zones",
  "aliases": [
    "Discount",
    "Discount Zone",
    "Premium",
    "Premium Zone"
  ],
  "school": "Smart Money Concepts (SMC)",
  "definition": "Premium refers to the price area above the 50% Fibonacci retracement level, while discount is below the 50% level. In trending markets, traders look to sell in premium (bearish) or buy in discount (bullish) after a pullback, seeking favorable risk-to-reward entries with lower timeframe confirmation.",
  "identification_rules": [
    "Use the Fibonacci retracement tool on the latest impulsive move in the direction of the higher timeframe trend.",
    "The area below the 0.5 (50%) retracement level is the discount zone; above 0.5 is the premium zone.",
    "In a bullish trend, wait for price to pull back into the discount zone.",
    "In a bearish trend, wait for price to pull back into the premium zone.",
    "Seek lower timeframe reversal confirmation (e.g., RSI divergence with change of character) before entering."
  ],
  "trading_implication": "Traders use premium and discount zones to find high-probability entries aligned with the higher timeframe trend. In a bullish HTF trend, buying in the discount zone after a pullback offers a favorable risk-to-reward, with the first target being the recent swing high and a stop-loss below the pullback low. In a bearish trend, selling in the premium zone targets the recent low, with a stop-loss above the pullback high.",
  "common_mistakes": [
    "Entering without lower timeframe confirmation.",
    "Trying to trade premium/discount zones when the pullback is too shallow or absent.",
    "Misapplying the Fibonacci tool from the wrong impulsive swing."
  ],
