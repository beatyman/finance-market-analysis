{
  "card_id": "risk_to_reward_management",
  "type": "merged_concept",
  "canonical_term": "Risk to Reward Management",
  "aliases": [
    "2R",
    "R:R",
    "R:R Ratio",
    "R:R比例",
    "Risk to Reward Ratio",
    "risk to reward ratio",
    "Risk-Reward Ratio",
    "Risk/Reward",
    "Risk/Reward Ratio",
    "RR Management",
    "rr management",
    "RRR",
    "Solid RR",
    "solid rr",
    "风险回报比"
  ],
  "school": "Risk Management",
  "definition": "Risk to Reward (RR) ratio measures the distance from entry to stop loss (risk) versus entry to target (reward), expressed as 1:X or XR. Minimum 2R is typically required. RR can be improved by dropping to lower timeframes for precise entry, adjusting stop placement (e.g., Breaker Block, Mean Threshold), or using multi-timeframe alignment.",
  "identification_rules": [
    "Determine entry price and stop loss price, calculate the point difference (risk distance).",
    "Determine target price and entry price, calculate the point difference (reward distance).",
    "Divide reward distance by risk distance to get the ratio (e.g., 80 points reward / 40 points risk = 2:1, i.e., 2R).",
    "Ratio must be ≥ 2:1 (2R standard) to consider entry; if not, adjust entry or stop.",
    "The closer entry is to stop, the higher the RR, but probability of fill may decrease; trade-off required.",
    "Drop to lower timeframes (e.g., 15m→5m→1m) to find better entry, narrowing stop while keeping target.",
    "Adjust stop placement (e.g., using Breaker Block stop, Mean Threshold entry) to optimize ratio.",
    "Multi-timeframe alignment (HTF bias → intermediate TF structure → LTF entry) yields higher RR.",
    "In A+ setups, partial profit targets can achieve different RR for each portion.",
    "Define 1R as distance from entry to stop; target distance divided by stop distance gives R multiple.",
    "Assess R value before entry; if below minimum (usually 2R), reconsider entry or adjust stop."
  ],
  "trading_implication": "RR is core for evaluating trade quality. Traders should balance RR with fill probability, not blindly chase high RR. Multi-timeframe alignment and lower timeframe precision can significantly improve RR (e.g., from 1:1.3 to 1:2.6 or higher). Higher RR allows profitability even with lower win rate. At 3R, move stop to breakeven to lock in risk-free trade.",
  "common_mistakes": [
    "Blindly pursuing highest RR while ignoring fill probability, leading to aggressive entries that don't fill.",
    "Selecting entry based solely on RR without considering market structure and PD array quality.",
    "Failing to adjust RR expectations based on timeframe and market conditions.",
    "Focusing only on absolute profit while ignoring risk distance, accepting poor ratio trades.",
    "Using the far end of an order block as stop instead of swing low, increasing stop-out risk despite higher ratio.",
    "Not adjusting entry (e.g., Mean Threshold) to optimize ratio, accepting initial poor setup.",
    "Entering on higher timeframe without dropping to lower timeframe, causing oversized stop and poor RR.",
    "Rushing entry without confirmation signals (e.g., structure break, FVG) on lower timeframe, increasing stop-out risk.",
    "Using too wide stop loss, leading to poor RR; failing to find precise entry on lower timeframe.",
    "Entering when RR is below 2R, taking excessive risk.",
    "Expanding target too far to achieve 2R, ignoring realistic liquidity targets.",
    "Analyzing only one timeframe, leading to suboptimal entry and low RR.",
    "Setting stop too wide or target too close, resulting in poor actual RR.",
    "Not calculating RR before entry, trading without quantitative basis.",
    "Accepting RR below 2R, reducing trade expectancy.",
    "Setting stop too wide, causing single trade risk too large and failing to meet 2R.",
    "Not moving stop to breakeven after reaching 3R, missing risk management opportunity.",
    "Setting stop too wide inflating RR, actual risk exceeds tolerance.",
    "Setting unrealistic target for high RR, leading to frequent stop-outs.",
    "Over-pursuing high RR while ignoring entry quality, causing frequent stops."
  ],
