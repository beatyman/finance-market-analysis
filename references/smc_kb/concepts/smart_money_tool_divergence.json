{
  "card_id": "smart_money_tool_divergence",
  "type": "merged_concept",
  "canonical_term": "Smart Money Tool Divergence",
  "aliases": [
    "Smart Money Tool",
    "SMT",
    "SMT Divergence"
  ],
  "school": "ICT",
  "definition": "A divergence between two correlated instruments (e.g., ES and NQ) where one makes a new swing high or low while the other fails to confirm that extreme, signaling weakening momentum and a potential reversal at a key level.",
  "identification_rules": [
    "Identify two correlated instruments (e.g., ES and NQ) and observe their swing highs or lows at the same time window.",
    "Confirm SMT divergence when one instrument prints a new swing high (or low) while the correlated instrument fails to reach or exceed its corresponding prior swing high (or low).",
    "The divergence must occur at or near a significant higher-time-frame level, order block, or liquidity zone to be considered actionable.",
    "The non-confirming instrument's failure swing leaves resting liquidity that can be used as a stop reference or reversal signal."
  ],
  "trading_implication": "SMT Divergence is used to validate reversal setups: when one correlated instrument sweeps a high or low that the other fails to confirm, it signals institutional selling or buying pressure. Traders use this divergence as confluence alongside order blocks, low-resistance liquidity clusters, and session timing (e.g., 8:30 or 9:30 New York) to enter counter-trend or reversal trades with defined risk.",
  "common_mistakes": [
    "Not explicitly detailed in the material beyond the single brief mention; no specific misapplication warnings are provided."
  ],
