{
  "card_id": "failed_breakout",
  "type": "merged_concept",
  "canonical_term": "Failed Breakout",
  "aliases": [
    "false breakout",
    "False Breakout"
  ],
  "school": "Price Action",
  "definition": "A failed breakout occurs when price briefly penetrates a key level (support, resistance, or moving average) but fails to sustain the move, reversing back within the level. It is often characterized by weak momentum, low volume, a long wick or close back inside, and lack of confirming price action, trapping breakout traders and signaling potential reversal or continuation.",
  "identification_rules": [
    "Price briefly breaks a level (support, resistance, moving average) but the candle closes back inside, or forms a long wick piercing and closing back inside.",
    "The breakout candle lacks momentum (small real body, decreased momentum compared to prior candles).",
    "Volume on the breakout is low or unremarkable, with no significant increase.",
    "The broken level is minor or not clearly visible on the chart.",
    "There is no confirming price action (e.g., no strong follow-through candle) after the breakout."
  ],
  "trading_implication": "Failed breakouts can signal reversals and provide entry opportunities in the opposite direction (fading the breakout) with a stop beyond the breakout extreme. They also act as a filter to avoid weak breakout signals, requiring confirmation (strong close or momentum) before entry. Use them to improve trade quality by avoiding premature entries.",
  "common_mistakes": [
    "Entering prematurely without waiting for strong confirmation (e.g., strong candle close, volume, momentum), mistaking a weak penetration for a valid breakout.",
    "Assuming any break of a level is significant, even if the level is minor or not clearly visible on the chart."
  ],
