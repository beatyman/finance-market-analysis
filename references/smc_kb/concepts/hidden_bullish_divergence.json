{
  "card_id": "hidden_bullish_divergence",
  "type": "merged_concept",
  "canonical_term": "Hidden Bullish Divergence",
  "aliases": [
    "hidden bullish div",
    "Hidden Bullish Div",
    "hidden bullish macd divergence",
    "Hidden Bullish MACD Divergence",
    "hidden bullish rsi divergence",
    "Hidden Bullish RSI Divergence"
  ],
  "school": "Indicator Based",
  "definition": "A technical pattern in an uptrend where price records a higher low while an oscillator (e.g., RSI, MACD, Stochastics) prints a lower low. This indicates trend continuation, not reversal, reflecting underlying buying pressure despite a temporary momentum decline on the oscillator.",
  "identification_rules": [
    "Confirm the market is in an established uptrend with higher highs and higher lows on the price chart.",
    "Identify at least two consecutive swing lows on price, with the second low higher than the first (higher low).",
    "For the same two swing lows, the corresponding lows on a momentum oscillator must show the second low lower than the first (lower low).",
    "Focus exclusively on the lows of both price and oscillator; ignore highs.",
    "Ensure the oscillator's lower low is distinct and well-defined, not marginal or overlapping, to avoid weak signals."
  ],
  "trading_implication": "The pattern signals that the uptrend is likely to continue, providing an opportunity to enter or add to long positions. Despite the oscillator showing weakening momentum, price maintains higher lows, demonstrating persistent buying pressure. Traders often wait for confirmation, such as a bullish candlestick pattern or a breakout of minor resistance, before acting.",
  "common_mistakes": [
    "Confusing hidden bullish divergence with regular bullish divergence, which requires lower lows on price and signals reversal, not continuation.",
    "Analyzing price or oscillator highs instead of exclusively focusing on the lows.",
    "Misapplying the pattern when not in an established uptrend.",
    "Accepting near-equal or poorly defined oscillator lows as valid divergence, leading to false signals.",
    "Using an inappropriate oscillator line (e.g., Stochastic %K instead of %D) that produces noisy divergence readings.",
    "Interpreting the oscillator's lower low as a bearish reversal signal rather than part of a continuation pattern."
  ],
