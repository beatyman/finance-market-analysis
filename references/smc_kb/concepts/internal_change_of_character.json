{
  "card_id": "internal_change_of_character",
  "type": "merged_concept",
  "canonical_term": "Internal Change of Character",
  "aliases": [],
  "school": "Price Action",
  "definition": "An internal change of character is a change of character occurring on a lower time frame, where price fails to maintain lows in a short-term uptrend or highs in a short-term downtrend, signaling a lower-timeframe trend reversal and often indicating the start of a pullback on the higher time frame.",
  "identification_rules": [
    "Identify the lower time frame trend (uptrend or downtrend) by observing a series of higher highs/higher lows (uptrend) or lower highs/lower lows (downtrend).",
    "In an uptrend on the lower time frame, an internal change of character occurs when price breaks below the most recent higher low.",
    "In a downtrend on the lower time frame, an internal change of character occurs when price breaks above the most recent lower high.",
    "The break must not be an external change of character on the higher time frame; it is confined to the lower time frame's market structure."
  ],
  "trading_implication": "An internal change of character signals a potential shift from the short-term trend to a counter-trend move, often marking the beginning of a pullback on the higher time frame. Traders can use this to anticipate pullback entries or exits, improving timing by aligning lower time frame reversals with higher time frame trend continuations.",
  "common_mistakes": [
    "Mistaking an internal change of character for an external change of character, which would incorrectly suggest a higher time frame trend reversal.",
    "Failing to confirm that the break actually violates the last swing low/high on the lower time frame before labeling it a change of character.",
    "Overlooking the need for the higher time frame trend to still be intact; an internal change of character only indicates a pullback, not a full reversal on the higher time frame."
  ],
