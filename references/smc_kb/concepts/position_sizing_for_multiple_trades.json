{
  "card_id": "position_sizing_for_multiple_trades",
  "type": "merged_concept",
  "canonical_term": "Position Sizing for Multiple Trades",
  "aliases": [],
  "school": "Risk Management",
  "definition": "A rule limiting simultaneous open positions to a maximum of three, with each subsequent entry sized at half the first trade's position to reduce cumulative risk exposure.",
  "identification_rules": [
    "Count open positions when considering a new trade; do not exceed three total at any time.",
    "For the second and third trades, calculate position size as exactly 50% of the first entry's size."
  ],
  "trading_implication": "This concept mitigates risk when multiple trade setups occur concurrently, preventing overexposure from large aggregate positions while still capitalizing on valid opportunities.",
  "common_mistakes": [
    "Opening more than three simultaneous trades, violating the exposure limit.",
    "Using the same position size for all entries instead of halving subsequent ones, leading to excessive risk."
  ],
  "related_concepts": [],
