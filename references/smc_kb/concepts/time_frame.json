{
  "card_id": "time_frame",
  "type": "merged_concept",
  "canonical_term": "Time Frame",
  "aliases": [
    "High Time Frame / Low Time Frame",
    "htf/ltf",
    "HTF/LTF",
    "timeframe",
    "Timeframe",
    "周期",
    "时间框架"
  ],
  "school": "General",
  "definition": "The period each candlestick represents on a chart, such as daily or hourly. In trading, time frames are classified as high (daily and above), medium (1-hour to daily), or low (1-minute to 1-hour). Multi-timeframe analysis combines them: higher frames for macro structure, lower frames for precise entries. For example, in the Silver Bullet strategy, the 1-hour chart defines the range and the 1-minute chart pinpoints entry.",
  "identification_rules": [
    "Check the chart's time frame setting (e.g., 1D, 4H, 1H) as it defines the period each candlestick represents.",
    "Classify a time frame as high, medium, or low based on trading style: high (daily and above), medium (1-hour to daily), low (1-minute to 1-hour).",
    "For top-down multi‑timeframe analysis, select three time frames with a ratio between 4:1 and 8:1 (e.g., daily/4‑hour/30‑min or 1‑hour/15‑min/3‑min).",
    "High time frame (HTF) is used to determine macro structure and reference points, such as the previous hour's high and low.",
    "Low time frame (LTF) is used to identify specific price action and entry signals.",
    "Both time frames must be used together: first mark the range on HTF, then observe price reaction on LTF."
  ],
  "trading_implication": "Multi-timeframe analysis improves trading precision. Higher frames reveal long-term trends and key support/resistance; lower frames pinpoint precise entry/exit signals. Top-down analysis dictates starting on the highest time frame to gauge overall direction, then refining to lower frames for timing entries. Proper time frame selection (with a 4:1–8:1 ratio) prevents conflicting signals and increases trade probability. In the Silver Bullet strategy, the 1-hour chart provides the trading framework (9:00 a.m. high/low), and the 1-minute chart is used within a specific time window (10-11 a.m.) to find entry opportunities.",
  "common_mistakes": [
    "Analyzing on only a single time frame, ignoring higher-period structure.",
    "Acting on signals from a low time frame without confirming the higher time frame conditions."
  ],
