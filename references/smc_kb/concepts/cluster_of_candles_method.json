{
  "card_id": "cluster_of_candles_method",
  "type": "merged_concept",
  "canonical_term": "Cluster of Candles Method",
  "aliases": [],
  "school": "Smart Money Concepts",
  "definition": "A method to draw supply/demand zones by identifying a cluster of candles that form a strong impulsive move, where the origin candle completely engulfs the bodies of preceding candles, signaling a significant shift in supply or demand.",
  "identification_rules": [
    "Look for a cluster of at least 2-3 candles showing a strong directional (impulsive) move with large bodies.",
    "Confirm the origin candle of the cluster engulfs the real bodies of the immediately preceding candles (e.g., 3-4 candles).",
    "Draw a rectangular zone covering the highest to lowest point of the cluster, extending it to the right as a potential future support/resistance area."
  ],
  "trading_implication": "It identifies potential reaction zones (demand or supply) for trade entries. Traders wait for price to return to the drawn zone, then look for a candlestick reaction or confirmation before entering in the direction of the initial impulsive move. Stop-loss can be placed below the zone low (for longs).",
  "common_mistakes": [
    "No explicit common mistakes mentioned in the material."
  ],
