{
  "card_id": "liquidity_pool",
  "type": "merged_concept",
  "canonical_term": "Liquidity Pool",
  "aliases": [
    "Liquidity",
    "liquidity level",
    "Liquidity Level"
  ],
  "school": "Smart Money Concepts (SMC)",
  "definition": "Price levels where stop-losses and pending orders concentrate, typically above swing highs (buy-side) and below swing lows (sell-side), including equal highs/lows and key S/R. Institutions manipulate price into these pools to trigger orders before continuing or reversing. They range from static zones (order blocks, equal highs/lows) to dynamic liquidity (fair value gaps, swing waves).",
  "identification_rules": [
    "Identify equal highs (two or more swing highs at identical level) as buy-side liquidity pools.",
    "Identify equal lows (two or more swing lows at identical level) as sell-side liquidity pools.",
    "Mark buy-side liquidity above significant swing highs and sell-side liquidity below significant swing lows.",
    "Identify traditional support/resistance levels with multiple price rejections as potential liquidity zones.",
    "Locate trendlines connecting minor swing highs/lows; stop-loss orders accumulate just beyond the trendline, forming a liquidity pool.",
    "Detect double/triple tops and bottoms, where stop orders cluster beyond pattern necks, creating a liquidity pool.",
    "Note that liquidity pools frequently form at key structural levels: order blocks, supply/demand zones, Fibonacci levels, and fair value gaps (dynamic liquidity)."
  ],
  "trading_implication": "Liquidity pools attract price, which often sweeps them to trigger orders before reversing or continuing. Traders wait for a confirmed liquidity sweep (price briefly breaks the level and reverses) to enter in the reversal direction, as this clears pending orders and validates the zone. Failing to wait risks being trapped; entering after a sweep at a point of interest increases probability. Secure partial profits before untapped pools to avoid adverse reactions.",
  "common_mistakes": [
    "Entering a trade before a liquidity sweep has occurred, hoping for a reversal without confirmation.",
    "Assuming a support/resistance or key zone will hold without allowing for a liquidity sweep (fake breakout) first.",
    "Treating a liquidity sweep as a valid break of structure and trading in the breakout direction.",
    "Failing to secure partial profits before price reaches an untapped liquidity zone.",
    "Failing to wait for reversal confirmation after a liquidity grab.",
    "Failing to recognize liquidity zones, leading to trade losses.",
    "Assuming a demand/supply area is safe to trade while ignoring an unswept liquidity pool nearby."
  ],
