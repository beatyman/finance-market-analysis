{
  "card_id": "failure_test",
  "type": "merged_concept",
  "canonical_term": "Failure Test",
  "aliases": [
    "False Breakout"
  ],
  "school": "Price Action",
  "definition": "A false breakout where price temporarily penetrates a key level (support/resistance, supply/demand zone, or prior swing high/low) and then sharply reverses back, closing beyond the level. It confirms the level's strength, signals a potential reversal, and is used for entries and refining zone boundaries.",
  "identification_rules": [
    "Identify a clearly defined key level (support/resistance, supply/demand zone, or prior swing high/low).",
    "Price temporarily breaks beyond this level, often with a wick, but the break is short-lived.",
    "The price quickly reverses, and the confirming candle closes back beyond the broken level, signaling a false breakout.",
    "The break may occur on low volume, indicating weak momentum.",
    "The pattern is strengthened by additional confluence such as reversal candlestick patterns, divergence, or proximity to supply/demand zones."
  ],
  "trading_implication": "A failure test validates the significance of the level and signals a potential reversal. Traders typically enter on the close of the reversal candle, placing a stop-loss just beyond the extreme of the false break. Profit targets may use risk-to-reward ratios or measured moves. The pattern is more reliable with confluences like candlestick patterns, volume, or divergence. In supply/demand analysis, the zone is adjusted to include the failure test wick.",
  "common_mistakes": [
    "Entering prematurely before the reversal candle close confirms the failure.",
    "Confusing a failure test with a genuine breakout, leading to wrong-direction entries.",
    "Redrawing supply/demand zones incorrectly by not extending boundaries to include the failure test wick.",
    "Ignoring broader market structure and trend context.",
    "Treating any small break as a failure test without a clearly defined prior level or additional confluence.",
    "Using rigid entry rules (e.g., three-candle cluster) without accounting for the failure test wick."
  ],
