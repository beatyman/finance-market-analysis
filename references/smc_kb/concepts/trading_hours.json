{
  "card_id": "trading_hours",
  "type": "merged_concept",
  "canonical_term": "Trading Hours",
  "aliases": [],
  "school": "General",
  "definition": "The specific times and days when a financial market is open for trading; stock markets operate during local business hours and are closed on weekends, cryptocurrency markets are open 24/7, and forex markets are open 24 hours a day, 5 days a week (closed on weekends).",
  "identification_rules": [
    "Check the exchange's official schedule: stock markets have set local trading sessions (e.g., 9:30–16:00 local time) and are closed on weekends.",
    "Cryptocurrency markets never close; trading is available 24 hours a day, 7 days a week.",
    "Forex markets operate continuously from Sunday evening (UTC) to Friday evening, closing only on weekends."
  ],
  "trading_implication": "Knowing trading hours allows traders to plan entries and exits; crypto's 24/7 schedule offers maximum flexibility but requires constant monitoring, while stock sessions concentrate activity in specific periods, and forex's 24/5 provides broad accessibility with weekend gaps.",
  "common_mistakes": [
    "Assuming all markets have identical trading hours, leading to attempted trades outside open sessions.",
    "Not accounting for time zone differences when trading stock markets in different countries."
  ],
