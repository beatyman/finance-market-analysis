{
  "card_id": "silver_bullet",
  "type": "merged_concept",
  "canonical_term": "Silver Bullet",
  "aliases": [
    "am silver bullet",
    "AM Silver Bullet",
    "silver bullet window",
    "Silver Bullet Window"
  ],
  "school": "ICT",
  "definition": "A one-hour trading window from 10:00 to 11:00 Eastern Standard Time that narrows down the New York AM kill zone. Within this window, traders look for opportunities where price draws toward a liquidity pool or drawn-on liquidity to find high-probability entries.",
  "identification_rules": [
    "Mark the window from 10:00 EST (start) to 11:00 EST (end) using vertical lines or a session highlight on the chart.",
    "Within the 1-hour window, identify a liquidity pool or drawn-on liquidity that price is reaching toward.",
    "Use indicator settings such as customizing time stamps to 10 and 11, or repurposing a session (e.g. New York lunch) as 'AM Silver Bullet' to visualize the window.",
    "Observe whether price is moving toward a liquidity pool or drawn-on liquidity within the window."
  ],
  "trading_implication": "The Silver Bullet narrows the broader kill zone into a precise 1-hour entry window where high-probability moves toward liquidity are anticipated. Traders use it to time entries during the New York AM session, looking for price to draw into a liquidity pool within this window. It serves as a temporal filter, ensuring setups align with a high-probability time-of-day, and is typically paired with other ICT tools (POIs, liquidity targets) for execution.",
  "common_mistakes": [
    "Not explicitly stated in the material."
  ],
