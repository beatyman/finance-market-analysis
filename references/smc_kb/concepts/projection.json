{
  "card_id": "projection",
  "type": "merged_concept",
  "canonical_term": "Projection",
  "aliases": [
    "London Manipulation Projection",
    "london manipulation projection",
    "manipulation leg projection",
    "Manipulation Leg Projection",
    "Price Projection",
    "price projection",
    "Standard Deviation Projection"
  ],
  "school": "ICT",
  "definition": "A technique that measures the height of a manipulation leg (from high to low or low to high) and projects that distance from the leg's endpoint or breakout point along the expected direction, generating multiple target levels (e.g., 2x, 2.5x, 4x, 4.5x) corresponding to standard deviation levels (-2, -2.5, -4, -4.5) for profit targets.",
  "identification_rules": [
    "Identify a complete low-high-low-high structure (precursor to breaker block) or a manipulation leg: price sweeps old high/low (liquidity sweep) then reverses, defining start and end extremes.",
    "Measure the vertical distance from the start extreme to the end extreme of the manipulation leg.",
    "Project that distance from the leg's endpoint (or breakout point) along the expected direction, marking levels at 2x, 2.5x, 4x, 4.5x (corresponding to -2, -2.5, -4, -4.5 standard deviations).",
    "Focus on -2 to -2.5 as primary target zone, -4 to -4.5 as extension zone.",
    "Check if projected levels align with existing PD Array (equal highs/lows, order blocks, FVG, old highs/lows) for confluence.",
    "Use Fibonacci projection tool from start to end of manipulation leg to read standard deviation levels.",
    "In breaker block, manipulation leg is the move from high to lower low in a low-high-lower low structure; project from the breakout high."
  ],
  "trading_implication": "After manipulation phase confirmation (e.g., CISD, AMD leg completion, London liquidity sweep), use -2 to -2.5 standard deviation as primary take-profit, -4 to -4.5 as extension. Confluence with PD Array increases reliability. If near target gives less than 2R, use projection target instead. Combine with OTE entry for 3R+ targets.",
  "common_mistakes": [
    "Incorrectly identifying the manipulation leg (must be the down move in low-high-low-high structure, not arbitrary price segment).",
    "Projecting in wrong direction (up for bullish structure, down for bearish).",
    "Ignoring confluence with breaker block/FVG/PD Array, leading to unsupported targets.",
    "Over-relying on projection targets while neglecting quick 2R opportunities.",
    "Selecting wrong start point for manipulation leg (should be the extreme that initiated the sweep).",
    "Using projection targets without waiting for manipulation phase confirmation (e.g., CISD).",
    "Failing to align projection targets with existing PD Array for validation.",
    "Not using multiple timeframe projection confirmation."
  ],
