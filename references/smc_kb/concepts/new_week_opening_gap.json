{
  "card_id": "new_week_opening_gap",
  "type": "merged_concept",
  "canonical_term": "New Week Opening Gap",
  "aliases": [
    "nwog",
    "NWOG",
    "周一开盘缺口"
  ],
  "school": "ICT",
  "definition": "The price range between the prior Friday's closing price and the Sunday/Monday opening session. Its consequent encroachment (50% midpoint) is marked as a support/resistance reference level where price often reacts during the following trading week.",
  "identification_rules": [
    "Locate the closing price of the last Friday candle on a daily or weekly chart and the opening price of the first session of the new week (typically Sunday open for forex/futures). The price range between them, if there is a gap, defines the New Week Opening Gap.",
    "Mark the gap's high and low boundaries and calculate the consequent encroachment (50% level) as a horizontal reference line.",
    "Extend the gap’s high, low, and consequent encroachment lines forward into the new trading week to monitor price reactions.",
    "Observe whether price retests and fills the gap region on Monday or subsequent days."
  ],
  "trading_implication": "The New Week Opening Gap and its consequent encroachment (50% midpoint) function as key support or resistance levels where price often reacts. They serve as price targets and help gauge intraweek directional bias. Confluence with other reference points (e.g., previous day high/low) can strengthen trade setups, anticipating reactions, reversals, or expansions toward the gap, especially when confirmed by lower time frame signals.",
  "common_mistakes": [
    "Not explicitly stated in the material."
  ],
