{
  "card_id": "continuation_closure",
  "type": "merged_concept",
  "canonical_term": "Continuation Closure",
  "aliases": [
    "continuation candle closure"
  ],
  "school": "ICT",
  "definition": "A candle closure where price sweeps the previous candle's high or low and closes beyond that level in the same direction, signaling trend continuation. In the Candle 3 Closure variant, the third candle need not sweep but must close through the second candle's body.",
  "identification_rules": [
    "Mark the previous candle's high and low on the chart.",
    "If price trades through the previous candle's low and closes below it, that is a bearish continuation closure.",
    "If price trades through the previous candle's high and closes above it, that is a bullish continuation closure.",
    "The close must be beyond the swept level (not back inside the previous candle's range — otherwise it becomes a reversal closure).",
    "Candle 3 Closure variant: The third candle does not break the second candle's high/low, but its close must penetrate the second candle's body to confirm continuation.",
    "The pattern should occur at high time frame key levels (e.g., FVG, swing highs/lows) for higher probability.",
    "Can be used with Equilibrium (0.5 Fibonacci level) to anticipate expansion in the next candle."
  ],
  "trading_implication": "A continuation closure confirms trend continuation, not reversal. After identification, expect the next candle to expand in the same direction. In bullish scenarios, target the upper half of the expansion candle; in bearish, the lower half. Use with high time frame key levels and Equilibrium for better accuracy. Contrast with reversal closure to avoid false signals.",
  "common_mistakes": [
    "Confusing continuation closure with reversal closure: reversal closure sweeps a level but closes back inside the previous candle's range.",
    "Confusing Candle 2 Closure with Candle 3 Closure: Candle 2 requires a sweep; Candle 3 does not require a sweep but needs close through the body.",
    "Counting every sweep+close pattern without high time frame key level context, leading to signal overload."
  ],
