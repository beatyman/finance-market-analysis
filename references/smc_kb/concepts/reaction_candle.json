{
  "card_id": "reaction_candle",
  "type": "merged_concept",
  "canonical_term": "Reaction Candle",
  "aliases": [],
  "school": "Smart Money Concepts (SMC)",
  "definition": "A candle (or series of candles) that appears within a point of interest after the initial push, showing rejection from that zone, indicating a potential shift in market sentiment and reversal.",
  "identification_rules": [
    "Must occur after an initial candle pushes into an unmitigated point of interest (supply/demand zone or order block).",
    "The reaction candle closes in the opposite direction of the initial push, demonstrating rejection (e.g., bearish candle after bullish push into supply).",
    "Can manifest as a single candle or multiple candles that collectively exhibit rejection.",
    "Rejection phase is confirmed by a subsequent engulfing candle that breaks out of the zone and engulfs the reaction candle(s)."
  ],
  "trading_implication": "The reaction candle warns that the zone is holding and a reversal is probable. Traders should not enter immediately; instead, wait for the engulfing breakout candle to confirm the reversal, enabling a safer entry with a defined stop-loss placed above/below the reaction candle's high/low.",
  "common_mistakes": [
    "Identifying a reaction candle at random or previously mitigated levels instead of only at unmitigated points of interest.",
    "Assuming the reaction candle must be a single candle; it can be multiple candles showing gradual rejection.",
    "Entering a trade based solely on the reaction candle without waiting for the engulfing breakout confirmation."
  ],
