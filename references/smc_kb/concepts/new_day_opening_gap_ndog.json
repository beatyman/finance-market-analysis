{
  "card_id": "new_day_opening_gap_ndog",
  "type": "merged_concept",
  "canonical_term": "New Day Opening Gap (NDOG)",
  "aliases": [],
  "school": "ICT",
  "definition": "The gap between the previous day's close and the current day's open (midnight open price). Used as a reference level for intraday bias and a consequent encroachment zone within AMD analysis.",
  "identification_rules": [
    "Calculate the gap as the difference between the previous day's closing price and the current day's midnight opening price.",
    "Mark the opening gap zone on the chart spanning from the close to the open price.",
    "Identify the consequent encroachment (50% midpoint) of the gap for potential reaction levels."
  ],
  "trading_implication": "The NDOG serves as a point of interest for intraday bias: price remaining above it indicates bullish intent, while price below suggests bearish intent. Its consequent encroachment often acts as a reaction level for entries or targets within the AMD (Power of Three) framework.",
