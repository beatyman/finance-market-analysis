{
  "card_id": "tradeoffs",
  "type": "merged_concept",
  "canonical_term": "Tradeoffs",
  "aliases": [],
  "school": "Indicator Based",
  "definition": "The balance between an indicator's responsiveness (early signals) and smoothness (reducing false signals) when selecting moving average type or settings; optimal choice depends on asset volatility and trading strategy.",
  "identification_rules": [
    "Compare the number of price breaches that reverse quickly (false signals) against how promptly the indicator reacts to genuine trend changes.",
    "Evaluate the asset's volatility: high volatility often requires smoother indicators to filter noise.",
    "Align indicator choice with trading approach: breakout strategies favor smoother indicators to reduce false breaks, while fast scalping may prefer more responsive ones."
  ],
  "trading_implication": "Guides selection of moving average type: more responsive (e.g., HMA) catches moves earlier but generates many false signals, suitable for short-term traders who can act quickly; smoother (e.g., ALMA) filters noise and respects trends better, preferred for trend following and avoiding false breakouts.",
  "common_mistakes": [
    "Assuming faster-reacting indicators are always superior.",
    "Applying the same moving average to all assets regardless of their volatility characteristics.",
    "Ignoring the impact of trading strategy on the optimal balance between responsiveness and false signals."
  ],
