{
  "card_id": "secondary_test",
  "type": "merged_concept",
  "canonical_term": "Secondary Test",
  "aliases": [
    "ST",
    "st"
  ],
  "school": "Wyckoff",
  "definition": "A Wyckoff accumulation event where price retests the selling climax (SC) low after the automatic rally (AR). The test can be at or slightly above the SC low, helping confirm the start of a trading range and potential accumulation.",
  "identification_rules": [
    "It occurs after the automatic rally (AR) in a Wyckoff accumulation sequence.",
    "Price moves down toward the selling climax (SC) low.",
    "The low of the secondary test is at or slightly above the SC low.",
    "It should not substantially break the SC low (a break would signal a potential spring).",
    "It is easier to identify when the test precisely reaches the SC low."
  ],
  "trading_implication": "The secondary test indicates that selling pressure from the selling climax is being absorbed, suggesting the downtrend is ending and an accumulation range is forming. It provides early confirmation for traders to anticipate a trading range and potential future markup.",
  "common_mistakes": [
    "Misidentifying a shallow pullback as a secondary test when it does not closely approach the SC low, leading to premature accumulation conclusions."
  ],
