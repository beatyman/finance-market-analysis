{
  "card_id": "bear_flag",
  "type": "merged_concept",
  "canonical_term": "Bear Flag",
  "aliases": [
    "bar flag",
    "Bar Flag"
  ],
  "school": "Price Action",
  "definition": "A bearish continuation pattern forming after a downtrend, where price consolidates in an upward-sloping channel before breaking down to resume the downtrend.",
  "identification_rules": [
    "Identify a clear downtrend with lower highs and lower lows.",
    "Spot a consolidation zone moving slightly upward, bounded by two parallel rising trendlines (the flag).",
    "The flag may show minor higher highs and higher lows or appear more sideways, but it must slope against the downtrend.",
    "Confirm the pattern when price breaks below the lower flag line with a decisive close (breakdown), ideally with increased momentum."
  ],
  "trading_implication": "The Bear Flag signals continuation of the downtrend. Traders enter short on the breakdown, often waiting for a candle close below the flag's support or a confirmation candle. A stop-loss is placed just above the flag's highest point. Targets are set using the measured move of the preceding impulsive wave (projected from the flag's high) or a favorable risk-to-reward ratio (e.g., 1:2).",
  "common_mistakes": [
    "Expecting the flag to always print textbook higher highs and higher lows; real flags may be less defined.",
    "Entering before the breakout close or confirmation candle, risking a false breakdown.",
    "Misidentifying a minor consolidation as a Bear Flag without a strong preceding downtrend."
  ],
  "related_concepts": [],
