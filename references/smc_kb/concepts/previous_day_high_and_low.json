{
  "card_id": "previous_day_high_and_low",
  "type": "merged_concept",
  "canonical_term": "Previous Day High and Low",
  "aliases": [
    "前一交易日高低点",
    "昨日高低"
  ],
  "school": "ICT",
  "definition": "The high and low of the prior trading day, used to mark key liquidity levels. In trending markets, price tends to reach for the previous day high in uptrends and previous day low in downtrends. Failure to close outside can signal a bias reversal.",
  "identification_rules": [
    "Identify the previous day's high and low from a daily candlestick chart and extend them as horizontal levels onto the current day.",
    "In a clear uptrend (price making higher highs), use the previous day high as the target for continuation.",
    "In a clear downtrend (price making lower lows), use the previous day low as the target for continuation.",
    "If price reaches the previous day high/low but fails to close beyond it and instead closes back inside the range, interpret this as a potential reversal and anticipate a move to the opposite level.",
    "A daily close above the previous day high confirms bullish bias and continuation targeting higher levels; a close below the previous day low confirms bearish bias.",
    "Observe price approaching, touching, or breaking these levels on lower timeframes (e.g., 4H, 1H)."
  ],
  "trading_implication": "Previous day high and low serve as key liquidity levels for establishing daily bias and draw on liquidity. In uptrends, price is drawn to the previous day high; in downtrends, to the previous day low. A failure to displace through these levels followed by a close back inside the range signals a possible bias flip, with the opposite level becoming the new target. This concept underpins the Next Day Model and daily directional setups.",
  "common_mistakes": [
    "Assuming price will always reach the previous day high or low without considering consolidation or range-bound days where neither level is taken.",
    "Treating a mere touch of the previous day high/low as a reversal signal without waiting for a close back inside the range or displacement failure.",
    "Entering on a return to the level without confirming the day's trend context (e.g., using the high as a short target in a strong uptrend)."
  ],
