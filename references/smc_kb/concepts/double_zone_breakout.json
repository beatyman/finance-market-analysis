{
  "card_id": "double_zone_breakout",
  "type": "merged_concept",
  "canonical_term": "Double Zone Breakout",
  "aliases": [],
  "school": "ICT",
  "definition": "A pattern where price breaks and closes beyond two consecutive supply or demand zones in a single leg, confirming a change of character and providing a high-probability entry with strong confluence.",
  "identification_rules": [
    "Identify a change of character pattern with a break of a recent major swing point.",
    "Confirm price has broken and closed beyond the first supply or demand zone in the direction of the breakout.",
    "Verify that price continues and breaks with a close beyond the second, adjacent supply or demand zone in the same direction.",
    "For maximum effectiveness, the breakout should occur in a single impulsive leg without significant pullbacks between zones."
  ],
  "trading_implication": "A double zone breakout serves as strong confluence for trend continuation or reversal trades, indicating robust momentum. It often leaves inefficiencies that price may retrace to fill, offering entry opportunities after the breakout. Traders can place limit orders at the newly formed opposite zone (extreme zone) with stops beyond it and targets at higher time frame levels or unmitigated zones.",
  "common_mistakes": [
    "Entering trades from a decisional zone (a lower supply/demand zone formed after a pullback) instead of waiting for the extreme zone to be reached, risking being stopped out by a liquidity sweep."
  ],
  "related_concepts": [],
  "illustrated_by_cases": [
