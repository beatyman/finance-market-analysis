{
  "card_id": "daily_low",
  "type": "merged_concept",
  "canonical_term": "Daily Low",
  "aliases": [],
  "school": "Smart Money Concepts (SMC)",
  "definition": "The lowest price reached during the trading day, acting as a liquidity zone where stop-losses from long positions accumulate. Price often briefly breaks below to sweep this liquidity before reversing upward.",
  "identification_rules": [
    "Mark the daily low as the lowest price of the current trading day.",
    "Wait for price to approach this level; it often briefly breaks below to trigger stop-losses.",
    "Look for a sharp reversal after the break, such as a bullish momentum candlestick or change of character.",
    "Confirm the trade direction aligns with the overall trend on a higher timeframe."
  ],
  "trading_implication": "After a liquidity sweep below the daily low, price often reverses, offering a buy entry. Place a stop-loss just below the sweep low and target the next key resistance or supply zone.",
  "common_mistakes": [
    "Entering long before the liquidity sweep below the daily low is complete.",
    "Ignoring the higher timeframe trend when taking a reversal trade.",
    "Failing to wait for a confirmed reversal signal after the break."
  ],
