{
  "card_id": "point_of_control",
  "type": "merged_concept",
  "canonical_term": "Point of Control",
  "aliases": [
    "poc",
    "POC"
  ],
  "school": "Volume Analysis",
  "definition": "The price level with the highest traded volume within the visible range on a volume profile, indicated by a horizontal line at the peak of the volume bars.",
  "identification_rules": [
    "Locate the visible range volume profile on the chart; the Point of Control is the horizontal line at the price level where the volume bar is tallest.",
    "When the chart's visible range is adjusted by zooming in or out, the Point of Control line automatically updates to reflect the new highest-volume level."
  ],
  "trading_implication": "The Point of Control marks the area of greatest trading activity, often forming a trading range rather than a definitive support or resistance. Price may consolidate or stall around this level. Key breakout levels tend to occur just above or below high-volume zones, while low-volume areas may indicate fast price moves.",
  "common_mistakes": [
    "Interpreting the Point of Control as a strong support or resistance level; it is more commonly a trading range or area of consolidation."
  ],
