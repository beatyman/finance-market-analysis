{
  "card_id": "delta",
  "type": "merged_concept",
  "canonical_term": "Delta",
  "aliases": [],
  "school": "Volume Analysis",
  "definition": "Delta is a setting in the Volume Footprint chart that displays the net difference between buyer and seller volume at each price level, shown as green (net buying) or red (net selling) boxes, used to assess buying/selling pressure.",
  "identification_rules": [
    "Set the Volume Footprint type to 'Delta' to display net volume differences instead of separate buy/sell columns.",
    "Green boxes represent net buying volume, indicating bullish pressure at that price level.",
    "Red boxes represent net selling volume, indicating bearish pressure at that price level.",
    "During uptrends, green boxes should dominate; during downtrends, red boxes should dominate."
  ],
  "trading_implication": "Delta confirms trend strength and breakout validity. A surge in green boxes during an upside breakout signals strong buying interest, supporting the move. In uptrends, persistent red boxes warn of weakening momentum and potential reversal.",
