{
  "card_id": "downtrend",
  "type": "merged_concept",
  "canonical_term": "Downtrend",
  "aliases": [],
  "school": "Price Action",
  "definition": "A bearish market phase characterized by a sequence of lower lows and lower highs, where impulsive moves break prior swing lows and pullbacks form lower highs below previous swing highs, reflecting sustained downward momentum.",
  "identification_rules": [
    "Price forms a sequence of lower lows and lower highs over the observed time frame.",
    "A break of structure (BOS) occurs when price closes below a previous major low, confirming downtrend continuation.",
    "The trend is valid as long as price remains below the most recent major high; internal retracements are irrelevant.",
    "Once price breaks and closes above the most recent major high, the downtrend is considered over.",
    "Lower lows are created by impulsive moves that break prior swing lows.",
    "Lower highs are produced by pullbacks that fail to exceed the prior swing high.",
    "The downtrend is intact as long as price remains below the high of the last pullback; a break above this high signals a potential trend change."
  ],
  "trading_implication": "During a downtrend, traders prioritize short entries, targeting lower lows and new break of structure points. Pullbacks to internal highs or supply zones offer selling opportunities, with stop losses placed above the most recent major high. The trend's direction provides a bias, and counter-trend trades are avoided until a confirmed reversal signal appears.",
  "common_mistakes": [
    "Misidentifying major swing points, leading to incorrect trade direction.",
    "Treating a corrective upward move as a trend reversal before the major high is broken.",
    "Focusing on internal structure noise and ignoring the external major high bound.",
    "Misidentifying a complex pullback as the start of a trend reversal due to choppy price action.",
    "Failing to use objective rules and instead relying on subjective judgment to determine trend direction.",
    "Prematurely declaring the downtrend over without waiting for price to break above the critical swing high."
  ],
