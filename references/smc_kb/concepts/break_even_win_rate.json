{
  "card_id": "break_even_win_rate",
  "type": "merged_concept",
  "canonical_term": "Break-even Win Rate",
  "aliases": [],
  "school": "Risk Management",
  "definition": "The minimum win rate required for a trading strategy to neither profit nor lose, given a fixed risk-to-reward ratio. It is calculated as 1 divided by (1 + reward-to-risk ratio). For example, a 1:2 risk-to-reward requires a win rate above 33.3% to be profitable.",
  "identification_rules": [
    "Determine the risk-to-reward ratio (e.g., 1:2 means risking 1 unit to gain 2).",
    "Apply the formula: Break-even win rate = 1 / (1 + reward-to-risk).",
    "Compare the strategy's actual win rate to the break-even win rate; profitability requires actual win rate > break-even."
  ],
  "trading_implication": "It quantifies the necessary win rate for a strategy's viability. Traders use it to assess if a strategy with a given risk-to-reward ratio and backtested win rate can be profitable. Positive expected value requires the win rate to exceed this threshold.",
