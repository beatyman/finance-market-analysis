{
  "card_id": "pivot_points",
  "type": "merged_concept",
  "canonical_term": "Pivot Points",
  "aliases": [
    "pivot high",
    "Pivot High",
    "Pivot High Low",
    "pivot high low",
    "Pivot Low",
    "pivot low",
    "pivot point",
    "Pivot Point",
    "Pivot Points High Low",
    "pivot points high low"
  ],
  "school": "Indicator Based",
  "definition": "A pivot point is a significant swing high or low where a candle's high (for pivot high) or low (for pivot low) is the highest or lowest over a specified number of preceding and following candles, typically 20. Clusters of these pivots at the same price level form key support or resistance zones, with longer periods filtering minor swings to highlight stronger market structure.",
  "identification_rules": [
    "A pivot high occurs when a candle's high is the highest over a specified number of preceding and following candles (commonly 20 on each side).",
    "A pivot low occurs when a candle's low is the lowest over the same specified number of preceding and following candles.",
    "Increase the lookback period to filter out minor pivots; longer periods isolate more significant swing points.",
    "Identify price levels where multiple pivot points (highs or lows) cluster at approximately the same price.",
    "Draw horizontal support lines through clusters of pivot lows and resistance lines through clusters of pivot highs.",
    "The strength of the support/resistance level increases with the number of clustered pivots."
  ],
  "trading_implication": "Pivot points identify key support and resistance zones formed by clusters of multiple pivot highs or lows. These zones are significant levels where price often reverses or stalls. A breakout through such a zone can lead to a strong directional move, and the broken level may act as new support/resistance. Traders use these levels to anticipate bounces or breakouts, often seeking confluence with indicators like MACD or market structure breaks for entries. Trendlines connecting pivots can reveal chart patterns like triangles, aiding breakout direction predictions.",
  "common_mistakes": [
    "Using too short a lookback period (e.g., 5 or 10) generates excessive minor pivots, obscuring significant levels.",
    "Treating a single pivot point as strong support/resistance without considering clustering of multiple pivots reduces effectiveness."
  ],
