{
  "card_id": "rsi_divergence",
  "type": "merged_concept",
  "canonical_term": "RSI Divergence",
  "aliases": [
    "bearish divergence",
    "bullish divergence",
    "divergence",
    "regular divergence"
  ],
  "school": "Indicator Based",
  "definition": "RSI divergence occurs when price and the Relative Strength Index move in opposite directions, signaling weakening momentum and a potential trend reversal. In a downtrend, price makes a lower low but RSI makes a higher low (bullish divergence); in an uptrend, price makes a higher high but RSI makes a lower high (bearish divergence).",
  "identification_rules": [
    "For bearish reversal: price records a higher high while RSI records a lower high.",
    "For bullish reversal: price records a lower low while RSI records a higher low.",
    "Confirm RSI is in overbought (>70) or oversold (<30) area to increase reliability.",
    "Apply only in clearly trending markets; avoid during consolidation/ranging.",
    "Give more weight to divergences that form after a sustained, long-term trend.",
    "Do not trade divergence alone; always wait for market structure confirmation (e.g., CHoCH)."
  ],
  "trading_implication": "RSI divergence indicates weakening momentum and potential trend reversal. Traders use it to anticipate reversals, but it should be combined with other confirmations like CHoCH, supply/demand zones, liquidity sweeps, or premium/discount zones for higher-probability entries. It is not a standalone signal; its reliability increases when occurring after a prolonged trend and in overbought/oversold conditions.",
  "common_mistakes": [
    "Entering a trade immediately on the first divergence signal without structural confirmation, leading to premature entries as price may continue the trend.",
    "Applying divergence in ranging or consolidating markets, where signals are often false.",
    "Ignoring the context of trend strength and duration; divergences after short-term moves are less reliable."
  ],
