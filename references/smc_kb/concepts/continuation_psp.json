{
  "card_id": "continuation_psp",
  "type": "merged_concept",
  "canonical_term": "Continuation PSP",
  "aliases": [
    "Continuation Precision Swing Point",
    "continuation precision swing point",
    "持续精密摆动点"
  ],
  "school": "ICT",
  "definition": "A Precision Swing Point (two correlated assets closing in opposite directions on the same candle) that forms after the reversal low/high of the day is confirmed, while the draw on liquidity remains open. It signals a continuation entry in the established direction, not a reversal.",
  "identification_rules": [
    "Confirm the reversal low/high of the day has already formed (e.g., via V-shaped signature, two-stage SMT at a key level).",
    "Verify the draw on liquidity (target high/low) remains open in the direction of bias.",
    "Identify two correlated assets closing in opposite directions on the same candle during the retracement after the initial reversal.",
    "The PSP must oppose the current minor pullback direction, aligning with the larger directional draw, not against it.",
    "One asset retraces into a prior range, closing to form a PSP; the other asset breaks above the PSP high, forming a two-stage SMT that does not create a new swing point."
  ],
  "trading_implication": "Continuation PSPs are used as secondary entries when a trader missed the initial reversal entry at the actual low/high of the day. Enter on the continuation PSP candle (or its fair value gap) targeting the open draw on liquidity. In the RB example, the trader entered on the hourly continuation PSP and targeted the swing high for approximately 2.8R. Critically, never trade a PSP opposing the draw on liquidity as a reversal signal — it is only valid as continuation.",
  "common_mistakes": [
    "Misinterpreting a continuation PSP as a reversal signal and entering against the draw on liquidity, leading to being stopped out.",
    "Confusing the continuation PSP with the initial reversal PSP, which forms at the low/high of the day with a two-stage SMT.",
    "Ignoring whether the target is still open; trading continuation PSP after the target has been reached.",
    "Failing to distinguish continuation PSP from standard two-stage PSP based on whether a new swing point is created.",
    "Marking a continuation PSP when the correlated asset has not formed a two-stage SMT."
  ],
  "related_concepts": [],
  "merge_strategy": "llm_synthesis",
  "merge_model": "deepseek/deepseek-chat",
  "merge_notes": "School conflict: one card says SMC, the other ICT. Picked ICT by majority (2 ICT vs 1 SMC). Definition merged: both agree on two correlated assets closing opposite, but the first card adds detail about one asset retracing into range and the other breaking high without new swing point. Identification rules combined.",
  "warnings": [
    "school_conflict: ['ICT', 'SMC']"
  ],
