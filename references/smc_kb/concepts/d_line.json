{
  "card_id": "d_line",
  "type": "merged_concept",
  "canonical_term": "%D line",
  "aliases": [
    "Percentage D Line",
    "percentage d line",
    "Slow Stochastic Line",
    "slow stochastic line",
    "stochastic RSI %D",
    "stochastic rsi %d"
  ],
  "school": "Indicator Based",
  "definition": "The %D line is the slow stochastic line in the Stochastic RSI indicator, calculated as a 3-period simple moving average of the %K line. It smooths the %K line, making it less volatile and suitable for divergence analysis, where it provides fewer false signals than %K.",
  "identification_rules": [
    "Displayed as an orange line in the Stochastic RSI indicator panel, typically following the %K line.",
    "It is a moving average of the %K line, making it slower and less volatile.",
    "It tends to move higher when the %K line is above it and lower when the %K line is below it.",
    "Crosses of the %K line above or below the %D line generate bullish or bearish signals respectively.",
    "Preferred over %K for divergence analysis because it reaches extreme values less frequently."
  ],
  "trading_implication": "Used for divergence analysis: bearish when price makes higher high but %D lower high; bullish when price makes lower low but %D higher low. Acts as a signal line: %K crossing above %D indicates bullish momentum, below bearish. Smoothing filters noise but introduces lag. Overbought (>80) and oversold (<20) readings can anticipate reversals but require confirmation.",
  "common_mistakes": [
    "Using %K rather than %D for divergence, leading to false signals due to %K's frequent extreme readings.",
    "Treating overbought/oversold readings on %D as immediate reversal signals without confirmation, as Stochastic RSI can persist in these zones during strong trends."
  ],
