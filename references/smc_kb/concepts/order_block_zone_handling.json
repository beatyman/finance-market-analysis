{
  "card_id": "order_block_zone_handling",
  "type": "merged_concept",
  "canonical_term": "Order Block Zone Handling",
  "aliases": [],
  "school": "ICT",
  "definition": "A risk management technique for order blocks where small order blocks require widening the stop-loss to avoid premature exits, while large order blocks suggest entering at the midpoint or using a tighter stop to maintain favorable risk-to-reward. Multiple order blocks can be traded with reduced risk, not exceeding 2% per trade and maintaining no more than three simultaneous positions.",
  "identification_rules": [
    "If the lower timeframe order block is very small, widen the stop-loss zone to avoid being stopped out by normal fluctuations.",
    "If the lower timeframe order block is very large, either use a tighter stop below a smaller sub-zone or place the entry closer to the midpoint of the order block.",
    "When multiple order blocks form sequentially, trade them only if they offer a favorable risk-to-reward ratio, ensuring each trade risks no more than 2% of the account and never having more than three simultaneous open trades."
  ],
  "trading_implication": "Order block zone handling adjusts entries and stops based on the size of the order block to optimize risk-to-reward. For small zones, a wider stop prevents noise-driven exits; for large zones, entering at midpoint or tightening stops improves reward potential. Multiple order blocks are managed with reduced risk per trade to avoid overexposure, ensuring overall account risk remains controlled.",
  "common_mistakes": [
    "Using a stop that is too tight on a small order block, leading to unnecessary stop-outs from normal market fluctuations.",
    "Placing the stop below the entire large order block, which widens the stop and worsens the risk-to-reward ratio.",
    "Trading multiple order blocks without reducing risk per trade or exceeding three open trades simultaneously, increasing account vulnerability."
  ],
