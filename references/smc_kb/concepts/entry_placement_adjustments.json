{
  "card_id": "entry_placement_adjustments",
  "type": "merged_concept",
  "canonical_term": "Entry Placement Adjustments",
  "aliases": [],
  "school": "Smart Money Concepts (SMC)",
  "definition": "Practical adjustments to entry and stop-loss placement near supply/demand zones. For demand zones, place entry slightly above the zone to avoid missing trades, give stops extra room in small zones to avoid stop hunts, and enter near the middle of larger zones with stop below.",
  "identification_rules": [
    "When a demand zone is small, place the stop loss with additional room below the zone to avoid premature stop-outs.",
    "When a demand zone is large, place the entry order near the middle of the zone and the stop loss below the entire zone.",
    "To prevent missing trades due to minor price touches, place a buy limit order a spread size above the demand zone's lower boundary."
  ],
  "trading_implication": "Enhances trade execution reliability by increasing the probability of entry without being overly aggressive, while reducing the risk of stop hunts that prematurely exit a technically valid setup, thereby improving overall risk management.",
  "common_mistakes": [
    "Entering too deep into a large demand zone, causing missed fills.",
    "Placing stops too tight in small zones, leading to unnecessary stop-outs.",
    "Not accounting for spread, resulting in missed entries when price barely touches the zone."
  ],
