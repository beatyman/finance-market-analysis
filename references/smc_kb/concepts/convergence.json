{
  "card_id": "convergence",
  "type": "merged_concept",
  "canonical_term": "Convergence",
  "aliases": [],
  "school": "Indicator-Based",
  "definition": "A condition where the swing highs and lows of price and an oscillator (e.g., MACD) move in the same direction, forming higher highs/lows or lower highs/lows together, indicating aligned momentum.",
  "identification_rules": [
    "Compare the most recent swing high on the price chart with the corresponding swing high on the MACD histogram; if both are higher than previous swing highs, convergence is present.",
    "Compare the most recent swing low on the price chart with the corresponding swing low on the MACD histogram; if both are lower than previous swing lows, convergence is present.",
    "Ensure that swing points are clearly separated and not part of the same broader swing to avoid misinterpretation."
  ],
  "trading_implication": "Convergence itself does not provide a direct trade signal. It indicates that price and momentum are moving together, confirming the current trend's strength. Traders often look for divergence to spot potential reversals; the absence of divergence (convergence) suggests the trend is intact.",
  "common_mistakes": [
    "Confusing convergence with divergence; convergence requires price and oscillator to move in the same direction, not opposite.",
    "Comparing mismatched swing points (e.g., a price high with an oscillator low), leading to false convergence identification.",
    "Failing to ensure swing points are sufficiently separated; minor fluctuations can mimic convergence but lack significance."
  ],
