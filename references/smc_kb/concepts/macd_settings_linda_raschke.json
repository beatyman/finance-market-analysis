{
  "card_id": "macd_settings_linda_raschke",
  "type": "merged_concept",
  "canonical_term": "MACD Settings (Linda Raschke)",
  "aliases": [
    "3-10-16 macd",
    "3-10-16 MACD",
    "Linda Raschke MACD settings",
    "linda raschke macd settings"
  ],
  "school": "Indicator-Based",
  "definition": "A custom configuration of the MACD indicator using fast length 3, slow length 10, simple moving averages for both oscillator and signal line, and signal smoothing 16; designed by Linda Raschke to generate faster signals compared to the standard 12/26/9 EMA MACD.",
  "identification_rules": [
    "Configure MACD with fast length = 3.",
    "Configure MACD with slow length = 10.",
    "Set oscillator MA type to Simple Moving Average (SMA).",
    "Set signal line MA type to Simple Moving Average (SMA).",
    "Set signal smoothing to 16.",
    "The MACD line will react faster to price changes, often printing earlier highs/lows and crossover signals compared to the default settings."
  ],
  "trading_implication": "Provides earlier divergence and crossover signals, enabling quicker trade entries. However, increased sensitivity leads to more false signals; traders must confirm with price action, market structure, or additional indicators to avoid whipsaws. Best used as a timing tool within a broader confirmation framework.",
  "common_mistakes": [
    "Using this MACD in isolation without supplementary confirmation, leading to frequent false signals.",
    "Assuming it is superior to standard settings in all conditions without recognizing the higher false signal rate."
  ],
