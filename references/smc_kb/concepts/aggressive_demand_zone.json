{
  "card_id": "aggressive_demand_zone",
  "type": "merged_concept",
  "canonical_term": "Aggressive Demand Zone",
  "aliases": [],
  "school": "Price Action",
  "definition": "A demand zone formed after a strong bullish engulfing candle that initiates a sharp upward price move; drawn as a rectangle to the right of the candle, expecting demand to re-emerge when price returns to that area.",
  "identification_rules": [
    "Price must show a sharp upward movement indicating a strong demand shift.",
    "Identify a bullish candle that engulfs at least two prior red candles (preferably three), opening below and closing above them.",
    "Confirm follow-through: the engulfing candle must start a sustained strong move upward, not an isolated spike.",
    "Draw the demand zone as a horizontal rectangle placed to the right of the engulfing candle."
  ],
  "trading_implication": "Aggressive demand zones mark areas of historical strong buying, suggesting a high-probability bounce when price returns. Traders typically place buy limit orders within the zone to capitalize on expected renewed demand, with stop losses set below the zone to manage risk if the zone fails.",
  "common_mistakes": [
    "Treating any isolated strong bullish candle as an aggressive demand zone without verifying that it leads to a sustained upward move.",
    "Drawing the demand zone extending to the left of the engulfing candle instead of only to the right."
  ],
