{
  "card_id": "measured_move",
  "type": "merged_concept",
  "canonical_term": "Measured Move",
  "aliases": [],
  "school": "Price Action",
  "definition": "A target projection method that measures the vertical distance of a prior impulsive move and applies that same distance from the lowest point of a consolidation pattern to estimate a profit target.",
  "identification_rules": [
    "Identify the impulsive move that preceded the consolidation pattern.",
    "Measure the full vertical distance (in price) of that impulsive move.",
    "Project the measured distance upward from the lowest point within the pattern to set the target level."
  ],
  "trading_implication": "Provides a predetermined profit target for breakout trades from consolidation patterns. It helps traders set objectives based on historical price movement, offering a systematic way to manage exits alongside risk/reward ratios.",
