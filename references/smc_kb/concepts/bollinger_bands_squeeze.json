{
  "card_id": "bollinger_bands_squeeze",
  "type": "merged_concept",
  "canonical_term": "Bollinger Bands Squeeze",
  "aliases": [],
  "school": "Indicator Based",
  "definition": "A pattern where Bollinger Bands contract, indicating low volatility and an impending breakout. A breakout is confirmed by a strong candle closing decisively outside the bands, ideally validated by support/resistance, volume, or chart patterns.",
  "identification_rules": [
    "The Bollinger Bands must be visibly contracting (squeezing) from a wider state to a narrow range.",
    "The price must have been trading inside the bands before the breakout.",
    "The breakout candle must close decisively outside the band with a strong real body and additional distance, not just a slight poke.",
    "The breakout is more reliable if it occurs at a support or resistance level.",
    "Increased volume on the breakout candle adds confirmation.",
    "A bullish or bearish chart pattern (e.g., ascending triangle) at the breakout level strengthens the signal."
  ],
  "trading_implication": "The squeeze signals an imminent expansion in volatility and a directional breakout. Traders wait for a decisive close outside the bands to enter in the breakout direction. The strategy is strengthened by confluent support/resistance breaks, volume spikes, and chart patterns, helping capture early trend moves. It requires confirmation to avoid false signals.",
  "common_mistakes": [
    "Prematurely entering on a small push outside the bands rather than waiting for a strong candle close.",
    "Assuming all breakouts are valid without additional confirmation like support/resistance or volume.",
    "Confusing a squeeze breakout with a free bar (candle completely outside bands) that could signal reversal."
  ],
