{
  "card_id": "directional_bias",
  "type": "merged_concept",
  "canonical_term": "Directional Bias",
  "aliases": [
    "Bias",
    "Market Direction",
    "market direction",
    "交易偏向",
    "方向性偏好"
  ],
  "school": "ICT",
  "definition": "Directional bias is the overall trend direction determined by market structure: a bullish bias with higher highs and higher lows, a bearish bias with lower highs and lower lows. It is established by analyzing swing points and displacement, guiding trade decisions to align with the dominant direction.",
  "identification_rules": [
    "Observe swing highs and swing lows to determine if price breaks the range (Displacement).",
    "If price fails to break a swing point and returns within the range, bias favors the opposite direction (e.g., high not broken → bearish bias).",
    "If price breaks a swing point and continues extending, confirm bias in that direction (e.g., break above high → bullish bias).",
    "If price forms a higher high and a higher low relative to prior swing points, bias is bullish.",
    "If price forms a lower high and a lower low relative to prior swing points, bias is bearish.",
    "Focus on the most recent swing range (from last swing low to swing high) for current bias.",
    "Ignore liquidity outside the current swing range until a change of character (CHoCH) occurs.",
    "After establishing bias, only trade setups that align with that direction (displacement and failed break patterns)."
  ],
  "trading_implication": "Directional bias dictates the only trade direction: long in bullish bias, short in bearish bias. It must be established first, then liquidity and points of interest are filtered accordingly. In bullish bias, only look for upward displacement and upward failed breaks; in bearish bias, only downward setups. This avoids counter-trend trades and improves consistency. Applicable from minute to daily charts.",
  "common_mistakes": [
    "Establishing bias hastily when market structure is unclear, then stubbornly trading against the actual direction.",
    "Ignoring displacement confirmation and judging bias based on a single swing point.",
    "Not updating bias when price breaks a swing point, clinging to the old bias.",
    "Trading against the bias without a confirmed change of character.",
    "Relying solely on liquidity levels without structural context.",
    "Assuming price will move toward a distant liquidity pool outside the current swing range.",
    "Failing to first determine bias before analyzing internal liquidity or order blocks."
  ],
  "related_concepts": [],
  "merge_strategy": "llm_synthesis",
  "merge_model": "deepseek/deepseek-chat",
  "merge_notes": "Both cards are from ICT school; no conflict. The first card emphasizes displacement and failed breaks, the second focuses on swing structure and CHoCH. Combined rules preserve both perspectives.",
