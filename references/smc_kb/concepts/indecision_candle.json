{
  "card_id": "indecision_candle",
  "type": "merged_concept",
  "canonical_term": "Indecision Candle",
  "aliases": [
    "Broadening Formation Candle",
    "broadening formation candle",
    "Doji",
    "doji",
    "Doji Candle",
    "doji-like candle",
    "Doji-like Candle",
    "indecision bar",
    "Seek and Destroy candle",
    "seek and destroy candle",
    "Seek and Destroy Candle",
    "无方向K线",
    "无方向k线",
    "犹豫k线",
    "犹豫K线"
  ],
  "school": "Price Action",
  "definition": "A candlestick, typically on daily or higher timeframes, with a small real body (open and close near the same price) and long wicks on both sides. Price sweeps both directions without sustaining a breakout, indicating a lack of directional conviction and no net displacement.",
  "identification_rules": [
    "The candle's open and close are at approximately the same level, resulting in a very small real body.",
    "Wicks extend in both directions (above and below the body), with wick length significantly greater than the body.",
    "Price sweeps both sides of a preceding range (e.g., Asia range) without closing beyond either extreme.",
    "On lower timeframes, London takes both sides of the Asia range and fails to produce directional expansion; New York oscillates within the established range.",
    "No clear directional bias: neither a strong bullish nor bearish close, and price rejects expansions beyond the range.",
    "Often preceded by intraday double-sided sweeps of a preceding range without displacement, or by early session exhausting the daily range.",
    "Frequently occurs on higher timeframes when the market lacks directional context or before major news announcements (e.g., CPI, FOMC, NFP).",
    "The distinction between a bullish and bearish indecision candle is determined solely by whether the close is marginally above or below the open."
  ],
  "trading_implication": "Signals consolidation and lack of directional momentum; avoid breakout trades. If trading, use range strategies: mark equilibrium (0.5 level) of the range, and expect price to revert from outside back inside. Typically appears after expansion or before major news. Wait for a subsequent candle to confirm reversal or continuation. In a series of directional candles, an indecision candle may indicate an impending reversal or consolidation.",
  "common_mistakes": [
    "Attempting breakout or expansion trades when the candle indicates consolidation, leading to failed inside-out plays.",
    "Misinterpreting the candle as an immediate reversal or directional signal without awaiting confirmation from subsequent price action.",
    "Ignoring the context that produces indecision candles — such as pre-CPI, pre-FOMC, or pre-NFP sessions, or days following a very large range day.",
    "Failing to recognize that London having already created most of the daily range is also a Seek and Destroy condition for New York, and continuing to look for large New York moves.",
    "Confusing Indecision Candle with Reversal Candle; Reversal Candle has a clear directional reversal (e.g., open high low close), while Indecision Candle only indicates lack of direction.",
    "Overlooking early session behavior (e.g., double-sided sweeps of Asia range) that signals an impending indecision day.",
    "Holding expectations of a large move late in the session when the early session has already produced most of the daily range."
  ],
