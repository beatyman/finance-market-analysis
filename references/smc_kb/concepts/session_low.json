{
  "card_id": "session_low",
  "type": "merged_concept",
  "canonical_term": "Session Low",
  "aliases": [
    "AS.L",
    "as.l",
    "Asia Low",
    "asia low",
    "asian session low",
    "Asian Session Low",
    "lo.l",
    "LO.L",
    "London Session Low",
    "New York Session Low",
    "nyam.l",
    "NYAM.L",
    "nyl.l",
    "NYL.L",
    "NYPM.L",
    "nypm.l",
    "session lows",
    "时段低点"
  ],
  "school": "ICT",
  "definition": "特定交易时段（亚洲、伦敦、纽约AM/PM）内所有K线的最低价，构成该时段流动性参考下边界，标记卖方流动性聚集区，用于判断价格有效突破方向、识别SMT背离锚点及确定后续运行目标。",
  "identification_rules": [
    "确定目标时段的时间范围：亚洲时段 20:00–00:00（标注为 AS.L）、伦敦时段 02:00–05:00（标注为 LO.L）、纽约AM时段 08:30–11:00（标注为 NYAM.L），均为东部标准时间",
    "等待时段结束或区间形成后，取该时段内所有K线的最低价，水平标记为 Session Low",
    "使用 ICT Killzones & Pivots 指标时，开启 Killzone Pivots 选项后各时段低点自动以水平线形式绘制；水平线延伸时间可通过 Drawing Cut Off Time 参数调整",
    "观察价格是否在 Session Low 处出现有效位移（Displacement）：收盘价明显突破该水平且伴随方向性K线视为有效突破；仅刺穿但未收盘突破则视为扫流动性",
    "在双面板对比中，同时标记两个相关资产在同一时段的最低价，当一个资产触及或跌破 Session Low 而另一相关资产未能同步跌破时，该水平即成为 SMT 背离的观察位"
  ],
  "trading_implication": "Session Low 可作为：①Draw On Liquidity 目标——当价格未能突破 Session High 且出现位移时，预期价格向 Session Low 运动；②方向性确认——亚洲高点被扫除后价格向下位移并突破亚洲 Session Low，确认看跌偏向；③做多机会——伦敦时段扫亚洲 Session Low 后快速回归区间，可结合 Fair Value Gap、Order Block 等 PD Array 寻找做多入场；④SMT背离锚点——需结合更高时间框架结构综合确认。",
  "common_mistakes": [
    "将价格仅刺穿 Session Low（未收盘突破）误判为有效位移，应等待收盘确认",
    "在未观察到 Session High 被扫除的前提下，直接将 Session Low 突破作为做空信号，忽略先扫高点再破低点的顺序逻辑",
    "仅凭价格触及 Session Low 就直接入场，而不等待 SMT 背离或结构确认",
    "在没有更高时间框架偏差支撑的情况下，将随机位置的 SMT 背离与 Session Low 结合使用",
    "SMT 出现在 Session Low 附近时立即做空，而不等待实际入场结构（如位移、订单块等）对齐"
  ],
