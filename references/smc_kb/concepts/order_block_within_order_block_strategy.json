{
  "card_id": "order_block_within_order_block_strategy",
  "type": "merged_concept",
  "canonical_term": "Order Block within Order Block Strategy",
  "aliases": [
    "order block in order block"
  ],
  "school": "ICT",
  "definition": "A two-timeframe trading strategy where the higher timeframe order block defines the trade zone, and after a pullback, a lower timeframe change of character confirms entry at a fresh lower timeframe order block, aligning with the higher timeframe trend.",
  "identification_rules": [
    "Determine the higher timeframe trend direction using breaks of structure or changes of character.",
    "Identify a valid order block on the higher timeframe in the direction of the trend.",
    "Wait for price to pull back into the higher timeframe order block zone.",
    "Switch to a lower timeframe (at least half the higher timeframe) and wait for a change of character (e.g., break of a recent swing low for shorts).",
    "After the change of character, mark the new order block formed on the lower timeframe.",
    "Enter the trade at the start of the lower timeframe order block with a stop loss beyond its extreme."
  ],
  "trading_implication": "This strategy improves entry precision by combining higher timeframe directional bias with lower timeframe reversal confirmation. The higher timeframe order block acts as a key supply/demand zone, while the lower timeframe change of character and order block confirm seller/buyer intent, filtering out false moves and enhancing trade timing.",
  "common_mistakes": [
    "Entering the trade before price has reached the higher timeframe order block zone, leading to premature entries and potential traps.",
    "Using too tight a stop loss on a very small lower timeframe order block, causing premature stop-outs from normal market noise.",
    "Placing a stop loss for the entire width of a very large lower timeframe order block, which widens risk and worsens risk-to-reward; instead, adjust entry or use a smaller stop zone.",
    "Trading multiple order blocks simultaneously without limiting total risk to 2% of the account and restricting concurrent trades to three or fewer.",
    "Forcing trades when the higher timeframe market direction is unclear, increasing the probability of trading against the broader trend."
  ],
