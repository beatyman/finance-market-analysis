{
  "card_id": "fvg_psychology",
  "type": "merged_concept",
  "canonical_term": "FVG Psychology",
  "aliases": [
    "Fair Value Gap Psychology",
    "fair value gap psychology"
  ],
  "school": "ICT",
  "definition": "The principle that fair value gaps contain pending orders from traders who missed the initial impulse move, creating a liquidity pool. This pool draws price back to fill the gap, rebalancing the imbalance before the trend continues with stronger momentum.",
  "identification_rules": [
    "Identify a valid fair value gap using the three-candle sequence (or four-candle when an inside bar precedes).",
    "Recognize that the gap represents a liquidity pool where buy/sell orders accumulate.",
    "Observe price reaction when it enters the FVG: a rejection signals continuation toward liquidity above; no reaction signals a move to sweep liquidity below."
  ],
  "trading_implication": "Traders can anticipate price returning to fill FVGs to sweep the accumulated pending orders. Price reaction within the gap (respect/jump vs. no reaction) helps determine the next directional target: if rejected higher, aim for buy-side liquidity; if no reaction, expect continuation to sell-side liquidity.",
  "common_mistakes": [
    "Ignoring price action inside the FVG; entering without confirming whether price respects or breaks through the gap.",
    "Assuming every FVG will fill without considering the broader trend and structure."
  ],
