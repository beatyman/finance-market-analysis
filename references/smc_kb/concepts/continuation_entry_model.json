{
  "card_id": "continuation_entry_model",
  "type": "merged_concept",
  "canonical_term": "Continuation Entry Model",
  "aliases": [],
  "school": "Smart Money Concepts (SMC)",
  "definition": "A trading strategy for entering after missing the initial CHoCH, requiring four conditions: a CHoCH pattern after hitting a HTF zone, a BOS with zone breakout, remaining inefficiency, and static liquidity near the POI.",
  "identification_rules": [
    "Price must form a CHoCH pattern or flip pattern after reaching the higher time frame supply or demand zone.",
    "A break of structure and a zone breakout must occur in the price movement.",
    "Inefficiency (e.g., Fair Value Gap) must be left behind when forming the break of structure.",
    "Static liquidity zones (e.g., double bottoms, trendline liquidity) must be present near the identified point of interest."
  ],
  "trading_implication": "Provides a high-probability continuation entry after a missed CHoCH. Place a limit order at the new supply/demand zone only after the liquidity sweep. Take-profit targets include HTF unmitigated demand/supply zones or the current timeframe's swing low/high, with a defined risk-reward ratio.",
  "common_mistakes": [
    "Placing a limit order at the new supply/demand zone without waiting for the liquidity sweep, risking a stop-out from a liquidity grab.",
    "Not confirming all four criteria, especially the presence of static liquidity, leading to lower-probability setups."
  ],
