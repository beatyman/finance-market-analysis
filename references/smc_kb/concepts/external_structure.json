{
  "card_id": "external_structure",
  "type": "merged_concept",
  "canonical_term": "External Structure",
  "aliases": [],
  "school": "Smart Money Concepts (SMC)",
  "definition": "The external structure consists of the most recent major swing high and major swing low that establish the overall trading range. The major high is the highest point before a retracement that leads to a break of structure; the major low is the lowest point of the impulsive wave that caused that break. All price action within these extremes is internal.",
  "identification_rules": [
    "In an uptrend, identify the most recent valid break of structure (BOS) to the upside; the major low is the lowest point of the impulsive wave that immediately preceded that BOS.",
    "The major high is the highest point reached before the retracement phase that eventually led to the BOS.",
    "In a downtrend, locate the most recent valid BOS to the downside; the major high is the highest reactionary high before the impulsive drop, and the major low is the lowest point after the BOS.",
    "External structure boundaries are these major high and low; all price action between them is internal structure.",
    "External structures are updated only when a new valid break of structure occurs, replacing the previous major extreme."
  ],
  "trading_implication": "External structure defines the dominant trading range and trend direction. As long as price remains above the major low in a bullish structure, the uptrend is intact; below the major high in a bearish structure, the downtrend persists. A break of these extremes signals a potential trend reversal (change of character) and triggers reassessment of bias.",
  "common_mistakes": [
    "Mistaking internal highs or lows for major extremes, leading to incorrect trend analysis.",
    "Failing to update external structure after a valid break of structure, causing outdated range boundaries.",
    "Using minor swing points instead of the extreme low or high that initiated the impulsive move."
  ],
