{
  "card_id": "scalping",
  "type": "merged_concept",
  "canonical_term": "Scalping",
  "aliases": [
    "短线交易",
    "超短期交易"
  ],
  "school": "Price Action",
  "definition": "A fast-paced trading style aiming to profit from small price changes by executing many short-term trades, typically lasting seconds to minutes. It uses low timeframes (e.g., 15-second charts) to capture small moves, often after confirming high-probability zones on higher timeframes like FVG or OTE.",
  "identification_rules": [
    "Use short timeframes (1-minute or lower) for trade execution and analysis.",
    "Execute a high number of trades per day, often dozens to hundreds.",
    "Aim for small profit targets on each trade rather than large moves.",
    "Close all positions before the market closes to avoid overnight risk.",
    "After confirming FVG and discount zone on higher timeframe (e.g., 15-minute), switch to lower timeframe (15-second) to observe price action.",
    "Identify Displacement through structure into FVG/OTE zone on lower timeframe.",
    "Use FVG or OTE zone formed on lower timeframe as precise entry point.",
    "Set first partial profit target at swing high or recent high.",
    "Place stop loss below liquidity or key support level at entry."
  ],
  "trading_implication": "Scalping is a multi-timeframe method: confirm direction and key zones (FVG, discount) on higher timeframe, then pinpoint entry on lower timeframe. Manage risk via partial profit-taking and moving stop to breakeven after first target. Best during high volatility (e.g., London session). Requires high focus, quick decisions, and discipline. Use liquid markets with tight spreads.",
  "common_mistakes": [
    "Trading on low timeframe without confirming high-probability zones on higher timeframe.",
    "Ignoring bearish signals when swing high not broken on lower timeframe while holding long.",
    "Failing to execute partial profit-taking or stop management, turning small profits into losses.",
    "Scalping while distracted (e.g., watching other content).",
    "Allowing emotions to override trading discipline.",
    "Using indicators without fully understanding how they work.",
    "Ignoring price action and market structure in favor of only indicators.",
    "Trading illiquid markets or during low-liquidity periods."
  ],
  "related_concepts": [],
  "merge_strategy": "llm_synthesis",
  "merge_model": "deepseek/deepseek-chat",
  "merge_notes": "School conflict: ICT card says 'Price Action', SMC card says 'Scalping'. Picked 'Price Action' as more standard. ICT card adds multi-timeframe specifics (FVG, OTE) not in SMC card; SMC card adds general scalping rules (high trade count, close before close). Both preserved.",
