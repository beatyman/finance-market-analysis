{
  "card_id": "bearish_engulfing_pattern",
  "type": "merged_concept",
  "canonical_term": "Bearish Engulfing Pattern",
  "aliases": [],
  "school": "Price Action",
  "definition": "A two-candle reversal pattern: a green candle followed by a larger red candle that fully engulfs the previous candle's body, used as a sell signal.",
  "identification_rules": [
    "Pattern occurs at the top of an uptrend or near a resistance level.",
    "First candle is bullish (green body).",
    "Second candle is bearish (red body) and its body completely covers the body of the first candle.",
    "Often confirmed by other bearish signals such as bearish divergence."
  ],
  "trading_implication": "Signals a potential bearish reversal, providing a short entry. A stop loss is placed just above the pattern's high or nearby resistance, with a take profit target based on a risk-to-reward ratio of at least 1:2, as demonstrated in the material.",
