{
  "card_id": "position_sizing",
  "type": "merged_concept",
  "canonical_term": "Position Sizing",
  "aliases": [
    "Fixed Dollar Risk",
    "Fixed Percentage Risk",
    "仓位管理",
    "仓位规模",
    "合约数量计算"
  ],
  "school": "Risk Management",
  "definition": "Position sizing adjusts contract or lot size per trade to maintain a fixed dollar or percentage risk, calculated as defined risk divided by instrument value per point divided by stop size in points. It ensures consistent risk exposure, making win rate and risk-to-reward ratios mathematically valid for profitability.",
  "identification_rules": [
    "Define a fixed dollar or percentage risk amount per trade (e.g., $1,000 or 1% of account) before sizing.",
    "Calculate contracts as: defined risk ÷ instrument value per point ÷ stop size in points.",
    "Multiply contract result by 10 to convert from minis to micros when fractional minis are needed.",
    "Round down to the nearest whole micro/contract when the calculation yields a fraction.",
    "For prop firm accounts, base the risk percentage on the drawdown limit, not the nominal account size.",
    "Determine account size in dollars.",
    "Set maximum risk percentage per trade (commonly 1-2% of account).",
    "Calculate dollar risk: account size × risk percentage.",
    "Determine stop-loss distance: entry price minus stop-loss price.",
    "Divide dollar risk by stop-loss distance per unit to get position size (number of units)."
  ],
  "trading_implication": "Consistent position sizing is prerequisite for win rate and risk-to-reward to translate into profitability. Fixed dollar/percentage risk ensures each trade risks the same amount, preserving expected value. Micros are preferred for granularity. On prop firm accounts, size against drawdown (e.g., 7-10% of $1,500 drawdown on 25K account) to absorb 10-15 consecutive losses. Use calculators or TradingView tools for precision.",
  "common_mistakes": [
    "Using fixed contract size instead of fixed dollar risk, causing inconsistent R values across different stop sizes and breaking win rate/RR profitability math.",
    "Risking a different dollar amount on each trade, converting a winning system into break-even or worse.",
    "Sizing prop firm accounts against nominal balance instead of drawdown limit, leading to blow-up in few losses.",
    "Attempting fractional mini contracts instead of using micros for precision.",
    "Risking too large a percentage of account on a single trade, exceeding 1-2% rule.",
    "Trading without calculating position size, effectively gambling.",
    "Miscalculating position size due to incorrect stop-loss distance or ignoring leverage effects.",
    "Rounding up fractional contracts instead of down, causing risk to exceed preset limit."
  ],
