{
  "card_id": "simple_moving_average",
  "type": "merged_concept",
  "canonical_term": "Simple Moving Average",
  "aliases": [
    "SMA",
    "sma"
  ],
  "school": "Indicator-Based",
  "definition": "A moving average that calculates the average of a chosen price (typically close) over a specified number of periods, giving equal weight to each data point.",
  "identification_rules": [
    "The SMA line smooths price data by averaging the selected price over a user-defined length (e.g., 20 periods).",
    "On a chart, shorter lengths result in a line that closely follows price, while longer lengths produce a smoother, slower line.",
    "Default source is the closing price, but can be changed to open, high, low, or an average of them.",
    "It appears as a continuous line overlaying price candles."
  ],
  "trading_implication": "SMA is used to identify trend direction (rising = uptrend, falling = downtrend) and potential dynamic support/resistance. Crossovers of SMAs with different lengths can signal entry/exit points. It lags price, providing smoother signals.",
  "common_mistakes": [
    "Dismissing SMA as too basic without understanding its utility in trend identification and as a component in other indicators.",
    "Using an excessively short length that causes the SMA to hug price too closely, generating frequent false signals.",
    "Not accounting for SMA's lag; it reacts slower to price changes than EMA, which can delay signals."
  ],
