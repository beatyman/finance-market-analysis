{
  "card_id": "price_action_confirmation",
  "type": "merged_concept",
  "canonical_term": "Price Action Confirmation",
  "aliases": [],
  "school": "Price Action",
  "definition": "A confirmation technique where, after an initial breakout candle closes beyond a moving average, traders wait for an additional candle to close beyond that same moving average before entering a trade, aiming to filter false breakouts.",
  "identification_rules": [
    "After an initial candle closes decisively beyond a moving average (breakout candle), wait for the next full candle to also close on the breakout side of the moving average; only then is the breakout confirmed."
  ],
  "trading_implication": "This rule delays entry until a second candle close confirms the breakout, reducing the likelihood of being trapped by failed breakouts. It increases trade reliability at the cost of missing the very start of a move.",
  "common_mistakes": [
    "Entering a trade immediately on the first breakout candle without waiting for confirmation, which often results in being caught in a false breakout."
  ],
