{
  "card_id": "initiation",
  "type": "merged_concept",
  "canonical_term": "Initiation",
  "aliases": [],
  "school": "SMC",
  "definition": "The initial aggressive move by smart money after a manipulation, signaling the start of the real trend.",
  "identification_rules": [
    "Occurs immediately after a manipulation phase that sweeps liquidity.",
    "Characterized by a rapid, impulsive price move that breaks a key structural level (e.g., swing high/low).",
    "Often accompanied by a noticeable spike in trading volume.",
    "Results in a change of character (CHoCH) on the relevant timeframe, confirming the trend shift."
  ],
  "trading_implication": "Initiation confirms that smart money is actively driving the market and that the manipulation phase has ended. Traders wait for this confirmation before entering, then look for a pullback (mitigation) to join the move. It prevents premature entries and aligns trades with institutional momentum.",
  "common_mistakes": [
    "Entering too early without waiting for the initiation phase, leading to trades based on incomplete confirmation."
  ],
