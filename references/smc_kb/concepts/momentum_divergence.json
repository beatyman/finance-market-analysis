{
  "card_id": "momentum_divergence",
  "type": "merged_concept",
  "canonical_term": "Momentum Divergence",
  "aliases": [],
  "school": "Indicator Based",
  "definition": "A situation where price moves in one direction (e.g., higher high) while momentum, measured by an oscillator like MACD, moves opposite (e.g., lower high), indicating the trend's strength is fading.",
  "identification_rules": [
    "Identify a new price swing high (or low) on the chart.",
    "Check the MACD line's corresponding high (or low) at that price swing.",
    "If price makes a higher high but MACD makes a lower high, a bearish momentum divergence exists.",
    "If price makes a lower low but MACD makes a higher low, a bullish momentum divergence exists.",
    "Compare the candle sizes: the impulsive move may have large candles, but MACD fails to confirm the new extreme."
  ],
  "trading_implication": "Momentum divergence warns that the prior impulsive move was weak. Traders should avoid entering pullback trades expecting continuation, as the trend may reverse or consolidate. It serves as a cautionary signal rather than a direct entry trigger.",
  "common_mistakes": [
    "Entering a pullback trade after a momentum divergence, assuming the trend remains strong, when momentum actually points to weakening."
  ],
  "related_concepts": [],
  "illustrated_by_cases": [
    {
      "card_id": "hgRUNDW-exM_case_001_impulsive_move_identification_on",
      "video_id": "hgRUNDW-exM",
      "title": "Identifying impulsive moves on ETH/USD 4H chart using candle size, steepness, and custom MACD settings"
    }
