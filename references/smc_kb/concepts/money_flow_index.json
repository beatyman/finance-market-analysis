{
  "card_id": "money_flow_index",
  "type": "merged_concept",
  "canonical_term": "Money Flow Index",
  "aliases": [
    "MFI",
    "mfi"
  ],
  "school": "Indicator Based",
  "definition": "A volume-weighted momentum oscillator that combines price and volume to measure buying and selling pressure, oscillating between 0 and 100, with overbought and oversold thresholds at 80 and 20 respectively.",
  "identification_rules": [
    "MFI above 80 indicates overbought conditions, suggesting a potential downside reversal; below 20 indicates oversold, suggesting a potential upside reversal.",
    "A bearish divergence occurs when price makes higher highs while MFI makes lower highs, signaling weakening bullish momentum and a potential downside reversal."
  ],
  "trading_implication": "MFI helps anticipate reversals: overbought/oversold crossovers can warn of exhaustion, but are less reliable; divergence between price and MFI (especially when price rises but MFI falls) indicates that volume is not supporting the price move, offering a higher-probability reversal signal.",
  "common_mistakes": [
    "Relying solely on overbought (above 80) or oversold (below 20) readings as precise reversal signals, as in strong trends MFI can remain in these zones for extended periods.",
    "Ignoring divergence signals, which the material suggests are more valuable than overbought/oversold levels."
  ],
