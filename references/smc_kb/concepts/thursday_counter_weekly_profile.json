{
  "card_id": "thursday_counter_weekly_profile",
  "type": "merged_concept",
  "canonical_term": "Thursday Counter Weekly Profile",
  "aliases": [
    "Thursday Counter",
    "thursday counter"
  ],
  "school": "ICT",
  "definition": "A weekly profile where Monday-Wednesday expand away from the weekly open without forming a significant high or low, then Thursday counters with a candle 2 closure and SMT, setting up a Friday continuation back toward the weekly open or current week high/low.",
  "identification_rules": [
    "Monday through Wednesday expand in one direction without a significant opposing swing high/low.",
    "Thursday forms a candle 2 closure (reversal candle) that counters the prior three-day expansion.",
    "Thursday's reversal is confirmed by an hourly change in state of delivery (CISD) within its range.",
    "Thursday often pairs with SMT divergence off a previous day high or low.",
    "Friday provides a continuation move back toward the weekly open, current week high/low, or resting failure swings."
  ],
  "trading_implication": "This profile offers two trading opportunities: (1) trade Thursday's reversal if it has a small wick and is confirmed by SMT off PDH/PDL; (2) trade Friday's continuation after Thursday's hourly CISD confirms the daily wick, targeting the weekly open or current week high/low. Always wait for lower-timeframe confirmation before entry.",
  "common_mistakes": [
    "Entering the Friday continuation without confirming hourly CISD inside Thursday's range.",
    "Assuming any Thursday reversal is valid without checking for SMT divergence or small wick.",
    "Failing to identify that Monday-Wednesday must expand without a significant opposing swing (no candle 2 closure prior to Thursday)."
  ],
