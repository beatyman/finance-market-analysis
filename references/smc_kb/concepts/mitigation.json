{
  "card_id": "mitigation",
  "type": "merged_concept",
  "canonical_term": "Mitigation",
  "aliases": [],
  "school": "ICT",
  "definition": "After an initiation move, price returns to a previously identified order block or fair value gap to fill any remaining orders before continuing in the direction of the trend. This pullback provides a high-probability entry point for traders aligned with the smart money's direction.",
  "identification_rules": [
    "Wait for a strong impulsive move (initiation) that breaks structure or sweeps liquidity in the intended trend direction.",
    "Identify the nearest unmitigated order block or fair value gap that was created before the impulsive move.",
    "Price should retrace into this zone without violating the level, indicating mitigation.",
    "On a lower timeframe, look for a change of character (e.g., break of a minor swing high/low) to confirm the reversal before entering.",
    "Ensure the retracement stays within the premium/discount zone favorable to the bias (discount for longs, premium for shorts)."
  ],
  "trading_implication": "Mitigation offers a low-risk entry to join the trend after smart money has established positions. By waiting for the pullback to a point of interest, traders avoid chasing the initial move and enter with a tight stop below the order block or FVG. This aligns with the institutional order flow, targeting the next liquidity level for profits.",
  "common_mistakes": [
    "Entering immediately after initiation without waiting for the mitigation pullback to the precise order block or FVG.",
    "Mistaking a deeper retracement that breaches the order block as a valid mitigation, when it may signal a change in structure.",
    "Taking a mitigation entry without a clear higher-timeframe bias, leading to trades against the overall trend."
  ],
