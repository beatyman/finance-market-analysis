{
  "card_id": "short_term_high_short_term_low",
  "type": "merged_concept",
  "canonical_term": "Short-Term High / Short-Term Low",
  "aliases": [
    "Short-Term High",
    "short-term high",
    "short-term low",
    "Short-Term Low",
    "Short-Term Swing Low",
    "sth",
    "STH",
    "STH / STL",
    "STL",
    "stl",
    "Swing High / Swing Low"
  ],
  "school": "ICT",
  "definition": "Minor swing points on the current time frame formed by adjacent candles: a short-term high has lower highs on both sides; a short-term low has higher lows on both sides. They represent external liquidity levels and are the smallest units of market structure, used to build intermediate and long-term swings.",
  "identification_rules": [
    "Short-term high: current candle high is higher than the highs of the two adjacent candles, i.e., there is at least one lower high on each side.",
    "Short-term low: current candle low is lower than the lows of the two adjacent candles, i.e., there is at least one higher low on each side.",
    "Must have clear two-sided comparison; isolated extreme points do not qualify.",
    "In an uptrend, identify alternating higher highs and higher lows; in a downtrend, identify alternating lower highs and lower lows.",
    "Prioritize swing points associated with important price levels (e.g., previous order blocks, fair value gaps, prior day/week highs/lows).",
    "After a sweep, a price displacement and close beyond the relevant candle confirms the swing point and may turn that candle into an order block.",
    "Can be identified on any time frame; higher time frame short-term highs/lows have higher priority.",
    "Multiple short-term highs/lows combine to form intermediate-term highs/lows.",
    "Flag a short-term high/low as relevant if the continuation candle closes through a series of opposing candles and wicks or closes beyond it.",
    "Treat the short-term high/low as taken when the continuation candle's range extends beyond it, not merely when price approaches."
  ],
  "trading_implication": "Short-term highs/lows mark external liquidity zones (buy stops above, sell stops below) and are targets for institutional sweeps. Use them to: (1) identify liquidity targets for price sweeps; (2) set stops beyond the swing point to avoid false triggers; (3) confirm market structure shifts when price breaks a prior swing point; (4) as profit targets. When a continuation setup sweeps a short-term high/low, wait for additional confirmation (e.g., a close beyond the level) before entering; if price reverses after the sweep, trade the opposite direction using the swept level as a new point of interest.",
  "common_mistakes": [
    "Misidentifying isolated extreme points as valid short-term highs/lows without two-sided confirmation.",
    "Choosing random swing points not associated with key levels (order blocks, FVGs, prior highs/lows).",
    "Trading immediately after a sweep without waiting for a close beyond the level to confirm continuation.",
    "Confusing short-term highs/lows with order blocks: swing points are reference levels, order blocks are support/resistance zones from specific candles.",
    "Confusing short-term with intermediate-term structure, leading to incorrect hierarchy.",
    "Acting before the swing point is validated by subsequent price action (e.g., a higher high after a short-term low).",
    "Ignoring time frame context: treating a low-time-frame swing reversal as a high-time-frame trend reversal.",
    "Expecting a swept short-term high/low to continue providing support/resistance; instead look for internal liquidity or new order blocks.",
    "Trusting a continuation closure that also sweeps a short-term high/low without further confirmation, often leading to stop-outs.",
    "Confusing a sweep of a short-term low with a protected swing reversal; sometimes price sweeps and continues lower."
  ],
