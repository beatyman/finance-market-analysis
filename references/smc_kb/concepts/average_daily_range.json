{
  "card_id": "average_daily_range",
  "type": "merged_concept",
  "canonical_term": "Average Daily Range",
  "aliases": [
    "ADR",
    "adr"
  ],
  "school": "Risk Management",
  "definition": "The average price range a market traverses within a single trading day, used as a benchmark to set realistic expansion targets and assess whether a directional move still has room to run before exhausting its typical daily distribution.",
  "identification_rules": [
    "Measure the typical daily high-to-low range of the instrument over a representative look-back period to establish the ADR value.",
    "On an expansion day, project the ADR from the day's open or formation low/high to define the realistic outer target zone.",
    "Treat ADR as exhausted when the current day's range approaches or matches the average, signalling diminished further expansion potential."
  ],
  "trading_implication": "ADR is used to set realistic profit targets on expansion days following a consolidation reversal. After Thursday's candle 2 closure sweeps the consolidation range, Friday's expansion is traded toward either a higher time frame key level or until the ADR is exhausted. It prevents overstaying in a trade when the day has already delivered its typical range and helps determine whether a higher time frame target is realistically reachable within the session.",
  "common_mistakes": [
    "Not explicitly stated in the material."
  ],
