{
  "card_id": "static_liquidity",
  "type": "merged_concept",
  "canonical_term": "Static Liquidity",
  "aliases": [],
  "school": "Smart Money Concepts (SMC)",
  "definition": "Static liquidity refers to specific zones on a price chart where large pools of money rest, such as stop-losses and pending orders. These zones attract price to absorb liquidity before continuing the trend. They are found at equal highs/lows, swing points, order blocks, trend lines, and Fibonacci levels.",
  "identification_rules": [
    "Locate equal highs or equal lows: at least two swing points at the same price level.",
    "Identify key technical levels: swing highs/lows, order blocks, dynamic trend lines, channels, and Fibonacci retracement levels.",
    "Confirm the presence of resting liquidity by observing clusters of stop-losses or pending orders just beyond these levels.",
    "Prioritize zones with multiple technical confluences, which attract larger liquidity pools."
  ],
  "trading_implication": "Static liquidity zones are targeted for sweeps before sustained moves. A liquidity sweep at such a zone validates the strength of a supply or demand area, providing a high-probability entry. Traders wait for price to clear these zones and then enter from the opposite side, as the market no longer needs to collect stop-losses.",
  "common_mistakes": [
    "Neglecting static liquidity, leading to premature stop-outs.",
    "Entering without a confirmed liquidity sweep at the zone.",
    "Failing to recognize that widely recognized zones attract larger liquidity pools, making them high-probability targets."
  ],
