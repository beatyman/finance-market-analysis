{
  "card_id": "optimal_trade_entry_ote",
  "type": "merged_concept",
  "canonical_term": "Optimal Trade Entry (OTE)",
  "aliases": [
    "optimal entry zone",
    "OT",
    "OTE",
    "OTE zone",
    "最优交易入场点",
    "最优入场点"
  ],
  "school": "ICT",
  "definition": "A Fibonacci-based entry method using the 0.62-0.79 zone (with 0.705 as midpoint) of a displacement leg, where price retraces into the discount (below 0.5) for longs or premium (above 0.5) for shorts, forming a lower high (bearish) or higher low (bullish) to enter in the trend direction.",
  "identification_rules": [
    "Identify a clear impulse or displacement leg with an aggressive directional move.",
    "Draw a Fibonacci retracement from swing high to swing low (bearish) or low to high (bullish) of that leg.",
    "Identify the 0.62, 0.705 (midpoint), and 0.79 levels as the core OTE zone.",
    "Use the 0.5 level (equilibrium) as boundary: discount zone (below 0.5) for long OTE, premium zone (above 0.5) for short OTE.",
    "Wait for price to retrace into the 0.705 Fibonacci zone.",
    "Confirm a lower high forms in a bearish trend or a higher low in a bullish trend at the 0.705 level.",
    "Enter in the direction of the original displacement upon the formation of the reversal pattern.",
    "Look for confluence with other PD Array (FVG, order block) within the OTE zone for confirmation.",
    "Ensure prerequisites are met: stop raid, market structure shift (MSS), or clear displacement before entry.",
    "Confirm higher timeframe liquidity targets and session structure (e.g., Killzone) to align OTE direction.",
    "Nest OTE across timeframes: mark OTE on higher timeframe, then refine entry on lower timeframe.",
    "If order block open price is outside OTE zone, use its midpoint (50%) as alternative entry reference."
  ],
  "trading_implication": "OTE provides a high-probability entry zone within a trend pullback, allowing traders to enter at a discount (in a retracement) with tight stops and target trend continuation. It is the final step from multi-timeframe analysis to execution: first confirm trend and liquidity targets on HTF, then identify displacement and structure shift on LTF, finally enter within OTE zone. Balance risk-reward: entry closer to stop yields higher RR but lower fill probability.",
  "common_mistakes": [
    "Entering in premium zone for longs or discount zone for shorts, violating OTE direction principle.",
    "Drawing Fibonacci without clear swing high/swing low.",
    "Relying solely on OTE without confluence from other PD Array (FVG, order block).",
    "Applying OTE before price completes displacement, leading to false entries in consolidation.",
    "Searching for OTE on lower timeframe without confirming higher timeframe liquidity targets.",
    "Entering before session structure (e.g., Killzone) completes or without clear displacement confirmation.",
    "Confusing OTE with a specific price level instead of a zone.",
    "Mistaking OTE for a final target rather than an entry zone.",
    "Ignoring time factors (e.g., Killzone) when entering OTE.",
    "Failing to distinguish OTE application across timeframes."
  ],
