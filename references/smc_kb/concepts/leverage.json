{
  "card_id": "leverage",
  "type": "merged_concept",
  "canonical_term": "Leverage",
  "aliases": [],
  "school": "General",
  "definition": "Leverage allows controlling a larger position than the capital deposited, e.g., 100:1 leverage means $1,000 controls $100,000. It amplifies both potential profits and losses proportionally.",
  "identification_rules": [
    "The use of leverage is identified when the notional position size exceeds the account balance; for instance, controlling $100,000 with only $1,000 in margin."
  ],
  "trading_implication": "Leverage magnifies gains and losses, enabling small accounts to trade large positions. It requires strict risk management to avoid excessive losses, as over-leverage can quickly deplete capital.",
  "common_mistakes": [
    "Using excessive leverage (over-leverage) relative to account size.",
    "Trading without proper risk management, such as stop-loss orders."
  ],
  "related_concepts": [],
