{
  "card_id": "weekly_bias",
  "type": "merged_concept",
  "canonical_term": "Weekly Bias",
  "aliases": [
    "weekly directional bias",
    "Weekly Directional Bias",
    "周线偏向",
    "周线方向预期"
  ],
  "school": "ICT",
  "definition": "The directional expectation for the current week established on the weekly timeframe by analyzing liquidity, swing highs and lows, fair value gaps, and candle closures to anticipate whether price will expand higher or lower.",
  "identification_rules": [
    "Analyze the weekly chart for internal-to-external liquidity sequence (price moving from a fair value gap toward a swing high or low).",
    "Look for a weekly candle 2 closure (sweep of prior candle's high/low with close back inside) to anticipate candle 3 expansion in the opposite direction.",
    "Confirm bias using weekly highs/lows, fair value gaps, and candle closure direction.",
    "Once bias is set, expect the weekly candle to expand in the anticipated direction over the remaining days."
  ],
  "trading_implication": "Weekly Bias is the first step of the top-down fractal model and dictates the directional filter for all lower-timeframe setups. Once established, the trader drops to the daily chart to locate a daily swing point (candle 2 or candle 3 closure with a change in state of delivery), then to the hourly chart for the entry. The same fractal logic applies one tier higher (monthly bias → weekly swing → 4-hour entry) for longer-horizon swing trading.",
  "common_mistakes": [
    "Anticipating continuation on candle 3 without first confirming a valid candle 2 closure on the weekly.",
    "Skipping weekly bias and entering on lower timeframes without higher-timeframe directional alignment.",
    "Assuming Thursday will expand without first confirming Wednesday's closure supports continuation."
  ],
  "related_concepts": [],
  "merge_strategy": "llm_synthesis",
  "merge_model": "deepseek/deepseek-chat",
  "merge_notes": "Both cards are from ICT school; no conflict. The updated card provides more operational identification rules and trading implications, which were adopted.",
