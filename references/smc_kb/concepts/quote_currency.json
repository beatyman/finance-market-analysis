{
  "card_id": "quote_currency",
  "type": "merged_concept",
  "canonical_term": "Quote Currency",
  "aliases": [],
  "school": "General",
  "definition": "In a currency pair, the second currency listed; it indicates how much of that currency is required to purchase one unit of the base currency. For example, in EUR/USD at 1.25, USD is the quote currency, meaning €1 costs $1.25.",
  "identification_rules": [
    "In a forex pair notation (e.g., EUR/USD), the quote currency appears after the base currency, usually following a slash.",
    "The exchange rate quoted for a pair represents the value of one base currency unit expressed in terms of the quote currency."
  ],
  "trading_implication": "The quote currency is the currency you sell when going long a pair and buy when going short. Profit and loss are measured in quote currency units, so a rising exchange rate means the base currency strengthens against the quote currency.",
  "common_mistakes": [
    "Not explicitly stated in the material."
  ],
