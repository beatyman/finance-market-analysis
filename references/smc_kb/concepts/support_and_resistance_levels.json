{
  "card_id": "support_and_resistance_levels",
  "type": "merged_concept",
  "canonical_term": "Support and Resistance Levels",
  "aliases": [
    "S&R Levels",
    "s&r levels",
    "Support/Resistance",
    "support/resistance",
    "时间支撑阻力位"
  ],
  "school": "Price Action",
  "definition": "Price levels or zones where clusters of significant pivot highs/lows indicate strong historical buying/selling pressure, often formed at specific times (midnight, 8:30, 9:30, 10:00, 14:00) or by multiple bounces, expected to cause future reversals or continuations.",
  "identification_rules": [
    "Identify pivot points using a lookback period (e.g., 20 periods) to filter out insignificant swings.",
    "Locate areas where multiple pivot highs (resistance) or pivot lows (support) cluster together.",
    "Draw a rectangle encompassing all clustered pivot points to mark the support or resistance zone.",
    "Midnight open (0:00): daily new candle open, used as support/resistance or premium/discount boundary.",
    "8:30 open: news embargo lift or high-impact news release, often forms Judas swing or order block.",
    "9:30 open: NYSE open, marks volatility entry, often accompanied by distribution phase.",
    "10:00 and 14:00: 4-hour candle opens, used to identify 4-hour cycle OHLC patterns.",
    "Price repeatedly touching the same level at these times confirms validity for trading reference."
  ],
  "trading_implication": "Support levels are expected to halt declines and trigger bounces; resistance levels are expected to cap rallies and trigger reversals. A decisive breakout above resistance can initiate a strong uptrend. Monitor price action at key time levels; if price fails to break, expect reversal; if broken, the level flips to opposite support/resistance.",
  "common_mistakes": [
    "Relying on a single time level without considering premium/discount zones.",
    "Trading time levels without confirmation on lower timeframes.",
    "Ignoring combination of time levels with order blocks and Judas swings.",
    "Using wrong time levels for different asset classes (e.g., forex lacks 9:30 open).",
    "Using too small a lookback period (e.g., 5) generating excessive insignificant pivot points.",
    "Treating a single pivot point as valid support/resistance without clustering confirmation."
  ],
  "related_concepts": [],
  "merge_strategy": "llm_synthesis",
  "merge_model": "deepseek/deepseek-chat",
  "merge_notes": "Both cards agree on Price Action school. ICT card emphasizes time-based levels; SMC card emphasizes pivot clustering. Unified card combines both identification methods.",
