{
  "card_id": "head_and_shoulders",
  "type": "merged_concept",
  "canonical_term": "Head and Shoulders",
  "aliases": [
    "inverse head and shoulders",
    "Inverse Head and Shoulders"
  ],
  "school": "Price Action",
  "definition": "A reversal pattern characterized by three peaks (bearish) or three troughs (bullish, also called Inverse Head and Shoulders). In the bearish form, the head is the highest peak and shoulders are lower; in the bullish form, the head is the lowest trough and shoulders are higher. Confirmation comes with a neckline breakout, projecting a move equal to the head-to-neckline distance.",
  "identification_rules": [
    "The pattern consists of three distinct troughs with the middle trough (head) being the lowest.",
    "The left and right troughs (shoulders) are at approximately similar price levels.",
    "A trendline (neckline) connects the highs between the shoulders.",
    "A breakout above the neckline confirms the pattern and signals a bullish reversal."
  ],
  "trading_implication": "It indicates a potential reversal; traders typically enter positions upon a confirmed neckline breakout, with price targets estimated by measuring the distance from the head to the neckline and projecting in the breakout direction.",
  "common_mistakes": [
    "Entering a trade before the price breaks the neckline, risking false pattern formation.",
    "Using the pattern in isolation without confirmation from trend context or other technical indicators."
  ],
