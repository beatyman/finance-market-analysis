{
  "card_id": "htf_ltf_high_time_frame_low_time_frame",
  "type": "merged_concept",
  "canonical_term": "HTF/LTF (High Time Frame / Low Time Frame)",
  "aliases": [
    "HTF/LTF Analysis",
    "HTF/LTF分析",
    "Multi-timeframe Analysis",
    "Nested Timeframe Structure",
    "nested timeframe structure",
    "Time Frame Analysis",
    "time frame analysis",
    "多时间框架分析",
    "时间框架下钻",
    "时间框架对比分析",
    "跨周期分析"
  ],
  "school": "ICT",
  "definition": "A layered analysis method using higher time frames (e.g., daily, 4H) to determine trend bias and key liquidity targets, and lower time frames (e.g., 15m, 5m, 1m) to pinpoint entry triggers such as market structure shifts or FVG fills, ensuring alignment with the higher timeframe direction.",
  "identification_rules": [
    "Identify key liquidity targets (FVG, OB, swing highs/lows, PD Array) on higher time frames (daily, 4H, 1H) to set the overall bias.",
    "After confirming HTF bias, drill down to lower time frames (15m, 5m, 1m, 15s) to find precise entry signals like MSS, displacement, FVG fill, or OTE retracement.",
    "Ensure LTF signal direction aligns with HTF trend; if HTF structure is unbroken, LTF counter-trend signals are only retracement opportunities.",
    "Look for aggressive price move out and back into a range on LTF, confirming no effective displacement on HTF.",
    "When HTF is in active expansion, LTF retracements should be shallow and fast, not deep.",
    "Compare stop and target levels across time frames to select the best risk-reward ratio for entry.",
    "Verify LTF candlestick patterns (small wicks support expansion, large wicks indicate reversal) align with HTF expectation.",
    "At HTF new candle open, check LTF price action for expected expansion or retracement characteristics.",
    "LTF entry must be executed within Kill Zone time windows."
  ],
  "trading_implication": "HTF provides strategic direction and risk management (stop placement), while LTF offers tactical entry and tighter stops. By nesting LTF signals within HTF targets, traders achieve better risk-reward ratios and avoid being shaken out by short-term noise. Entry triggers are confirmed LTF MSS or FVG fills after HTF bias is set, with targets at HTF liquidity levels, typically aiming for 2R.",
  "common_mistakes": [
    "Trading on LTF without confirming HTF bias, leading to counter-trend trades.",
    "Confusing HTF internal vs external range liquidity, e.g., treating swing low as FVG.",
    "Entering immediately on LTF signal without checking risk-reward meets minimum 2R.",
    "Ignoring Kill Zone time restrictions for LTF signals.",
    "Misinterpreting LTF structure break as trend reversal without checking HTF trend intact.",
    "Looking for deep retracements on LTF when HTF is in active expansion (should be shallow).",
    "Entering without waiting for LTF confirmation (MSS, FVG fill, structure break).",
    "Drilling down to LTF when no clear HTF opportunity exists (no FVG, OB, or discount zone).",
    "Trading LTF signal that contradicts HTF macro direction.",
    "Entering immediately after HTF POI is touched without waiting for LTF aggressive return move.",
    "Ignoring HTF displacement, leading to entry at false breakouts.",
    "Using LTF POI as HTF bias instead of vice versa.",
    "Trading on LTF before HTF candle completes, lacking confirmation.",
    "Confusing HTF reversal day vs continuation day, misinterpreting LTF signals.",
    "Closing position prematurely without verifying HTF target area is actually reached on LTF.",
    "Mistaking LTF consolidation for valid retracement, trading invalid setups.",
    "Trading structure breaks on HTF without displacement, risking inducement."
  ],
