{
  "card_id": "dynamic_liquidity",
  "type": "merged_concept",
  "canonical_term": "Dynamic Liquidity",
  "aliases": [],
  "school": "Smart Money Concepts (SMC)",
  "definition": "Dynamic liquidity is the interplay between external liquidity (swing highs/lows) and internal liquidity (fair value gaps) that drives market movement, as price oscillates between these levels to balance imbalances and sweep liquidity.",
  "identification_rules": [
    "Identify swing highs and lows as external liquidity points.",
    "Identify fair value gaps (FVGs) within the price range between a swing high and low as internal liquidity.",
    "Observe price movement oscillating between sweeping external liquidity (highs/lows) and filling internal liquidity (FVGs)."
  ],
  "trading_implication": "Traders can anticipate price movement by tracking dynamic liquidity: after sweeping external liquidity (swing high/low), price often retraces to fill internal liquidity (FVGs); after filling a gap, price may target the next external liquidity pool. This guides entry and profit targets within the market structure.",
