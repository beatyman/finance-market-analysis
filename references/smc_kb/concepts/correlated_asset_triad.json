{
  "card_id": "correlated_asset_triad",
  "type": "merged_concept",
  "canonical_term": "Correlated Asset Triad",
  "aliases": [
    "correlated markets triad",
    "Correlated Markets Triad",
    "Triad",
    "triad"
  ],
  "school": "ICT",
  "definition": "A grouping of three correlated markets used as the reference set for SMT divergence analysis. Standard triads: forex (DXY, EURUSD, GBPUSD), indices (ES, NQ, YM), gold (GC, XAUEUR, XAUGBP), and oil (CL, RB, HO).",
  "identification_rules": [
    "Group three markets that share a known correlation (e.g. all dollar-denominated forex pairs, US equity indices, gold pairs, or energy products).",
    "Use the predefined sets: DXY/EURUSD/GBPUSD for forex, ES/NQ/YM for indices, GC/XAUEUR/XAUGBP for gold, CL/RB/HO for oil.",
    "Within the triad, compare swing highs/lows or fair value gap fills across assets to detect divergence (one asset takes the level, another does not).",
    "Apply the triad comparison at the same time and same key level on all three charts."
  ],
  "trading_implication": "The triad provides the reference set required to identify SMT divergences, which are mandatory for reversal confirmation since the market cannot reverse without both a swing point and SMT. Traders scan the triad at key levels (range highs/lows, fair value gaps) for divergence: one asset sweeps the level or fills the gap while another does not, signalling a potential reversal. The triad is then combined with candle 2 closures and universal models to build a mechanical entry framework.",
  "common_mistakes": [
    "Not explicitly stated in the material."
  ],
