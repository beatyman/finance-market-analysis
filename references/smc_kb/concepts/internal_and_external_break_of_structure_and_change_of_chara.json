{
  "card_id": "internal_and_external_break_of_structure_and_change_of_chara",
  "type": "merged_concept",
  "canonical_term": "Internal and External Break of Structure and Change of Character",
  "aliases": [
    "Fractal Market Structure Breaks",
    "fractal market structure breaks",
    "Internal and External BOS and CHoCH",
    "internal and external bos and choch"
  ],
  "school": "ICT / Smart Money Concepts (SMC)",
  "definition": "The fractal occurrence of break of structure (BOS) and change of character (CHoCH) across timeframes. External refers to structural breaks on higher timeframes, indicating major trend continuation or reversal. Internal refers to those on lower timeframes, representing smaller swings that refine entries and exits within the higher-timeframe trend.",
  "identification_rules": [
    "External BOS: On a higher timeframe (e.g., daily), price breaks a swing high in an uptrend or a swing low in a downtrend.",
    "External CHoCH: On a higher timeframe, price breaks a key swing low in an uptrend or swing high in a downtrend, warning of a larger trend reversal.",
    "Internal BOS: On a lower timeframe (e.g., 1-hour), price breaks a swing high in an uptrend or a swing low in a downtrend.",
    "Internal CHoCH: On a lower timeframe, price breaks a swing low in an uptrend or swing high in a downtrend, signaling a potential local trend change.",
    "Multi-timeframe alignment: An external BOS often contains multiple internal BOS/CHoCH sequences; an external CHoCH may start with internal CHoCHs."
  ],
  "trading_implication": "Used for multi-timeframe analysis: higher timeframes define the overall trend and major structural levels (external events), while lower timeframes provide precise entry/exit timing (internal events). Aligning lower-timeframe entries with higher-timeframe direction improves trade odds; external CHoCH warns of potential major reversals.",
  "common_mistakes": [
    "Misinterpreting two consecutive internal CHoCHs as a definitive trend reversal when they may only indicate a trading range.",
    "Confusing an internal BOS with an external BOS, leading to premature assumptions about the higher-timeframe trend.",
    "Overlooking that strong levels come from moves that break structure (BOS/CHoCH), while weak levels come from moves that fail to break structure."
  ],
