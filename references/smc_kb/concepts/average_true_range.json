{
  "card_id": "average_true_range",
  "type": "merged_concept",
  "canonical_term": "Average True Range",
  "aliases": [
    "atr",
    "ATR"
  ],
  "school": "Indicator Based",
  "definition": "A volatility indicator that calculates the average true range — the maximum of: current high less low, absolute high less previous close, absolute low less previous close — over a specified number of periods, commonly 14, to measure market volatility.",
  "identification_rules": [
    "ATR is plotted as a line in a separate indicator panel below the price chart.",
    "The value at any point represents the average true range over the chosen period (commonly 14).",
    "Higher ATR values indicate increased volatility and larger price movements, while lower values indicate decreased volatility."
  ],
  "trading_implication": "Used to gauge market volatility, with higher ATR signaling greater price movement. Helps set volatility-adjusted stop-losses (e.g., 2x ATR) and take-profit targets (risk multiples of ATR), adapting risk management to current conditions. Also applied in range detection tools to define range width and sensitivity: longer ATR periods yield fewer, more significant ranges.",
