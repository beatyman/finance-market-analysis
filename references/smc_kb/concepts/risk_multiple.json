{
  "card_id": "risk_multiple",
  "type": "merged_concept",
  "canonical_term": "Risk Multiple",
  "aliases": [
    "R",
    "r",
    "r multiple",
    "R Multiple",
    "r multiples",
    "R multiples",
    "r trade",
    "R trade"
  ],
  "school": "Risk Management",
  "definition": "A unit expressing reward relative to initial risk on a trade. 1R equals the absolute price distance from entry to stop-loss; 2R means profit is twice that distance. Used to define minimum take-profit targets, evaluate whether a trade's potential reward justifies the risk, and assess trade quality without reference to dollar amounts.",
  "identification_rules": [
    "Measure the absolute price distance from the entry point to the stop-loss level; this distance equals 1R.",
    "Multiply 1R by the desired multiple (e.g., 2) and project that distance from the entry in the trade direction to locate the take-profit level.",
    "A trade meets the minimum threshold when the nearest logical target (e.g., failure swings, session highs/lows) is at least 2R away from the entry.",
    "A trade is confirmed to have hit 2R when price travels a distance equal to twice the entry-to-stop distance in the intended direction.",
    "When multiple confluent targets exist (e.g., midnight open, Asia/London highs), partial profits can be taken at each level provided the first partial is beyond 2R."
  ],
  "trading_implication": "Risk Multiple filters trade selection: only setups where the nearest logical target is at least 2R are taken, ensuring a minimum 2:1 reward-to-risk ratio. The stop is placed on the opposing manipulation swing; 2R is projected from entry to set the target. Once a trade exceeds 2R, partial exits at any confluent level (midnight open, session highs/lows, order blocks, failure swings, previous day highs/lows, liquidity pools) are acceptable.",
  "common_mistakes": [
    "Taking partial profits before reaching 2R.",
    "Targeting levels that do not offer at least 2R from the entry, making the trade not worthwhile in terms of risk-to-reward."
  ],
