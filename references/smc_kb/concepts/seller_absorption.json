{
  "card_id": "seller_absorption",
  "type": "merged_concept",
  "canonical_term": "Seller Absorption",
  "aliases": [],
  "school": "ICT",
  "definition": "A micro-level pattern where aggressive selling into a key area is absorbed by buyers, causing price stagnation and a shift to bullish order flow, confirming a continuation long entry.",
  "identification_rules": [
    "Price approaches a predetermined area of interest (order block, range) with strong bearish momentum.",
    "Upon reaching the area, price decelerates and begins to stagnate instead of breaking through.",
    "Sellers fail to push price lower and are gradually absorbed, with buyers protecting the level.",
    "Confirmation occurs when price breaks a recent swing high or runs a high within the area, signaling order flow flip to buyers."
  ],
  "trading_implication": "Used on lower timeframes (1-min, 5-min) as confirmation to enter continuation longs after a pullback. It indicates seller exhaustion and buyer dominance, allowing for tight stop placement below the absorption zone.",
  "common_mistakes": [
    "Entering long too early before confirmation of absorption and order flow shift.",
    "Misinterpreting an initial aggressive wick as a breakout rather than a potential trap (inducement).",
    "Turning bearish after a false break and selling into a liquidity run, getting trapped on the wrong side."
  ],
  "related_concepts": [],
  "illustrated_by_cases": [
