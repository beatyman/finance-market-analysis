{
  "card_id": "average_true_range_atr",
  "type": "merged_concept",
  "canonical_term": "Average True Range (ATR)",
  "aliases": [
    "ATR"
  ],
  "school": "Smart Money Concepts (SMC)",
  "definition": "A volatility indicator that measures the average range of the previous 14 candles. In SMC, when an order block candle's range is less than 60% of ATR, the order block zone is extended by one ATR on each side to account for insufficient area.",
  "identification_rules": [
    "Set the ATR indicator to the default 14-period setting on the chart.",
    "Measure the order block candle's range (high minus low) in pips.",
    "Compare the candle's range to 60% of the ATR value.",
    "If the candle range is less than 60% of ATR, extend the order block zone by adding one full ATR value above and below the candle's high and low.",
    "The resulting zone becomes the new order block area for trade entry."
  ],
  "trading_implication": "Using ATR to widen small order block zones prevents traders from placing stop losses too close, reducing the likelihood of being stopped out by minor liquidity grabs. This improves the reliability of the order block as a reversal zone and enhances trade execution in volatile markets.",
  "common_mistakes": [
    "Trading a small order block without applying the ATR extension, leading to stop-outs from normal price fluctuation.",
    "Ignoring the ATR rule and entering with a tight stop, assuming the small candle will hold."
  ],
