{
  "card_id": "higher_high_higher_low",
  "type": "merged_concept",
  "canonical_term": "Higher High / Higher Low",
  "aliases": [],
  "school": "Price Action",
  "definition": "In an uptrend, price forms a sequence of progressively higher swing highs and higher swing lows. A higher high exceeds the previous swing high; a higher low stays above the prior swing low.",
  "identification_rules": [
    "Identify swing highs and swing lows; an uptrend is present when each new swing high is above the prior swing high.",
    "Each subsequent swing low must be above the prior swing low, forming a series of higher lows.",
    "If a higher low fails to form and price drops below the previous swing low, the uptrend may be in jeopardy."
  ],
  "trading_implication": "Higher highs and higher lows confirm a bullish trend, giving a long bias. Traders seek entries on pullbacks to higher lows, expecting continuation to new higher highs. A break below a higher low warns of a potential trend change.",
  "common_mistakes": [
    "Attempting to short after a lower low forms without considering the higher-timeframe trend, which may still be bullish.",
    "Assuming a higher high or low has formed before the swing point is completed, leading to premature trend confirmation.",
    "Misinterpreting sideways consolidation as a higher high/low sequence, which can generate false signals."
  ],
