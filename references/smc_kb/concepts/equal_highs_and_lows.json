{
  "card_id": "equal_highs_and_lows",
  "type": "merged_concept",
  "canonical_term": "Equal Highs and Lows",
  "aliases": [
    "double bottoms",
    "double tops",
    "triple bottoms",
    "triple tops"
  ],
  "school": "Smart Money Concepts (SMC)",
  "definition": "Price levels where two or more swing highs or lows form at approximately the same price, creating a support/resistance zone that attracts retail stop-loss orders, which smart money may sweep before reversing.",
  "identification_rules": [
    "Identify swing highs using the three-candle pattern (middle candle makes a higher high than both sides) and swing lows (middle candle makes a lower low than both sides) after the third candle closes.",
    "Locate two or more swing highs or two or more swing lows at roughly the same price level, forming a horizontal line.",
    "Mark the area as a liquidity zone where retail stop-losses accumulate above equal highs or below equal lows."
  ],
  "trading_implication": "Equal highs/lows signal potential liquidity sweeps. Do not enter immediately on a retest; instead, wait for price to break the level, trigger stop-losses, and then reverse. Enter at confirmed demand (below equal lows) or supply (above equal highs) zones after the sweep, in alignment with the higher timeframe trend.",
  "common_mistakes": [
    "Entering long at equal lows or short at equal highs without waiting for the liquidity sweep, leading to stop-outs.",
    "Placing stop losses just above/below the equal level, making them an easy target for smart money sweeps."
  ],
