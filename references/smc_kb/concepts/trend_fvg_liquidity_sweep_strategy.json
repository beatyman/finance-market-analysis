{
  "card_id": "trend_fvg_liquidity_sweep_strategy",
  "type": "merged_concept",
  "canonical_term": "Trend + FVG + Liquidity Sweep Strategy",
  "aliases": [
    "strategy one",
    "Strategy One"
  ],
  "school": "ICT",
  "definition": "A two-timeframe strategy: on the HTF, identify trend via market structure and mark fair value gaps. Wait for a pullback into an FVG, then on the LTF, confirm a reversal with a liquidity sweep (price wicks beyond a recent swing point and reverses) and optionally a change of character. Enter after confirmation, with stop loss beyond the sweep, and target the next HTF level.",
  "identification_rules": [
    "On the higher time frame, determine trend using market structure (higher highs/higher lows for bullish, lower lows/lower highs for bearish).",
    "Mark fair value gaps on the higher time frame as potential support (bullish) or resistance (bearish).",
    "Wait for price to retrace into a higher time frame fair value gap.",
    "Switch to a lower time frame (at least two times lower, e.g., 1H and 5min).",
    "Look for a bullish liquidity grab (price wicks below a recent low then reverses up) in an uptrend, or a bearish liquidity grab (wicks above a recent high then reverses down) in a downtrend.",
    "Optionally confirm the reversal with a break of short-term market structure on the lower time frame (change of character).",
    "Enter the trade after the confirmation signal on the lower time frame.",
    "Place stop loss below the low of the bullish liquidity grab or above the high of the bearish liquidity grab.",
    "Set take profit at the next significant higher time frame level (e.g., swing high/low, next FVG)."
  ],
  "trading_implication": "This strategy provides a structured approach to trade in the direction of the HTF trend, using FVGs as premium/discount zones and liquidity sweeps for precise entries. It combines multiple confirmations to filter low-probability setups. It is suited for trending markets and offers clear risk-to-reward parameters, with stops placed beyond the sweep and targets at the next HTF level.",
  "common_mistakes": [
    "Applying the strategy in choppy or ranging markets where HTF trend is unclear."
  ],
