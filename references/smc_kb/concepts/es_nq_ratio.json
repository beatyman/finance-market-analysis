{
  "card_id": "es_nq_ratio",
  "type": "merged_concept",
  "canonical_term": "ES/NQ Ratio",
  "aliases": [
    "ES/NQ comparison chart",
    "es/nq comparison chart",
    "relative strength ratio ES/NQ",
    "relative strength ratio es/nq"
  ],
  "school": "ICT",
  "definition": "A chart of ES futures price divided by NQ futures price. A rising ratio indicates ES is relatively stronger than NQ; a falling ratio indicates NQ is relatively stronger. Reversals on this ratio chart can signal a shift in correlation and often precede reversals on ES or NQ individual charts.",
  "identification_rules": [
    "Chart the ES/NQ ratio by dividing ES price by NQ price on any standard platform (e.g., TradingView).",
    "Interpret a bullish (rising) ratio as ES outperforming NQ and a bearish (falling) ratio as NQ outperforming ES.",
    "Identify reversals on the ratio chart (e.g., a swing high and subsequent close back inside the range) to anticipate upcoming reversals on ES or NQ.",
    "Use ratio-based relative strength to select the stronger asset for long trades and the weaker asset for short trades.",
    "Combine ratio analysis with SMT divergences between ES and NQ for higher-confidence signals."
  ],
  "trading_implication": "The ratio helps traders determine relative strength, guiding which correlated asset to trade. A bullish ratio suggests taking long setups in ES and short setups in NQ; a bearish ratio does the opposite. Reversals on the ratio chart can provide early warning of reversals on the underlying index futures, allowing preemptive positioning before confirmation on the individual charts.",
  "common_mistakes": [
    "Trading against the ratio’s relative strength bias (e.g., buying NQ when the ratio is falling and NQ is weaker).",
    "Ignoring ratio reversals and missing early reversal signals on ES or NQ.",
    "Using the ratio in isolation without confirming with SMT or market structure on the individual instruments."
  ],
