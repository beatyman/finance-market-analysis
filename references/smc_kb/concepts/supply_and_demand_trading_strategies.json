{
  "card_id": "supply_and_demand_trading_strategies",
  "type": "merged_concept",
  "canonical_term": "Supply and Demand Trading Strategies",
  "aliases": [],
  "school": "Smart Money Concepts (SMC)",
  "definition": "A trading approach that identifies supply and demand zones from impulsive price moves. Trades align with trend on a single timeframe, using higher timeframe context to avoid counter-trend trades. A multi-timeframe variant adds lower timeframe confirmation via liquidity grabs after price retraces to the zone.",
  "identification_rules": [
    "Determine trend using market structure: an uptrend has higher swing lows holding with breakouts; a downtrend has lower swing highs holding.",
    "Mark supply zones at the base of strong bearish impulsive moves and demand zones at the base of strong bullish impulsive moves.",
    "In single timeframe, place limit orders at the zone edge with stop loss below the demand zone (or protective swing low) and above for supply zones.",
    "Before entry, check higher timeframe to ensure distance to next opposing key level; avoid trades if price is near a major resistance in an uptrend or support in a downtrend.",
    "In multi-timeframe, after price enters the zone, drop to a lower timeframe (at least 2× smaller) and wait for a liquidity grab: a false breakout of the recent swing low (for buys) or high (for sells) that closes back inside range.",
    "Enter on the close of the liquidity grab candle; place stop loss beyond the swept swing point; target the next significant level."
  ],
  "trading_implication": "Provides a systematic framework to enter high-probability trades aligned with institutional order flow. The single timeframe method offers simplicity; the multi-timeframe addition increases precision by demanding lower timeframe reversal confirmation after a liquidity sweep, reducing false signals.",
  "common_mistakes": [
    "Entering prematurely before price fully retraces into the identified zone, resulting in being caught as liquidity.",
    "Ignoring higher timeframe context and taking trades near major opposing supply or demand levels that could cause reversals.",
    "Placing stop losses too tightly within small zones, leading to unnecessary stop-outs from normal price fluctuations."
  ],
