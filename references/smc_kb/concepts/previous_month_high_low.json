{
  "card_id": "previous_month_high_low",
  "type": "merged_concept",
  "canonical_term": "Previous Month High / Low",
  "aliases": [
    "Previous Month's High and Low",
    "previous month's high and low"
  ],
  "school": "ICT",
  "definition": "The highest and lowest price points of the prior monthly candle, used as reference levels. Unless the current month consolidates, price tends to reach toward one or both sides of the range, serving as liquidity targets and potential reversal zones.",
  "identification_rules": [
    "Identify the high and low of the previous completed calendar month's candle on a monthly chart.",
    "Extend horizontal lines from the previous month's high and low into the current month's price action, using dashed or different colored lines to distinguish.",
    "Monitor whether price is trending toward or reacting at these extended levels.",
    "Unless price is in a consolidation phase, expect price to move toward the previous month's high or low (or both)."
  ],
  "trading_implication": "These levels act as draw-on-liquidity targets; price is likely to move toward them unless consolidating. A hold or rejection at these levels can frame a reversal, while a sweep often confirms continuation. They help anticipate directional bias and set profit targets. Use across multiple timeframes for higher-level liquidity targets.",
  "common_mistakes": [
    "Assuming price will always reach previous month's high/low in all market conditions — consolidation phases may prevent this.",
    "Trading reversals at these levels without additional confirmation (e.g., displacement, session liquidity).",
    "Failing to mark previous month high/low on multiple timeframes, missing higher-level liquidity targets.",
    "Confusing previous month high/low with current month high/low, leading to incorrect liquidity predictions."
  ],
