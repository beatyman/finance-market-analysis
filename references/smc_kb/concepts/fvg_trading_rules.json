{
  "card_id": "fvg_trading_rules",
  "type": "merged_concept",
  "canonical_term": "FVG Trading Rules",
  "aliases": [],
  "school": "ICT",
  "definition": "A set of criteria for using Fair Value Gaps as trade entry points: trade only after a valid Break of Structure or Change of Character; in bearish markets, only short from premium‑zone FVGs; in bullish markets, only long from discount‑zone FVGs; extreme FVGs have priority; and only use unmitigated FVGs.",
  "identification_rules": [
    "Trade setup requires a preceding valid Break of Structure (BOS) or Change of Character (CHoCH); do not use FVGs without this signal.",
    "In a bearish trend, only consider FVGs located in the premium zone for short entries; in a bullish trend, only consider FVGs in the discount zone for long entries.",
    "FVGs at market extremes (the highest or lowest point of a move) take priority over other FVGs for trade execution.",
    "Use only unmitigated FVGs; once price has entered and filled an FVG, do not consider it for future trading opportunities."
  ],
  "trading_implication": "FVG Trading Rules filter high‑probability entry zones that align with market structure and directional bias. They ensure entries occur only in the direction of the trend after a structural shift, within optimal premium/discount areas, and on fresh imbalances, thereby reducing false signals and improving risk‑to‑reward.",
  "common_mistakes": [
    "Executing a trade based on an FVG without first confirming a valid BOS or CHoCH, leading to entries against the market structure.",
    "Trading a mitigated FVG that has already been filled by price, expecting it to act as support or resistance again."
  ],
