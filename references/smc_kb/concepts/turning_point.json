{
  "card_id": "turning_point",
  "type": "merged_concept",
  "canonical_term": "Swing Point",
  "aliases": [
    "turning point"
  ],
  "school": "Smart Money Concepts (SMC)",
  "definition": "A price area where the market reversed direction after a long-term trend, often perceived as overbought or oversold. These levels hold significant liquidity due to clustered stop-loss orders and attract both retail and institutional attention.",
  "identification_rules": [
    "Identify key turning points where price has sharply reversed in the past, likely holding clusters of stop-loss orders.",
    "Wait for a liquidity grab below the turning point, appearing as a spike beyond the level followed by a sharp reversal.",
    "After the liquidity sweep, look for reversal confirmation such as a long bullish momentum candlestick or a change of character.",
    "Enter the trade in the direction of the reversal after confirmation.",
    "Set stop-loss just beyond the liquidity sweep to protect against further unexpected moves.",
    "Target the next significant support or resistance level, or use Fibonacci retracement for take-profit."
  ],
  "trading_implication": "Turning points are used to identify high-probability reversal zones. Traders wait for a liquidity sweep (stop-loss hunt) at these levels, then enter upon reversal confirmation, aiming for the next key level. This approach exploits the accumulation of retail orders and institutional manipulation.",
  "common_mistakes": [
    "Not explicitly mentioned in the material."
  ],
