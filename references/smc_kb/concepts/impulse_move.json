{
  "card_id": "impulse_move",
  "type": "merged_concept",
  "canonical_term": "Impulse Move",
  "aliases": [
    "Impulsive Move"
  ],
  "school": "Smart Money Concepts (SMC)",
  "definition": "A strong directional price movement driven by momentum, characterized by consecutive large-bodied candles of the same color covering significant distance, typically exceeding corrective waves. It forms the trending leg within market structure, part of a fractal impulse-correction pattern.",
  "identification_rules": [
    "Consists of at least three consecutive candles of the same color with large bodies and minimal wicks.",
    "Covers a greater distance compared to adjacent corrective waves, with little overlap between candles.",
    "Occurs after a corrective pullback/retracement, continuing the dominant trend.",
    "Creates a new swing high or low beyond a recent structure level, breaking market structure.",
    "The move is not interrupted by a correction reaching the 38.2% Fibonacci retracement level.",
    "On higher timeframes, multiple smaller impulsive and corrective waves may compose a single impulsive move."
  ],
  "trading_implication": "Impulse moves establish trend direction. Traders anticipate entries after a corrective pullback, using Fibonacci retracement on the impulse range to define premium/discount zones. In uptrends, buying at the discount zone targets the next impulsive leg; in downtrends, selling at the premium zone. A valid pullback retraces at least 38.2% of the impulse. Breaks of impulse-derived swing points signal continuation or reversal. This approach improves risk-to-reward and entry timing, while providing key structure levels.",
  "common_mistakes": [
    "Entering too early before the correction has fully ended, leading to losses if the pullback deepens.",
    "Waiting too long and missing the entry as the impulsive move starts without confirmation.",
    "Misidentifying a corrective bounce as a new impulsive move, especially in ranging markets.",
    "Failing to adjust Fibonacci levels when the impulsive wave extends further.",
    "Misidentifying shallow internal moves that fail to retrace 38.2% as valid pullbacks.",
    "Confusing a single impulsive leg with multiple separate legs if not checking Fibonacci depth.",
    "Prematurely calling a reversal when price only makes a minor correction that doesn't break impulse structure."
  ],
