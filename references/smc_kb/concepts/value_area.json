{
  "card_id": "value_area",
  "type": "merged_concept",
  "canonical_term": "Value Area",
  "aliases": [],
  "school": "Volume Analysis",
  "definition": "The price range where a specified percentage (default 70%) of total volume occurred over a given period, bounded by the Value Area High (VAH) and Value Area Low (VAL). Typically calculated using the Volume Profile indicator.",
  "identification_rules": [
    "Add the Volume Profile indicator to the chart (e.g., Visible Range Volume Profile on TradingView).",
    "Enable the Value Area High (VAH) and Value Area Low (VAL) lines in the indicator settings.",
    "The Value Area is the horizontal band between VAH and VAL, containing the default 70% of total volume for the viewed price range."
  ],
  "trading_implication": "The Value Area marks the zone where most trading activity occurred, often acting as a balance range. Price acceptance within it suggests consolidation, while moves outside may signal breakouts. The boundaries (VAH/VAL) can serve as potential support/resistance, but key reversals often occur just beyond them. Used to gauge market balance and potential mean reversion.",
  "common_mistakes": [
    "Assuming the Value Area acts as definitive support or resistance; in practice, key reversals often occur just above VAH or below VAL."
  ],
