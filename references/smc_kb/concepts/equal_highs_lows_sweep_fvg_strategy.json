{
  "card_id": "equal_highs_lows_sweep_fvg_strategy",
  "type": "merged_concept",
  "canonical_term": "Equal Highs/Lows Sweep + FVG Strategy",
  "aliases": [
    "Strategy Three",
    "strategy three"
  ],
  "school": "ICT",
  "definition": "A single-timeframe smart money strategy that combines equal highs/lows, liquidity sweeps, and fair value gaps. It triggers entries when price sweeps equal highs (bearish) or lows (bullish) and then retraces into an unfilled FVG, offering a high-probability setup with defined risk.",
  "identification_rules": [
    "Identify equal highs (resistance) or equal lows (support) using auto-detection or manual marking.",
    "Wait for price to sweep these levels, breaking and reversing sharply.",
    "Verify a fair value gap forms in the reversal direction: bearish FVG above swept highs, bullish FVG below swept lows.",
    "Ensure the FVG remains unfilled and price retraces into it as support (bullish) or resistance (bearish).",
    "Enter at the FVG zone, place stop loss beyond the sweep extreme, target the next liquidity pool (e.g., opposite equal level)."
  ],
  "trading_implication": "This strategy captures high-probability reversals after liquidity grabs, entering at a discounted or premium FVG. It leverages the tendency of smart money to fill imbalances after triggering retail stops. Patience is critical—only the cleanest setups with confirmed sweeps and unmitigated FVGs should be traded to avoid false signals.",
  "common_mistakes": [
    "Entering on every liquidity sweep without waiting for FVG confirmation.",
    "Failing to check if the FVG has been filled before entry.",
    "Overtrading low-quality setups instead of filtering for clean sweeps and clear FVGs."
  ],
