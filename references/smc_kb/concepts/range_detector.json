{
  "card_id": "range_detector",
  "type": "merged_concept",
  "canonical_term": "Range Detector",
  "aliases": [],
  "school": "Indicator Based",
  "definition": "A LuxAlgo indicator that automatically identifies horizontal trading ranges (price moving sideways between support and resistance). It draws shaded rectangles and horizontal lines, confirming a range after sufficient data (default 20 candles). Breakouts are signaled by line color changes: green for upside breaks, red for downside breaks. Best used with price action confirmation.",
  "identification_rules": [
    "A gray vertical line marks the candle where the range is first detected after the required minimum length (default 20 candles).",
    "The detected range appears as a shaded rectangle bounded by horizontal support and resistance lines.",
    "An upside breakout is indicated when the horizontal line turns green.",
    "A downside breakout is indicated when the horizontal line turns red.",
    "Increasing the minimum range length setting requires more historical data, filtering out weaker ranges."
  ],
  "trading_implication": "The Range Detector helps identify consolidation zones and potential breakout opportunities. Traders can use line color changes as entry signals, but should confirm with price action (e.g., higher lows into resistance for bullish breaks, lower highs into support for bearish) to avoid false breakouts. It is suitable for higher timeframes with default settings for reliability.",
  "common_mistakes": [
    "Setting the minimum range length too low (below 20) generates many false ranges due to insufficient data.",
    "Relying solely on line color changes without price action confirmation, leading to false breakout entries."
  ],
