{
  "card_id": "higher_time_frame",
  "type": "merged_concept",
  "canonical_term": "Higher Time Frame",
  "aliases": [
    "Higher Time Frame Context",
    "higher time frame context",
    "higher time frame key level",
    "Higher Time Frame Key Level",
    "Higher Time Frame Level",
    "higher time frame level",
