{
  "card_id": "corrective_pullback",
  "type": "merged_concept",
  "canonical_term": "Corrective Pullback",
  "aliases": [],
  "school": "Smart Money Concepts (SMC)",
  "definition": "A deeper pullback against the dominant trend, typically retracing to Fibonacci levels or key order blocks, offering higher-probability entry opportunities.",
  "identification_rules": [
    "The pullback extends beyond minor retracements, often reaching at least the 50% Fibonacci level.",
    "It frequently tests a significant order block or supply/demand zone.",
    "The pullback may consist of overlapping candles with smaller bodies, indicating corrective price action."
  ],
  "trading_implication": "Corrective pullbacks provide high-probability entry points in the trend direction, especially when price reaches discount zones or order blocks, offering favorable risk-to-reward ratios for trades aligned with the higher-timeframe trend.",
  "common_mistakes": [
    "Entering prematurely before the pullback reaches the deeper Fibonacci level or order block.",
    "Confusing a corrective pullback with a trend reversal pattern."
  ],
