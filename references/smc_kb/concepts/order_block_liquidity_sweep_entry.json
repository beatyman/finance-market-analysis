{
  "card_id": "order_block_liquidity_sweep_entry",
  "type": "merged_concept",
  "canonical_term": "Order Block Liquidity Sweep Entry",
  "aliases": [],
  "school": "ICT",
  "definition": "A bullish entry setup in an uptrend where, after a break of structure with no inefficiency, price sweeps below a minor swing low to grab liquidity, then enters an underlying order block, triggering a long entry above the block with a stop below the swing low.",
  "identification_rules": [
    "In an uptrend, after a break of structure to the upside that created no fair value gap on the impulse move, identify a swing low with a fair value gap and valid order block just below it.",
    "Price must break below that swing low to sweep liquidity, then retrace into the order block zone.",
    "Place a buy order one spread above the order block zone.",
    "Set a stop loss below the swept swing low.",
    "Target the next key resistance level in the trend direction.",
    "For a bearish setup, mirror the rules: look for a downtrend, sweep above a swing high with inefficiency and order block, sell below the order block, stop above the swing high."
  ],
  "trading_implication": "This setup offers a high-probability trend continuation entry by confirming that stop-losses behind a swing low have been cleared and price is reacting from a demand order block. It provides a precise entry with a tight stop, improving risk-to-reward.",
  "common_mistakes": [
    "Failing to analyze the left side for additional liquidity zones or order blocks below, which may cause further liquidity grabs and stop out the trade early.",
    "Entering before price actually taps into the order block, risking premature entry during the sweep.",
    "Ignoring the quality of the order block (e.g., lacking obvious inefficiency) leading to a weak reaction."
  ],
