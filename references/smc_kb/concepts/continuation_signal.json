{
  "card_id": "continuation_signal",
  "type": "merged_concept",
  "canonical_term": "Continuation Signal",
  "aliases": [
    "trend continuation signal",
    "Trend Continuation Signal"
  ],
  "school": "Smart Money Concepts (SMC)",
  "definition": "A price move that breaks and closes beyond the major high (in an uptrend) or major low (in a downtrend) with a valid Break of Structure (BOS), indicating that the prevailing trend is persisting rather than reversing.",
  "identification_rules": [
    "In an uptrend, identify the most recent major high (highest point before retracement) and major low (lowest point of the bullish impulse that created that high).",
    "Wait for price to break above the major high with the body of a candle and close above it to form a valid BOS.",
    "If the break occurs with a wick but the candle body closes below the high, and the next candle's wick does not exceed the first candle's wick, it is not a valid continuation signal.",
    "In a downtrend, identify the most recent major low and major high; wait for price to break below the major low with a body close to confirm continuation.",
    "The break must create a new major swing point; internal structures and retracements within the range are ignored as long as the most recent major low (uptrend) or major high (downtrend) is maintained."
  ],
  "trading_implication": "A continuation signal confirms the trend's persistence, providing a high-probability entry opportunity in the direction of the trend. Traders can enter on a pullback to a newly formed order block or fair value gap after the break, placing stops beyond the most recent major low (uptrend) or major high (downtrend).",
  "common_mistakes": [
    "Confusing a continuation signal with a reversal signal when price breaks the major low in an uptrend (or major high in a downtrend), which is a Change of Character.",
    "Treating a wick break that fails to close beyond the swing point as a valid continuation signal.",
    "Entering immediately after the break without waiting for a retracement to a discounted point of interest."
  ],
