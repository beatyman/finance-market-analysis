{
  "card_id": "volume_profile",
  "type": "merged_concept",
  "canonical_term": "Volume Profile",
  "aliases": [
    "visible range volume profile",
    "Visible Range Volume Profile",
    "VRVP",
    "vrvp"
  ],
  "school": "Volume Analysis",
  "definition": "An indicator that displays traded volume at each price level over the currently visible chart range, highlighting the Point of Control (POC) where most volume traded, and a Value Area with lines VAH and VAL enclosing a set percentage of volume (default 70%), while distinguishing buying vs selling volume with colored bars.",
  "identification_rules": [
    "Horizontal bars appear on the right side of the chart, each bar representing a price level.",
    "Bar height indicates total volume traded at that price; tallest bar marks the Point of Control (POC).",
    "Enabling Value Area High (VAH) and Value Area Low (VAL) lines shows boundaries where a specified percentage (default 70%) of volume was traded.",
    "The indicator recalculates and changes appearance when the chart is zoomed in/out or scrolled.",
    "Bars often display two colors (e.g., red/blue) to show buying vs. selling volume distribution."
  ],
  "trading_implication": "High-volume price zones often become trading ranges rather than clear support/resistance. Actual support/resistance often forms just above high-volume areas. Conversely, very low-volume areas suggest prices moved fast in the past, increasing the likelihood of similar fast moves in the future. Use low-volume regions to anticipate potential explosive moves, and treat high-volume regions as potential consolidation zones.",
  "common_mistakes": [
    "Mistaking high-volume bars as strong support or resistance levels; they usually indicate consolidation zones, not precise reversal levels.",
    "Ignoring low-volume areas, which can be key for identifying fast-moving price zones.",
    "Not adjusting the visible range and settings (like Value Area percentage) to match one's trading timeframe."
  ],
