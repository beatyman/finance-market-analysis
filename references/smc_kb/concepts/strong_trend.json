{
  "card_id": "strong_trend",
  "type": "merged_concept",
  "canonical_term": "Strong Trend",
  "aliases": [
    "clear trend",
    "steep trend"
  ],
  "school": "Price Action",
  "definition": "A steep, clear uptrend or downtrend where pullbacks are shallow and rarely breach the 0.5 Fibonacci retracement level, often reversing between 0.382 and 0.5, making a simplified Fibonacci tool effective.",
  "identification_rules": [
    "Price forms a steep sequence of higher highs and higher lows (uptrend) or lower highs and lower lows (downtrend).",
    "Pullbacks consistently hold above the 0.5 Fibonacci retracement level.",
    "Price frequently reverses in the 0.382 to 0.5 zone, often with confirming candlestick patterns like bullish engulfing."
  ],
  "trading_implication": "In strong trends, apply a custom Fibonacci retracement using only the 0, 0.382, 0.5, and 1 levels. Look for pullbacks to the 0.382–0.5 zone for trend-continuation entries, confirmed by reversal patterns (e.g., bullish engulfing in uptrends). This approach targets high-probability reversal areas.",
  "common_mistakes": [
    "Using standard Fibonacci retracement with many levels (0.236, 0.618, etc.) on strong trends, which clutters the chart and may lead to expecting deeper pullbacks that rarely occur."
  ],
