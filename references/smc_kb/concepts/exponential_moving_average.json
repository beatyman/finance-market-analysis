{
  "card_id": "exponential_moving_average",
  "type": "merged_concept",
  "canonical_term": "Exponential Moving Average",
  "aliases": [
    "EMA",
    "ema"
  ],
  "school": "Indicator-Based",
  "definition": "A moving average that assigns greater weight to recent price data, making it more responsive to current price action than the simple moving average. It reacts faster to price changes, falling sooner during declines and rising sooner during reversals.",
  "identification_rules": [
    "On a chart, the EMA line will turn down faster than an SMA of the same period during a price crash.",
    "At the start of an uptrend reversal, the EMA will begin rising earlier than an SMA of the same period."
  ],
  "trading_implication": "The EMA is favored by short-term traders for its quicker reaction to price changes, allowing earlier trend signals and potentially earlier entries and exits. It reduces lag compared to the SMA.",
