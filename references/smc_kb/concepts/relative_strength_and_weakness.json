{
  "card_id": "relative_strength_and_weakness",
  "type": "merged_concept",
  "canonical_term": "Relative Strength and Weakness",
  "aliases": [
    "Relative Strength",
    "Relative Weakness",
    "RS/RW",
    "rs/rw",
    "相关资产强弱对比",
    "相对强弱"
  ],
  "school": "ICT",
  "definition": "Comparison of two correlated assets (e.g., ES and NQ) to determine which is more bullish or bearish. Assessed via swing points, candle closures, order block reactions, displacement, and SMT divergences. The stronger asset is preferred for longs, the weaker for shorts.",
  "identification_rules": [
    "Compare swing points: one asset makes a higher high while the other makes a lower high or fails to reach a prior swing high.",
    "Examine candle closures and size: a weaker asset shows larger bearish candles or smaller bullish candles relative to the stronger asset.",
    "Check reactions at order blocks: the stronger asset may not respect the mean threshold, while the weaker one does, or vice versa.",
    "Observe displacement: aggressive moves in one asset that are not matched by the other indicate relative strength/weakness.",
    "Look for SMT divergences: correlated assets put in opposite swing points (e.g., higher high vs. lower high).",
    "Use the ES/NQ ratio chart: a rising ratio shows ES strength/NQ weakness; a falling ratio shows ES weakness/NQ strength."
  ],
  "trading_implication": "Traders use relative strength/weakness to bias trade direction: take long setups on the stronger asset and short setups on the weaker asset. It filters the preferred instrument for higher-probability entries and validates displacement and reversal signals, especially when dropping to lower time frames.",
  "common_mistakes": [
    "仅看单个资产的走势而忽视相关资产的对比，导致误判强弱关系。",
    "混淆ES/NQ比值图的方向含义，错误解读相对强弱。",
    "未能结合Order Block、Fair Value Gap等结构工具来验证相对强弱判断。"
  ],
