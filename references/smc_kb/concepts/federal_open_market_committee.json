{
  "card_id": "federal_open_market_committee",
  "type": "merged_concept",
  "canonical_term": "Federal Open Market Committee",
  "aliases": [
    "fed meeting",
    "Fed meeting",
    "FOMC",
    "fomc",
    "fomc day",
    "FOMC day"
  ],
  "school": "General",
  "definition": "A high-impact macroeconomic news event in which the Federal Reserve announces interest rate decisions. The uncertainty surrounding the announcement causes market participants to withhold directional commitment, producing range-bound, indecision price action on the session preceding or containing the release.",
  "identification_rules": [
    "Mark the calendar date of the scheduled FOMC interest rate announcement; the trading session on that day or the day prior is the relevant window.",
    "Observe whether the daily candle forms an indecision (doji-like) structure where open and close are at approximately the same price level with no sustained directional expansion.",
    "Confirm Seek and Destroy conditions: London sweeps both sides of the Asia range without holding a breakout, and New York continues to oscillate back into the established range rather than expanding directionally.",
    "If most of the daily range is already created in London with no clear expansion in New York, treat this as additional confirmation of a low-probability, range-bound FOMC session."
  ],
  "trading_implication": "Pre-FOMC sessions are expected to produce Seek and Destroy / indecision daily profiles. Directional expansion trades should be avoided. If trading is attempted, the preferred approach is fading moves back into the range: mark equilibrium (0.5 level) and premium/discount of the London or Asia range, then target the range interior when price deviates outside it. The daily open and equilibrium act as magnet targets.",
  "common_mistakes": [
    "Attempting to trade directional breakouts or expansions on a pre-FOMC session, expecting a London Reversal or New York Reversal profile when consolidation is the more probable outcome.",
    "Ignoring the high-impact news calendar and misclassifying an FOMC-driven indecision candle as a tradeable directional setup."
  ],
