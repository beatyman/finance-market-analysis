{
  "card_id": "failure_to_displace",
  "type": "merged_concept",
  "canonical_term": "Failure to Displace",
  "aliases": [
    "Failed Displacement",
    "failed displacement",
    "Failure to Close Outside",
    "lack of displacement",
    "Lack of Displacement"
  ],
  "school": "ICT",
  "definition": "Price probes beyond a key level (swing high/low, previous day/week high/low) but closes back inside the range, indicating insufficient momentum to sustain a breakout. This failure frames a reversal bias toward the opposite side.",
  "identification_rules": [
    "Identify a relevant level: swing high, swing low, previous day high, previous day low, previous week high, or previous week low.",
    "Price must wick through the level but close back inside the prior range.",
    "The close inside the range confirms the failure to displace.",
    "Bias is framed in the direction opposite the failed breakout: bullish if fails below a low, bearish if fails above a high.",
    "Use the failure to anticipate the next candle's OHLC direction via the Next Day Model (bullish open-high-low-close, bearish open-low-high-close).",
    "Observe if a strong counter-directional candle (aggressive up/down candle) appears after the failure, forming a reversal signal.",
    "Often accompanied by a candle closing back within the previous candle's range or forming an inside bar.",
    "Can be applied across multiple timeframes (daily, 4H, 1H, etc.), with higher timeframe failures taking precedence."
  ],
  "trading_implication": "Failure to Displace signals a likely reversal or retracement. It is used to frame the next session's bias (e.g., next day) and target the opposite side of the range or a liquidity pool. Entry can be taken near the failure point, combined with PD Array (FVG, OB) and Next Candle/Next Day Model for targets toward higher structure or prior swing points.",
  "common_mistakes": [
    "Treating a wick beyond the level as failure before the candle closes.",
    "Using minor intra-swing levels rather than significant swing points or previous period extremes.",
    "Expecting immediate expansion without accounting for consolidation or a re-test of the level.",
    "Confusing Failure to Displace with Displacement (strong breakout with FVG).",
    "Over-applying on lower timeframes without considering higher timeframe bias.",
    "Ignoring the strong counter-directional candle that often follows the failure.",
    "Using the concept in isolation without PD Array or liquidity framework.",
    "Neglecting to verify the swing point is a key structural turning point."
  ],
