{
  "card_id": "non_farm_payrolls",
  "type": "merged_concept",
  "canonical_term": "Non-Farm Payrolls",
  "aliases": [
    "nfp",
    "NFP"
  ],
  "school": "General",
  "definition": "A high-impact monthly US employment report. Its scheduled release creates market-wide uncertainty, causing participants to avoid directional commitment beforehand and producing indecision / Seek and Destroy daily candle profiles on the pre-release session.",
  "identification_rules": [
    "Check the economic calendar: if an NFP release is scheduled for the current or next session, flag the pre-NFP session as a potential Seek and Destroy / indecision day.",
    "On the pre-NFP daily candle, look for price opening and closing at approximately the same level with no sustained directional expansion — the hallmark indecision candle.",
    "During London (02:00–05:00 EST) on a pre-NFP day, observe whether price sweeps both sides of the Asia range without achieving displacement or a clean breakout, confirming consolidation conditions."
  ],
  "trading_implication": "Pre-NFP sessions are classified as high-probability Seek and Destroy / indecision profiles, meaning directional expansion trades should be avoided. If a trade is taken, the preferred approach is fading moves back into the established range (London or Asia range), targeting equilibrium (0.5 level) and internal liquidity rather than attempting breakout plays.",
  "common_mistakes": [
    "Attempting to trade directional breakouts or expansions on a pre-NFP session, when the market is likely to oscillate and return into the range rather than sustain a move.",
    "Ignoring the economic calendar and misclassifying a pre-NFP indecision candle as a tradeable London Reversal or New York Manipulation profile."
  ],
