{
  "card_id": "weak_support_resistance_levels",
  "type": "merged_concept",
  "canonical_term": "Weak Support/Resistance Levels",
  "aliases": [],
  "school": "Price Action",
  "definition": "A price action concept where repeated tests of a support or resistance level show decreasing reaction strength, signaled by lower highs near support or higher lows near resistance, indicating the level is weakening and a breakout is likely.",
  "identification_rules": [
    "For support: On successive bounces, each reaction high is lower than the previous one.",
    "For resistance: On successive rejections, each reaction low is higher than the previous one.",
    "The pattern often resembles a descending triangle at support or an ascending triangle at resistance.",
    "Price 'crawling' along the level with small candles signals imminent break."
  ],
  "trading_implication": "Traders use this weakening to anticipate a breakout. It warns of a high‑probability break through the level, allowing early positioning or preparation for a breakout trade. Confirmation via a strong momentum candle through the level validates the expectation.",
