{
  "card_id": "old_highs_and_lows",
  "type": "merged_concept",
  "canonical_term": "Old Highs and Lows",
  "aliases": [
    "previous highs and lows",
    "Previous Highs and Lows"
  ],
  "school": "ICT",
  "definition": "Single swing points (highs or lows) that stand out as distinct previous highs or lows, not clustered with other swing points. They serve as clear liquidity levels for draw-on-liquidity or potential reversal points.",
  "identification_rules": [
    "Locate a swing high or low that is not part of a cluster of relatively equal highs or lows.",
    "Confirm the point is a single, isolated previous high or low, making it visually stand out on the chart.",
    "Ensure the level is not recently traded through or part of a congested zone of overlapping swing points."
  ],
  "trading_implication": "Old highs and lows are used as draw-on-liquidity targets, where price is expected to reach and potentially sweep the level before reversing or continuing. They also act as potential reversal points after a liquidity sweep. These levels help frame market direction and provide high-probability zones for trade entries.",
  "common_mistakes": [
    "Confusing a cluster of relatively equal highs/lows with an old single high/low, leading to incorrect liquidity analysis.",
    "Ignoring the distinction between a single swing point and clustered levels, causing premature or misplaced trade entries."
  ],
