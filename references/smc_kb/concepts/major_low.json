{
  "card_id": "major_low",
  "type": "merged_concept",
  "canonical_term": "Major Low",
  "aliases": [],
  "school": "Smart Money Concepts (SMC)",
  "definition": "The lowest point of a bullish wave that initiates an upward movement leading to a break of structure (BOS). It marks a key support level defining the lower boundary of external structure; as long as price remains above it, the uptrend is considered intact.",
  "identification_rules": [
    "Identify the most recent break of structure (BOS) where price breaks a previous swing high.",
    "Locate the lowest point of the bullish wave that immediately preceded that BOS.",
    "Confirm that this low is the extreme low before the upward impulse; no lower low exists between it and the BOS.",
    "Ensure that the low is not an internal low that formed after the BOS; it must be the low that originated the move.",
    "Verify that price has not subsequently broken below this level; a break below signals potential trend reversal."
  ],
  "trading_implication": "The major low acts as a critical support level in an uptrend. As long as price holds above it, the bullish structure remains valid, and traders can look for buying opportunities on pullbacks. A decisive break below the major low indicates a change of character and potential trend reversal, prompting traders to exit longs or consider short positions.",
  "common_mistakes": [
    "Confusing an internal low (a minor swing low within the range) for the major low.",
    "Selecting a low that is not the absolute lowest point before the bullish impulse that caused the BOS.",
    "Updating the major low based on an invalid break of structure (e.g., a wick break that closes back below the high)."
  ],
