{
  "card_id": "major_swing",
  "type": "merged_concept",
  "canonical_term": "Major Swing",
  "aliases": [],
  "school": "Smart Money Concepts (SMC)",
  "definition": "A swing point (high or low) that originated a valid break of structure, often accompanied by a fair value gap and a push of at least half the prior impulse's distance; its breach signals a valid change of character.",
  "identification_rules": [
    "The swing is the origin of a valid break of structure (price closes beyond a prior swing high/low).",
    "The impulsive move that caused the break of structure contains a fair value gap.",
    "The distance from the swing to the break of structure is at least half the length of the previous impulsive move.",
    "A level is only marked as a major swing after the break of structure has occurred.",
    "Do not confuse with minor swings, which lack these criteria and whose breaks do not signal a reversal."
  ],
  "trading_implication": "Major swings act as critical structural boundaries. A decisive close beyond a major swing low (in an uptrend) or high (in a downtrend) indicates a trend reversal (change of character). Trades are often entered on retests of these levels. However, false breaks can occur if liquidity sweeps or unmitigated fair value gaps are nearby, so always check the left-side context before acting.",
  "common_mistakes": [
    "Treating a break of a minor swing as a valid reversal.",
    "Marking a swing as major before a valid break of structure confirms it.",
    "Ignoring sellside/buyside liquidity below/above the major swing, leading to fakeouts.",
    "Overlooking an unmitigated fair value gap that may cause a retracement without a true reversal."
  ],
