{
  "card_id": "technical_analysis",
  "type": "merged_concept",
  "canonical_term": "Technical Analysis",
  "aliases": [],
  "school": "General",
  "definition": "The study of past price movements using charts, indicators, and patterns to predict future price movements, aiming for positive expected value over many trades and managing risk with stop-loss orders.",
  "identification_rules": [
    "The trader uses historical price charts as the primary data source for decision-making.",
    "Mathematical indicators are applied to price data to generate signals.",
    "Specific candlestick or chart formations (patterns) are identified to anticipate future moves."
  ],
  "trading_implication": "Technical analysis is used to make informed trading decisions by identifying buy and sell opportunities. It focuses on achieving a positive expected value over a large number of trades, not winning every trade. Risk is managed by setting stop-loss orders and profit targets.",
  "common_mistakes": [
    "Believing that technical analysis can win every trade, expecting 100% accuracy.",
    "Neglecting risk management by not placing stop-loss orders."
  ],
